<div class="bg-white border-bottom d-flex align-items-center justify-content-between px-4" style="height: 60px;">
    <div>
        <h6 class="mb-0 text-muted">
            <AuthorizeView>
                <Authorized>
                    Bienvenue, <strong>@context.User.FindFirst("firstName")?.Value</strong>
                </Authorized>
            </AuthorizeView>
        </h6>
    </div>
    <div class="d-flex align-items-center gap-3">
        <AuthorizeView>
            <Authorized>
                <span class="badge bg-primary">@context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                <button class="btn btn-sm btn-outline-danger" @onclick="Logout">
                    <i class="bi bi-box-arrow-right"></i> Deconnexion
                </button>
            </Authorized>
            <NotAuthorized>
                <a href="/login" class="btn btn-sm btn-primary">Connexion</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

@code {
    [Inject] private IAuthApiService AuthService { get; set; } = null!;
    [Inject] private NavigationManager NavManager { get; set; } = null!;

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        NavManager.NavigateTo("/login", true);
    }
}
