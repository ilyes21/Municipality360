@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Municipality360.Web.Services
@using Municipality360.Application.DTOs.Notifications
@using System.Security.Claims
@implements IAsyncDisposable

@inject ISignalRNotificationService SignalRNotif
@inject INotificationApiService NotifApi
@inject ILocalStorageService LocalStorage

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap');

    :root {
        --sidebar-w: 268px;
        --topbar-h: 62px;
        --accent: #0ea5e9;
        --accent-dark: #0369a1;
        --accent-glow: rgba(14,165,233,0.18);
        --sidebar-bg1: #0b1628;
        --sidebar-bg2: #0d2035;
        --txt-muted: #64748b;
        --txt-dim: #94a3b8;
        --txt-light: #e0f2fe;
        --font: 'Tajawal', sans-serif;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        font-family: var(--font);
        background: #f0f4f8;
        direction: rtl;
    }

    /* ══ SIDEBAR ══════════════════════════════════════════ */
    .app-sidebar {
        position: fixed;
        top: 0;
        right: 0;
        width: var(--sidebar-w);
        height: 100vh;
        background: linear-gradient(170deg, var(--sidebar-bg1) 0%, var(--sidebar-bg2) 100%);
        display: flex;
        flex-direction: column;
        z-index: 300;
        overflow: hidden;
        box-shadow: -3px 0 30px rgba(0,0,0,.35);
        transition: transform .3s cubic-bezier(.4,0,.2,1);
    }

        .app-sidebar::before {
            content: '';
            position: absolute;
            inset: 0;
            pointer-events: none;
            background-image: linear-gradient(rgba(255,255,255,.022) 1px,transparent 1px), linear-gradient(90deg,rgba(255,255,255,.022) 1px,transparent 1px);
            background-size: 44px 44px;
        }

        .app-sidebar::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 3px;
            height: 100%;
            background: linear-gradient(180deg,transparent 0%,var(--accent) 40%,var(--accent) 60%,transparent 100%);
            opacity: .45;
        }

    /* Brand */
    .sb-brand {
        padding: 1.1rem 1.15rem .9rem;
        display: flex;
        align-items: center;
        gap: .85rem;
        border-bottom: 1px solid rgba(255,255,255,.06);
        flex-shrink: 0;
        position: relative;
        z-index: 1;
    }

    .sb-logo {
        width: 40px;
        height: 40px;
        border-radius: 11px;
        background: linear-gradient(135deg,#1e3a5f,#2d6a9f);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 14px rgba(14,165,233,.28);
        flex-shrink: 0;
    }

        .sb-logo i {
            font-size: 1.25rem;
            color: #7dd3fc;
        }

    .sb-title {
        font-size: .97rem;
        font-weight: 800;
        color: var(--txt-light);
        line-height: 1.2;
    }

    .sb-sub {
        font-size: .65rem;
        color: #3d5068;
        font-weight: 400;
        letter-spacing: .04em;
    }

    /* Nav scroll */
    .sb-nav {
        flex: 1;
        overflow-y: auto;
        padding: .5rem 0 .75rem;
        position: relative;
        z-index: 1;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,.08) transparent;
    }

        .sb-nav::-webkit-scrollbar {
            width: 3px;
        }

        .sb-nav::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,.09);
            border-radius: 2px;
        }

    /* Section label */
    .sb-label {
        font-size: .6rem;
        font-weight: 700;
        color: #2d3e52;
        letter-spacing: .13em;
        text-transform: uppercase;
        padding: .9rem 1.35rem .25rem;
        user-select: none;
    }

    /* Group header */
    .sb-group-btn {
        width: calc(100% - 1rem);
        display: flex;
        align-items: center;
        gap: .7rem;
        padding: .6rem 1.1rem .6rem 1rem;
        margin: .05rem .5rem;
        background: none;
        border: none;
        border-radius: 10px;
        color: var(--txt-dim);
        font-family: var(--font);
        font-size: .86rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        text-align: right;
    }

        .sb-group-btn:hover {
            background: rgba(255,255,255,.06);
            color: var(--txt-light);
        }

        .sb-group-btn.open {
            color: var(--txt-light);
            background: rgba(14,165,233,.08);
        }

    .sb-group-icon {
        font-size: 1rem;
        width: 20px;
        text-align: center;
        flex-shrink: 0;
    }

    .sb-group-btn.open .sb-group-icon {
        color: var(--accent);
    }

    .sb-group-label {
        flex: 1;
    }

    .sb-group-arrow {
        font-size: .7rem;
        color: var(--txt-muted);
        transition: transform .25s;
        flex-shrink: 0;
    }

    .sb-group-btn.open .sb-group-arrow {
        transform: rotate(90deg);
        color: var(--accent);
    }

    /* Badge */
    .sb-badge {
        font-size: .6rem;
        font-weight: 700;
        line-height: 1;
        background: var(--accent);
        color: #fff;
        border-radius: 99px;
        padding: .18em .5em;
        flex-shrink: 0;
    }

        .sb-badge.red {
            background: #ef4444;
        }

    /* Children */
    .sb-children {
        overflow: hidden;
        max-height: 0;
        transition: max-height .3s ease;
    }

        .sb-children.open {
            max-height: 800px;
        }

    .sb-child-link {
        display: flex;
        align-items: center;
        gap: .65rem;
        padding: .5rem .9rem .5rem 1rem;
        margin: .03rem .5rem .03rem 1.2rem;
        border-radius: 8px;
        color: #6b8099;
        text-decoration: none;
        font-size: .82rem;
        font-weight: 500;
        transition: all .18s;
        position: relative;
    }

        .sb-child-link::before {
            content: '';
            position: absolute;
            right: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 1px;
            height: 60%;
            background: rgba(255,255,255,.07);
        }

        .sb-child-link i {
            font-size: .88rem;
            width: 18px;
            text-align: center;
            flex-shrink: 0;
        }

        .sb-child-link:hover {
            background: rgba(255,255,255,.06);
            color: var(--txt-light);
            padding-right: 1.1rem;
        }

        .sb-child-link.active {
            background: rgba(14,165,233,.13);
            color: var(--txt-light);
            font-weight: 600;
        }

            .sb-child-link.active i {
                color: var(--accent);
            }

            .sb-child-link.active::after {
                content: '';
                position: absolute;
                right: -.55rem;
                top: 50%;
                transform: translateY(-50%);
                width: 3px;
                height: 55%;
                background: var(--accent);
                border-radius: 0 0 0 3px;
            }

    /* Simple link */
    .sb-link {
        display: flex;
        align-items: center;
        gap: .7rem;
        padding: .62rem 1.1rem;
        margin: .05rem .5rem;
        border-radius: 10px;
        color: var(--txt-dim);
        text-decoration: none;
        font-size: .86rem;
        font-weight: 500;
        transition: all .2s;
        position: relative;
    }

        .sb-link i {
            font-size: 1rem;
            width: 20px;
            text-align: center;
            flex-shrink: 0;
        }

        .sb-link:hover {
            background: rgba(255,255,255,.07);
            color: var(--txt-light);
            transform: translateX(-2px);
        }

        .sb-link.active {
            background: rgba(14,165,233,.15);
            color: var(--txt-light);
            font-weight: 600;
        }

            .sb-link.active i {
                color: var(--accent);
            }

            .sb-link.active::before {
                content: '';
                position: absolute;
                right: -.5rem;
                top: 50%;
                transform: translateY(-50%);
                width: 3px;
                height: 60%;
                background: var(--accent);
                border-radius: 0 0 0 3px;
            }

    /* Footer */
    .sb-footer {
        padding: .9rem 1.1rem;
        border-top: 1px solid rgba(255,255,255,.06);
        flex-shrink: 0;
        z-index: 1;
        position: relative;
    }

    .sb-user {
        display: flex;
        align-items: center;
        gap: .7rem;
        padding: .55rem .7rem;
        margin-bottom: .65rem;
        background: rgba(255,255,255,.05);
        border-radius: 10px;
    }

    .sb-avatar {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        flex-shrink: 0;
        background: linear-gradient(135deg,#0369a1,#0ea5e9);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .sb-avatar i {
            font-size: .95rem;
            color: #fff;
        }

    .sb-uname {
        font-size: .8rem;
        font-weight: 700;
        color: #cbd5e1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sb-urole {
        font-size: .65rem;
        color: #3d5068;
    }

        .sb-urole.superadmin {
            color: #f59e0b;
        }

    /* رول badge ديناميكي */
    .sb-role-tag {
        display: inline-block;
        font-size: .58rem;
        font-weight: 700;
        border-radius: 4px;
        padding: .08rem .35rem;
        margin-top: .18rem;
    }

    .sb-user-link {
        display: flex;
        align-items: center;
        gap: .7rem;
        padding: .55rem .7rem;
        margin-bottom: .45rem;
        background: rgba(255,255,255,.05);
        border-radius: 10px;
        text-decoration: none;
        cursor: pointer;
        transition: background .15s;
    }

        .sb-user-link:hover {
            background: rgba(255,255,255,.09);
        }

    .sb-profile-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .38rem;
        padding: .42rem .6rem;
        border-radius: 8px;
        cursor: pointer;
        background: rgba(14,165,233,.1);
        border: 1px solid rgba(14,165,233,.2);
        color: #7dd3fc;
        font-family: var(--font);
        font-size: .78rem;
        font-weight: 600;
        text-decoration: none;
        transition: all .18s;
    }

        .sb-profile-btn:hover {
            background: rgba(14,165,233,.2);
            color: #bae6fd;
        }

        .sb-profile-btn i {
            font-size: .82rem;
        }

    .sb-logout-btn {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        padding: .52rem;
        border-radius: 9px;
        cursor: pointer;
        background: rgba(239,68,68,.07);
        border: 1px solid rgba(239,68,68,.15);
        color: #f87171;
        font-family: var(--font);
        font-size: .82rem;
        font-weight: 600;
        transition: all .2s;
    }

        .sb-logout-btn:hover {
            background: rgba(239,68,68,.15);
            color: #fca5a5;
            border-color: rgba(239,68,68,.3);
        }

    /* ══ TOPBAR ══════════════════════════════════════════ */
    .app-topbar {
        position: fixed;
        top: 0;
        right: var(--sidebar-w);
        left: 0;
        height: var(--topbar-h);
        background: #fff;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 1.5rem;
        z-index: 200;
        box-shadow: 0 1px 10px rgba(0,0,0,.06);
    }

    .tb-left {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .tb-right {
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    .tb-toggle {
        display: none;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        background: none;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        cursor: pointer;
        color: #64748b;
        font-size: 1.1rem;
    }

    .tb-divider {
        width: 1px;
        height: 22px;
        background: #e2e8f0;
    }

    .tb-page-title {
        font-size: .98rem;
        font-weight: 700;
        color: #0f172a;
    }

    .tb-page-sub {
        font-size: .73rem;
        color: #94a3b8;
    }

    .tb-notif-btn {
        position: relative;
        width: 38px;
        height: 38px;
        border-radius: 10px;
        background: none;
        border: 1px solid #e2e8f0;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #64748b;
        font-size: 1.1rem;
        transition: all .2s;
    }

        .tb-notif-btn:hover {
            background: #f8fafc;
            color: #0f172a;
            border-color: #cbd5e1;
        }

    .notif-dot {
        position: absolute;
        top: 7px;
        right: 8px;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #ef4444;
        border: 2px solid #fff;
        animation: notif-ping 1.5s ease-in-out infinite;
    }

    @@keyframes notif-ping {
        0%, 100% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.3);
            opacity: .7;
        }
    }

    .tb-online {
        display: flex;
        align-items: center;
        gap: .35rem;
        font-size: .75rem;
        color: #22c55e;
    }

        .tb-online i {
            font-size: .45rem;
        }

    /* Notification dropdown */
    .notif-dropdown {
        position: fixed;
        top: calc(var(--topbar-h) + 6px);
        left: 1.2rem;
        width: 320px;
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 8px 32px rgba(0,0,0,.14);
        border: 1px solid #e2e8f0;
        z-index: 498;
        overflow: hidden;
        animation: notif-in .18s ease;
    }

    @@keyframes notif-in {
        from {
            opacity: 0;
            transform: translateY(-8px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    .notif-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .85rem 1rem .65rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .notif-header-title {
        font-size: .88rem;
        font-weight: 700;
        color: #0f172a;
    }

    .notif-count-badge {
        background: #ef4444;
        color: #fff;
        border-radius: 99px;
        font-size: .65rem;
        font-weight: 700;
        padding: .15em .5em;
    }

    .notif-item {
        display: flex;
        align-items: flex-start;
        gap: .7rem;
        padding: .72rem 1rem;
        cursor: pointer;
        transition: background .15s;
        border-bottom: 1px solid #f8fafc;
    }

        .notif-item:hover {
            background: #f8fafc;
        }

        .notif-item.unread {
            background: #f0f9ff;
        }

    .notif-icon-wrap {
        width: 32px;
        height: 32px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .88rem;
        flex-shrink: 0;
    }

        .notif-icon-wrap.blue {
            background: #e0f2fe;
            color: #0369a1;
        }

        .notif-icon-wrap.green {
            background: #dcfce7;
            color: #16a34a;
        }

        .notif-icon-wrap.amber {
            background: #fef3c7;
            color: #d97706;
        }

    .notif-title-text {
        font-size: .8rem;
        font-weight: 600;
        color: #0f172a;
        line-height: 1.35;
    }

    .notif-time {
        font-size: .69rem;
        color: #94a3b8;
        margin-top: .18rem;
    }

    .notif-footer {
        text-align: center;
        padding: .62rem;
        border-top: 1px solid #f1f5f9;
    }

        .notif-footer a {
            font-size: .78rem;
            color: var(--accent);
            text-decoration: none;
            font-weight: 600;
        }

    /* ══ MAIN ════════════════════════════════════════════ */
    .app-main {
        margin-right: var(--sidebar-w);
        padding-top: var(--topbar-h);
        min-height: 100vh;
        padding: calc(var(--topbar-h) + 1.5rem) 1.6rem 1.6rem;
    }

    /* ══ LOGOUT MODAL ════════════════════════════════════ */
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.5);
        backdrop-filter: blur(4px);
        z-index: 900;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: fade-in .2s ease;
    }

    @@keyframes fade-in {
        from {
            opacity: 0
        }

        to {
            opacity: 1
        }
    }

    .logout-modal {
        background: #fff;
        border-radius: 18px;
        padding: 2rem 2.2rem;
        max-width: 380px;
        width: 90%;
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
        animation: modal-in .25s cubic-bezier(.34,1.56,.64,1);
        text-align: center;
    }

    @@keyframes modal-in {
        from {
            opacity: 0;
            transform: scale(.9) translateY(10px)
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0)
        }
    }

    .logout-modal-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #fef2f2;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.2rem;
        font-size: 1.8rem;
        color: #ef4444;
    }

    .logout-modal-title {
        font-size: 1.15rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: .4rem;
    }

    .logout-modal-msg {
        font-size: .87rem;
        color: #64748b;
        line-height: 1.6;
        margin-bottom: 1.5rem;
    }

    .logout-modal-btns {
        display: flex;
        gap: .75rem;
        justify-content: center;
    }

    .modal-btn-cancel {
        flex: 1;
        padding: .65rem;
        border-radius: 10px;
        cursor: pointer;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #374151;
        font-family: var(--font);
        font-size: .88rem;
        font-weight: 600;
        transition: all .2s;
    }

        .modal-btn-cancel:hover {
            background: #e2e8f0;
        }

    .modal-btn-confirm {
        flex: 1;
        padding: .65rem;
        border-radius: 10px;
        cursor: pointer;
        background: linear-gradient(135deg,#dc2626,#ef4444);
        border: none;
        color: #fff;
        font-family: var(--font);
        font-size: .88rem;
        font-weight: 700;
        transition: all .2s;
        box-shadow: 0 4px 14px rgba(239,68,68,.3);
    }

        .modal-btn-confirm:hover {
            box-shadow: 0 6px 20px rgba(239,68,68,.45);
            transform: translateY(-1px);
        }

    /* ══ RESPONSIVE ══════════════════════════════════════ */
    @@media (max-width:768px) {
        .app-sidebar {
            transform: translateX(100%);
        }

            .app-sidebar.open {
                transform: translateX(0);
            }

        .app-topbar {
            right: 0;
        }

        .app-main {
            margin-right: 0;
            padding: calc(var(--topbar-h) + 1rem) 1rem 1rem;
        }

        .tb-toggle {
            display: flex;
        }

        .notif-dropdown {
            left: .5rem;
            right: .5rem;
            width: auto;
        }
    }

    .sb-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.5);
        z-index: 299;
    }

        .sb-overlay.show {
            display: block;
        }

    /* ══ NOTIFICATION COUNT BADGE (topbar) ═══════════ */
    .notif-count-abs {
        position: absolute;
        top: -5px;
        right: -5px;
        min-width: 17px;
        height: 17px;
        border-radius: 99px;
        background: #ef4444;
        color: #fff;
        font-size: .6rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 3px;
        border: 2px solid #fff;
        line-height: 1;
    }

    /* ══ SIGNALR STATUS DOT ══════════════════════════ */
    .signalr-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
        transition: background .4s;
    }
    .signalr-dot.connected    { background: #22c55e; }
    .signalr-dot.disconnected { background: #ef4444; }
    .signalr-dot.connecting   { background: #f59e0b; animation: notif-ping 1s infinite; }

    /* ══ LIVE TOAST ══════════════════════════════════ */
    .notif-toast-wrap {
        position: fixed;
        bottom: 1.5rem;
        left: 1.5rem;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: .6rem;
        pointer-events: none;
    }
    .notif-toast {
        background: #1e293b;
        color: #f1f5f9;
        border-radius: 14px;
        padding: .85rem 1.1rem;
        display: flex;
        align-items: flex-start;
        gap: .75rem;
        min-width: 280px;
        max-width: 340px;
        box-shadow: 0 12px 40px rgba(0,0,0,.28);
        pointer-events: all;
        border-right: 4px solid var(--accent);
        animation: toast-slide .3s cubic-bezier(.34,1.56,.64,1);
    }
    @@keyframes toast-slide {
        from { opacity: 0; transform: translateY(16px) scale(.95); }
        to   { opacity: 1; transform: translateY(0)    scale(1);   }
    }
    .toast-icon {
        width: 34px; height: 34px; border-radius: 9px;
        background: rgba(14,165,233,.18); color: #7dd3fc;
        display: flex; align-items: center; justify-content: center;
        font-size: .95rem; flex-shrink: 0;
    }
    .toast-body { flex: 1; min-width: 0; }
    .toast-title {
        font-size: .8rem; font-weight: 700; color: #e2e8f0;
        margin-bottom: .18rem;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .toast-msg {
        font-size: .74rem; color: #94a3b8; line-height: 1.4;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
    }
    .toast-close {
        background: none; border: none; color: #475569;
        cursor: pointer; font-size: .8rem; padding: .1rem;
        border-radius: 4px; flex-shrink: 0;
        transition: color .15s; pointer-events: all;
    }
    .toast-close:hover { color: #94a3b8; }

</style>

@* ══ OVERLAY MOBILE ══ *@
<div class="sb-overlay @(SidebarOpen ? "show" : "")" @onclick="CloseSidebar"></div>

@* ══ LOGOUT MODAL ══ *@
@if (ShowLogoutModal)
{
    <div class="modal-backdrop-custom" @onclick="CancelLogout">
        <div class="logout-modal" @onclick:stopPropagation="true">
            <div class="logout-modal-icon"><i class="bi bi-box-arrow-right"></i></div>
            <div class="logout-modal-title">تسجيل الخروج</div>
            <div class="logout-modal-msg">هل أنت متأكد من رغبتك في تسجيل الخروج؟<br />سيتم إنهاء جلستك الحالية.</div>
            <div class="logout-modal-btns">
                <button class="modal-btn-cancel" @onclick="CancelLogout">إلغاء</button>
                <button class="modal-btn-confirm" @onclick="ConfirmLogout">
                    @if (IsLoggingOut)
                    {
                        <span class="spinner-border spinner-border-sm me-1" style="width:.85rem;height:.85rem;border-width:2px;"></span>
                    }
                    تأكيد الخروج
                </button>
            </div>
        </div>
    </div>
}

@* ══ NOTIFICATION DROPDOWN ══ *@
@if (ShowNotifications)
{
    <div style="position:fixed;inset:0;z-index:497;" @onclick="() => ShowNotifications = false"></div>
    <div class="notif-dropdown">
        <div class="notif-header">
            <span class="notif-header-title"><i class="bi bi-bell-fill me-2" style="color:var(--accent);"></i>الإشعارات</span>
            @if (SignalRNotif.UnreadCount > 0)
            {
                <span class="notif-count-badge">@SignalRNotif.UnreadCount</span>
            }
        </div>
        @if (!SignalRNotif.Notifications.Any())
        {
            <div style="padding:1.5rem;text-align:center;color:#94a3b8;font-size:.82rem;">
                <i class="bi bi-bell-slash" style="font-size:1.5rem;display:block;margin-bottom:.5rem;color:#cbd5e1;"></i>
                لا توجد إشعارات
            </div>
        }
        else
        {
            @foreach (var n in SignalRNotif.Notifications.Take(6))
            {
                <div class="notif-item @(!n.EstLue ? "unread" : "")" @onclick="() => HandleNotifClick(n)">
                    <div class="notif-icon-wrap @GetNotifColor(n.Type)"><i class="bi @GetNotifIcon(n.Type)"></i></div>
                    <div class="notif-body">
                        <div class="notif-title-text">@n.Titre</div>
                        <div class="notif-time">@FormatTime(n.DateCreation)</div>
                    </div>
                </div>
            }
        }
        <div class="notif-footer"><a href="/notifications" @onclick="() => ShowNotifications = false">عرض كل الإشعارات</a></div>
    </div>
}

@* ══ LIVE TOAST ══ *@
@if (ToastNotif != null)
{
    <div class="notif-toast-wrap">
        <div class="notif-toast">
            <div class="toast-icon"><i class="bi @GetNotifIcon(ToastNotif.Type)"></i></div>
            <div class="toast-body">
                <div class="toast-title">@ToastNotif.Titre</div>
                <div class="toast-msg">@ToastNotif.Message</div>
            </div>
            <button class="toast-close" @onclick="() => ToastNotif = null"><i class="bi bi-x"></i></button>
        </div>
    </div>
}

