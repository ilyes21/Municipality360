@* ══ MAIN CONTENT ══ *@
<main class="app-main">
    @Body
</main>

@code {
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = null!;
    [Inject] private NavigationManager NavManager { get; set; } = null!;

    // ── State ──────────────────────────────
    private bool SidebarOpen = false;
    private bool ShowLogoutModal = false;
    private bool IsLoggingOut = false;
    private bool ShowNotifications = false;
    private string OpenGroup = "";

    // ── User info ──────────────────────────
    private string UserDisplay = "مسؤول";
    private string UserRole = "مستخدم";
    private bool IsSuperAdmin = false;
    private int UnreadComplaints = 3;

    // ── Notifications ──────────────────────
    private List<NotifItem> Notifications = new()
    {
        new("شكوى جديدة بانتظار المراجعة",    "منذ 5 دقائق",  "bi-chat-square-text", "blue",  false),
        new("طلب رخصة بناء #2041 تمت الموافقة","منذ 30 دقيقة", "bi-file-check",       "green", false),
        new("بريد وارد – مديرية التعمير",      "منذ ساعة",     "bi-envelope",         "amber", false),
        new("تقرير شهري جاهز للتحميل",         "منذ يومين",    "bi-file-earmark-bar-graph","blue",true),
    };

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = state.User;

        if (!(user.Identity?.IsAuthenticated ?? false))
        {
            NavManager.NavigateTo("/login", forceLoad: false);
            return;
        }

        // استخراج البيانات من الـ Claims
        UserDisplay = user.Identity?.Name
            ?? user.FindFirst("email")?.Value
            ?? user.FindFirst(ClaimTypes.Email)?.Value
            ?? "مسؤول";

        var roles = user.FindAll(ClaimTypes.Role).Select(c => c.Value).ToList();
        IsSuperAdmin = roles.Contains("SuperAdmin");
        UserRole = IsSuperAdmin ? "مدير النظام الأعلى"
                     : roles.Contains("Admin") ? "مسؤول"
                     : roles.Contains("Agent") ? "عون إداري"
                     : "مستخدم";

        // فتح المجموعة بناءً على المسار الحالي
        AutoOpenGroup();
    }

    private void AutoOpenGroup()
    {
        var path = NavManager.Uri;
        if (path.Contains("/bureau")) OpenGroup = "bureau";
        else if (path.Contains("/complaints")) OpenGroup = "complaints";
        else if (path.Contains("/permits")) OpenGroup = "permits";
        else if (path.Contains("/departements") || path.Contains("/services") ||
                 path.Contains("/postes") || path.Contains("/employes") ||
                 path.Contains("/org")) OpenGroup = "org";
        else if (path.Contains("/admin")) OpenGroup = "users";
    }

    private void ToggleGroup(string name)
        => OpenGroup = (OpenGroup == name) ? "" : name;

    private void ToggleSidebar() => SidebarOpen = !SidebarOpen;
    private void CloseSidebar() => SidebarOpen = false;

    // ── Logout flow ───────────────────────
    private void AskLogout()
    {
        ShowLogoutModal = true;
        ShowNotifications = false;
    }

    private void CancelLogout() => ShowLogoutModal = false;

    private async Task ConfirmLogout()
    {
        IsLoggingOut = true;
        StateHasChanged();
        if (AuthStateProvider is CustomAuthStateProvider provider)
            await provider.NotifyUserLoggedOut();
        NavManager.NavigateTo("/login", forceLoad: true);
    }

    // ── Notifications ─────────────────────
    private void MarkRead(NotifItem n) { n.IsRead = true; ShowNotifications = false; }

    // ── Model ─────────────────────────────
    private record NotifItem(string Title, string Time, string Icon, string Color, bool IsReadInit)
    {
        public bool IsRead { get; set; } = IsReadInit;
    }
}
