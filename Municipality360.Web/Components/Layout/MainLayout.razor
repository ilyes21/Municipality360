                @if (IsSuperAdmin)
                {
                    <NavLink class="sb-child-link" href="/admin/logs">
                        <i class="bi bi-journal-text"></i><span>سجل النشاطات</span>
                    </NavLink>
                }
            </div>

            @* ── الإعدادات العامة (SuperAdmin فقط) ── *@
            @if (IsSuperAdmin)
            {
                <button class="sb-group-btn @(OpenGroup == "settings" ? "open" : "")" @onclick='() => ToggleGroup("settings")'>
                    <i class="bi bi-gear-fill sb-group-icon"></i>
                    <span class="sb-group-label">إعدادات النظام</span>
                    <i class="bi bi-chevron-left sb-group-arrow"></i>
                </button>
                <div class="sb-children @(OpenGroup == "settings" ? "open" : "")">
                    <NavLink class="sb-child-link" href="/settings/general">
                        <i class="bi bi-sliders"></i><span>الإعدادات العامة</span>
                    </NavLink>
                    <NavLink class="sb-child-link" href="/settings/municipality">
                        <i class="bi bi-building-gear"></i><span>بيانات البلدية</span>
                    </NavLink>
                    <NavLink class="sb-child-link" href="/settings/backup">
                        <i class="bi bi-cloud-arrow-up"></i><span>النسخ الاحتياطي</span>
                    </NavLink>
                </div>
            }
        }

    </nav>

    @* ── Footer: معلومات المستخدم ── *@
    <div class="sb-footer">
        <a class="sb-user sb-user-link" href="/profile">
            <div class="sb-avatar"><i class="bi bi-person-fill"></i></div>
            <div style="overflow:hidden;flex:1;">
                <div class="sb-uname">@UserDisplay</div>
                <div class="sb-urole @(IsSuperAdmin ? "superadmin" : "")">
                    @UserRoleDisplay
                </div>
            </div>
            <i class="bi bi-pencil-square" style="font-size:.72rem;color:#475569;flex-shrink:0;"></i>
        </a>
        <div style="display:flex;gap:.45rem;margin-bottom:.5rem;">
            <a href="/profile" class="sb-profile-btn">
                <i class="bi bi-person-gear"></i><span>الملف الشخصي</span>
            </a>
        </div>
        <button class="sb-logout-btn" @onclick="AskLogout">
            <i class="bi bi-box-arrow-right"></i><span>تسجيل الخروج</span>
        </button>
    </div>

</aside>

@* ══ TOPBAR ══ *@
<header class="app-topbar">
    <div class="tb-left">
        <button class="tb-toggle" @onclick="ToggleSidebar"><i class="bi bi-list"></i></button>
        <div class="tb-divider"></div>
        <div>
            <div class="tb-page-title">Municipality360</div>
            <div class="tb-page-sub">نظام إدارة البلدية الرقمية</div>
        </div>
    </div>
    <div class="tb-right">
        <button class="tb-notif-btn" @onclick='() => ShowNotifications = !ShowNotifications' style="position:relative;">
            <i class="bi bi-bell"></i>
            @if (SignalRNotif.UnreadCount > 0)
            {
                <span class="notif-count-abs">@(SignalRNotif.UnreadCount > 99 ? "99+" : SignalRNotif.UnreadCount.ToString())</span>
            }
            else if (Notifications.Any(n => !n.IsRead))
            {
                <span class="notif-dot"></span>
            }
        </button>
        <div class="tb-online" title="@(SignalRNotif.IsConnected ? "متصل بالنظام" : "غير متصل")">
            <div class="signalr-dot @(SignalRNotif.IsConnected ? "connected" : "disconnected")"></div>
            <span>@(SignalRNotif.IsConnected ? "متصل" : "غير متصل")</span>
        </div>
    </div>
</header>

@* ══ MAIN CONTENT ══ *@
<main class="app-main">@Body</main>

@code {
    [Inject] AuthenticationStateProvider AuthStateProvider { get; set; } = null!;
    [Inject] NavigationManager NavManager { get; set; } = null!;

    // ── State ──────────────────────────────────────────
    private bool SidebarOpen = false;
    private bool ShowLogoutModal = false;
    private bool IsLoggingOut = false;
    private bool ShowNotifications = false;
    private string OpenGroup = "";

    // ── User ───────────────────────────────────────────
    private string UserDisplay = "مستخدم";
    private string UserRoleDisplay = "مستخدم";
    private bool IsSuperAdmin = false;
    private List<string> UserRoles = new();
    private int UnreadComplaints = 0;

    // ── Notifications (fallback ثابتة للعرض قبل SignalR) ──
    private List<NotifItem> Notifications = new()
    {
        new("شكوى جديدة بانتظار المراجعة",    "منذ 5 دقائق",  "bi-chat-square-text",        "blue",  false),
        new("رخصة بناء #2041 تمت الموافقة",   "منذ 30 دقيقة", "bi-file-check",              "green", false),
        new("بريد وارد – مديرية التعمير",      "منذ ساعة",     "bi-envelope",                "amber", false),
        new("تقرير شهري جاهز للتحميل",         "منذ يومين",    "bi-file-earmark-bar-graph",  "blue",  true),
    };

    // ── Toast ───────────────────────────────────────────
    private NotificationDto? ToastNotif;

    // ✅ OnInitializedAsync
    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user  = state.User;

        if (user.Identity?.IsAuthenticated == true)
            LoadUserData(user);

        // الاشتراك في تحديثات SignalR
        SignalRNotif.OnChanged             += HandleSignalRChanged;
        SignalRNotif.OnNotificationReceived += HandleNewNotification;
    }

    // ✅ OnAfterRenderAsync: JS جاهز هنا
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user  = state.User;

        if (!(user.Identity?.IsAuthenticated ?? false))
        {
            NavManager.NavigateTo("/login", forceLoad: false);
            return;
        }

        LoadUserData(user);

        // بدء SignalR إذا لم يكن متصلاً
        if (!SignalRNotif.IsConnected)
        {
            try
            {
                var token = await LocalStorage.GetItemAsync<string>("auth_token");
                if (!string.IsNullOrEmpty(token))
                {
                    await SignalRNotif.StartAsync(token);

                    // تحميل الإشعارات الأولية من API
                    var initialNotifs = await NotifApi.GetMyNotificationsAsync();
                    SignalRNotif.LoadInitialNotifications(initialNotifs);

                    // تحديث badge الشكاوى
                    UnreadComplaints = SignalRNotif.Notifications
                        .Count(n => !n.EstLue &&
                               (n.Type == "NouvelleReclamation" || n.Type == "ReclamationAssignee"));
                }
            }
            catch { /* fail silently — Notifications ستبقى فارغة */ }
        }

        StateHasChanged();
    }

    // ── استقبال تحديث من SignalR ─────────────────────────
    private void HandleSignalRChanged()
    {
        UnreadComplaints = SignalRNotif.Notifications
            .Count(n => !n.EstLue &&
                   (n.Type == "NouvelleReclamation" || n.Type == "ReclamationAssignee"));
        InvokeAsync(StateHasChanged);
    }

    private void HandleNewNotification(NotificationDto notif)
    {
        InvokeAsync(async () =>
        {
            ToastNotif = notif;
            StateHasChanged();
            await Task.Delay(5000);
            if (ToastNotif == notif) { ToastNotif = null; StateHasChanged(); }
        });
    }

    // ── استخراج بيانات المستخدم من الـ Claims ──────────
    private void LoadUserData(System.Security.Claims.ClaimsPrincipal user)
    {
        UserDisplay = user.FindFirst("firstName")?.Value is { Length: > 0 } fn
                    ? fn + " " + (user.FindFirst("lastName")?.Value ?? "")
                    : user.Identity?.Name
                   ?? user.FindFirst(ClaimTypes.Email)?.Value
                   ?? "مستخدم";

        UserRoles = user.FindAll(ClaimTypes.Role).Select(c => c.Value).ToList();
        IsSuperAdmin = UserRoles.Contains("SuperAdmin");

        UserRoleDisplay = IsSuperAdmin ? "⭐ مدير النظام الأعلى"
            : UserRoles.Contains("Admin") ? "🛡 مسؤول"
            : UserRoles.Contains("Manager") ? "👤 مشرف"
            : UserRoles.Contains("Finances") ? "💰 المالية"
            : UserRoles.Contains("Urbanisme") ? "🏢 التعمير"
            : UserRoles.Contains("EtatCivil") ? "📄 الحالة المدنية"
            : UserRoles.Contains("SIG") ? "🗺 نظام GIS"
            : UserRoles.Contains("BureauOrdre") ? "✉ مكتب الضبط"
            : UserRoles.Contains("Reclamations") ? "💬 الشكاوى"
            : UserRoles.Contains("Nettoyage") ? "♻ النظافة"
            : UserRoles.Contains("Stock") ? "📦 المخزون"
            : UserRoles.Contains("RessourcesHumaines") ? "👥 الموارد البشرية"
            : UserRoles.Contains("Employee") ? "🔖 موظف"
            : "مستخدم";

        AutoOpenGroup();
    }

    // ── دالة مساعدة: هل المستخدم يمتلك أحد هذه الأدوار ─────────
    private bool CanAccess(params string[] roles)
        => IsSuperAdmin || roles.Any(r => UserRoles.Contains(r));

    // ── فتح المجموعة تلقائياً حسب المسار ──────────────────────
    private void AutoOpenGroup()
    {
        var path = NavManager.Uri;
        OpenGroup = path switch
        {
            _ when path.Contains("/bureau") => "bureau",
            _ when path.Contains("/complaints") => "complaints",
            _ when path.Contains("/permits") => "permits",
            _ when path.Contains("/civil") => "civil",
            _ when path.Contains("/finance") => "finance",
            _ when path.Contains("/clean") => "clean",
            _ when path.Contains("/stock") => "stock",
            _ when path.Contains("/rh") => "rh",
            _ when path.Contains("/departements") || path.Contains("/services") ||
                   path.Contains("/postes") || path.Contains("/employes") ||
                   path.Contains("/org") => "org",
            _ when path.Contains("/sig") => "",
            _ when path.Contains("/reports") => "reports",
            _ when path.Contains("/admin") => "users",
            _ when path.Contains("/settings") => "settings",
            _ => ""
        };
    }

    private void ToggleGroup(string name)
        => OpenGroup = (OpenGroup == name) ? "" : name;

    private void ToggleSidebar() => SidebarOpen = !SidebarOpen;
    private void CloseSidebar()  => SidebarOpen = false;

    // ── إجراءات الإشعارات ──────────────────────────────
    private async Task HandleNotifClick(NotificationDto n)
    {
        if (!n.EstLue)
        {
            await SignalRNotif.MarkAsReadAsync(n.Id);
            try { await NotifApi.MarkAsReadAsync(n.Id); } catch { }
        }
        ShowNotifications = false;
        if (!string.IsNullOrEmpty(n.LienNavigation))
            NavManager.NavigateTo(n.LienNavigation);
    }

    // ── Helpers ─────────────────────────────────────────
    private string GetNotifColor(string type) => type switch
    {
        "NouveauCourrier" or "CourrierAssigne"         => "amber",
        "CourrierTraite"                               => "green",
        "NouvelleReclamation" or "ReclamationAssignee" => "blue",
        "ReclamationResolue"                           => "green",
        "ReclamationRejetee"                           => "red",
        "DemandePermisApprouvee" or "PermisDelivre"    => "green",
        "DemandePermisRefusee"                         => "red",
        _ => "blue"
    };

    private string GetNotifIcon(string type) => type switch
    {
        "NouveauCourrier"        => "bi-envelope",
        "CourrierAssigne"        => "bi-envelope-arrow-down",
        "CourrierTraite"         => "bi-envelope-check",
        "NouvelleReclamation"    => "bi-chat-square-text",
        "ReclamationAssignee"    => "bi-chat-square-arrow",
        "ReclamationResolue"     => "bi-check-circle",
        "ReclamationRejetee"     => "bi-x-circle",
        "NouvelleDemandePermis"  => "bi-building",
        "DemandePermisApprouvee" => "bi-building-check",
        "DemandePermisRefusee"   => "bi-building-x",
        "PermisDelivre"          => "bi-file-earmark-check",
        _ => "bi-bell"
    };

    private string FormatTime(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        return diff.TotalMinutes < 1  ? "الآن"
             : diff.TotalMinutes < 60 ? $"منذ {(int)diff.TotalMinutes} دقيقة"
             : diff.TotalHours < 24   ? $"منذ {(int)diff.TotalHours} ساعة"
             : diff.TotalDays < 7     ? $"منذ {(int)diff.TotalDays} يوم"
             : dt.ToString("yyyy/MM/dd");
    }

    // ── Logout ──────────────────────────────────────────
    private void AskLogout() { ShowLogoutModal = true; ShowNotifications = false; }
    private void CancelLogout() => ShowLogoutModal = false;

    private async Task ConfirmLogout()
    {
        IsLoggingOut = true; StateHasChanged();
        await SignalRNotif.StopAsync();
        if (AuthStateProvider is CustomAuthStateProvider p)
            await p.NotifyUserLoggedOut();
        NavManager.NavigateTo("/login", forceLoad: true);
    }

    // ── Dispose ─────────────────────────────────────────
    public async ValueTask DisposeAsync()
    {
        SignalRNotif.OnChanged             -= HandleSignalRChanged;
        SignalRNotif.OnNotificationReceived -= HandleNewNotification;
    }

    // ── Legacy fallback record (للتوافقية مع بيانات ثابتة) ──
    private record NotifItem(string Title, string Time, string Icon, string Color, bool IsReadInit)
    {
        public bool IsRead { get; set; } = IsReadInit;
    }
}
