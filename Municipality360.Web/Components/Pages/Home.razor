@page "/"
@using System.Security.Claims
@implements IDisposable
@layout Municipality360.Web.Components.Layout.MainLayout

<PageTitle>لوحة التحكم — Municipality360</PageTitle>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&family=Cairo+Play:wght@400;600;700&display=swap');

    :root {
        --ink: #0a1628;
        --ink2: #1e3a5f;
        --sky: #0ea5e9;
        --sky-d: #0369a1;
        --sky-l: #e0f2fe;
        --gold: #f59e0b;
        --gold-l: #fef3c7;
        --jade: #10b981;
        --jade-l: #d1fae5;
        --rose: #f43f5e;
        --rose-l: #ffe4e6;
        --amber: #f97316;
        --amber-l: #fff7ed;
        --violet: #8b5cf6;
        --violet-l: #ede9fe;
        --surface: #f8fafd;
        --card: #ffffff;
        --border: #e8eef5;
        --muted: #64748b;
        --font: 'Cairo', sans-serif;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        font-family: var(--font);
        direction: rtl;
    }

    /* ══ PAGE WRAPPER ══════════════════════════════════════ */
    .dash {
        padding: 0;
        direction: rtl;
    }

    /* ══ GREETING HERO ════════════════════════════════════ */
    .greeting {
        background: linear-gradient(135deg, var(--ink) 0%, var(--ink2) 55%, #0d3461 100%);
        border-radius: 20px;
        padding: 2rem 2.2rem;
        margin-bottom: 1.6rem;
        position: relative;
        overflow: hidden;
        animation: slideDown .5s cubic-bezier(.22,1,.36,1);
    }

        .greeting::before {
            content: '';
            position: absolute;
            top: -40px;
            left: -60px;
            width: 280px;
            height: 280px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(14,165,233,.18) 0%, transparent 70%);
            pointer-events: none;
        }

        .greeting::after {
            content: '';
            position: absolute;
            bottom: -30px;
            right: 10%;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(245,158,11,.1) 0%, transparent 70%);
            pointer-events: none;
        }
    /* شبكة خفية في الخلفية */
    .greeting-grid {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background-image: linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
        background-size: 48px 48px;
    }

    .greeting-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .greet-left {
        flex: 1;
    }

    .greet-eyebrow {
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--sky);
        margin-bottom: .35rem;
    }

    .greet-name {
        font-size: 1.65rem;
        font-weight: 900;
        color: #f0f9ff;
        line-height: 1.2;
        margin-bottom: .25rem;
    }

        .greet-name span {
            color: var(--gold);
        }

    .greet-sub {
        font-size: .82rem;
        color: #64748b;
    }

    .greet-right {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .greet-time-box {
        background: rgba(255,255,255,.07);
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 14px;
        padding: .85rem 1.2rem;
        text-align: center;
        backdrop-filter: blur(4px);
        min-width: 110px;
    }

    .greet-time {
        font-size: 1.55rem;
        font-weight: 900;
        color: #e2e8f0;
        letter-spacing: .03em;
    }

    .greet-date {
        font-size: .69rem;
        color: #475569;
        margin-top: .12rem;
    }

    .greet-weather {
        background: rgba(255,255,255,.07);
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 14px;
        padding: .85rem 1rem;
        text-align: center;
        backdrop-filter: blur(4px);
    }

        .greet-weather i {
            font-size: 1.5rem;
            color: #fde68a;
            display: block;
        }

    .greet-weather-t {
        font-size: .85rem;
        font-weight: 700;
        color: #e2e8f0;
    }

    .greet-weather-s {
        font-size: .67rem;
        color: #475569;
    }

    /* ══ KPI RIBBON ═══════════════════════════════════════ */
    .kpi-ribbon {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-bottom: 1.6rem;
    }

    @@media (max-width:900px) {
        .kpi-ribbon {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width:540px) {
        .kpi-ribbon {
            grid-template-columns: 1fr;
        }
    }

    .kpi {
        background: var(--card);
        border-radius: 16px;
        border: 1px solid var(--border);
        padding: 1.2rem 1.3rem;
        box-shadow: 0 2px 12px rgba(10,22,40,.05);
        position: relative;
        overflow: hidden;
        animation: fadeUp .45s cubic-bezier(.22,1,.36,1) both;
        transition: transform .2s, box-shadow .2s;
    }

        .kpi:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 28px rgba(10,22,40,.1);
        }

        .kpi:nth-child(1) {
            animation-delay: .05s
        }

        .kpi:nth-child(2) {
            animation-delay: .10s
        }

        .kpi:nth-child(3) {
            animation-delay: .15s
        }

        .kpi:nth-child(4) {
            animation-delay: .20s
        }

    .kpi-stripe {
        position: absolute;
        top: 0;
        right: 0;
        width: 4px;
        height: 100%;
        border-radius: 0 16px 16px 0;
    }

    .kpi-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        margin-bottom: .75rem;
    }

    .kpi-val {
        font-size: 2rem;
        font-weight: 900;
        line-height: 1;
        color: var(--ink);
        margin-bottom: .15rem;
        font-variant-numeric: tabular-nums;
    }

    .kpi-lbl {
        font-size: .75rem;
        color: var(--muted);
        font-weight: 600;
    }

    .kpi-delta {
        display: inline-flex;
        align-items: center;
        gap: .18rem;
        font-size: .68rem;
        font-weight: 700;
        margin-top: .4rem;
        padding: .12rem .42rem;
        border-radius: 99px;
    }

    .delta-up {
        background: var(--jade-l);
        color: var(--jade);
    }

    .delta-down {
        background: var(--rose-l);
        color: var(--rose);
    }

    .delta-flat {
        background: var(--sky-l);
        color: var(--sky-d);
    }

    /* ══ MAIN GRID ════════════════════════════════════════ */
    .main-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        grid-template-rows: auto auto;
        gap: 1.1rem;
        margin-bottom: 1.4rem;
    }

    @@media (max-width:1100px) {
        .main-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width:680px) {
        .main-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ══ CARD BASE ════════════════════════════════════════ */
    .dcard {
        background: var(--card);
        border-radius: 16px;
        border: 1px solid var(--border);
        box-shadow: 0 2px 12px rgba(10,22,40,.05);
        overflow: hidden;
        animation: fadeUp .5s cubic-bezier(.22,1,.36,1) both;
    }

    .dcard-head {
        padding: .9rem 1.2rem .75rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .dcard-title {
        font-size: .88rem;
        font-weight: 800;
        color: var(--ink);
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .dcard-title-ico {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .78rem;
    }

    .dcard-link {
        font-size: .72rem;
        color: var(--sky-d);
        font-weight: 600;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: .2rem;
        transition: color .15s;
    }

        .dcard-link:hover {
            color: var(--sky);
        }

    .dcard-body {
        padding: .9rem 1.2rem 1.1rem;
    }

    /* ══ ACTIVITY FEED ════════════════════════════════════ */
    .act-item {
        display: flex;
        align-items: flex-start;
        gap: .72rem;
        padding: .55rem 0;
        border-bottom: 1px solid #f8fafc;
        position: relative;
    }

        .act-item:last-child {
            border-bottom: none;
        }

    .act-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-top: .3rem;
        flex-shrink: 0;
    }

    .act-text {
        font-size: .8rem;
        color: #374151;
        line-height: 1.45;
        flex: 1;
    }

        .act-text strong {
            font-weight: 700;
            color: var(--ink);
        }

    .act-time {
        font-size: .67rem;
        color: #94a3b8;
        white-space: nowrap;
        margin-top: .12rem;
    }

    /* ══ COMPLAINTS FUNNEL ════════════════════════════════ */
    .funnel-row {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .48rem 0;
        border-bottom: 1px solid #f8fafc;
    }

        .funnel-row:last-child {
            border-bottom: none;
        }

    .funnel-label {
        font-size: .78rem;
        font-weight: 600;
        color: var(--ink);
        width: 90px;
        flex-shrink: 0;
    }

    .funnel-bar-wrap {
        flex: 1;
        height: 8px;
        background: #f1f5f9;
        border-radius: 99px;
        overflow: hidden;
    }

    .funnel-bar {
        height: 100%;
        border-radius: 99px;
        transition: width 1.2s cubic-bezier(.22,1,.36,1);
    }

    .funnel-count {
        font-size: .78rem;
        font-weight: 800;
        color: var(--ink);
        width: 28px;
        text-align: left;
    }

    .funnel-pct {
        font-size: .67rem;
        color: var(--muted);
        width: 34px;
        text-align: left;
    }

    /* ══ TASKS ════════════════════════════════════════════ */
    .task-item {
        display: flex;
        align-items: center;
        gap: .65rem;
        padding: .52rem 0;
        border-bottom: 1px solid #f8fafc;
    }

        .task-item:last-child {
            border-bottom: none;
        }

    .task-check {
        width: 18px;
        height: 18px;
        border-radius: 5px;
        flex-shrink: 0;
        border: 2px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .6rem;
        color: #fff;
        cursor: pointer;
        transition: all .15s;
    }

        .task-check.done {
            background: var(--jade);
            border-color: var(--jade);
        }

    .task-text {
        font-size: .8rem;
        color: #374151;
        flex: 1;
        line-height: 1.35;
    }

        .task-text.done-text {
            text-decoration: line-through;
            color: #94a3b8;
        }

    .task-prio {
        font-size: .62rem;
        font-weight: 700;
        padding: .1rem .38rem;
        border-radius: 4px;
    }

    .p-high {
        background: var(--rose-l);
        color: var(--rose);
    }

    .p-med {
        background: var(--amber-l);
        color: var(--amber);
    }

    .p-low {
        background: var(--jade-l);
        color: var(--jade);
    }

    /* ══ SERVICES GRID ════════════════════════════════════ */
    .svc-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: .55rem;
    }

    .svc-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: .35rem;
        padding: .85rem .5rem;
        border-radius: 12px;
        border: 1.5px solid var(--border);
        background: #fafbff;
        text-decoration: none;
        transition: all .18s;
        cursor: pointer;
    }

        .svc-btn:hover {
            border-color: var(--sky);
            background: var(--sky-l);
            transform: translateY(-2px);
            box-shadow: 0 4px 14px rgba(14,165,233,.15);
        }

    .svc-ico {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .95rem;
    }

    .svc-name {
        font-size: .7rem;
        font-weight: 700;
        color: var(--ink);
        text-align: center;
    }

    /* ══ CALENDAR / EVENTS ════════════════════════════════ */
    .ev-item {
        display: flex;
        gap: .7rem;
        padding: .52rem 0;
        border-bottom: 1px solid #f8fafc;
        align-items: flex-start;
    }

        .ev-item:last-child {
            border-bottom: none;
        }

    .ev-date-box {
        min-width: 38px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .ev-day {
        font-size: 1.05rem;
        font-weight: 900;
        line-height: 1;
    }

    .ev-mon {
        font-size: .58rem;
        font-weight: 600;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .ev-info {
        flex: 1;
    }

    .ev-title {
        font-size: .8rem;
        font-weight: 700;
        color: var(--ink);
        line-height: 1.3;
    }

    .ev-meta {
        font-size: .68rem;
        color: var(--muted);
        margin-top: .12rem;
        display: flex;
        gap: .5rem;
    }

    /* ══ BUDGET DONUT (SVG) ═══════════════════════════════ */
    .budget-wrap {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        flex-wrap: wrap;
    }

    .donut-svg {
        flex-shrink: 0;
    }

    .donut-legend {
        flex: 1;
    }

    .legend-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .35rem 0;
        border-bottom: 1px solid #f8fafc;
    }

        .legend-row:last-child {
            border-bottom: none;
        }

    .legend-dot {
        width: 9px;
        height: 9px;
        border-radius: 2px;
        flex-shrink: 0;
    }

    .legend-lbl {
        font-size: .76rem;
        color: var(--ink);
        flex: 1;
        font-weight: 600;
    }

    .legend-pct {
        font-size: .76rem;
        font-weight: 800;
        color: var(--ink);
    }

    .legend-amt {
        font-size: .67rem;
        color: var(--muted);
    }

    /* ══ SCROLLABLE TABLES ════════════════════════════════ */
    .mini-table {
        width: 100%;
        border-collapse: collapse;
    }

        .mini-table th {
            font-size: .67rem;
            font-weight: 700;
            color: var(--muted);
            letter-spacing: .08em;
            text-transform: uppercase;
            padding: .38rem .6rem;
            background: #f8fafc;
            border-bottom: 1.5px solid var(--border);
            text-align: right;
        }

        .mini-table td {
            padding: .52rem .6rem;
            font-size: .78rem;
            color: #374151;
            border-bottom: 1px solid #f8fafc;
            vertical-align: middle;
        }

        .mini-table tr:last-child td {
            border-bottom: none;
        }

        .mini-table tr:hover td {
            background: #fafbff;
        }

    /* ══ STATUS PILLS ═════════════════════════════════════ */
    .spill {
        display: inline-flex;
        align-items: center;
        gap: .22rem;
        font-size: .67rem;
        font-weight: 700;
        padding: .14rem .48rem;
        border-radius: 99px;
    }

    .s-open {
        background: var(--sky-l);
        color: var(--sky-d);
    }

    .s-prog {
        background: var(--amber-l);
        color: var(--amber);
    }

    .s-done {
        background: var(--jade-l);
        color: var(--jade);
    }

    .s-pending {
        background: var(--violet-l);
        color: var(--violet);
    }

    .s-reject {
        background: var(--rose-l);
        color: var(--rose);
    }

    /* ══ WIDE CARD MODIFIER ═══════════════════════════════ */
    .span2 {
        grid-column: span 2;
    }

    .span3 {
        grid-column: span 3;
    }

    /* ══ MINI SPARKLINE BAR ═══════════════════════════════ */
    .spark {
        display: flex;
        align-items: flex-end;
        gap: 3px;
        height: 36px;
    }

    .spark-b {
        flex: 1;
        border-radius: 3px 3px 0 0;
        min-width: 8px;
        transition: opacity .2s;
    }

        .spark-b:hover {
            opacity: .75;
        }

    /* ══ DIVIDER LABEL ════════════════════════════════════ */
    .section-sep {
        font-size: .65rem;
        font-weight: 800;
        color: #94a3b8;
        letter-spacing: .14em;
        text-transform: uppercase;
        margin-bottom: .7rem;
        margin-top: .2rem;
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .section-sep::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

    /* ══ ANIMATIONS ═══════════════════════════════════════ */
    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-14px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(16px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes countUp {
        from {
            opacity: 0;
            transform: scale(.8)
        }

        to {
            opacity: 1;
            transform: scale(1)
        }
    }

    .kpi-val {
        animation: countUp .55s cubic-bezier(.22,1,.36,1) both;
    }

    /* ══ WEATHER MINI ══════════════════════════════════════ */
    .weather-mini {
        display: flex;
        align-items: center;
        gap: .65rem;
        background: linear-gradient(135deg,#fef9f0,#fff7e6);
        border: 1px solid #fde68a;
        border-radius: 12px;
        padding: .7rem .95rem;
    }

    .wm-icon {
        font-size: 1.6rem;
    }

    .wm-info {
        flex: 1;
    }

    .wm-temp {
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--ink);
    }

    .wm-desc {
        font-size: .7rem;
        color: var(--muted);
    }

    .wm-extra {
        font-size: .67rem;
        color: #94a3b8;
        display: flex;
        gap: .5rem;
        margin-top: .12rem;
    }

    /* ══ PULSE DOT ════════════════════════════════════════ */
    .pulse {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--jade);
        display: inline-block;
        box-shadow: 0 0 0 0 rgba(16,185,129,.4);
        animation: pulse-anim 1.8s ease-in-out infinite;
    }

    @@keyframes pulse-anim {
        0% {
            box-shadow: 0 0 0 0 rgba(16,185,129,.45);
        }

        70% {
            box-shadow: 0 0 0 8px rgba(16,185,129,0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(16,185,129,0);
        }
    }
</style>

<div class="dash">

    <!-- ═══════════════════════ GREETING ═══════════════════════ -->
    <div class="greeting">
        <div class="greeting-grid"></div>
        <div class="greeting-inner">
            <div class="greet-left">
                <div class="greet-eyebrow">Municipality 360 · ELAIN · نظام إدارة البلدية</div>
                <div class="greet-name">
                    مرحباً، <span>@GreetName</span> 
                </div>
                <div class="greet-sub">
                    <span class="pulse"></span>
                    &nbsp;@DayName — @TodayDate · آخر تسجيل دخول: اليوم
                </div>
            </div>
            <div class="greet-right">
                <div class="greet-time-box">
                    <div class="greet-time">@CurrentTime</div>
                    <div class="greet-date">@TodayShort</div>
                </div>
                <div class="greet-weather">
                    <i class="bi bi-sun-fill"></i>
                    <div class="greet-weather-t">28°</div>
                    <div class="greet-weather-s">مشمس · بسكرة</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════ KPI RIBBON ═══════════════════════ -->
    <div class="kpi-ribbon">

        <div class="kpi">
            <div class="kpi-stripe" style="background:var(--sky);"></div>
            <div class="kpi-icon" style="background:var(--sky-l);color:var(--sky-d);">
                <i class="bi bi-people-fill"></i>
            </div>
            <div class="kpi-val">1 284</div>
            <div class="kpi-lbl">إجمالي الموظفين</div>
