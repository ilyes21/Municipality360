@code {
    [Inject] AuthenticationStateProvider AuthSP { get; set; } = null!;

    // ── User ───────────────────────────────────────────
    private string GreetName = "المستخدم";

    // ── Time ───────────────────────────────────────────
    private string CurrentTime = "";
    private string TodayDate = "";
    private string TodayShort = "";
    private string DayName = "";
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthSP.GetAuthenticationStateAsync();
        var user = state.User;
        GreetName = user.FindFirst("firstName")?.Value
                 ?? user.FindFirst(ClaimTypes.Name)?.Value
                 ?? user.FindFirst(ClaimTypes.Email)?.Value
                 ?? user.FindFirst("email")?.Value
                 ?? "المستخدم";

        UpdateTime();
        _timer = new System.Threading.Timer(_ =>
        {
            UpdateTime();
            InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    private void UpdateTime()
    {
        var now = DateTime.Now;
        CurrentTime = now.ToString("HH:mm");
        TodayDate = now.ToString("dd MMMM yyyy");
        TodayShort = now.ToString("dd/MM/yyyy");
        DayName = now.DayOfWeek switch
        {
            DayOfWeek.Saturday => "السبت",
            DayOfWeek.Sunday => "الأحد",
            DayOfWeek.Monday => "الاثنين",
            DayOfWeek.Tuesday => "الثلاثاء",
            DayOfWeek.Wednesday => "الأربعاء",
            DayOfWeek.Thursday => "الخميس",
            DayOfWeek.Friday => "الجمعة",
            _ => ""
        };
    }

    public void Dispose() => _timer?.Dispose();

    // ══ DATA MODELS ══════════════════════════════════════

