@page "/"
@* @attribute [Authorize] *@

<PageTitle>Tableau de bord - Municipality360</PageTitle>

<div class="mb-4">
    <h4 class="fw-bold">Tableau de bord</h4>
    <p class="text-muted">Bienvenue dans Municipality360 - Systeme de gestion municipale</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 bg-primary text-white shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="small opacity-75">Departements</div>
                    <h3 class="fw-bold mb-0">@Stats.Departements</h3>
                </div>
                <i class="bi bi-building fs-1 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-success text-white shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="small opacity-75">Services</div>
                    <h3 class="fw-bold mb-0">@Stats.Services</h3>
                </div>
                <i class="bi bi-diagram-3 fs-1 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-warning text-dark shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="small opacity-75">Postes</div>
                    <h3 class="fw-bold mb-0">@Stats.Postes</h3>
                </div>
                <i class="bi bi-briefcase fs-1 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-info text-dark shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="small opacity-75">Employes</div>
                    <h3 class="fw-bold mb-0">@Stats.Employes</h3>
                </div>
                <i class="bi bi-people fs-1 opacity-50"></i>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private IDepartementApiService DeptService { get; set; } = null!;
    [Inject] private IServiceApiService SvcService { get; set; } = null!;
    [Inject] private IPosteApiService PosteService { get; set; } = null!;
    [Inject] private IEmployeApiService EmpService { get; set; } = null!;

    private (int Departements, int Services, int Postes, int Employes) Stats;

    protected override async Task OnInitializedAsync()
    {
        var depts = await DeptService.GetAllAsync();
        var svcs = await SvcService.GetAllAsync();
        var postes = await PosteService.GetAllAsync();
        var emps = await EmpService.GetPagedAsync(new() { PageSize = 1 });

        Stats = (
            depts?.Data?.Count() ?? 0,
            svcs?.Data?.Count() ?? 0,
            postes?.Data?.Count() ?? 0,
            emps?.Data?.TotalCount ?? 0
        );
    }
}
