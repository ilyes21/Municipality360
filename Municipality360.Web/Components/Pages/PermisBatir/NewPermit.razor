@page "/permits/new"
@using Municipality360.Application.DTOs.PermisBatir
@using Municipality360.Web.Services
@inject IPermisBatirApiService PermisApi
@inject IDemandeurApiService DemandeurApi
@inject IArchitecteApiService ArchitecteApi
@inject IPermisReferentielsApiService RefsApi
@inject NavigationManager Nav

<PageTitle>طلب رخصة بناء جديد</PageTitle>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap');
    * { box-sizing: border-box; }
    .pnew-root { font-family: 'Tajawal', sans-serif; max-width: 860px; margin: 0 auto; }

    .pnew-header {
        display: flex; align-items: center; gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .pnew-header-icon {
        width: 50px; height: 50px; border-radius: 14px;
        background: linear-gradient(135deg, #0369a1, #0ea5e9);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; color: #fff;
        box-shadow: 0 4px 14px rgba(14,165,233,.35); flex-shrink: 0;
    }

    .step-bar {
        display: flex; gap: 0; margin-bottom: 1.5rem;
        background: #fff; border: 1px solid #e2e8f0;
        border-radius: 12px; overflow: hidden;
    }
    .step {
        flex: 1; padding: .65rem .5rem; text-align: center;
        font-size: .75rem; font-weight: 600; color: #94a3b8;
        border-left: 1px solid #e2e8f0; cursor: pointer;
        transition: all .18s;
        display: flex; flex-direction: column; align-items: center; gap: .2rem;
    }
    .step:first-child { border-left: none; }
    .step i { font-size: 1rem; }
    .step.active { background: #f0f9ff; color: #0369a1; }
    .step.done   { background: #f0fdf4; color: #15803d; }

    .pnew-card {
        background: #fff; border: 1px solid #e2e8f0;
        border-radius: 16px; padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.04); margin-bottom: 1.1rem;
    }
    .pnew-section-title {
        font-size: .9rem; font-weight: 800; color: #0f172a;
        margin-bottom: 1.1rem; padding-bottom: .6rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex; align-items: center; gap: .5rem;
    }
    .pnew-section-title i { color: #0ea5e9; }

    .form-grid { display: grid; gap: .9rem; }
    .col2 { grid-template-columns: 1fr 1fr; }
    .col3 { grid-template-columns: 1fr 1fr 1fr; }
    @@media (max-width: 640px) { .col2,.col3 { grid-template-columns: 1fr; } }

    .form-group { display: flex; flex-direction: column; gap: .3rem; }
    .form-label {
        font-size: .75rem; font-weight: 700; color: #374151;
        display: flex; align-items: center; gap: .3rem;
    }
    .required { color: #ef4444; }
    .form-control {
        padding: .5rem .75rem; border: 1px solid #e2e8f0;
        border-radius: 9px; font-family: 'Tajawal', sans-serif;
        font-size: .85rem; color: #0f172a; background: #f8fafc;
        outline: none; transition: border-color .15s;
    }
    .form-control:focus { border-color: #0ea5e9; background: #fff; }
    .form-control.error { border-color: #ef4444; }
    select.form-control { cursor: pointer; }
    textarea.form-control { resize: vertical; min-height: 80px; }
    .form-hint { font-size: .7rem; color: #94a3b8; margin-top: .15rem; }
    .form-error { font-size: .7rem; color: #ef4444; margin-top: .15rem; }

    .search-results {
        border: 1px solid #e2e8f0; border-radius: 9px;
        background: #fff; max-height: 180px; overflow-y: auto;
        box-shadow: 0 4px 14px rgba(0,0,0,.1);
    }
    .search-item {
        padding: .6rem .85rem; cursor: pointer;
        transition: background .12s; border-bottom: 1px solid #f8fafc;
        font-size: .82rem;
    }
    .search-item:hover { background: #f0f9ff; }
    .search-item:last-child { border-bottom: none; }
    .si-name { font-weight: 600; color: #0f172a; }
    .si-sub  { font-size: .72rem; color: #94a3b8; }

    .selected-badge {
        display: flex; align-items: center; gap: .5rem;
        background: #f0f9ff; border: 1px solid #bae6fd;
        border-radius: 9px; padding: .45rem .75rem;
        font-size: .82rem;
    }
    .selected-badge i { color: #0ea5e9; }
    .selected-badge .clear {
        margin-right: auto; cursor: pointer; color: #94a3b8;
        background: none; border: none; font-size: .8rem;
        transition: color .15s;
    }
    .selected-badge .clear:hover { color: #ef4444; }

    .btn-nav-row {
        display: flex; justify-content: space-between; align-items: center;
        margin-top: 1.25rem; padding-top: 1rem;
        border-top: 1px solid #f1f5f9;
    }
    .btn {
        padding: .55rem 1.2rem; border-radius: 9px;
        border: none; font-family: 'Tajawal', sans-serif;
        font-size: .85rem; font-weight: 700;
        cursor: pointer; display: inline-flex;
        align-items: center; gap: .4rem; transition: all .18s;
    }
    .btn-primary { background: #0ea5e9; color: #fff; }
    .btn-primary:hover { background: #0369a1; }
    .btn-outline { background: #fff; color: #374151; border: 1px solid #e2e8f0; }
    .btn-outline:hover { background: #f8fafc; }
    .btn-success { background: #22c55e; color: #fff; }
    .btn-success:hover { background: #15803d; }
    .btn:disabled { opacity: .5; cursor: not-allowed; }

    @@keyframes spin { to { transform: rotate(360deg); } }
    .spinner { animation: spin .75s linear infinite; }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="pnew-root">

    <div class="pnew-header">
        <div class="pnew-header-icon"><i class="bi bi-plus-square-fill"></i></div>
        <div>
            <div style="font-size:1.25rem;font-weight:800;color:#0f172a;">طلب رخصة بناء جديد</div>
            <div style="font-size:.8rem;color:#64748b;">أدخل جميع البيانات المطلوبة لإيداع الطلب</div>
        </div>
        <button class="btn btn-outline" style="margin-right:auto;" @onclick='() => Nav.NavigateTo("/permits")'>
            <i class="bi bi-arrow-right"></i> إلغاء
        </button>
    </div>

    <!-- Step bar -->
    <div class="step-bar">
        <div class="step @(CurrentStep == 1 ? "active" : CurrentStep > 1 ? "done" : "")" @onclick="() => TryGoToStep(1)">
            <i class="bi @(CurrentStep > 1 ? "bi-check-circle-fill" : "bi-person-fill")"></i>
            <span>المتقدم</span>
        </div>
        <div class="step @(CurrentStep == 2 ? "active" : CurrentStep > 2 ? "done" : "")" @onclick="() => TryGoToStep(2)">
            <i class="bi @(CurrentStep > 2 ? "bi-check-circle-fill" : "bi-building")"></i>
            <span>المشروع</span>
        </div>
        <div class="step @(CurrentStep == 3 ? "active" : CurrentStep > 3 ? "done" : "")" @onclick="() => TryGoToStep(3)">
            <i class="bi @(CurrentStep > 3 ? "bi-check-circle-fill" : "bi-compass")"></i>
            <span>المهندس</span>
        </div>
        <div class="step @(CurrentStep == 4 ? "active" : "")" @onclick="() => TryGoToStep(4)">
            <i class="bi bi-check2-square"></i>
            <span>مراجعة</span>
        </div>
    </div>

    <!-- ═══ STEP 1: Demandeur ═══ -->
    @if (CurrentStep == 1)
    {
        <div class="pnew-card">
            <div class="pnew-section-title"><i class="bi bi-person-fill"></i> بيانات المتقدم</div>

            @if (SelectedDemandeur != null)
            {
                <div class="selected-badge" style="margin-bottom:1rem;">
                    <i class="bi bi-person-check-fill"></i>
                    <div>
                        <div style="font-weight:700;">@SelectedDemandeur.NomComplet</div>
                        <div style="font-size:.72rem;color:#64748b;">@SelectedDemandeur.Telephone · @SelectedDemandeur.Type</div>
                    </div>
                    <button class="clear" @onclick="() => SelectedDemandeur = null"><i class="bi bi-x-lg"></i></button>
                </div>
            }
            else
            {
                <div class="form-group" style="margin-bottom:.75rem;">
                    <label class="form-label"><i class="bi bi-search"></i> البحث عن متقدم موجود</label>
                    <input class="form-control" @bind="DemSearchTerm" @bind:event="oninput"
                            placeholder="ابحث بالاسم أو CIN أو الهاتف..." />
                </div>

                @if (DemSearchResults.Any())
                {
                    <div class="search-results" style="margin-bottom:.75rem;">
                        @foreach (var d in DemSearchResults)
                        {
                            <div class="search-item" @onclick="() => SelectDemandeur(d)">
                                <div class="si-name">@d.NomComplet</div>
                                <div class="si-sub">@d.Telephone @(!string.IsNullOrEmpty(d.CIN) ? $"· {d.CIN}" : "")</div>
                            </div>
                        }
                    </div>
                }

                <div style="text-align:center;font-size:.78rem;color:#94a3b8;margin:.75rem 0;">أو أنشئ متقدماً جديداً</div>

                <div class="form-grid col2">
                    <div class="form-group">
                        <label class="form-label">النوع <span class="required">*</span></label>
                        <select class="form-control" @bind="NewDem.Type">
                            <option value="Personne">شخص طبيعي</option>
                            <option value="SocieteConstruction">شركة بناء</option>
                        </select>
                    </div>
                    @if (NewDem.Type == "Personne")
                    {
                        <div></div>
                        <div class="form-group">
                            <label class="form-label">اللقب <span class="required">*</span></label>
                            <input class="form-control @(Errors.ContainsKey("Nom") ? "error" : "")" @bind="NewDem.Nom" placeholder="اللقب..." />
                            @if (Errors.ContainsKey("Nom")) { <span class="form-error">@Errors["Nom"]</span> }
                        </div>
                        <div class="form-group">
                            <label class="form-label">الاسم <span class="required">*</span></label>
                            <input class="form-control" @bind="NewDem.Prenom" placeholder="الاسم..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">CIN</label>
                            <input class="form-control" @bind="NewDem.CIN" placeholder="رقم بطاقة الهوية..." />
                        </div>
                    }
                    else
                    {
                        <div></div>
                        <div class="form-group" style="grid-column:span 2;">
                            <label class="form-label">اسم الشركة <span class="required">*</span></label>
                            <input class="form-control" @bind="NewDem.RaisonSociale" placeholder="اسم الشركة..." />
                            <input class="form-control" @bind="NewDem.Nom" style="margin-top:.4rem;" placeholder="المسؤول القانوني..." />
                        </div>
                    }
                    <div class="form-group">
                        <label class="form-label">الهاتف <span class="required">*</span></label>
                        <input class="form-control @(Errors.ContainsKey("Tel") ? "error" : "")" @bind="NewDem.Telephone" placeholder="+216 XX XXX XXX" />
                        @if (Errors.ContainsKey("Tel")) { <span class="form-error">@Errors["Tel"]</span> }
                    </div>
                    <div class="form-group">
                        <label class="form-label">البريد الإلكتروني</label>
                        <input class="form-control" @bind="NewDem.Email" type="email" placeholder="example@email.com" />
                    </div>
                    <div class="form-group" style="grid-column:span 2;">
                        <label class="form-label">العنوان <span class="required">*</span></label>
                        <input class="form-control @(Errors.ContainsKey("Adresse") ? "error" : "")" @bind="NewDem.Adresse" placeholder="العنوان الكامل..." />
                        @if (Errors.ContainsKey("Adresse")) { <span class="form-error">@Errors["Adresse"]</span> }
                    </div>
                </div>
            }
        </div>

        <div class="btn-nav-row">
            <button class="btn btn-outline" @onclick='() => Nav.NavigateTo("/permits")'>
                <i class="bi bi-arrow-right"></i> إلغاء
            </button>
            <button class="btn btn-primary" @onclick="NextStep1">
                التالي <i class="bi bi-arrow-left"></i>
            </button>
        </div>
    }

    <!-- ═══ STEP 2: Projet ═══ -->
    else if (CurrentStep == 2)
    {
        <div class="pnew-card">
            <div class="pnew-section-title"><i class="bi bi-building"></i> بيانات المشروع</div>

            <div class="form-grid col2">
                <div class="form-group">
                    <label class="form-label">نوع الطلب <span class="required">*</span></label>
                    <select class="form-control @(Errors.ContainsKey("TypeDemande") ? "error" : "")"
                            @bind="Dto.TypeDemandeId">
                        <option value="0">-- اختر النوع --</option>
                        @foreach (var t in TypesDemande)
                        {
                            <option value="@t.Id">@t.Libelle @(t.TarifBase.HasValue ? $"(أساس: {t.TarifBase} د.ت)" : "")</option>
                        }
                    </select>
                    @if (Errors.ContainsKey("TypeDemande")) { <span class="form-error">@Errors["TypeDemande"]</span> }
                </div>
                <div class="form-group">
                    <label class="form-label">نوع البناء</label>
                    <select class="form-control" @bind="TypeConstructionStr">
                        <option value="">-- اختر --</option>
                        <option value="Residential">سكني</option>
                        <option value="Commercial">تجاري</option>
                        <option value="Industriel">صناعي</option>
                        <option value="Mixte">مختلط</option>
                        <option value="Agricole">فلاحي</option>
                    </select>
                </div>

                <div class="form-group" style="grid-column:span 2;">
                    <label class="form-label">عنوان المشروع <span class="required">*</span></label>
                    <input class="form-control @(Errors.ContainsKey("Adresse") ? "error" : "")"
                           @bind="Dto.AdresseProjet" placeholder="عنوان موقع البناء الكامل..." />
                    @if (Errors.ContainsKey("Adresse")) { <span class="form-error">@Errors["Adresse"]</span> }
                </div>

                <div class="form-group">
                    <label class="form-label">رقم القطعة</label>
                    <input class="form-control" @bind="Dto.NumeroParcelle" placeholder="مثال: 45/B" />
                </div>
                <div class="form-group">
                    <label class="form-label">التخطيط العمراني</label>
                    <select class="form-control" @bind="Dto.ZonageId">
                        <option value="">-- اختر --</option>
                        @foreach (var z in Zonages)
                        {
                            <option value="@z.Id">@z.Code — @z.Libelle</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">مساحة الأرض (م²)</label>
                    <input class="form-control" type="number" step="0.01" @bind="Dto.SuperficieTerrain" placeholder="0.00" />
                </div>
                <div class="form-group">
                    <label class="form-label">المساحة المبنية (م²)</label>
                    <input class="form-control" type="number" step="0.01" @bind="Dto.SuperficieAConstruire" placeholder="0.00" />
                </div>
                <div class="form-group">
                    <label class="form-label">عدد الطوابق</label>
                    <input class="form-control" type="number" min="1" @bind="Dto.NombreNiveaux" placeholder="1" />
                </div>
                <div class="form-group">
                    <label class="form-label">التكلفة التقديرية (د.ت)</label>
                    <input class="form-control" type="number" step="0.01" @bind="Dto.CoutEstimatif" placeholder="0.00" />
                </div>

                <div class="form-group" style="grid-column:span 2;">
                    <label class="form-label">ملاحظات</label>
                    <textarea class="form-control" @bind="Dto.Observations" rows="3" placeholder="معلومات إضافية عن المشروع..."></textarea>
                </div>
            </div>
        </div>

        <div class="btn-nav-row">
            <button class="btn btn-outline" @onclick='() => CurrentStep = 1'>
                <i class="bi bi-arrow-right"></i> السابق
            </button>
            <button class="btn btn-primary" @onclick="NextStep2">
                التالي <i class="bi bi-arrow-left"></i>
            </button>
        </div>
    }

    <!-- ═══ STEP 3: Architecte ═══ -->
    else if (CurrentStep == 3)
    {
        <div class="pnew-card">
            <div class="pnew-section-title"><i class="bi bi-compass"></i> المهندس المعماري (اختياري)</div>

            @if (SelectedArchitecte != null)
            {
                <div class="selected-badge">
                    <i class="bi bi-person-check-fill" style="color:#22c55e;"></i>
                    <div>
                        <div style="font-weight:700;">@SelectedArchitecte.NomComplet</div>
                        <div style="font-size:.72rem;color:#64748b;">رقم النقابة: @SelectedArchitecte.NumeroOrdre · @SelectedArchitecte.Telephone</div>
                    </div>
                    <button class="clear" @onclick="() => { SelectedArchitecte = null; Dto.ArchitecteId = null; }">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            }
            else
            {
                <div style="font-size:.82rem;color:#64748b;margin-bottom:.75rem;">
                    <i class="bi bi-info-circle-fill" style="color:#0ea5e9;"></i>
                    تعيين مهندس معماري اختياري — يمكن إضافته لاحقاً
                </div>

                @foreach (var a in Architectes)
                {
                    <div class="search-item" style="border:1px solid #e2e8f0;border-radius:9px;margin-bottom:.4rem;"
                         @onclick="() => { SelectedArchitecte = a; Dto.ArchitecteId = a.Id; }">
                        <div class="si-name">@a.NomComplet</div>
                        <div class="si-sub">رقم النقابة: @a.NumeroOrdre · @a.Telephone</div>
                    </div>
                }
            }
        </div>

        <div class="btn-nav-row">
            <button class="btn btn-outline" @onclick='() => CurrentStep = 2'>
                <i class="bi bi-arrow-right"></i> السابق
            </button>
            <button class="btn btn-primary" @onclick='() => CurrentStep = 4'>
                مراجعة <i class="bi bi-arrow-left"></i>
            </button>
        </div>
    }

    <!-- ═══ STEP 4: Review ═══ -->
    else if (CurrentStep == 4)
    {
        <div class="pnew-card">
            <div class="pnew-section-title"><i class="bi bi-check2-square"></i> مراجعة الطلب قبل الإيداع</div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                <div>
                    <div style="font-size:.7rem;font-weight:700;color:#94a3b8;letter-spacing:.06em;text-transform:uppercase;margin-bottom:.4rem;">المتقدم</div>
                    <div style="font-size:.85rem;font-weight:700;color:#0f172a;">
                        @(SelectedDemandeur?.NomComplet ?? $"{NewDem.Prenom} {NewDem.Nom}".Trim())
                    </div>
                    <div style="font-size:.78rem;color:#64748b;">@(SelectedDemandeur?.Telephone ?? NewDem.Telephone)</div>
                </div>
                <div>
                    <div style="font-size:.7rem;font-weight:700;color:#94a3b8;letter-spacing:.06em;text-transform:uppercase;margin-bottom:.4rem;">نوع الطلب</div>
                    <div style="font-size:.85rem;font-weight:700;color:#0f172a;">
                        @(TypesDemande.FirstOrDefault(t => t.Id == Dto.TypeDemandeId)?.Libelle ?? "—")
                    </div>
                    <div style="font-size:.78rem;color:#64748b;">@(string.IsNullOrEmpty(TypeConstructionStr) ? "" : GetTypeConstrLabel(TypeConstructionStr))</div>
                </div>
                <div style="grid-column:span 2;">
                    <div style="font-size:.7rem;font-weight:700;color:#94a3b8;letter-spacing:.06em;text-transform:uppercase;margin-bottom:.4rem;">عنوان المشروع</div>
                    <div style="font-size:.85rem;color:#0f172a;">@Dto.AdresseProjet</div>
                </div>
                @if (Dto.SuperficieTerrain.HasValue || Dto.NombreNiveaux.HasValue || Dto.CoutEstimatif.HasValue)
                {
                    <div>
                        <div style="font-size:.7rem;font-weight:700;color:#94a3b8;letter-spacing:.06em;text-transform:uppercase;margin-bottom:.4rem;">المواصفات</div>
                        @if (Dto.SuperficieTerrain.HasValue) { <div style="font-size:.8rem;color:#374151;">مساحة: @Dto.SuperficieTerrain م²</div> }
                        @if (Dto.NombreNiveaux.HasValue) { <div style="font-size:.8rem;color:#374151;">طوابق: @Dto.NombreNiveaux</div> }
                        @if (Dto.CoutEstimatif.HasValue) { <div style="font-size:.8rem;color:#374151;">تكلفة: @Dto.CoutEstimatif.Value.ToString("N0") د.ت</div> }
                    </div>
                }
                @if (SelectedArchitecte != null)
                {
                    <div>
                        <div style="font-size:.7rem;font-weight:700;color:#94a3b8;letter-spacing:.06em;text-transform:uppercase;margin-bottom:.4rem;">المهندس المعماري</div>
                        <div style="font-size:.85rem;color:#0f172a;">@SelectedArchitecte.NomComplet</div>
                        <div style="font-size:.78rem;color:#64748b;">@SelectedArchitecte.NumeroOrdre</div>
                    </div>
                }
            </div>
        </div>

        <div class="btn-nav-row">
            <button class="btn btn-outline" @onclick='() => CurrentStep = 3'>
                <i class="bi bi-arrow-right"></i> السابق
            </button>
            <button class="btn btn-success" @onclick="SubmitForm" disabled="@IsSaving">
                @if (IsSaving) { <i class="bi bi-arrow-clockwise spinner"></i> }
                <i class="bi bi-check-circle-fill"></i> إيداع الطلب الآن
            </button>
        </div>
    }
</div>

@code {
    private int CurrentStep = 1;
    private CreateDemandePermisDto Dto = new();
    private bool IsSaving = false;
    private Dictionary<string, string> Errors = new();

    // Demandeur
    private string DemSearchTerm = "";
    private List<DemandeurDto> DemSearchResults = new();
    private DemandeurDto? SelectedDemandeur = null;
    private CreateDemandeurDto NewDem = new() { Type = "Personne" };

    // Architecte
    private List<ArchitecteDto> Architectes = new();
    private ArchitecteDto? SelectedArchitecte = null;

    // Refs
    private List<TypeDemandePermisDto> TypesDemande = new();
    private List<ZonageUrbanismeDto>   Zonages      = new();
    private string TypeConstructionStr = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            TypesDemande = await RefsApi.GetTypesDemandeAsync() ?? new();
            Zonages      = await RefsApi.GetZonagesAsync() ?? new();
            Architectes  = await ArchitecteApi.GetAllAsync() ?? new();
        }
        catch { }
        StateHasChanged();
    }

    private async Task SearchDemandeurs()
    {
        if (DemSearchTerm.Length < 2) { DemSearchResults.Clear(); return; }
        try { DemSearchResults = await DemandeurApi.SearchAsync(DemSearchTerm) ?? new(); }
        catch { }
    }

    private void SelectDemandeur(DemandeurDto d)
    {
        SelectedDemandeur = d;
        Dto.DemandeurId = d.Id;
        DemSearchResults.Clear();
        DemSearchTerm = "";
    }

    private void TryGoToStep(int step)
    {
        if (step < CurrentStep) CurrentStep = step;
    }

    private async Task NextStep1()
    {
        Errors.Clear();
        if (SelectedDemandeur == null)
        {
            // create new demandeur
            if (string.IsNullOrEmpty(NewDem.Nom)) { Errors["Nom"] = "اللقب مطلوب"; }
            if (string.IsNullOrEmpty(NewDem.Telephone)) { Errors["Tel"] = "الهاتف مطلوب"; }
            if (string.IsNullOrEmpty(NewDem.Adresse)) { Errors["Adresse"] = "العنوان مطلوب"; }
            if (Errors.Any()) return;

            try
            {
                var d = await DemandeurApi.CreateAsync(NewDem);
                if (d != null) { SelectedDemandeur = d; Dto.DemandeurId = d.Id; }
            }
            catch { Errors["Nom"] = "خطأ في إنشاء المتقدم"; return; }
        }
        CurrentStep = 2;
    }

    private void NextStep2()
    {
        Errors.Clear();
        if (Dto.TypeDemandeId == 0) { Errors["TypeDemande"] = "نوع الطلب مطلوب"; }
        if (string.IsNullOrEmpty(Dto.AdresseProjet)) { Errors["Adresse"] = "عنوان المشروع مطلوب"; }
        if (Errors.Any()) return;
        Dto.TypeConstruction = string.IsNullOrEmpty(TypeConstructionStr) ? null : TypeConstructionStr;
        CurrentStep = 3;
    }

    private async Task SubmitForm()
    {
        IsSaving = true;
        try
        {
            var result = await PermisApi.DeposerAsync(Dto);
            if (result != null)
                Nav.NavigateTo($"/permits/{result.Id}");
        }
        catch { }
        finally { IsSaving = false; }
    }

    private string GetTypeConstrLabel(string? t) => t switch
    {
        "Residential" => "سكني", "Commercial" => "تجاري",
        "Industriel"  => "صناعي", "Mixte" => "مختلط", "Agricole" => "فلاحي",
        _ => t ?? ""
    };
}
