    private string GetCommStatusLabel(string s) => s switch
    {
        "Programmee" => "مبرمجة",
        "Tenue"      => "منعقدة",
        "Reportee"   => "مؤجلة",
        "Annulee"    => "ملغاة",
        _ => s
    };

    private void ShowToast(string msg)
    {
        ToastMsg = msg; StateHasChanged();
        Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { ToastMsg = ""; StateHasChanged(); }));
    }
}
