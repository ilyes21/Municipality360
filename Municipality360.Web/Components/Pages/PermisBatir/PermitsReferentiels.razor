@page "/permits/referentiels"
@using Municipality360.Application.DTOs.PermisBatir
@using Municipality360.Web.Services
@inject IPermisReferentielsApiService RefsApi
@inject IDemandeurApiService DemandeurApi
@inject IArchitecteApiService ArchitecteApi
@inject NavigationManager Nav

<PageTitle>مراجع رخص البناء</PageTitle>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap');
    * { box-sizing: border-box; }
    .ref-root { font-family: 'Tajawal', sans-serif; }
    .ref-tabs { display:flex; gap:0; background:#fff; border:1px solid #e2e8f0; border-radius:12px; overflow:hidden; margin-bottom:1.25rem; }
    .ref-tab { flex:1; padding:.65rem .5rem; text-align:center; font-size:.78rem; font-weight:600; color:#64748b; cursor:pointer; border-left:1px solid #e2e8f0; transition:all .18s; font-family:'Tajawal',sans-serif; }
    .ref-tab:first-child { border-left:none; }
    .ref-tab.active { background:#f0f9ff; color:#0369a1; font-weight:700; }
    .ref-tab:hover:not(.active) { background:#f8fafc; color:#374151; }

    .ref-card { background:#fff; border:1px solid #e2e8f0; border-radius:14px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,.04); }
    .ref-card-header { padding:.8rem 1.1rem; border-bottom:1px solid #f1f5f9; display:flex; align-items:center; justify-content:space-between; }
    .ref-card-title { font-size:.88rem; font-weight:700; color:#0f172a; }

    .ref-table { width:100%; border-collapse:collapse; }
    .ref-table th { padding:.6rem 1rem; text-align:right; font-size:.7rem; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:.05em; background:#f8fafc; border-bottom:1px solid #f1f5f9; }
    .ref-table td { padding:.65rem 1rem; font-size:.82rem; color:#374151; border-bottom:1px solid #f8fafc; vertical-align:middle; }
    .ref-table tr:last-child td { border-bottom:none; }
    .ref-table tr:hover td { background:#f8fafc; }

    .badge-active   { background:#dcfce7; color:#15803d; padding:.15em .55em; border-radius:99px; font-size:.68rem; font-weight:700; }
    .badge-inactive { background:#f1f5f9; color:#64748b; padding:.15em .55em; border-radius:99px; font-size:.68rem; font-weight:700; }

    .btn { padding:.42rem .9rem; border-radius:8px; border:none; font-family:'Tajawal',sans-serif; font-size:.78rem; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:.35rem; transition:all .18s; }
    .btn-primary { background:#0ea5e9; color:#fff; }
    .btn-primary:hover { background:#0369a1; }
    .btn-outline { background:#fff; color:#374151; border:1px solid #e2e8f0; }
    .btn-outline:hover { background:#f8fafc; }
    .btn-sm { padding:.28rem .65rem; font-size:.72rem; }

    .add-form { background:#f8fafc; border:1px solid #e2e8f0; border-radius:12px; padding:1rem; margin:.75rem; }
    .add-form-title { font-size:.78rem; font-weight:700; color:#374151; margin-bottom:.7rem; }
    .add-form-grid { display:grid; gap:.65rem; }
    .col2 { grid-template-columns:1fr 1fr; }
    .col3 { grid-template-columns:1fr 1fr 1fr; }
    @@media (max-width:640px) { .col2,.col3 { grid-template-columns:1fr; } }
    .form-group { display:flex; flex-direction:column; gap:.25rem; }
    .form-label { font-size:.72rem; font-weight:600; color:#64748b; }
    .form-control { padding:.42rem .65rem; border:1px solid #e2e8f0; border-radius:8px; font-family:'Tajawal',sans-serif; font-size:.8rem; color:#0f172a; background:#fff; outline:none; transition:border-color .15s; }
    .form-control:focus { border-color:#0ea5e9; }

    @@keyframes spin { to { transform:rotate(360deg); } }
    .spinner { animation:spin .75s linear infinite; }
    .loading { padding:2.5rem; text-align:center; color:#94a3b8; font-size:.85rem; }
    .empty   { padding:2rem; text-align:center; color:#94a3b8; font-size:.82rem; }
    .empty i { font-size:1.8rem; display:block; margin-bottom:.4rem; color:#cbd5e1; }

    .pm-toast { position:fixed; bottom:1.5rem; right:1.5rem; background:#1e293b; color:#f1f5f9; padding:.75rem 1.1rem; border-radius:12px; font-size:.8rem; font-weight:600; z-index:9999; display:flex; align-items:center; gap:.5rem; box-shadow:0 8px 30px rgba(0,0,0,.25); border-right:3px solid #22c55e; animation:toast-in .3s ease; }
    @@keyframes toast-in { from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);} }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="ref-root">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:.5rem;">
        <div>
            <div style="font-size:1.2rem;font-weight:800;color:#0f172a;"><i class="bi bi-gear-fill" style="color:#0ea5e9;margin-left:.4rem;"></i>مراجع التعمير</div>
            <div style="font-size:.78rem;color:#64748b;">إدارة قوائم التخطيط والأنواع والهيئات</div>
        </div>
        <button class="btn btn-outline" @onclick='() => Nav.NavigateTo("/permits")'>
            <i class="bi bi-arrow-right"></i> العودة
        </button>
    </div>

    <div class="ref-tabs">
        @foreach (var (key, lbl, icon) in Tabs)
        {
            var k = key;
            <div class="ref-tab @(ActiveTab == k ? "active" : "")" @onclick="() => ActiveTab = k">
                <i class="bi @icon"></i> @lbl
            </div>
        }
    </div>

    <!-- ═══ ZONAGE ═══ -->
    @if (ActiveTab == "zonage")
    {
        <div class="ref-card">
            <div class="ref-card-header">
                <span class="ref-card-title"><i class="bi bi-map-fill" style="color:#0ea5e9;margin-left:.35rem;"></i>التخطيط العمراني</span>
                <button class="btn btn-primary btn-sm" @onclick='() => ShowAddZonage = !ShowAddZonage'>
                    <i class="bi bi-plus"></i> إضافة
                </button>
            </div>
            @if (ShowAddZonage)
            {
                <div class="add-form">
                    <div class="add-form-title">تخطيط عمراني جديد</div>
                    <div class="add-form-grid col3">
                        <div class="form-group">
                            <label class="form-label">الرمز *</label>
                            <input class="form-control" @bind="NzCode" placeholder="مثال: Z-RES-1" />
                        </div>
                        <div class="form-group" style="grid-column:span 2;">
                            <label class="form-label">التسمية *</label>
                            <input class="form-control" @bind="NzLibelle" placeholder="تسمية التخطيط..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">معامل استيعاب الأرض</label>
                            <input class="form-control" type="number" step="0.01" @bind="NzCOS" placeholder="0.00" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">معامل استخدام الأرض</label>
                            <input class="form-control" type="number" step="0.01" @bind="NzCUS" placeholder="0.00" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">الارتفاع الأقصى (م)</label>
                            <input class="form-control" type="number" step="0.5" @bind="NzHauteur" placeholder="0" />
                        </div>
                    </div>
                    <div style="display:flex;gap:.4rem;margin-top:.65rem;">
                        <button class="btn btn-primary btn-sm" @onclick="AddZonage" disabled="@IsSaving">
                            @if (IsSaving) { <i class="bi bi-arrow-clockwise spinner"></i> } حفظ
                        </button>
                        <button class="btn btn-outline btn-sm" @onclick='() => ShowAddZonage = false'>إلغاء</button>
                    </div>
                </div>
            }
            @if (IsLoadingTab) { <div class="loading"><i class="bi bi-arrow-clockwise spinner"></i> جارٍ التحميل...</div> }
            else if (!Zonages.Any()) { <div class="empty"><i class="bi bi-map"></i>لا توجد تخطيطات بعد</div> }
            else
            {
                <table class="ref-table">
                    <thead><tr><th>الرمز</th><th>التسمية</th><th>COS</th><th>CUS</th><th>الارتفاع</th><th>الحالة</th></tr></thead>
                    <tbody>
                        @foreach (var z in Zonages)
                        {
                            <tr>
                                <td><strong>@z.Code</strong></td>
                                <td>@z.Libelle</td>
                                <td>@(z.CoefficientOccupationSol?.ToString("F2") ?? "—")</td>
                                <td>@(z.CoefficientUtilisationSol?.ToString("F2") ?? "—")</td>
                                <td>@(z.HauteurMaximale.HasValue ? $"{z.HauteurMaximale} م" : "—")</td>
                                <td><span class="@(z.IsActive ? "badge-active" : "badge-inactive")">@(z.IsActive ? "نشط" : "غير نشط")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

    <!-- ═══ TYPES DEMANDE ═══ -->
    else if (ActiveTab == "types")
    {
        <div class="ref-card">
            <div class="ref-card-header">
                <span class="ref-card-title"><i class="bi bi-file-earmark-text" style="color:#0ea5e9;margin-left:.35rem;"></i>أنواع طلبات الرخص</span>
                <button class="btn btn-primary btn-sm" @onclick='() => ShowAddType = !ShowAddType'>
                    <i class="bi bi-plus"></i> إضافة
                </button>
            </div>
            @if (ShowAddType)
            {
                <div class="add-form">
                    <div class="add-form-title">نوع طلب جديد</div>
                    <div class="add-form-grid col3">
                        <div class="form-group">
                            <label class="form-label">الرمز *</label>
                            <input class="form-control" @bind="NtCode" placeholder="مثال: RB-RES" />
                        </div>
                        <div class="form-group" style="grid-column:span 2;">
                            <label class="form-label">التسمية *</label>
                            <input class="form-control" @bind="NtLibelle" placeholder="تسمية نوع الطلب..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">أجل المعالجة (يوم)</label>
                            <input class="form-control" type="number" @bind="NtDelai" placeholder="30" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">التعريفة الأساسية (د.ت)</label>
                            <input class="form-control" type="number" step="0.01" @bind="NtTarif" placeholder="0.00" />
                        </div>
                    </div>
                    <div style="display:flex;gap:.4rem;margin-top:.65rem;">
                        <button class="btn btn-primary btn-sm" @onclick="AddTypeDemande" disabled="@IsSaving">
                            @if (IsSaving) { <i class="bi bi-arrow-clockwise spinner"></i> } حفظ
                        </button>
                        <button class="btn btn-outline btn-sm" @onclick='() => ShowAddType = false'>إلغاء</button>
                    </div>
                </div>
            }
            @if (!TypesDemande.Any()) { <div class="empty"><i class="bi bi-file-earmark"></i>لا توجد أنواع بعد</div> }
            else
            {
                <table class="ref-table">
                    <thead><tr><th>الرمز</th><th>التسمية</th><th>الأجل</th><th>التعريفة</th><th>الحالة</th></tr></thead>
                    <tbody>
                        @foreach (var t in TypesDemande)
                        {
                            <tr>
                                <td><strong>@t.Code</strong></td>
                                <td>@t.Libelle</td>
                                <td>@t.DelaiTraitementJours يوم</td>
                                <td>@(t.TarifBase.HasValue ? $"{t.TarifBase.Value:N0} د.ت" : "—")</td>
                                <td><span class="@(t.IsActive ? "badge-active" : "badge-inactive")">@(t.IsActive ? "نشط" : "غير نشط")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

    <!-- ═══ COMMISSIONS ═══ -->
    else if (ActiveTab == "commissions")
    {
        <div class="ref-card">
            <div class="ref-card-header">
                <span class="ref-card-title"><i class="bi bi-people-fill" style="color:#0ea5e9;margin-left:.35rem;"></i>لجان الفحص</span>
                <button class="btn btn-primary btn-sm" @onclick='() => ShowAddComm = !ShowAddComm'>
                    <i class="bi bi-plus"></i> إضافة
                </button>
            </div>
            @if (ShowAddComm)
            {
                <div class="add-form">
                    <div class="add-form-title">لجنة جديدة</div>
                    <div class="add-form-grid col2">
                        <div class="form-group" style="grid-column:span 2;">
                            <label class="form-label">عنوان اللجنة *</label>
                            <input class="form-control" @bind="NcLibelle" placeholder="مثال: لجنة فحص أكتوبر 2024" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">تاريخ الاجتماع</label>
                            <input class="form-control" type="date" @bind="NcDate" />
                        </div>
                    </div>
                    <div style="display:flex;gap:.4rem;margin-top:.65rem;">
                        <button class="btn btn-primary btn-sm" @onclick="AddCommission" disabled="@IsSaving">
                            @if (IsSaving) { <i class="bi bi-arrow-clockwise spinner"></i> } حفظ
                        </button>
                        <button class="btn btn-outline btn-sm" @onclick='() => ShowAddComm = false'>إلغاء</button>
                    </div>
                </div>
            }
            @if (!Commissions.Any()) { <div class="empty"><i class="bi bi-people"></i>لا توجد لجان بعد</div> }
            else
            {
                <table class="ref-table">
                    <thead><tr><th>العنوان</th><th>تاريخ الاجتماع</th><th>الحالة</th></tr></thead>
                    <tbody>
                        @foreach (var c in Commissions)
                        {
                            <tr>
                                <td style="font-weight:600;">@c.Libelle</td>
                                <td>@(c.DateReunion.HasValue ? c.DateReunion.Value.ToString("dd/MM/yyyy") : "—")</td>
                                <td>
                                    <span class="@(c.StatutReunion == "Tenue" ? "badge-active" : "badge-inactive")">
                                        @GetCommStatusLabel(c.StatutReunion)
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

    <!-- ═══ TYPES TAXE ═══ -->
    else if (ActiveTab == "taxes")
    {
        <div class="ref-card">
            <div class="ref-card-header">
                <span class="ref-card-title"><i class="bi bi-cash-coin" style="color:#0ea5e9;margin-left:.35rem;"></i>أنواع الرسوم</span>
                <button class="btn btn-primary btn-sm" @onclick='() => ShowAddTaxe = !ShowAddTaxe'>
                    <i class="bi bi-plus"></i> إضافة
                </button>
            </div>
            @if (ShowAddTaxe)
            {
                <div class="add-form">
                    <div class="add-form-title">نوع رسم جديد</div>
                    <div class="add-form-grid col3">
                        <div class="form-group">
                            <label class="form-label">الرمز *</label>
                            <input class="form-control" @bind="NxCode" placeholder="مثال: TCA" />
                        </div>
                        <div class="form-group" style="grid-column:span 2;">
                            <label class="form-label">التسمية *</label>
                            <input class="form-control" @bind="NxLibelle" placeholder="تسمية الرسم..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">النسبة (%)</label>
                            <input class="form-control" type="number" step="0.01" @bind="NxTaux" placeholder="0.00" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">وحدة الحساب</label>
                            <input class="form-control" @bind="NxUnite" placeholder="مثال: م²، د.ت" />
                        </div>
                    </div>
                    <div style="display:flex;gap:.4rem;margin-top:.65rem;">
                        <button class="btn btn-primary btn-sm" @onclick="AddTypeTaxe" disabled="@IsSaving">
                            @if (IsSaving) { <i class="bi bi-arrow-clockwise spinner"></i> } حفظ
                        </button>
                        <button class="btn btn-outline btn-sm" @onclick='() => ShowAddTaxe = false'>إلغاء</button>
                    </div>
                </div>
            }
            @if (!TypesTaxe.Any()) { <div class="empty"><i class="bi bi-cash"></i>لا توجد أنواع رسوم بعد</div> }
            else
            {
                <table class="ref-table">
                    <thead><tr><th>الرمز</th><th>التسمية</th><th>النسبة</th><th>الوحدة</th><th>الحالة</th></tr></thead>
                    <tbody>
                        @foreach (var t in TypesTaxe)
                        {
                            <tr>
                                <td><strong>@t.Code</strong></td>
                                <td>@t.Libelle</td>
                                <td>@(t.TauxCalcul.HasValue ? $"{t.TauxCalcul}%" : "—")</td>
                                <td>@(t.UniteCalcul ?? "—")</td>
                                <td><span class="@(t.IsActive ? "badge-active" : "badge-inactive")">@(t.IsActive ? "نشط" : "غير نشط")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

    <!-- ═══ ARCHITECTES ═══ -->
    else if (ActiveTab == "architectes")
    {
        <div class="ref-card">
            <div class="ref-card-header">
                <span class="ref-card-title"><i class="bi bi-compass" style="color:#0ea5e9;margin-left:.35rem;"></i>المهندسون المعماريون</span>
                <button class="btn btn-primary btn-sm" @onclick='() => ShowAddArch = !ShowAddArch'>
                    <i class="bi bi-plus"></i> إضافة
                </button>
            </div>
            @if (ShowAddArch)
            {
                <div class="add-form">
                    <div class="add-form-title">مهندس معماري جديد</div>
                    <div class="add-form-grid col3">
                        <div class="form-group">
                            <label class="form-label">رقم النقابة *</label>
                            <input class="form-control" @bind="NaOrdre" placeholder="رقم انتساب نقابة المهندسين..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">اللقب *</label>
                            <input class="form-control" @bind="NaNom" placeholder="اللقب..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">الاسم *</label>
                            <input class="form-control" @bind="NaPrenom" placeholder="الاسم..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">CIN *</label>
                            <input class="form-control" @bind="NaCin" placeholder="رقم بطاقة الهوية..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">الهاتف *</label>
                            <input class="form-control" @bind="NaTel" placeholder="+216..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">البريد الإلكتروني</label>
                            <input class="form-control" @bind="NaEmail" type="email" placeholder="..." />
                        </div>
                    </div>
                    <div style="display:flex;gap:.4rem;margin-top:.65rem;">
                        <button class="btn btn-primary btn-sm" @onclick="AddArchitecte" disabled="@IsSaving">
                            @if (IsSaving) { <i class="bi bi-arrow-clockwise spinner"></i> } حفظ
                        </button>
                        <button class="btn btn-outline btn-sm" @onclick='() => ShowAddArch = false'>إلغاء</button>
                    </div>
                </div>
            }
            @if (!Architectes.Any()) { <div class="empty"><i class="bi bi-compass"></i>لا يوجد مهندسون بعد</div> }
            else
            {
                <table class="ref-table">
                    <thead><tr><th>رقم النقابة</th><th>الاسم الكامل</th><th>الهاتف</th><th>البريد</th><th>الحالة</th></tr></thead>
                    <tbody>
                        @foreach (var a in Architectes)
                        {
                            <tr>
                                <td style="font-weight:700;color:#0ea5e9;">@a.NumeroOrdre</td>
                                <td>@a.NomComplet</td>
                                <td>@a.Telephone</td>
                                <td>@(a.Email ?? "—")</td>
                                <td><span class="@(a.IsActive ? "badge-active" : "badge-inactive")">@(a.IsActive ? "نشط" : "غير نشط")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(ToastMsg))
{
    <div class="pm-toast">
        <i class="bi bi-check-circle-fill"></i> @ToastMsg
    </div>
}

@code {
    private string ActiveTab = "zonage";
    private bool IsLoadingTab = false;
    private bool IsSaving = false;
    private string ToastMsg = "";

    private (string key, string lbl, string icon)[] Tabs = new[]
    {
        ("zonage",       "التخطيط",      "bi-map-fill"),
        ("types",        "أنواع الطلبات","bi-file-earmark-text"),
        ("commissions",  "اللجان",       "bi-people-fill"),
        ("taxes",        "الرسوم",       "bi-cash-coin"),
        ("architectes",  "المهندسون",    "bi-compass"),
    };

    // Lists
    private List<ZonageUrbanismeDto>    Zonages      = new();
    private List<TypeDemandePermisDto>  TypesDemande = new();
    private List<CommissionExamenDto>   Commissions  = new();
    private List<TypeTaxeDto>           TypesTaxe    = new();
    private List<ArchitecteDto>         Architectes  = new();

    // Form toggles
    private bool ShowAddZonage = false;
    private bool ShowAddType   = false;
    private bool ShowAddComm   = false;
    private bool ShowAddTaxe   = false;
    private bool ShowAddArch   = false;

    // Zonage fields
    private string NzCode = ""; private string NzLibelle = "";
    private decimal? NzCOS; private decimal? NzCUS; private decimal? NzHauteur;

    // TypeDemande fields
    private string NtCode = ""; private string NtLibelle = "";
    private int NtDelai = 30; private decimal? NtTarif;

    // Commission fields
    private string NcLibelle = ""; private DateTime? NcDate;

    // TypeTaxe fields
    private string NxCode = ""; private string NxLibelle = "";
    private decimal? NxTaux; private string NxUnite = "";

    // Architecte fields
    private string NaOrdre = ""; private string NaNom = ""; private string NaPrenom = "";
    private string NaCin = ""; private string NaTel = ""; private string NaEmail = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadAll();
        StateHasChanged();
    }

    private async Task LoadAll()
    {
        IsLoadingTab = true;
        try
        {
            Zonages      = await RefsApi.GetZonagesAsync() ?? new();
            TypesDemande = await RefsApi.GetTypesDemandeAsync() ?? new();
            Commissions  = await RefsApi.GetCommissionsAsync() ?? new();
            TypesTaxe    = await RefsApi.GetTypesTaxeAsync() ?? new();
            Architectes  = await ArchitecteApi.GetAllAsync() ?? new();
        }
        catch { }
        finally { IsLoadingTab = false; }
    }

    private async Task AddZonage()
    {
        if (string.IsNullOrEmpty(NzCode) || string.IsNullOrEmpty(NzLibelle)) return;
        IsSaving = true;
        try
        {
            var r = await RefsApi.CreateZonageAsync(new CreateZonageDto
            {
                Code = NzCode, Libelle = NzLibelle,
                CoefficientOccupationSol = NzCOS,
                CoefficientUtilisationSol = NzCUS,
                HauteurMaximale = NzHauteur
            });
            if (r != null) { Zonages.Add(r); ShowAddZonage = false; NzCode = ""; NzLibelle = ""; NzCOS = null; NzCUS = null; NzHauteur = null; }
            ShowToast("تمت الإضافة ✓");
        }
        catch { } finally { IsSaving = false; }
    }

