@page "/permits/list"
@using Municipality360.Application.DTOs.PermisBatir
@using Municipality360.Application.Common
@using Municipality360.Web.Services
@inject IPermisBatirApiService PermisApi
@inject IPermisReferentielsApiService RefsApi
@inject ISignalRNotificationService SignalRNotif
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>قائمة الطلبات</PageTitle>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap');
    .pl-root{font-family:'Tajawal',sans-serif;}

    .filter-bar{
        background:#fff;border-radius:14px;
        border:1px solid #e2e8f0;padding:1rem;
        margin-bottom:1.1rem;
        display:flex;gap:.65rem;flex-wrap:wrap;align-items:flex-end;
    }
    .filter-group{display:flex;flex-direction:column;gap:.28rem;flex:1;min-width:140px;}
    .filter-label{font-size:.68rem;font-weight:700;color:#94a3b8;letter-spacing:.06em;text-transform:uppercase;}
    .filter-input,.filter-select{
        padding:.42rem .7rem;border:1px solid #e2e8f0;border-radius:8px;
        font-family:'Tajawal',sans-serif;font-size:.8rem;color:#0f172a;
        background:#f8fafc;outline:none;transition:border-color .15s;
    }
    .filter-input:focus,.filter-select:focus{border-color:#7c3aed;background:#fff;}
    .btn-filter{
        padding:.45rem 1rem;border-radius:9px;border:none;
        font-family:'Tajawal',sans-serif;font-size:.8rem;font-weight:700;
        cursor:pointer;transition:all .18s;
    }
    .btn-primary{background:#7c3aed;color:#fff;} .btn-primary:hover{background:#6d28d9;}
    .btn-reset{background:#f1f5f9;color:#374151;} .btn-reset:hover{background:#e2e8f0;}
    .btn-new{background:linear-gradient(135deg,#7c3aed,#a855f7);color:#fff;box-shadow:0 4px 12px rgba(124,58,237,.3);}
    .btn-new:hover{transform:translateY(-1px);box-shadow:0 6px 18px rgba(124,58,237,.4);}

    .table-card{background:#fff;border-radius:16px;border:1px solid #e2e8f0;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.04);}
    .tbl{width:100%;border-collapse:collapse;}
    .tbl th{padding:.7rem 1rem;font-size:.68rem;font-weight:700;color:#94a3b8;letter-spacing:.07em;text-transform:uppercase;background:#f8fafc;border-bottom:1px solid #f1f5f9;text-align:right;}
    .tbl td{padding:.8rem 1rem;font-size:.82rem;color:#374151;border-bottom:1px solid #f8fafc;vertical-align:middle;}
    .tbl tr:last-child td{border-bottom:none;}
    .tbl tr:hover td{background:#fafbff;cursor:pointer;}
    .tbl-num{font-weight:800;color:#7c3aed;}
    .tbl-addr{font-size:.75rem;color:#64748b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:180px;}

    .sp{display:inline-flex;align-items:center;gap:.25rem;padding:.2em .6em;border-radius:99px;font-size:.67rem;font-weight:700;}
    .sp-deposee  {background:#dbeafe;color:#1d4ed8;}
    .sp-examen   {background:#fef3c7;color:#b45309;}
    .sp-approuvee{background:#dcfce7;color:#15803d;}
    .sp-rejetee  {background:#fee2e2;color:#b91c1c;}
    .sp-suspendue{background:#f1f5f9;color:#64748b;}
    .sp-retard   {background:#fef2f2;color:#b91c1c;}

    .pager{display:flex;align-items:center;justify-content:space-between;padding:.75rem 1rem;border-top:1px solid #f1f5f9;}
    .pager-info{font-size:.75rem;color:#94a3b8;}
    .pager-btns{display:flex;gap:.4rem;}
    .pager-btn{
        padding:.35rem .75rem;border-radius:8px;
        border:1px solid #e2e8f0;background:#fff;
        font-family:'Tajawal',sans-serif;font-size:.78rem;font-weight:600;
        cursor:pointer;transition:all .15s;color:#374151;
    }
    .pager-btn:hover:not(:disabled){background:#f0f4f8;}
    .pager-btn:disabled{opacity:.4;cursor:not-allowed;}
    .pager-btn.active{background:#7c3aed;border-color:#7c3aed;color:#fff;}

    @@keyframes spin{to{transform:rotate(360deg);}}
    .spinner{animation:spin .75s linear infinite;}
    .loading-row td{text-align:center;padding:2.5rem;color:#94a3b8;}

    .action-cell{display:flex;gap:.35rem;}
    .act-btn{
        width:30px;height:30px;border-radius:8px;border:1px solid #e2e8f0;
        background:#fff;display:flex;align-items:center;justify-content:center;
        font-size:.8rem;cursor:pointer;transition:all .15s;color:#64748b;
    }
    .act-btn:hover{background:#f0f9ff;border-color:#7c3aed;color:#7c3aed;}
    .act-btn.danger:hover{background:#fef2f2;border-color:#ef4444;color:#ef4444;}
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>

<div class="pl-root">

    <!-- Header -->
    <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.1rem;">
        <div style="flex:1;">
            <h2 style="font-size:1.1rem;font-weight:800;color:#0f172a;margin:0;">
                <i class="bi bi-card-list me-2" style="color:#7c3aed;"></i> قائمة طلبات رخص البناء
            </h2>
            <div style="font-size:.75rem;color:#94a3b8;margin-top:.1rem;">
                @(Paged?.TotalCount ?? 0) طلب إجمالي
            </div>
        </div>
        <button class="btn-filter btn-new" @onclick='()=>Nav.NavigateTo("/permits/new")'>
            <i class="bi bi-plus-lg me-1"></i> طلب جديد
        </button>
    </div>

    <!-- Filter bar -->
    <div class="filter-bar">
        <div class="filter-group">
            <span class="filter-label">البحث</span>
            <input class="filter-input" type="text" placeholder="رقم الطلب، المتقدم، العنوان..."
                   @bind="Filter.SearchTerm" @bind:event="oninput" @onkeyup="OnSearchKey" />
        </div>
        <div class="filter-group" style="max-width:150px;">
            <span class="filter-label">الحالة</span>
            <select class="filter-select" @bind="Filter.Statut">
                <option value="">الكل</option>
                <option value="Deposee">مودعة</option>
                <option value="EnExamen">قيد الفحص</option>
                <option value="Approuvee">موافق عليها</option>
                <option value="Rejetee">مرفوضة</option>
                <option value="Suspendue">معلقة</option>
            </select>
        </div>
        <div class="filter-group" style="max-width:160px;">
            <span class="filter-label">نوع الطلب</span>
            <select class="filter-select" @bind="Filter.TypeDemandeId">
                <option value="">الكل</option>
                @foreach (var t in _typesDemande)
                {
                    <option value="@t.Id">@t.Libelle</option>
                }
            </select>
        </div>
        <div class="filter-group" style="max-width:150px;">
            <span class="filter-label">نوع البناء</span>
            <select class="filter-select" @bind="Filter.TypeConstruction">
                <option value="">الكل</option>
                <option value="Residential">سكني</option>
                <option value="Commercial">تجاري</option>
                <option value="Industriel">صناعي</option>
                <option value="Mixte">مختلط</option>
                <option value="Agricole">فلاحي</option>
            </select>
        </div>
        <div class="filter-group" style="max-width:130px;">
            <span class="filter-label">من تاريخ</span>
            <input class="filter-input" type="date" @bind="Filter.DateDebut" />
        </div>
        <div class="filter-group" style="max-width:130px;">
            <span class="filter-label">إلى تاريخ</span>
            <input class="filter-input" type="date" @bind="Filter.DateFin" />
        </div>
        <div style="display:flex;gap:.45rem;align-items:flex-end;">
            <button class="btn-filter btn-primary" @onclick="Search">
                <i class="bi bi-search me-1"></i> بحث
            </button>
            <button class="btn-filter btn-reset" @onclick="Reset">إعادة تعيين</button>
        </div>
    </div>

    <!-- Table -->
    <div class="table-card">
        <table class="tbl">
            <thead>
                <tr>
                    <th>رقم الطلب</th>
                    <th>المتقدم</th>
                    <th>عنوان المشروع</th>
                    <th>النوع</th>
                    <th>الحالة</th>
                    <th>الرسوم</th>
                    <th>تاريخ الإيداع</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (IsLoading)
                {
                    <tr><td colspan="8" class="loading-row" style="text-align:center;padding:2.5rem;color:#94a3b8;">
                        <i class="bi bi-arrow-clockwise spinner" style="font-size:1.3rem;"></i>
                        <div style="margin-top:.5rem;">جارٍ التحميل...</div>
                    </td></tr>
                }
                else if (!(Paged?.Items?.Any() ?? false))
                {
                    <tr><td colspan="8" style="text-align:center;padding:2.5rem;color:#94a3b8;">
                        <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:.5rem;color:#cbd5e1;"></i>
                        لا توجد نتائج مطابقة
                    </td></tr>
                }
                else
                {
                    @foreach (var d in Paged!.Items!)
                    {
                        <tr @onclick='()=>Nav.NavigateTo($"/permits/detail/{d.Id}")'>
                            <td><span class="tbl-num">@d.NumeroDemande</span></td>
                            <td>
                                <div style="font-weight:600;">@d.DemandeurNomComplet</div>
                                <div style="font-size:.72rem;color:#94a3b8;">@d.DemandeurTelephone</div>
                            </td>
                            <td><div class="tbl-addr">@d.AdresseProjet</div>
                                @if (!string.IsNullOrEmpty(d.NumeroParcelle))
                                {
                                    <div style="font-size:.7rem;color:#94a3b8;">قطعة @d.NumeroParcelle</div>
                                }
                            </td>
                            <td style="font-size:.75rem;">@GetConstructionLabel(d.TypeConstruction)</td>
                            <td>
                                <span class="sp @GetStatutClass(d.Statut)">@GetStatutLabel(d.Statut)</span>
                                
                            </td>
                            <td>
                                @if (d.TotalTaxes > 0)
                                {
                                    <span style="font-size:.78rem;font-weight:700;color:@(d.ToutesLTaxesPayees?"#15803d":"#b45309");">
                                        @d.TotalTaxes.ToString("N0") د.ج
                                        @if (!d.ToutesLTaxesPayees) { <text> ⚠</text> }
                                    </span>
                                }
                                else { <span style="color:#94a3b8;font-size:.75rem;">—</span> }
                            </td>
                            <td style="color:#94a3b8;font-size:.75rem;">@d.DateDepot.ToString("dd/MM/yyyy")</td>
                            <td @onclick:stopPropagation>
                                <div class="action-cell">
                                    <button class="act-btn" title="عرض التفاصيل"
                                            @onclick='()=>Nav.NavigateTo($"/permits/detail/{d.Id}")'>
                                        <i class="bi bi-eye-fill"></i>
                                    </button>
                                    @if (d.Statut == "Deposee")
                                    {
                                        <button class="act-btn" title="معالجة"
                                                @onclick='()=>Nav.NavigateTo($"/permits/process/{d.Id}")'>
                                            <i class="bi bi-gear-fill"></i>
                                        </button>
                                    }
                                    @if (d.Statut == "Approuvee" && string.IsNullOrEmpty(d.NumeroPermis))
                                    {
                                        <button class="act-btn" title="تسليم الرخصة"
                                                style="color:#15803d;"
                                                @onclick='()=>Nav.NavigateTo($"/permits/deliver/{d.Id}")'>
                                            <i class="bi bi-award-fill"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <!-- Pagination -->
        @if ((Paged?.TotalPages ?? 0) > 1)
        {
            <div class="pager">
                <span class="pager-info">
                    عرض @((Filter.PageNumber-1)*Filter.PageSize+1) — @(Math.Min(Filter.PageNumber*Filter.PageSize, Paged!.TotalCount))
                    من @Paged!.TotalCount
                </span>
                <div class="pager-btns">
                    <button class="pager-btn" @onclick="PrevPage" disabled="@(Filter.PageNumber <= 1)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                    @for (int p = Math.Max(1, Filter.PageNumber-2); p <= Math.Min(Paged!.TotalPages, Filter.PageNumber+2); p++)
                    {
                        var pg = p;
                        <button class="pager-btn @(pg==Filter.PageNumber?"active":"")" @onclick="()=>GoPage(pg)">@pg</button>
                    }
                    <button class="pager-btn" @onclick="NextPage" disabled="@(Filter.PageNumber >= (Paged?.TotalPages??1))">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? statut { get; set; }

    private DemandePermisFilterDto Filter = new() { PageSize = 15, PageNumber = 1 };
    private PagedResult<DemandePermisDto>? Paged;
    private bool IsLoading = true;
    private List<TypeDemandePermisDto> _typesDemande = new();

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(statut)) Filter.Statut = statut;
        SignalRNotif.OnChanged += Refresh;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var typesTask = RefsApi.GetTypesDemandeAsync();
        var dataTask  = PermisApi.GetPagedAsync(Filter);
        IsLoading = true;
        try
        {
            await Task.WhenAll(typesTask, dataTask);
            _typesDemande = await typesTask ?? new();
            Paged = await dataTask;
        }
        catch { }
        finally { IsLoading = false; }
        StateHasChanged();
    }

    private async Task LoadData()
    {
        IsLoading = true;
        try { Paged = await PermisApi.GetPagedAsync(Filter); }
        catch { }
        finally { IsLoading = false; }
    }

    private async Task Search()  { Filter.PageNumber = 1; await LoadData(); }
    private async Task Reset()   { Filter = new() { PageSize = 15, PageNumber = 1 }; await LoadData(); }
    private async Task OnSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") await Search(); }
    private async Task PrevPage(){ Filter.PageNumber--; await LoadData(); }
    private async Task NextPage(){ Filter.PageNumber++; await LoadData(); }
    private async Task GoPage(int p){ Filter.PageNumber = p; await LoadData(); }

    private void Refresh() => InvokeAsync(StateHasChanged);

    private string GetStatutClass(string s) => s switch
    {
        "Deposee"   => "sp-deposee",
        "EnExamen"  => "sp-examen",
        "Approuvee" => "sp-approuvee",
        "Rejetee"   => "sp-rejetee",
        _           => "sp-suspendue"
    };

    private string GetStatutLabel(string s) => s switch
    {
        "Deposee"   => "مودعة",
        "EnExamen"  => "قيد الفحص",
        "Approuvee" => "موافق عليها",
        "Rejetee"   => "مرفوضة",
        "Suspendue" => "معلقة",
        _ => s
    };

    private string GetConstructionLabel(string? s) => s switch
    {
        "Residential" => "سكني",
        "Commercial"  => "تجاري",
        "Industriel"  => "صناعي",
        "Mixte"       => "مختلط",
        "Agricole"    => "فلاحي",
        _ => s ?? "—"
    };

    public void Dispose() => SignalRNotif.OnChanged -= Refresh;
}
