@page "/employes"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@attribute [Authorize]
@layout Municipality360.Web.Components.Layout.MainLayout
@inject AuthenticationStateProvider AuthSP

<PageTitle>الموظفون - Municipality360</PageTitle>

<style>
    .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;}
    .page-title{font-size:1.35rem;font-weight:800;color:#0f172a;margin:0;}
    .page-sub{font-size:.8rem;color:#94a3b8;margin-top:.2rem;}
    .btn-add{display:flex;align-items:center;gap:.5rem;padding:.55rem 1.1rem;background:linear-gradient(135deg,#0369a1,#0ea5e9);color:#fff;border:none;border-radius:10px;font-family:'Tajawal',sans-serif;font-size:.88rem;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(14,165,233,.3);transition:all .2s;}
    .btn-add:hover{transform:translateY(-1px);}
    .stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1rem;margin-bottom:1.5rem;}
    .stat-card{background:#fff;border-radius:12px;padding:1rem 1.2rem;box-shadow:0 1px 6px rgba(0,0,0,.06);border:1px solid #f1f5f9;}
    .stat-val{font-size:1.6rem;font-weight:800;}
    .stat-lbl{font-size:.73rem;color:#94a3b8;margin-top:.15rem;}
    .filter-row{display:flex;gap:.75rem;margin-bottom:1.2rem;flex-wrap:wrap;align-items:center;}
    .search-wrap{position:relative;flex:2;min-width:200px;}
    .search-input{width:100%;height:40px;padding:0 1rem 0 2.5rem;border:1.5px solid #e2e8f0;border-radius:10px;font-family:'Tajawal',sans-serif;font-size:.88rem;outline:none;background:#fff;}
    .search-input:focus{border-color:#0ea5e9;box-shadow:0 0 0 3px rgba(14,165,233,.1);}
    .search-icon{position:absolute;right:10px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.9rem;pointer-events:none;}
    .filter-select{height:40px;padding:0 .85rem;border:1.5px solid #e2e8f0;border-radius:10px;font-family:'Tajawal',sans-serif;font-size:.85rem;outline:none;background:#fff;cursor:pointer;color:#374151;min-width:140px;}
    .filter-select:focus{border-color:#0ea5e9;}
    .table-card{background:#fff;border-radius:14px;box-shadow:0 1px 8px rgba(0,0,0,.07);border:1px solid #f1f5f9;overflow:hidden;}
    .table-inner{overflow-x:auto;}
    table{width:100%;border-collapse:collapse;}
    thead tr{background:#f8fafc;border-bottom:1px solid #e2e8f0;}
    th{padding:.75rem 1rem;text-align:right;font-size:.75rem;font-weight:700;color:#64748b;letter-spacing:.05em;text-transform:uppercase;white-space:nowrap;}
    td{padding:.8rem 1rem;font-size:.86rem;color:#374151;border-bottom:1px solid #f8fafc;vertical-align:middle;}
    tbody tr:hover{background:#f8fafc;}
    tbody tr:last-child td{border-bottom:none;}
    .emp-avatar{width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,#0369a1,#0ea5e9);display:flex;align-items:center;justify-content:center;color:#fff;font-size:.82rem;font-weight:700;flex-shrink:0;}
    .emp-info{display:flex;align-items:center;gap:.65rem;}
    .emp-name{font-weight:700;color:#0f172a;font-size:.88rem;}
    .emp-id{font-size:.72rem;color:#94a3b8;}
    .statut-actif{display:inline-flex;align-items:center;gap:.3rem;background:#dcfce7;color:#15803d;border-radius:99px;padding:.2rem .65rem;font-size:.72rem;font-weight:600;}
    .statut-conge{display:inline-flex;align-items:center;gap:.3rem;background:#fef3c7;color:#92400e;border-radius:99px;padding:.2rem .65rem;font-size:.72rem;font-weight:600;}
    .statut-inactif{display:inline-flex;align-items:center;gap:.3rem;background:#f1f5f9;color:#64748b;border-radius:99px;padding:.2rem .65rem;font-size:.72rem;font-weight:600;}
    .statut-suspendu{display:inline-flex;align-items:center;gap:.3rem;background:#fee2e2;color:#dc2626;border-radius:99px;padding:.2rem .65rem;font-size:.72rem;font-weight:600;}
    .dept-badge{display:inline-block;background:#ede9fe;color:#6d28d9;border-radius:6px;padding:.15rem .55rem;font-size:.73rem;font-weight:600;}
    .poste-badge{display:inline-block;background:#fef3c7;color:#92400e;border-radius:6px;padding:.15rem .55rem;font-size:.73rem;font-weight:600;}
    .genre-badge-m{display:inline-block;background:#e0f2fe;color:#0369a1;border-radius:6px;padding:.15rem .55rem;font-size:.72rem;font-weight:600;}
    .genre-badge-f{display:inline-block;background:#fce7f3;color:#be185d;border-radius:6px;padding:.15rem .55rem;font-size:.72rem;font-weight:600;}
    .btn-icon{width:30px;height:30px;border-radius:8px;border:none;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;font-size:.8rem;transition:all .15s;}
    .btn-view{background:#f0fdf4;color:#16a34a;}.btn-view:hover{background:#dcfce7;}
    .btn-edit{background:#f0f9ff;color:#0369a1;}.btn-edit:hover{background:#e0f2fe;}
    .btn-delete{background:#fef2f2;color:#dc2626;}.btn-delete:hover{background:#fee2e2;}
    .pagination{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.2rem;border-top:1px solid #f1f5f9;}
    .pagination-info{font-size:.8rem;color:#94a3b8;}
    .pagination-btns{display:flex;gap:.4rem;}
    .page-btn{width:32px;height:32px;border-radius:8px;border:1.5px solid #e2e8f0;background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.85rem;color:#64748b;transition:all .15s;}
    .page-btn:hover{background:#f8fafc;border-color:#cbd5e1;}
    .page-btn.active{background:#0ea5e9;border-color:#0ea5e9;color:#fff;}
    .page-btn:disabled{opacity:.4;cursor:not-allowed;}

    /* Modal */
    .modal-back{position:fixed;inset:0;background:rgba(0,0,0,.45);backdrop-filter:blur(3px);z-index:800;display:flex;align-items:center;justify-content:center;padding:1rem;}
    .modal-box{background:#fff;border-radius:16px;padding:1.75rem;width:100%;max-width:640px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.18);animation:modal-in .22s cubic-bezier(.34,1.56,.64,1);}
    @@keyframes modal-in{from{opacity:0;transform:scale(.93)}to{opacity:1;transform:scale(1)}}
    .modal-title{font-size:1.05rem;font-weight:800;color:#0f172a;margin-bottom:1.2rem;display:flex;align-items:center;gap:.6rem;}
    .form-section{background:#f8fafc;border-radius:10px;padding:1rem 1.1rem;margin-bottom:1rem;}
    .form-section-title{font-size:.75rem;font-weight:700;color:#64748b;letter-spacing:.08em;text-transform:uppercase;margin-bottom:.75rem;}
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;}
    .form-grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.75rem;}
    .form-group{margin-bottom:0;}
    .form-label{display:block;font-size:.78rem;font-weight:600;color:#374151;margin-bottom:.35rem;}
    .form-control{width:100%;height:40px;padding:0 .8rem;border:1.5px solid #e2e8f0;border-radius:9px;font-family:'Tajawal',sans-serif;font-size:.86rem;outline:none;transition:border-color .2s;background:#fff;}
    .form-control:focus{border-color:#0ea5e9;box-shadow:0 0 0 3px rgba(14,165,233,.1);}
    .modal-footer{display:flex;gap:.75rem;justify-content:flex-end;margin-top:1.3rem;}
    .btn-cancel{padding:.55rem 1.1rem;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:9px;color:#374151;font-family:'Tajawal',sans-serif;font-size:.86rem;font-weight:600;cursor:pointer;}
    .btn-cancel:hover{background:#e2e8f0;}
    .btn-save{padding:.55rem 1.3rem;background:linear-gradient(135deg,#0369a1,#0ea5e9);border:none;border-radius:9px;color:#fff;font-family:'Tajawal',sans-serif;font-size:.86rem;font-weight:700;cursor:pointer;box-shadow:0 3px 10px rgba(14,165,233,.3);}
    .btn-save:disabled{opacity:.6;cursor:not-allowed;}

    /* Details drawer */
    .detail-drawer{position:fixed;top:0;left:0;width:420px;height:100vh;background:#fff;box-shadow:-4px 0 30px rgba(0,0,0,.15);z-index:810;overflow-y:auto;animation:drawer-in .25s ease;}
    @@keyframes drawer-in{from{transform:translateX(-100%)}to{transform:translateX(0)}}
    .drawer-header{background:linear-gradient(135deg,#0d1b2a,#0d2035);padding:1.5rem;display:flex;align-items:center;justify-content:space-between;}
    .drawer-close{width:32px;height:32px;background:rgba(255,255,255,.1);border:none;border-radius:8px;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1rem;}
    .drawer-avatar{width:64px;height:64px;border-radius:16px;background:linear-gradient(135deg,#0369a1,#0ea5e9);display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.5rem;font-weight:700;margin:0 auto 1rem;}
    .drawer-name{font-size:1.1rem;font-weight:800;color:#e0f2fe;text-align:center;}
    .drawer-sub{font-size:.8rem;color:#475569;text-align:center;margin-top:.2rem;}
    .drawer-body{padding:1.2rem;}
    .detail-group{margin-bottom:1rem;}
    .detail-label{font-size:.7rem;font-weight:700;color:#94a3b8;letter-spacing:.08em;text-transform:uppercase;margin-bottom:.3rem;}
    .detail-val{font-size:.88rem;color:#374151;font-weight:500;}
    .detail-divider{height:1px;background:#f1f5f9;margin:1rem 0;}

    .confirm-icon{width:52px;height:52px;border-radius:50%;background:#fef2f2;display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#ef4444;margin:0 auto 1rem;}
    .confirm-msg{text-align:center;color:#64748b;font-size:.88rem;line-height:1.6;margin-bottom:1.3rem;}
    .alert-err{background:#fef2f2;border:1px solid #fecaca;border-radius:9px;padding:.65rem .9rem;color:#dc2626;font-size:.83rem;margin-bottom:.9rem;display:flex;align-items:center;gap:.5rem;}
    .alert-ok{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:9px;padding:.65rem .9rem;color:#16a34a;font-size:.83rem;margin-bottom:.9rem;display:flex;align-items:center;gap:.5rem;}
    .loading-wrap{display:flex;align-items:center;justify-content:center;padding:3rem;color:#94a3b8;gap:.75rem;}
    .empty-wrap{text-align:center;padding:3rem;color:#94a3b8;}
    .empty-wrap i{font-size:2.5rem;display:block;margin-bottom:.5rem;}
</style>

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-people me-2" style="color:#22c55e;"></i>الموظفون</h1>
        <div class="page-sub">إدارة موظفي البلدية</div>
    </div>
    @if (_canEdit)
    {
        <button class="btn-add" @onclick="OpenAdd"><i class="bi bi-person-plus"></i> إضافة موظف</button>
    }
</div>

@if (!string.IsNullOrEmpty(SuccessMsg)) { <div class="alert-ok"><i class="bi bi-check-circle-fill"></i>@SuccessMsg</div> }
@if (!string.IsNullOrEmpty(ErrorMsg))   { <div class="alert-err"><i class="bi bi-exclamation-circle-fill"></i>@ErrorMsg</div> }

<div class="stats-row">
    <div class="stat-card"><div class="stat-val" style="color:#22c55e;">@TotalCount</div><div class="stat-lbl">إجمالي الموظفين</div></div>
    <div class="stat-card"><div class="stat-val" style="color:#0ea5e9;">@(Items?.Count(x => x.Statut == "Actif") ?? 0)</div><div class="stat-lbl">في الخدمة</div></div>
    <div class="stat-card"><div class="stat-val" style="color:#f59e0b;">@(Items?.Count(x => x.Statut == "EnConge") ?? 0)</div><div class="stat-lbl">في إجازة</div></div>
    <div class="stat-card"><div class="stat-val" style="color:#94a3b8;">@(Items?.Count(x => x.Statut == "Inactif") ?? 0)</div><div class="stat-lbl">غير نشط</div></div>
</div>

<div class="filter-row">
    <div class="search-wrap">
        <input class="search-input" placeholder="بحث بالاسم أو رقم التعريف أو CIN..."
               value="@SearchTerm" @oninput="OnSearch" />
        <i class="bi bi-search search-icon"></i>
    </div>
    <select class="filter-select" @bind="FilterDeptId" @bind:after="ApplyFilter">
        <option value="0">كل الأقسام</option>
        @if (Departements != null) { @foreach (var d in Departements) { <option value="@d.Id">@d.Nom</option> } }
    </select>
    <select class="filter-select" @bind="FilterStatut" @bind:after="ApplyFilter">
        <option value="">كل الحالات</option>
        <option value="Actif">في الخدمة</option>
        <option value="EnConge">في إجازة</option>
        <option value="Inactif">غير نشط</option>
        <option value="Suspendu">موقوف</option>
    </select>
</div>

<div class="table-card">
    <div class="table-inner">
        @if (IsLoading) { <div class="loading-wrap"><div class="spinner-border spinner-border-sm" style="color:#22c55e;"></div><span>جاري التحميل...</span></div> }
        else if (Items == null || !Items.Any()) { <div class="empty-wrap"><i class="bi bi-people"></i><div>لا يوجد موظفون</div></div> }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>الموظف</th><th>المنصب</th><th>القسم / المصلحة</th>
                        <th>الجنس</th><th>الراتب</th><th>الحالة</th><th>تاريخ التوظيف</th><th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Items)
                    {
                        <tr>
                            <td>
                                <div class="emp-info">
                                    <div class="emp-avatar">@GetInitials(item.Prenom, item.Nom)</div>
                                    <div>
                                        <div class="emp-name">@item.NomComplet</div>
                                        <div class="emp-id">@item.Identifiant · @item.Cin</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="poste-badge">@item.PosteTitre</span></td>
                            <td>
                                <div><span class="dept-badge" style="font-size:.7rem;">@item.DepartementNom</span></div>
                                <div style="font-size:.75rem;color:#94a3b8;margin-top:.2rem;">@item.ServiceNom</div>
                            </td>
                            <td>@if(item.Genre == "Masculin") { <span class="genre-badge-m">ذكر</span> } else { <span class="genre-badge-f">أنثى</span> }</td>
                            <td style="font-weight:600;color:#0f172a;">@item.Salaire.ToString("N0") <span style="font-size:.7rem;color:#94a3b8;">د.ت</span></td>
                            <td>@GetStatutBadge(item.Statut)</td>
                            <td style="color:#64748b;font-size:.8rem;">@item.DateEmbauche.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div style="display:flex;gap:.35rem;">
                                    <button class="btn-icon btn-view" title="عرض" @onclick="() => OpenDetails(item)"><i class="bi bi-eye"></i></button>
                                    @if (_canEdit)
                                    {
                                        <button class="btn-icon btn-edit" title="تعديل" @onclick="() => OpenEdit(item)"><i class="bi bi-pencil"></i></button>
                                        <button class="btn-icon btn-delete" title="حذف" @onclick="() => OpenDelete(item)"><i class="bi bi-trash3"></i></button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="pagination">
                <div class="pagination-info">
                    عرض @((Filter.PageNumber - 1) * Filter.PageSize + 1)–@Math.Min(Filter.PageNumber * Filter.PageSize, TotalCount) من @TotalCount
                </div>
                <div class="pagination-btns">
                    <button class="page-btn" @onclick="PrevPage" disabled="@(Filter.PageNumber == 1)"><i class="bi bi-chevron-right"></i></button>
                    @for (int p = 1; p <= TotalPages; p++)
                    {
                        var pg = p;
                        <button class="page-btn @(Filter.PageNumber == pg ? "active" : "")" @onclick="() => GoPage(pg)">@pg</button>
                    }
                    <button class="page-btn" @onclick="NextPage" disabled="@(Filter.PageNumber >= TotalPages)"><i class="bi bi-chevron-left"></i></button>
                </div>
            </div>
        }
    </div>
</div>

@* ── DETAILS DRAWER ── *@
@if (DetailItem != null)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,.35);z-index:809;" @onclick="() => DetailItem = null"></div>
    <div class="detail-drawer">
        <div class="drawer-header">
            <div style="flex:1;">
                <div class="drawer-avatar">@GetInitials(DetailItem.Prenom, DetailItem.Nom)</div>
                <div class="drawer-name">@DetailItem.NomComplet</div>
                <div class="drawer-sub">@DetailItem.PosteTitre · @DetailItem.ServiceNom</div>
            </div>
            <button class="drawer-close" @onclick="() => DetailItem = null"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="drawer-body">
            <div class="detail-group"><div class="detail-label">رقم التعريف</div><div class="detail-val">@DetailItem.Identifiant</div></div>
            <div class="detail-group"><div class="detail-label">رقم الهوية (CIN)</div><div class="detail-val">@DetailItem.Cin</div></div>
            <div class="detail-group"><div class="detail-label">البريد الإلكتروني</div><div class="detail-val">@(DetailItem.Email ?? "—")</div></div>
            <div class="detail-group"><div class="detail-label">الهاتف</div><div class="detail-val">@(DetailItem.Telephone ?? "—")</div></div>
            <div class="detail-divider"></div>
            <div class="detail-group"><div class="detail-label">القسم</div><div class="detail-val">@DetailItem.DepartementNom</div></div>
            <div class="detail-group"><div class="detail-label">المصلحة</div><div class="detail-val">@DetailItem.ServiceNom</div></div>
            <div class="detail-group"><div class="detail-label">المنصب</div><div class="detail-val">@DetailItem.PosteTitre</div></div>
            <div class="detail-divider"></div>
            <div class="detail-group"><div class="detail-label">تاريخ الميلاد</div><div class="detail-val">@DetailItem.DateNaissance.ToString("dd/MM/yyyy")</div></div>
            <div class="detail-group"><div class="detail-label">تاريخ التوظيف</div><div class="detail-val">@DetailItem.DateEmbauche.ToString("dd/MM/yyyy")</div></div>
            <div class="detail-group"><div class="detail-label">الراتب</div><div class="detail-val" style="font-size:1.1rem;font-weight:700;color:#0f172a;">@DetailItem.Salaire.ToString("N0") د.ت</div></div>
            <div class="detail-group"><div class="detail-label">العنوان</div><div class="detail-val">@(DetailItem.Adresse ?? "—")</div></div>
        </div>
    </div>
}

@* ── ADD / EDIT MODAL ── *@
@if (ShowForm)
{
    <div class="modal-back" @onclick="CloseForm">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-title">
                <i class="bi @(IsEditing ? "bi-pencil-square" : "bi-person-plus")" style="color:#22c55e;"></i>
                @(IsEditing ? "تعديل بيانات الموظف" : "إضافة موظف جديد")
            </div>
            @if (!string.IsNullOrEmpty(FormError)) { <div class="alert-err"><i class="bi bi-exclamation-circle-fill"></i>@FormError</div> }

            <div class="form-section">
                <div class="form-section-title">المعلومات الشخصية</div>
                <div class="form-grid">
                    <div class="form-group"><label class="form-label">اللقب *</label><input class="form-control" @bind="F.Nom" placeholder="اللقب" /></div>
                    <div class="form-group"><label class="form-label">الاسم *</label><input class="form-control" @bind="F.Prenom" placeholder="الاسم" /></div>
                </div>
                <div class="form-grid" style="margin-top:.75rem;">
                    @if (!IsEditing) { <div class="form-group"><label class="form-label">رقم التعريف *</label><input class="form-control" @bind="F.Identifiant" placeholder="مثال: EMP001" /></div> }
                    @if (!IsEditing) { <div class="form-group"><label class="form-label">رقم الهوية (CIN) *</label><input class="form-control" @bind="F.Cin" placeholder="مثال: 123456789" /></div> }
                </div>
                @* <div class="form-grid" style="margin-top:.75rem;">
                    <div class="form-group"><label class="form-label">البريد الإلكتروني</label><input class="form-control" type="email" @bind="F.Email" placeholder="email@..." /></div>
                    <div class="form-group"><label class="form-label">الهاتف</label><input class="form-control" @bind="F.Telephone" placeholder="05xxxxxxxx" /></div>
                </div> *@
                <div class="form-grid" style="margin-top:.75rem;">
                    <div class="form-group"><label class="form-label">الجنس *</label>
                        <select class="form-control" @bind="F.Genre">
                            <option value="">-- اختر --</option>
                            <option value="Masculin">ذكر</option>
                            <option value="Feminin">أنثى</option>
                        </select>
                    </div>
                    <div class="form-group"><label class="form-label">تاريخ الميلاد *</label><input class="form-control" type="date" @bind="F.DateNaissance" /></div>
                </div>
                <div class="form-group" style="margin-top:.75rem;"><label class="form-label">العنوان</label><input class="form-control" @bind="F.Adresse" placeholder="العنوان الكامل" /></div>
            </div>

            <div class="form-section">
                <div class="form-section-title">معلومات الوظيفة</div>
                <div class="form-grid">
                    <div class="form-group"><label class="form-label">القسم</label>
                        <select class="form-control" @bind="SelectedDeptId" @bind:after="LoadServicesByDept">
                            <option value="0">-- اختر القسم --</option>
                            @if (Departements != null) { @foreach (var d in Departements) { <option value="@d.Id">@d.Nom</option> } }
                        </select>
                    </div>
                    <div class="form-group"><label class="form-label">المصلحة *</label>
                        <select class="form-control" @bind="F.ServiceId">
                            <option value="0">-- اختر المصلحة --</option>
                            @if (FilteredServices != null) { @foreach (var s in FilteredServices) { <option value="@s.Id">@s.Nom</option> } }
                        </select>
                    </div>
                </div>
                <div class="form-grid" style="margin-top:.75rem;">
                    <div class="form-group"><label class="form-label">المنصب *</label>
                        <select class="form-control" @bind="F.PosteId">
                            <option value="0">-- اختر المنصب --</option>
                            @if (Postes != null) { @foreach (var p in Postes) { <option value="@p.Id">@p.Titre</option> } }
                        </select>
                    </div>
                    <div class="form-group"><label class="form-label">الراتب (د.ت) *</label><input class="form-control" type="number" @bind="F.Salaire" placeholder="0" /></div>
                </div>
                <div class="form-grid" style="margin-top:.75rem;">
                    <div class="form-group"><label class="form-label">تاريخ التوظيف *</label><input class="form-control" type="date" @bind="F.DateEmbauche" /></div>
                    @if (IsEditing)
                    {
                        <div class="form-group"><label class="form-label">الحالة</label>
                            <select class="form-control" @bind="F.Statut">
                                <option value="Actif">في الخدمة</option>
                                <option value="EnConge">في إجازة</option>
                                <option value="Inactif">غير نشط</option>
                                <option value="Suspendu">موقوف</option>
                            </select>
                        </div>
                    }
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseForm">إلغاء</button>
                <button class="btn-save" @onclick="SaveForm" disabled="@IsSaving">
                    @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1" style="width:.8rem;height:.8rem;border-width:2px;"></span> }
                    @(IsEditing ? "حفظ التعديلات" : "إضافة الموظف")
                </button>
            </div>
        </div>
    </div>
}

@* ── DELETE CONFIRM ── *@
@if (ShowDelete)
{
    <div class="modal-back" @onclick="() => ShowDelete = false">
        <div class="modal-box" @onclick:stopPropagation="true" style="max-width:380px;">
            <div class="confirm-icon"><i class="bi bi-person-dash"></i></div>
            <div class="modal-title" style="justify-content:center;">تأكيد الحذف</div>
            <div class="confirm-msg">هل أنت متأكد من حذف الموظف <strong>@SelectedItem?.NomComplet</strong>؟</div>
            <div class="modal-footer" style="justify-content:center;">
                <button class="btn-cancel" @onclick="() => ShowDelete = false">إلغاء</button>
                <button class="btn-save" style="background:linear-gradient(135deg,#dc2626,#ef4444);box-shadow:0 3px 10px rgba(239,68,68,.3);" @onclick="ConfirmDelete" disabled="@IsSaving">حذف</button>
            </div>
        </div>
    </div>
}

@code {
    [Inject] IEmployeApiService Svc { get; set; } = null!;
    [Inject] IDepartementApiService DeptSvc { get; set; } = null!;
    [Inject] IServiceApiService ServiceSvc { get; set; } = null!;
    [Inject] IPosteApiService PosteSvc { get; set; } = null!;

    private bool _canEdit;

    private IEnumerable<EmployeDto>? Items;
    private IEnumerable<DepartementDto>? Departements;
    private IEnumerable<ServiceDto>? AllServices, FilteredServices;
    private IEnumerable<PosteDto>? Postes;

    private EmployeFilterDto Filter = new() { PageSize = 10 };
    private int TotalCount, TotalPages;
    private bool IsLoading = true;
    private string SearchTerm = "", FilterStatut = "";
    private int FilterDeptId = 0;
    private string SuccessMsg = "", ErrorMsg = "", FormError = "";
    private bool ShowForm, ShowDelete, IsEditing, IsSaving;
    private EmployeDto? SelectedItem, DetailItem;
    private int SelectedDeptId = 0;

    // Form model
    private class FormModel
    {
        public string Identifiant = "", Cin = "", Prenom = "", Nom = "";
        public string? Email, Telephone, Adresse;
        public string Genre = "", Statut = "Actif";
        public DateTime DateNaissance = DateTime.Today.AddYears(-25);
        public DateTime DateEmbauche = DateTime.Today;
        public DateTime? DateDepart;
        public int ServiceId, PosteId;
        public decimal Salaire;
    }
    private FormModel F = new();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthSP.GetAuthenticationStateAsync();
        var roles = state.User.FindAll(ClaimTypes.Role).Select(c => c.Value).ToList();
        _canEdit = roles.Any(r => r is "SuperAdmin" or "Admin" or "Manager" or "RessourcesHumaines");

        var dr = await DeptSvc.GetAllAsync();
        Departements = dr?.Data ?? Enumerable.Empty<DepartementDto>();
        var sr = await ServiceSvc.GetAllAsync();
        AllServices = sr?.Data ?? Enumerable.Empty<ServiceDto>();
        var pr = await PosteSvc.GetAllAsync();
        Postes = pr?.Data ?? Enumerable.Empty<PosteDto>();
        await Load();
    }

    private async Task Load()
    {
        IsLoading = true;
        var r = await Svc.GetPagedAsync(Filter);
        Items = r?.Data?.Items ?? Enumerable.Empty<EmployeDto>();
        TotalCount = r?.Data?.TotalCount ?? 0;
        TotalPages = (int)Math.Ceiling((double)TotalCount / Filter.PageSize);
        IsLoading = false;
    }

    private async Task OnSearch(ChangeEventArgs e)
    {
        SearchTerm = e.Value?.ToString() ?? "";
        Filter.SearchTerm = string.IsNullOrWhiteSpace(SearchTerm) ? null : SearchTerm.Trim();
        Filter.PageNumber = 1;
        await Load();
    }

    private async Task ApplyFilter()
    {
        Filter.DepartementId = FilterDeptId == 0 ? null : FilterDeptId;
        Filter.Statut = string.IsNullOrEmpty(FilterStatut) ? null : FilterStatut;
        Filter.PageNumber = 1;
        await Load();
    }

    private async Task LoadServicesByDept()
    {
        F.ServiceId = 0;
        FilteredServices = SelectedDeptId == 0
            ? AllServices
            : AllServices?.Where(s => s.DepartementId == SelectedDeptId);
    }

    private void OpenDetails(EmployeDto e) => DetailItem = e;

    private void OpenAdd()
    {
        IsEditing = false; SelectedItem = null; F = new(); SelectedDeptId = 0;
        FilteredServices = AllServices; FormError = ""; ShowForm = true;
    }

    private void OpenEdit(EmployeDto e)
    {
        IsEditing = true; SelectedItem = e;
        F = new FormModel
        {
            Identifiant = e.Identifiant, Cin = e.Cin, Prenom = e.Prenom, Nom = e.Nom,
            Email = e.Email, Telephone = e.Telephone, Adresse = e.Adresse,
            Genre = e.Genre, Statut = e.Statut,
            DateNaissance = e.DateNaissance, DateEmbauche = e.DateEmbauche, DateDepart = e.DateDepart,
            ServiceId = e.ServiceId, PosteId = e.PosteId, Salaire = e.Salaire
        };
        var svc = AllServices?.FirstOrDefault(s => s.Id == e.ServiceId);
        SelectedDeptId = svc?.DepartementId ?? 0;
        FilteredServices = SelectedDeptId == 0 ? AllServices : AllServices?.Where(s => s.DepartementId == SelectedDeptId);
        FormError = ""; ShowForm = true;
    }

    private void OpenDelete(EmployeDto e) { SelectedItem = e; ShowDelete = true; }
    private void CloseForm() { ShowForm = false; FormError = ""; }

    private async Task SaveForm()
    {
        if (string.IsNullOrWhiteSpace(F.Prenom)) { FormError = "الاسم مطلوب."; return; }
        if (string.IsNullOrWhiteSpace(F.Nom))    { FormError = "اللقب مطلوب."; return; }
        if (F.ServiceId == 0)  { FormError = "يجب اختيار المصلحة."; return; }
        if (F.PosteId == 0)    { FormError = "يجب اختيار المنصب."; return; }
        if (string.IsNullOrWhiteSpace(F.Genre)) { FormError = "يجب اختيار الجنس."; return; }
        IsSaving = true; FormError = "";
        if (IsEditing && SelectedItem != null)
        {
            var dto = new UpdateEmployeDto { Prenom=F.Prenom, Nom=F.Nom, Email=F.Email, Telephone=F.Telephone,
                DateNaissance=F.DateNaissance, DateEmbauche=F.DateEmbauche, DateDepart=F.DateDepart,
                Genre=F.Genre, Statut=F.Statut, Salaire=F.Salaire, Adresse=F.Adresse,
                ServiceId=F.ServiceId, PosteId=F.PosteId };
            var r = await Svc.UpdateAsync(SelectedItem.Id, dto);
            if (r?.Succeeded == true) { SuccessMsg = "تم تعديل بيانات الموظف."; CloseForm(); await Load(); }
            else FormError = r?.Errors?.FirstOrDefault() ?? "حدث خطأ.";
        }
        else
        {
            if (string.IsNullOrWhiteSpace(F.Identifiant)) { FormError = "رقم التعريف مطلوب."; IsSaving = false; return; }
            if (string.IsNullOrWhiteSpace(F.Cin)) { FormError = "رقم الهوية مطلوب."; IsSaving = false; return; }
            var dto = new CreateEmployeDto { Identifiant=F.Identifiant, Cin=F.Cin, Prenom=F.Prenom, Nom=F.Nom,
                Email=F.Email, Telephone=F.Telephone, DateNaissance=F.DateNaissance, DateEmbauche=F.DateEmbauche,
                Genre=F.Genre, Salaire=F.Salaire, Adresse=F.Adresse, ServiceId=F.ServiceId, PosteId=F.PosteId };
            var r = await Svc.CreateAsync(dto);
            if (r?.Succeeded == true) { SuccessMsg = "تم إضافة الموظف بنجاح."; CloseForm(); await Load(); }
            else FormError = r?.Errors?.FirstOrDefault() ?? "حدث خطأ.";
        }
        IsSaving = false;
        if (!string.IsNullOrEmpty(SuccessMsg)) { await Task.Delay(3500); SuccessMsg = ""; StateHasChanged(); }
    }

    private async Task ConfirmDelete()
    {
        if (SelectedItem == null) return;
        IsSaving = true;
        var ok = await Svc.DeleteAsync(SelectedItem.Id);
        IsSaving = false; ShowDelete = false;
        if (ok)
        {
            SuccessMsg = "تم حذف الموظف بنجاح.";
            await Load();
            await Task.Delay(3000); SuccessMsg = ""; StateHasChanged();
        }
        else
        {
            ErrorMsg = "فشل الحذف. تأكد من عدم ارتباط الموظف ببيانات أخرى.";
            await Task.Delay(4000); ErrorMsg = ""; StateHasChanged();
        }
    }

    private async Task PrevPage() { if (Filter.PageNumber > 1) { Filter.PageNumber--; await Load(); } }
    private async Task NextPage() { if (Filter.PageNumber < TotalPages) { Filter.PageNumber++; await Load(); } }
    private async Task GoPage(int p) { Filter.PageNumber = p; await Load(); }

    private string GetInitials(string prenom, string nom) =>
        $"{(prenom.Length > 0 ? prenom[0] : ' ')}{(nom.Length > 0 ? nom[0] : ' ')}".Trim().ToUpper();

    private RenderFragment GetStatutBadge(string statut) => statut switch
    {
        "Actif"     => @<span class="statut-actif"><i class="bi bi-circle-fill" style="font-size:.4rem;"></i>في الخدمة</span>,
        "EnConge"   => @<span class="statut-conge"><i class="bi bi-circle-fill" style="font-size:.4rem;"></i>إجازة</span>,
        "Inactif"   => @<span class="statut-inactif"><i class="bi bi-circle-fill" style="font-size:.4rem;"></i>غير نشط</span>,
        "Suspendu"  => @<span class="statut-suspendu"><i class="bi bi-circle-fill" style="font-size:.4rem;"></i>موقوف</span>,
        _           => @<span class="statut-inactif">@statut</span>
    };
}
