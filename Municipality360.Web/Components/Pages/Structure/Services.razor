@page "/services"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@layout Municipality360.Web.Components.Layout.MainLayout

<PageTitle>المصالح - Municipality360</PageTitle>

<style>
    .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;}
    .page-title{font-size:1.35rem;font-weight:800;color:#0f172a;margin:0;}
    .page-sub{font-size:.8rem;color:#94a3b8;margin-top:.2rem;}
    .btn-add{display:flex;align-items:center;gap:.5rem;padding:.55rem 1.1rem;background:linear-gradient(135deg,#0369a1,#0ea5e9);color:#fff;border:none;border-radius:10px;font-family:'Tajawal',sans-serif;font-size:.88rem;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(14,165,233,.3);transition:all .2s;}
    .btn-add:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(14,165,233,.4);}
    .stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1rem;margin-bottom:1.5rem;}
    .stat-card{background:#fff;border-radius:12px;padding:1rem 1.2rem;box-shadow:0 1px 6px rgba(0,0,0,.06);border:1px solid #f1f5f9;}
    .stat-val{font-size:1.6rem;font-weight:800;color:#0f172a;}
    .stat-lbl{font-size:.73rem;color:#94a3b8;margin-top:.15rem;}
    .filter-row{display:flex;gap:.75rem;margin-bottom:1.2rem;flex-wrap:wrap;align-items:center;}
    .search-wrap{position:relative;flex:1;min-width:180px;}
    .search-input{width:100%;height:40px;padding:0 1rem 0 2.5rem;border:1.5px solid #e2e8f0;border-radius:10px;font-family:'Tajawal',sans-serif;font-size:.88rem;outline:none;transition:border-color .2s;background:#fff;}
    .search-input:focus{border-color:#0ea5e9;box-shadow:0 0 0 3px rgba(14,165,233,.1);}
    .search-icon{position:absolute;right:10px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.9rem;pointer-events:none;}
    .filter-select{height:40px;padding:0 .85rem;border:1.5px solid #e2e8f0;border-radius:10px;font-family:'Tajawal',sans-serif;font-size:.85rem;outline:none;background:#fff;cursor:pointer;color:#374151;}
    .filter-select:focus{border-color:#0ea5e9;}
    .table-card{background:#fff;border-radius:14px;box-shadow:0 1px 8px rgba(0,0,0,.07);border:1px solid #f1f5f9;overflow:hidden;}
    .table-inner{overflow-x:auto;}
    table{width:100%;border-collapse:collapse;}
    thead tr{background:#f8fafc;border-bottom:1px solid #e2e8f0;}
    th{padding:.75rem 1rem;text-align:right;font-size:.75rem;font-weight:700;color:#64748b;letter-spacing:.05em;text-transform:uppercase;white-space:nowrap;}
    td{padding:.8rem 1rem;font-size:.86rem;color:#374151;border-bottom:1px solid #f8fafc;vertical-align:middle;}
    tbody tr:hover{background:#f8fafc;}
    tbody tr:last-child td{border-bottom:none;}
    .badge-active{display:inline-flex;align-items:center;gap:.35rem;background:#dcfce7;color:#15803d;border-radius:99px;padding:.22rem .7rem;font-size:.72rem;font-weight:600;}
    .badge-inactive{display:inline-flex;align-items:center;gap:.35rem;background:#fee2e2;color:#dc2626;border-radius:99px;padding:.22rem .7rem;font-size:.72rem;font-weight:600;}
    .dept-badge{display:inline-block;background:#ede9fe;color:#6d28d9;border-radius:6px;padding:.18rem .6rem;font-size:.75rem;font-weight:600;}
    .badge-count{display:inline-block;background:#e0f2fe;color:#0369a1;border-radius:99px;padding:.2rem .6rem;font-size:.72rem;font-weight:700;}
    .code-chip{display:inline-block;background:#f1f5f9;color:#475569;border-radius:6px;padding:.15rem .55rem;font-size:.75rem;font-family:monospace;font-weight:600;}
    .btn-icon{width:32px;height:32px;border-radius:8px;border:none;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;font-size:.85rem;transition:all .15s;}
    .btn-edit{background:#f0f9ff;color:#0369a1;}.btn-edit:hover{background:#e0f2fe;}
    .btn-delete{background:#fef2f2;color:#dc2626;}.btn-delete:hover{background:#fee2e2;}
    .modal-back{position:fixed;inset:0;background:rgba(0,0,0,.45);backdrop-filter:blur(3px);z-index:800;display:flex;align-items:center;justify-content:center;}
    .modal-box{background:#fff;border-radius:16px;padding:1.75rem;width:100%;max-width:460px;box-shadow:0 20px 60px rgba(0,0,0,.18);animation:modal-in .22s cubic-bezier(.34,1.56,.64,1);}
    @@keyframes modal-in{from{opacity:0;transform:scale(.93)}to{opacity:1;transform:scale(1)}}
    .modal-title{font-size:1.05rem;font-weight:800;color:#0f172a;margin-bottom:1.2rem;display:flex;align-items:center;gap:.6rem;}
    .form-group{margin-bottom:1rem;}
    .form-label{display:block;font-size:.8rem;font-weight:600;color:#374151;margin-bottom:.4rem;}
    .form-control{width:100%;height:42px;padding:0 .85rem;border:1.5px solid #e2e8f0;border-radius:10px;font-family:'Tajawal',sans-serif;font-size:.88rem;outline:none;transition:border-color .2s;}
    .form-control:focus{border-color:#0ea5e9;box-shadow:0 0 0 3px rgba(14,165,233,.1);}
    textarea.form-control{height:80px;padding:.6rem .85rem;resize:vertical;}
    .form-check{display:flex;align-items:center;gap:.5rem;cursor:pointer;font-size:.88rem;color:#374151;}
    .modal-footer{display:flex;gap:.75rem;justify-content:flex-end;margin-top:1.3rem;}
    .btn-cancel{padding:.55rem 1.1rem;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:9px;color:#374151;font-family:'Tajawal',sans-serif;font-size:.86rem;font-weight:600;cursor:pointer;transition:all .2s;}
    .btn-cancel:hover{background:#e2e8f0;}
    .btn-save{padding:.55rem 1.3rem;background:linear-gradient(135deg,#0369a1,#0ea5e9);border:none;border-radius:9px;color:#fff;font-family:'Tajawal',sans-serif;font-size:.86rem;font-weight:700;cursor:pointer;transition:all .2s;box-shadow:0 3px 10px rgba(14,165,233,.3);}
    .btn-save:disabled{opacity:.6;cursor:not-allowed;}
    .confirm-icon{width:52px;height:52px;border-radius:50%;background:#fef2f2;display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#ef4444;margin:0 auto 1rem;}
    .confirm-msg{text-align:center;color:#64748b;font-size:.88rem;line-height:1.6;margin-bottom:1.3rem;}
    .alert-err{background:#fef2f2;border:1px solid #fecaca;border-radius:9px;padding:.65rem .9rem;color:#dc2626;font-size:.83rem;margin-bottom:.9rem;display:flex;align-items:center;gap:.5rem;}
    .alert-ok{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:9px;padding:.65rem .9rem;color:#16a34a;font-size:.83rem;margin-bottom:.9rem;display:flex;align-items:center;gap:.5rem;}
    .loading-wrap{display:flex;align-items:center;justify-content:center;padding:3rem;color:#94a3b8;gap:.75rem;}
    .empty-wrap{text-align:center;padding:3rem;color:#94a3b8;}
    .empty-wrap i{font-size:2.5rem;display:block;margin-bottom:.5rem;}
</style>

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-diagram-3 me-2" style="color:#7c3aed;"></i>المصالح</h1>
        <div class="page-sub">إدارة مصالح البلدية</div>
    </div>
    <button class="btn-add" @onclick="OpenAdd">
        <i class="bi bi-plus-lg"></i> إضافة مصلحة
    </button>
</div>

@if (!string.IsNullOrEmpty(SuccessMsg)) { <div class="alert-ok"><i class="bi bi-check-circle-fill"></i>@SuccessMsg</div> }
@if (!string.IsNullOrEmpty(ErrorMsg))   { <div class="alert-err"><i class="bi bi-exclamation-circle-fill"></i>@ErrorMsg</div> }

<div class="stats-row">
    <div class="stat-card"><div class="stat-val" style="color:#7c3aed;">@(Items?.Count() ?? 0)</div><div class="stat-lbl">إجمالي المصالح</div></div>
    <div class="stat-card"><div class="stat-val" style="color:#22c55e;">@(Items?.Count(x => x.IsActive) ?? 0)</div><div class="stat-lbl">المصالح النشطة</div></div>
    <div class="stat-card"><div class="stat-val" style="color:#f59e0b;">@(Items?.Sum(x => x.NombreEmployes) ?? 0)</div><div class="stat-lbl">إجمالي الموظفين</div></div>
</div>

<div class="filter-row">
    <div class="search-wrap">
        <input class="search-input" placeholder="بحث باسم المصلحة أو الرمز..."
               @bind="SearchTerm" @bind:event="oninput" />
        <i class="bi bi-search search-icon"></i>
    </div>
    <select class="filter-select" @bind="FilterDeptId">
        <option value="0">كل الأقسام</option>
        @if (Departements != null)
        {
            @foreach (var d in Departements)
            { <option value="@d.Id">@d.Nom</option> }
        }
    </select>
</div>

<div class="table-card">
    <div class="table-inner">
        @if (IsLoading)
        {
            <div class="loading-wrap"><div class="spinner-border spinner-border-sm" style="color:#7c3aed;"></div><span>جاري التحميل...</span></div>
        }
        else if (!Filtered.Any())
        {
            <div class="empty-wrap"><i class="bi bi-diagram-3"></i><div>لا توجد مصالح</div></div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th><th>اسم المصلحة</th><th>الرمز</th><th>القسم</th>
                        <th>الموظفون</th><th>الحالة</th><th>تاريخ الإنشاء</th><th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (item, i) in Filtered.Select((x, i) => (x, i + 1)))
                    {
                        <tr>
                            <td style="color:#94a3b8;font-weight:600;">@i</td>
                            <td style="font-weight:600;color:#0f172a;">@item.Nom</td>
                            <td>@if (!string.IsNullOrEmpty(item.Code)) { <span class="code-chip">@item.Code</span> } else { <span style="color:#cbd5e1;">—</span> }</td>
                            <td><span class="dept-badge">@item.DepartementNom</span></td>
                            <td><span class="badge-count">@item.NombreEmployes موظف</span></td>
                            <td>@if (item.IsActive) { <span class="badge-active"><i class="bi bi-circle-fill" style="font-size:.45rem;"></i>نشط</span> } else { <span class="badge-inactive"><i class="bi bi-circle-fill" style="font-size:.45rem;"></i>غير نشط</span> }</td>
                            <td style="color:#64748b;font-size:.8rem;">@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div style="display:flex;gap:.4rem;">
                                    <button class="btn-icon btn-edit" @onclick="() => OpenEdit(item)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn-icon btn-delete" @onclick="() => OpenDelete(item)"><i class="bi bi-trash3"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (ShowForm)
{
    <div class="modal-back" @onclick="CloseForm">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-title">
                <i class="bi @(IsEditing ? "bi-pencil-square" : "bi-plus-circle")" style="color:#7c3aed;"></i>
                @(IsEditing ? "تعديل المصلحة" : "إضافة مصلحة جديدة")
            </div>
            @if (!string.IsNullOrEmpty(FormError)) { <div class="alert-err"><i class="bi bi-exclamation-circle-fill"></i>@FormError</div> }
            <div class="form-group">
                <label class="form-label">القسم *</label>
                <select class="form-control" @bind="FormDeptId">
                    <option value="0">-- اختر القسم --</option>
                    @if (Departements != null) { @foreach (var d in Departements) { <option value="@d.Id">@d.Nom</option> } }
                </select>
            </div>
            <div class="form-group"><label class="form-label">اسم المصلحة *</label><input class="form-control" @bind="FormNom" placeholder="مثال: سكرتارية" /></div>
            <div class="form-group"><label class="form-label">الرمز</label><input class="form-control" @bind="FormCode" placeholder="مثال: ADM-SEC" /></div>
            <div class="form-group"><label class="form-label">الوصف</label><textarea class="form-control" @bind="FormDescription" placeholder="وصف مختصر..."></textarea></div>
            @if (IsEditing) { <div class="form-group"><label class="form-check"><input type="checkbox" @bind="FormIsActive" /> <span>نشط</span></label></div> }
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseForm">إلغاء</button>
                <button class="btn-save" @onclick="SaveForm" disabled="@IsSaving">
                    @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1" style="width:.8rem;height:.8rem;border-width:2px;"></span> }
                    @(IsEditing ? "حفظ التعديلات" : "إضافة")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowDelete)
{
    <div class="modal-back" @onclick="() => ShowDelete = false">
        <div class="modal-box" @onclick:stopPropagation="true" style="max-width:380px;">
            <div class="confirm-icon"><i class="bi bi-trash3"></i></div>
            <div class="modal-title" style="justify-content:center;">تأكيد الحذف</div>
            <div class="confirm-msg">هل أنت متأكد من حذف المصلحة <strong>@SelectedItem?.Nom</strong>؟</div>
            <div class="modal-footer" style="justify-content:center;">
                <button class="btn-cancel" @onclick="() => ShowDelete = false">إلغاء</button>
                <button class="btn-save" style="background:linear-gradient(135deg,#dc2626,#ef4444);box-shadow:0 3px 10px rgba(239,68,68,.3);" @onclick="ConfirmDelete" disabled="@IsSaving">
                    @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1" style="width:.8rem;height:.8rem;border-width:2px;"></span> }
                    تأكيد الحذف
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Inject] IServiceApiService Svc { get; set; } = null!;
    [Inject] IDepartementApiService DeptSvc { get; set; } = null!;

    private IEnumerable<ServiceDto>? Items;
    private IEnumerable<DepartementDto>? Departements;
    private bool IsLoading = true;
    private string SearchTerm = "", SuccessMsg = "", ErrorMsg = "", FormError = "";
    private int FilterDeptId = 0;
    private bool ShowForm, ShowDelete, IsEditing, IsSaving;
    private ServiceDto? SelectedItem;
    private string FormNom = "", FormCode = "", FormDescription = "";
    private int FormDeptId = 0;
    private bool FormIsActive = true;

    private IEnumerable<ServiceDto> Filtered => Items?.Where(x =>
        (FilterDeptId == 0 || x.DepartementId == FilterDeptId) &&
        (string.IsNullOrEmpty(SearchTerm) ||
         x.Nom.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
         (x.Code?.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ?? false)))
        ?? Enumerable.Empty<ServiceDto>();

    protected override async Task OnInitializedAsync()
    {
        var dr = await DeptSvc.GetAllAsync();
        Departements = dr?.Data ?? Enumerable.Empty<DepartementDto>();
        await Load();
    }

    private async Task Load()
    {
        IsLoading = true;
        var r = await Svc.GetAllAsync();
        Items = r?.Data ?? Enumerable.Empty<ServiceDto>();
        IsLoading = false;
    }

    private void OpenAdd()
    {
        IsEditing = false; SelectedItem = null;
        FormNom = ""; FormCode = ""; FormDescription = ""; FormDeptId = 0; FormIsActive = true; FormError = "";
        ShowForm = true;
    }

    private void OpenEdit(ServiceDto s)
    {
        IsEditing = true; SelectedItem = s;
        FormNom = s.Nom; FormCode = s.Code ?? ""; FormDescription = s.Description ?? "";
        FormDeptId = s.DepartementId; FormIsActive = s.IsActive; FormError = "";
        ShowForm = true;
    }

    private void OpenDelete(ServiceDto s) { SelectedItem = s; ShowDelete = true; }
    private void CloseForm() { ShowForm = false; FormError = ""; }

    private async Task SaveForm()
    {
        if (string.IsNullOrWhiteSpace(FormNom)) { FormError = "اسم المصلحة مطلوب."; return; }
        if (FormDeptId == 0) { FormError = "يجب اختيار القسم."; return; }
        IsSaving = true; FormError = "";
        if (IsEditing && SelectedItem != null)
        {
            var dto = new UpdateServiceDto { Nom = FormNom, Code = FormCode, Description = FormDescription, DepartementId = FormDeptId, IsActive = FormIsActive };
            var r = await Svc.UpdateAsync(SelectedItem.Id, dto);
            if (r?.Succeeded == true) { SuccessMsg = "تم تعديل المصلحة بنجاح."; CloseForm(); await Load(); }
            else FormError = r?.Errors?.FirstOrDefault() ?? "حدث خطأ.";
        }
        else
        {
            var dto = new CreateServiceDto { Nom = FormNom, Code = FormCode, Description = FormDescription, DepartementId = FormDeptId };
            var r = await Svc.CreateAsync(dto);
            if (r?.Succeeded == true) { SuccessMsg = "تم إضافة المصلحة بنجاح."; CloseForm(); await Load(); }
            else FormError = r?.Errors?.FirstOrDefault() ?? "حدث خطأ.";
        }
        IsSaving = false;
        if (!string.IsNullOrEmpty(SuccessMsg)) { await Task.Delay(3500); SuccessMsg = ""; StateHasChanged(); }
    }

    private async Task ConfirmDelete()
    {
        if (SelectedItem == null) return;
        IsSaving = true;
        var ok = await Svc.DeleteAsync(SelectedItem.Id);
        IsSaving = false; ShowDelete = false;
        if (ok) { SuccessMsg = "تم حذف المصلحة."; await Load(); await Task.Delay(3000); SuccessMsg = ""; StateHasChanged(); }
        else ErrorMsg = "فشل الحذف.";
    }
}
