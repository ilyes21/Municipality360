        "RessourcesHumaines" => "bi-people-fill",
        _ => "bi-person"
    };

    private static string RoleAr(string r) => r switch
    {
        "SuperAdmin" => "مدير النظام الأعلى",
        "Admin" => "مسؤول",
        "Manager" => "مشرف",
        "Employee" => "موظف",
        "Finances" => "المالية",
        "Urbanisme" => "التعمير",
        "EtatCivil" => "الحالة المدنية",
        "SIG" => "نظام GIS",
