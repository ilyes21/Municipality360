@page "/admin/users"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using Municipality360.Application.DTOs.Identity
@using Municipality360.Web.Services
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@layout Municipality360.Web.Components.Layout.MainLayout

<PageTitle>المستخدمون والصلاحيات — Municipality360</PageTitle>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;600;700;800;900&display=swap');

    * {
        box-sizing: border-box;
        font-family: 'Tajawal',sans-serif;
    }

    /* ══ Layout ═════════════════════════════════════════════ */
    .pu-wrap {
        direction: rtl;
    }

    /* ══ Header ═════════════════════════════════════════════ */
    .pu-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: .75rem;
        margin-bottom: 1.5rem;
    }

    .pu-head-t {
        font-size: 1.4rem;
        font-weight: 900;
        color: #0f172a;
        margin: 0;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .pu-head-s {
        font-size: .76rem;
        color: #94a3b8;
        margin-top: .2rem;
    }

    .pu-head-ico {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg,#7c3aed,#a855f7);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .head-actions {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    /* ══ Stats ══════════════════════════════════════════════ */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(120px,1fr));
        gap: .7rem;
        margin-bottom: 1.3rem;
    }

    .sc {
        background: #fff;
        border-radius: 12px;
        padding: .8rem .95rem;
        border: 2px solid #f1f5f9;
        cursor: pointer;
        transition: all .16s;
        box-shadow: 0 1px 4px rgba(0,0,0,.05);
    }

        .sc:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0,0,0,.09);
        }

        .sc.asc {
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(0,0,0,.12);
        }

    .sc-val {
        font-size: 1.45rem;
        font-weight: 800;
        line-height: 1;
    }

    .sc-lbl {
        font-size: .68rem;
        color: #94a3b8;
        margin-top: .25rem;
        font-weight: 500;
    }

    /* ══ Toolbar ════════════════════════════════════════════ */
    .toolbar {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
        align-items: center;
        margin-bottom: 1.1rem;
    }

    .search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
    }

    .search-input {
        width: 100%;
        height: 40px;
        padding: 0 2.4rem 0 .9rem;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-family: 'Tajawal',sans-serif;
        font-size: .87rem;
        outline: none;
        background: #fff;
        color: #0f172a;
        direction: rtl;
        transition: border-color .15s;
    }

        .search-input:focus {
            border-color: #7c3aed;
            box-shadow: 0 0 0 3px rgba(124,58,237,.1);
        }

    .search-ico {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        pointer-events: none;
    }

    .role-filter-select {
        height: 40px;
        padding: 0 .8rem;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-family: 'Tajawal',sans-serif;
        font-size: .84rem;
        outline: none;
        background: #fff;
        color: #374151;
        cursor: pointer;
        min-width: 170px;
    }

        .role-filter-select:focus {
            border-color: #7c3aed;
        }

    /* ══ Buttons ════════════════════════════════════════════ */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .5rem 1rem;
        border: none;
        border-radius: 10px;
        font-family: 'Tajawal',sans-serif;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .16s;
        white-space: nowrap;
    }

        .btn:disabled {
            opacity: .5;
            cursor: not-allowed;
        }

    .btn-primary {
        background: linear-gradient(135deg,#7c3aed,#a855f7);
        color: #fff;
        box-shadow: 0 3px 10px rgba(124,58,237,.25);
    }

        .btn-primary:hover:not(:disabled) {
            box-shadow: 0 5px 16px rgba(124,58,237,.38);
            transform: translateY(-1px);
        }

    .btn-info {
        background: linear-gradient(135deg,#0369a1,#0ea5e9);
        color: #fff;
        box-shadow: 0 3px 10px rgba(14,165,233,.25);
    }

        .btn-info:hover:not(:disabled) {
            box-shadow: 0 5px 16px rgba(14,165,233,.35);
            transform: translateY(-1px);
        }

    .btn-ghost {
        background: #f1f5f9;
        color: #374151;
        border: 1px solid #e2e8f0;
    }

        .btn-ghost:hover {
            background: #e2e8f0;
        }

    .btn-danger {
        background: linear-gradient(135deg,#dc2626,#ef4444);
        color: #fff;
        box-shadow: 0 3px 10px rgba(239,68,68,.25);
    }

        .btn-danger:hover:not(:disabled) {
            box-shadow: 0 5px 16px rgba(239,68,68,.35);
            transform: translateY(-1px);
        }

    .btn-sm {
        padding: .32rem .7rem;
        font-size: .78rem;
    }

    /* ══ Alerts ══════════════════════════════════════════════ */
    .aok {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 10px;
        padding: .58rem .9rem;
        color: #15803d;
        font-size: .82rem;
        margin-bottom: .85rem;
        display: flex;
        align-items: center;
        gap: .45rem;
        animation: ain .25s ease;
    }

    .aerr {
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 10px;
        padding: .58rem .9rem;
        color: #dc2626;
        font-size: .82rem;
        margin-bottom: .85rem;
        display: flex;
        align-items: center;
        gap: .45rem;
        animation: ain .25s ease;
    }

    @@keyframes ain {
        from {
            opacity: 0;
            transform: translateY(-4px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    /* ══ Table card ══════════════════════════════════════════ */
    .tcard {
        background: #fff;
        border-radius: 14px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 1px 8px rgba(0,0,0,.06);
        overflow: hidden;
    }

    .tscroll {
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead tr {
        background: linear-gradient(135deg,#f8fafc,#f1f5f9);
        border-bottom: 2px solid #e2e8f0;
    }

    th {
        padding: .62rem 1rem;
        text-align: right;
        font-size: .7rem;
        font-weight: 700;
        color: #64748b;
        letter-spacing: .06em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    td {
        padding: .7rem 1rem;
        font-size: .84rem;
        color: #374151;
        border-bottom: 1px solid #f8fafc;
        vertical-align: middle;
    }

    tbody tr:hover {
        background: #fafbff;
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    tbody tr.row-off {
        opacity: .58;
    }

    /* ══ Avatar ══════════════════════════════════════════════ */
    .av {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .79rem;
        font-weight: 800;
        color: #fff;
        flex-shrink: 0;
    }

    .ucell {
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    .uname {
        font-weight: 700;
        color: #0f172a;
        font-size: .87rem;
        line-height: 1.25;
    }

    .uemail {
        font-size: .71rem;
        color: #94a3b8;
        margin-top: .05rem;
    }

    .me-badge {
        background: #dcfce7;
        color: #15803d;
        border-radius: 99px;
        padding: .06rem .4rem;
        font-size: .61rem;
        font-weight: 700;
        margin-right: .3rem;
        vertical-align: middle;
    }

    /* ══ Role tags ════════════════════════════════════════════ */
    .roles-wrap {
        display: flex;
        flex-wrap: wrap;
        gap: .22rem;
    }

    .rtag {
        display: inline-flex;
        align-items: center;
        gap: .2rem;
        border-radius: 5px;
        padding: .13rem .45rem;
        font-size: .66rem;
        font-weight: 700;
        border: 1px solid transparent;
    }

    /* Couleurs par rôle */
    .r-SuperAdmin {
        background: linear-gradient(135deg,#fef3c7,#fde68a);
        color: #92400e;
        border-color: #fcd34d;
    }

    .r-Admin {
        background: #ede9fe;
        color: #5b21b6;
        border-color: #c4b5fd;
    }

    .r-Manager {
        background: #e0f2fe;
        color: #0369a1;
        border-color: #7dd3fc;
    }

    .r-Employee {
        background: #dcfce7;
        color: #15803d;
        border-color: #86efac;
    }

    .r-Finances {
        background: #fef9c3;
        color: #854d0e;
        border-color: #fde047;
    }

    .r-Urbanisme {
        background: #f0fdf4;
        color: #166534;
        border-color: #86efac;
    }

    .r-EtatCivil {
        background: #fff7ed;
        color: #9a3412;
        border-color: #fdba74;
    }

    .r-SIG {
        background: #ecfeff;
        color: #155e75;
        border-color: #67e8f9;
    }

    .r-BureauOrdre {
        background: #f0f9ff;
        color: #075985;
        border-color: #7dd3fc;
    }

    .r-Reclamations {
        background: #fdf2f8;
        color: #86198f;
        border-color: #f0abfc;
    }

    .r-Nettoyage {
        background: #f7fee7;
        color: #3f6212;
        border-color: #a3e635;
    }

    .r-Stock {
        background: #fff1f2;
        color: #9f1239;
        border-color: #fda4af;
    }

    .r-RessourcesHumaines {
        background: #faf5ff;
        color: #6b21a8;
        border-color: #d8b4fe;
    }

    .r-default {
        background: #f1f5f9;
        color: #475569;
        border-color: #cbd5e1;
    }

    /* ══ Status ══════════════════════════════════════════════ */
    .pill-on {
        display: inline-flex;
        align-items: center;
        gap: .26rem;
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
        border-radius: 99px;
        padding: .18rem .58rem;
        font-size: .7rem;
        font-weight: 600;
    }

    .pill-off {
        display: inline-flex;
        align-items: center;
        gap: .26rem;
        background: #fef2f2;
        color: #dc2626;
        border: 1px solid #fecaca;
        border-radius: 99px;
        padding: .18rem .58rem;
        font-size: .7rem;
        font-weight: 600;
    }

    .sdot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* ══ Icon buttons ════════════════════════════════════════ */
    .ibwrap {
        display: flex;
        gap: .28rem;
        flex-wrap: nowrap;
    }

    .ib {
        width: 29px;
        height: 29px;
        border: none;
        border-radius: 7px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .76rem;
        transition: all .13s;
    }

        .ib:disabled {
            opacity: .35;
            cursor: not-allowed;
        }

    .ib-v {
        background: #f5f3ff;
        color: #7c3aed;
    }

        .ib-v:hover:not(:disabled) {
            background: #ede9fe;
        }

    .ib-b {
        background: #e0f2fe;
        color: #0369a1;
    }

        .ib-b:hover:not(:disabled) {
            background: #bae6fd;
        }

    .ib-g {
        background: #f0fdf4;
        color: #16a34a;
    }

        .ib-g:hover:not(:disabled) {
            background: #dcfce7;
        }

    .ib-r {
        background: #fef2f2;
        color: #dc2626;
    }

        .ib-r:hover:not(:disabled) {
            background: #fee2e2;
        }

    .ib-a {
        background: #fef3c7;
        color: #d97706;
    }

        .ib-a:hover:not(:disabled) {
            background: #fde68a;
        }

    /* ══ Modal ═══════════════════════════════════════════════ */
    .mbk {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.5);
        backdrop-filter: blur(5px);
        z-index: 900;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .mbox {
        background: #fff;
        border-radius: 16px;
        padding: 1.6rem;
        width: 100%;
        box-shadow: 0 24px 64px rgba(0,0,0,.22);
        animation: mopen .2s cubic-bezier(.34,1.56,.64,1);
        overflow-y: auto;
        max-height: 92vh;
    }

    @@keyframes mopen {
        from {
            opacity: 0;
            transform: scale(.92)
        }

        to {
            opacity: 1;
            transform: scale(1)
        }
    }

    .mhead {
        font-size: 1rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 1.1rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .mfoot {
        display: flex;
        gap: .55rem;
        justify-content: flex-end;
        margin-top: 1.15rem;
        flex-wrap: wrap;
    }

    /* ══ Form ════════════════════════════════════════════════ */
    .fg {
        margin-bottom: .85rem;
    }

    .fg2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .65rem;
    }

    .fl {
        display: block;
        font-size: .76rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: .32rem;
    }

    .fc {
        width: 100%;
        height: 42px;
        padding: 0 .85rem;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-family: 'Tajawal',sans-serif;
        font-size: .86rem;
        outline: none;
        color: #0f172a;
        background: #fff;
        transition: border-color .15s;
    }

        .fc:focus {
            border-color: #7c3aed;
            box-shadow: 0 0 0 3px rgba(124,58,237,.1);
        }

    .hint {
        font-size: .69rem;
        color: #94a3b8;
        margin-top: .25rem;
    }

    /* ══ Role multi-select grid ══════════════════════════════ */
    .role-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(145px,1fr));
        gap: .4rem;
        margin-top: .38rem;
    }

    .rchip {
        display: flex;
        align-items: center;
        gap: .35rem;
        padding: .38rem .65rem;
        border-radius: 8px;
        border: 1.5px solid #e2e8f0;
        font-family: 'Tajawal',sans-serif;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .13s;
        color: #64748b;
        background: #f8fafc;
        user-select: none;
    }

        .rchip:hover {
            border-color: #7c3aed;
            color: #7c3aed;
            background: #f5f3ff;
        }

        .rchip.rsel {
            color: #fff !important;
            border-color: transparent !important;
        }
            /* couleurs sélectionnées */
            .rchip.rsel.rc-SuperAdmin {
                background: linear-gradient(135deg,#f59e0b,#f97316);
            }

            .rchip.rsel.rc-Admin {
                background: linear-gradient(135deg,#7c3aed,#a855f7);
            }

            .rchip.rsel.rc-Manager {
                background: linear-gradient(135deg,#0369a1,#0ea5e9);
            }

            .rchip.rsel.rc-Employee {
                background: linear-gradient(135deg,#16a34a,#22c55e);
            }

            .rchip.rsel.rc-Finances {
                background: linear-gradient(135deg,#d97706,#f59e0b);
            }

            .rchip.rsel.rc-Urbanisme {
                background: linear-gradient(135deg,#059669,#10b981);
            }

            .rchip.rsel.rc-EtatCivil {
                background: linear-gradient(135deg,#ea580c,#f97316);
            }

            .rchip.rsel.rc-SIG {
                background: linear-gradient(135deg,#0e7490,#06b6d4);
            }

            .rchip.rsel.rc-BureauOrdre {
                background: linear-gradient(135deg,#0369a1,#38bdf8);
            }

            .rchip.rsel.rc-Reclamations {
                background: linear-gradient(135deg,#a21caf,#d946ef);
            }

            .rchip.rsel.rc-Nettoyage {
                background: linear-gradient(135deg,#4d7c0f,#84cc16);
            }

            .rchip.rsel.rc-Stock {
                background: linear-gradient(135deg,#be123c,#fb7185);
            }

            .rchip.rsel.rc-RessourcesHumaines {
                background: linear-gradient(135deg,#6d28d9,#c084fc);
            }

    .rchip-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
        flex-shrink: 0;
    }

    /* ══ Roles manager rows ══════════════════════════════════ */
    .rm-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .45rem .55rem;
        border-radius: 9px;
        margin-bottom: .22rem;
        transition: background .12s;
    }

        .rm-row:hover {
            background: #f8fafc;
        }

    .rm-l {
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .rm-dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .rm-name {
        font-size: .83rem;
        font-weight: 700;
        color: #0f172a;
    }

    .rm-desc {
        font-size: .69rem;
        color: #94a3b8;
    }

    .btn-add-role {
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
        border-radius: 7px;
        padding: .23rem .55rem;
        font-size: .72rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .12s;
    }

        .btn-add-role:hover:not(:disabled) {
            background: #dcfce7;
        }

    .btn-rem-role {
        background: #fef2f2;
        color: #dc2626;
        border: 1px solid #fecaca;
        border-radius: 7px;
        padding: .23rem .55rem;
        font-size: .72rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .12s;
    }

        .btn-rem-role:hover:not(:disabled) {
            background: #fee2e2;
        }

        .btn-add-role:disabled, .btn-rem-role:disabled {
            opacity: .38;
            cursor: not-allowed;
        }

    /* ══ Role category divider ═══════════════════════════════ */
    .role-cat {
        font-size: .65rem;
        font-weight: 700;
        color: #94a3b8;
        letter-spacing: .1em;
        text-transform: uppercase;
        padding: .3rem .55rem .15rem;
        margin-top: .3rem;
    }

    /* ══ Permissions matrix ══════════════════════════════════ */
    .pmatrix {
        width: 100%;
        border-collapse: collapse;
        font-size: .77rem;
    }

        .pmatrix th {
            padding: .42rem .6rem;
            background: #f8fafc;
            font-size: .67rem;
            font-weight: 700;
            color: #64748b;
            border: 1px solid #e2e8f0;
            text-align: center;
            white-space: nowrap;
        }

            .pmatrix th:first-child {
                text-align: right;
                min-width: 160px;
            }

        .pmatrix td {
            padding: .38rem .6rem;
            border: 1px solid #f1f5f9;
            text-align: center;
        }

        .pmatrix tr:hover td {
            background: #f8fafc;
        }

        .pmatrix td:first-child {
            text-align: right;
            font-weight: 600;
            color: #374151;
        }

    .pyes {
        color: #22c55e;
        font-size: .9rem;
    }

    .pno {
        color: #d1d5db;
        font-size: .9rem;
    }

    /* ══ Confirm ═════════════════════════════════════════════ */
    .conf-ico {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        margin: 0 auto .85rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
    }

    .conf-msg {
        text-align: center;
        color: #64748b;
        font-size: .86rem;
        line-height: 1.65;
        margin-bottom: 1.1rem;
    }

    .warn-box {
        background: #fef3c7;
        border: 1px solid #fde68a;
        border-radius: 9px;
        padding: .6rem .85rem;
        font-size: .79rem;
        color: #92400e;
        margin-bottom: .85rem;
    }

    /* ══ Sidebar ═════════════════════════════════════════════ */
    .dbk {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.35);
        z-index: 808;
    }

    .dsb {
        position: fixed;
        top: 0;
        right: 0;
        width: 380px;
        height: 100vh;
        background: #fff;
        box-shadow: -6px 0 32px rgba(0,0,0,.13);
        z-index: 809;
        overflow-y: auto;
        animation: dsbin .2s ease;
        direction: rtl;
    }

    @@keyframes dsbin {
        from {
            transform: translateX(100%)
        }

        to {
            transform: translateX(0)
        }
    }

    .dsb-head {
        background: linear-gradient(145deg,#0d1b2a,#1e293b);
        padding: 1.35rem;
        position: relative;
    }

    .dsb-av {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        margin: 0 auto .8rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        font-weight: 800;
        color: #fff;
    }

    .dsb-name {
        text-align: center;
        font-size: .98rem;
        font-weight: 800;
        color: #e2e8f0;
    }

    .dsb-email {
        text-align: center;
        font-size: .72rem;
        color: #475569;
        margin-top: .15rem;
    }

    .dsb-tags {
        text-align: center;
        margin-top: .6rem;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: .2rem;
    }

    .dsb-close {
        position: absolute;
        top: .85rem;
        left: .85rem;
        width: 28px;
        height: 28px;
        background: rgba(255,255,255,.12);
        border: none;
        border-radius: 7px;
        color: #94a3b8;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .8rem;
        transition: all .12s;
    }

        .dsb-close:hover {
            background: rgba(255,255,255,.2);
            color: #e2e8f0;
        }

    .dsb-body {
        padding: 1.1rem;
    }

    .dsb-sec {
        margin-bottom: 1.1rem;
    }

    .dsb-sec-t {
        font-size: .64rem;
        font-weight: 700;
        color: #94a3b8;
        letter-spacing: .1em;
        text-transform: uppercase;
        margin-bottom: .6rem;
    }

    .dsb-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .38rem 0;
        border-bottom: 1px solid #f8fafc;
    }

    .dsb-l {
        font-size: .77rem;
        color: #64748b;
    }

    .dsb-v {
        font-size: .79rem;
        font-weight: 600;
        color: #0f172a;
    }

    /* ══ Loading / Empty ═════════════════════════════════════ */
    .ldg {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem;
        color: #94a3b8;
        gap: .65rem;
    }

    .empty-state {
        text-align: center;
        padding: 2.8rem;
        color: #94a3b8;
    }

        .empty-state i {
            font-size: 2rem;
            display: block;
            margin-bottom: .45rem;
        }

    /* ══ Spinner ═════════════════════════════════════════════ */
    .spin {
        display: inline-block;
        width: .8rem;
        height: .8rem;
        border: 2px solid rgba(255,255,255,.35);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin .6s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg)
        }
    }

    /* ══ Role count badge ════════════════════════════════════ */
    .rc-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 20px;
        height: 20px;
        background: #f1f5f9;
        color: #64748b;
        border-radius: 99px;
        font-size: .67rem;
        font-weight: 700;
        padding: 0 .35rem;
        margin-right: .2rem;
    }
</style>

<div class="pu-wrap">

    <!-- ═══════════════ HEADER ═══════════════ -->
    <div class="pu-head">
        <div style="display:flex;align-items:center;gap:.75rem;">
            <div class="pu-head-ico"><i class="bi bi-shield-lock"></i></div>
            <div>
                <h1 class="pu-head-t">المستخدمون والصلاحيات</h1>
                <div class="pu-head-s">إدارة الحسابات · الأدوار · الصلاحيات</div>
            </div>
        </div>
        <div class="head-actions">
            <button class="btn btn-info" @onclick="() => ShowPerms = true">
                <i class="bi bi-table"></i> مرجع الصلاحيات
            </button>
            <AuthorizeView Roles="SuperAdmin,Admin">
                <Authorized>
                    <button class="btn btn-primary" @onclick="OpenAdd">
                        <i class="bi bi-person-plus"></i> مستخدم جديد
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(OkMsg))
    {
        <div class="aok"><i class="bi bi-check-circle-fill"></i> @OkMsg</div>
    }
    @if (!string.IsNullOrEmpty(ErrMsg))
    {
        <div class="aerr"><i class="bi bi-exclamation-circle-fill"></i> @ErrMsg</div>
    }

    <!-- ═══════════════ STATS ═══════════════ -->
    <div class="stats-grid">
        <div class="sc @(SF == "" ? "asc" : "")" style="border-color:@(SF == "" ? "#7c3aed" : "#f1f5f9");" @onclick='() => SF = ""'>
            <div class="sc-val" style="color:#7c3aed;">@(UserList?.Count() ?? 0)</div>
            <div class="sc-lbl">الكل</div>
        </div>
        @foreach (var (role, color) in RoleColors)
        {
            var rr = role;
            var cc = color;
            <div class="sc @(SF == rr ? "asc" : "")" style="border-color:@(SF == rr ? cc : "#f1f5f9");" @onclick="() => SF = rr">
                <div class="sc-val" style="color:@cc;">@(UserList?.Count(u => u.Roles.Contains(rr)) ?? 0)</div>
                <div class="sc-lbl">@RoleAr(rr)</div>
            </div>
        }
        <div class="sc @(SF == "on" ? "asc" : "")" style="border-color:@(SF == "on" ? "#22c55e" : "#f1f5f9");" @onclick='() => SF = "on"'>
            <div class="sc-val" style="color:#22c55e;">@(UserList?.Count(u => u.IsActive) ?? 0)</div>
            <div class="sc-lbl">نشطون</div>
        </div>
        <div class="sc @(SF == "off" ? "asc" : "")" style="border-color:@(SF == "off" ? "#ef4444" : "#f1f5f9");" @onclick='() => SF = "off"'>
            <div class="sc-val" style="color:#ef4444;">@(UserList?.Count(u => !u.IsActive) ?? 0)</div>
            <div class="sc-lbl">موقوفون</div>
        </div>
    </div>

    <!-- ═══════════════ TOOLBAR ═══════════════ -->
    <div class="toolbar">
        <div class="search-wrap">
            <input class="search-input" placeholder="بحث بالاسم أو البريد..."
                   @bind="Search" @bind:event="oninput" />
            <i class="bi bi-search search-ico"></i>
        </div>
        <select class="role-filter-select" @bind="SF">
            <option value="">— جميع الأدوار —</option>
            @foreach (var r in AllRoles)
            {
                <option value="@r">@RoleAr(r)</option>
            }
            <option value="on">نشط</option>
            <option value="off">موقوف</option>
        </select>
    </div>

    <!-- ═══════════════ TABLE ═══════════════ -->
    <div class="tcard">
        <div class="tscroll">
            @if (Loading)
            {
                <div class="ldg">
                    <div class="spinner-border spinner-border-sm" style="color:#7c3aed;width:.95rem;height:.95rem;border-width:2px;"></div>
                    <span>جاري تحميل المستخدمين...</span>
                </div>
            }
            else if (!Visible.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-people"></i>
                    <div>لا يوجد مستخدمون مطابقون</div>
                </div>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th style="width:42px;">#</th>
                            <th>المستخدم</th>
                            <th>الأدوار <span class="rc-badge">@Visible.Count()</span></th>
                            <th>الحالة</th>
                            <th style="text-align:center;">البريد</th>
                            <th>إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int idx = 0;
                        }
                        @foreach (var u in Visible)
                        {
                            idx++;
                            bool isMe = u.Email == MeEmail;
                            <tr class="@(!u.IsActive ? "row-off" : "")">
                                <td style="color:#94a3b8;font-size:.76rem;font-weight:600;">@idx</td>
                                <td>
                                    <div class="ucell">
                                        <div class="av" style="background:@AvatarGradient(u.Roles);">
                                            @Initials(u)
                                        </div>
                                        <div>
                                            <div class="uname">
                                                @u.FullName
                                                @if (isMe)
                                                {
                                                    <span class="me-badge">أنا</span>
                                                }
                                            </div>
                                            <div class="uemail">@u.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="roles-wrap">
                                        @foreach (var r in u.Roles.Take(3))
                                        {
                                            <span class="rtag r-@r"><i class="bi @RoleIco(r)" style="font-size:.6rem;"></i>@RoleAr(r)</span>
                                        }
                                        @if (u.Roles.Count > 3)
                                        {
                                            <span class="rtag r-default">+@(u.Roles.Count - 3)</span>
                                        }
                                        @if (!u.Roles.Any())
                                        {
                                            <span style="color:#cbd5e1;font-size:.75rem;">—</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (u.IsActive)
                                    {
                                        <span class="pill-on"><span class="sdot" style="background:#22c55e;"></span>نشط</span>
                                    }
                                    else
                                    {

                                        <span class="pill-off"><span class="sdot" style="background:#dc2626;"></span>موقوف</span>
                                    }
                                </td>
                                <td style="text-align:center;">
                                    @if (u.EmailConfirmed)
                                    {
                                        <i class="bi bi-patch-check-fill" style="color:#22c55e;" title="مؤكد"></i>
                                    }
                                    else
                                    {

                                        <i class="bi bi-patch-question" style="color:#cbd5e1;" title="غير مؤكد"></i>
                                    }
                                </td>
                                <td>
                                    <div class="ibwrap">
                                        <button class="ib ib-v" title="تفاصيل" @onclick="() => OpenDetail(u)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <AuthorizeView Roles="SuperAdmin">
                                            <Authorized>
                                                <button class="ib ib-a" title="إدارة الأدوار" @onclick="() => OpenRolesMgr(u)">
                                                    <i class="bi bi-key"></i>
                                                </button>
                                            </Authorized>
                                        </AuthorizeView>
                                        @if (!isMe)
                                        {
                                            @if (u.IsActive)
                                            {
                                                <button class="ib ib-r" title="إيقاف" @onclick="() => ConfirmOff(u)">
                                                    <i class="bi bi-person-dash"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="ib ib-g" title="تفعيل" @onclick="() => DoToggle(u, true)">
                                                    <i class="bi bi-person-check"></i>
                                                </button>
                                            }
                                            <AuthorizeView Roles="SuperAdmin">
                                                <Authorized>
                                                    <button class="ib ib-b" title="إعادة كلمة المرور" @onclick="() => OpenResetPwd(u)">
                                                        <i class="bi bi-lock-fill"></i>
                                                    </button>
                                                    <button class="ib ib-r" title="حذف" @onclick="() => OpenDelete(u)">
                                                        <i class="bi bi-trash3"></i>
                                                    </button>
                                                </Authorized>
                                            </AuthorizeView>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

</div><!-- end pu-wrap -->
<!-- ══════════════════════════════════════════════════════════════
     MODAL: إضافة مستخدم جديد
     POST api/auth/users
══════════════════════════════════════════════════════════════ -->
@if (ShowAdd)
{
    <div class="mbk" @onclick="() => ShowAdd = false">
        <div class="mbox" @onclick:stopPropagation="true" style="max-width:540px;" dir="rtl">
            <div class="mhead"><i class="bi bi-person-plus-fill" style="color:#7c3aed;"></i>إضافة مستخدم جديد</div>
            @if (!string.IsNullOrEmpty(FErr))
            {
                <div class="aerr"><i class="bi bi-exclamation-circle-fill"></i> @FErr</div>
            }
            <div class="fg2">
                <div class="fg"><label class="fl">الاسم *</label><input class="fc" @bind="FA" placeholder="الاسم" /></div>
                <div class="fg"><label class="fl">اللقب *</label><input class="fc" @bind="FB" placeholder="اللقب" /></div>
            </div>
            <div class="fg">
                <label class="fl">البريد الإلكتروني *</label>
                <input class="fc" type="email" @bind="FC" placeholder="user@municipality360.dz" />
            </div>
            <div class="fg">
                <label class="fl">كلمة المرور *</label>
                <input class="fc" type="password" @bind="FD" placeholder="••••••••" />
                <div class="hint">8 أحرف على الأقل · حرف كبير · رقم · رمز خاص (مثال: Admin@2025)</div>
            </div>
            <div class="fg">
                <label class="fl">الدور الرئيسي *</label>
                <div class="role-grid">
                    @foreach (var r in AllRoles)
                    {
                        var rr = r;
                        <div class="rchip @(FRole == rr ? "rsel rc-" + rr : "")" @onclick="() => FRole = rr">
                            <span class="rchip-dot"></span>
                            <i class="bi @RoleIco(rr)"></i>
                            @RoleAr(rr)
                        </div>
                    }
                </div>
                <div class="hint">سيتم تعيين أدوار إضافية لاحقاً عبر "إدارة الأدوار"</div>
            </div>
            <div class="mfoot">
                <button class="btn btn-ghost" @onclick="() => ShowAdd = false">إلغاء</button>
                <button class="btn btn-primary" @onclick="DoAdd" disabled="@Busy">
                    @if (Busy)
                    {
                        <span class="spin"></span>
                    }
     إنشاء الحساب
                </button>
            </div>
        </div>
    </div>
}


<!-- ══════════════════════════════════════════════════════════════
     MODAL: إدارة أدوار مستخدم
     POST api/auth/roles/assign | POST api/auth/roles/remove
══════════════════════════════════════════════════════════════ -->
@if (ShowRoles && RUser != null)
{
    <div class="mbk" @onclick="() => ShowRoles = false">
        <div class="mbox" @onclick:stopPropagation="true" style="max-width:500px;" dir="rtl">
            <div class="mhead"><i class="bi bi-key-fill" style="color:#f59e0b;"></i>إدارة أدوار — @RUser.FullName</div>
            @if (!string.IsNullOrEmpty(ROk))
            {
                <div class="aok"><i class="bi bi-check-circle-fill"></i> @ROk</div>
            }
            @if (!string.IsNullOrEmpty(RErr))
            {
                <div class="aerr"><i class="bi bi-exclamation-circle-fill"></i> @RErr</div>
            }

            <!-- ── الأدوار الإدارية ── -->
            <div class="role-cat">الأدوار الإدارية</div>
            @foreach (var role in AdminRoles)
            {
                var rr = role; bool has = RUser.Roles.Contains(rr);
                <div class="rm-row">
                    <div class="rm-l">
                        <div class="rm-dot" style="background:@RoleColor(rr);"></div>
                        <div>
                            <div class="rm-name"><i class="bi @RoleIco(rr)"></i> @RoleAr(rr)</div>
                            <div class="rm-desc">@RoleDesc(rr)</div>
                        </div>
                    </div>
                    @if (has)
                    {
                        <button class="btn-rem-role" @onclick="() => DoRemRole(rr)" disabled="@Busy"><i class="bi bi-dash-circle"></i> إلغاء</button>
                    }
                    else
                    {

                        <button class="btn-add-role" @onclick="() => DoAddRole(rr)" disabled="@Busy"><i class="bi bi-plus-circle"></i> تعيين</button>
                    }
                </div>
            }

            <!-- ── أدوار الوحدات ── -->
            <div class="role-cat" style="margin-top:.7rem;">أدوار الوحدات والمصالح</div>
            @foreach (var role in UnitRoles)
            {
                var rr = role; bool has = RUser.Roles.Contains(rr);
                <div class="rm-row">
                    <div class="rm-l">
                        <div class="rm-dot" style="background:@RoleColor(rr);"></div>
                        <div>
                            <div class="rm-name"><i class="bi @RoleIco(rr)"></i> @RoleAr(rr)</div>
                            <div class="rm-desc">@RoleDesc(rr)</div>
                        </div>
                    </div>
                    @if (has)
                    {
                        <button class="btn-rem-role" @onclick="() => DoRemRole(rr)" disabled="@Busy"><i class="bi bi-dash-circle"></i> إلغاء</button>
                    }
                    else
                    {

                        <button class="btn-add-role" @onclick="() => DoAddRole(rr)" disabled="@Busy"><i class="bi bi-plus-circle"></i> تعيين</button>
                    }
                </div>
            }

            <div class="mfoot">
                <button class="btn btn-ghost" @onclick="() => ShowRoles = false">إغلاق</button>
            </div>
        </div>
    </div>
}


<!-- ══════════════════════════════════════════════════════════════
     MODAL: مرجع الصلاحيات
══════════════════════════════════════════════════════════════ -->
@if (ShowPerms)
{
    <div class="mbk" @onclick="() => ShowPerms = false">
        <div class="mbox" @onclick:stopPropagation="true" style="max-width:720px;" dir="rtl">
            <div class="mhead"><i class="bi bi-table" style="color:#0ea5e9;"></i>مرجع الأدوار والصلاحيات</div>
            <div style="overflow-x:auto;">
                <table class="pmatrix">
                    <thead>
                        <tr>
                            <th>الصلاحية</th>
                            <th>SuperAdmin</th>
                            <th>Admin</th>
                            <th>Manager</th>
                            <th>Employee</th>
                            <th>Finances</th>
                            <th>Urbanisme</th>
                            <th>EtatCivil</th>
                            <th>SIG</th>
                            <th>BureauOrdre</th>
                            <th>Reclamations</th>
                            <th>Nettoyage</th>
                            <th>Stock</th>
                            <th>RH</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Perms)
                        {
                            <tr>
                                <td>@p.N</td>
                                <td><i class="bi @(p.V[0] ? "bi-check-circle-fill pyes" : "bi-x-circle pno")"></i></td>
                                <td><i class="bi @(p.V[1] ? "bi-check-circle-fill pyes" : "bi-x-circle pno")"></i></td>
                                <td><i class="bi @(p.V[2] ? "bi-check-circle-fill pyes" : "bi-x-circle pno")"></i></td>
                                <td><i class="bi @(p.V[3] ? "bi-check-circle-fill pyes" : "bi-x-circle pno")"></i></td>
                                <td><i class="bi @(p.V[4] ? "bi-check-circle-fill pyes" : "bi-x-circle pno")"></i></td>
                                <td><i class="bi @(p.V[5] ? "bi-check-circle-fill pyes" : "bi-x-circle pno")"></i></td>
                                <td><i class="bi @(p.V[6] ? "bi-check-circle-fill pyes" : "bi-x-circle pno")"></i></td>
                                <td><i class="bi @(p.V[7] ? "bi-check-circle-fill pyes" : "bi-x-circle pno")"></i></td>
                                <td><i class="bi @(p.V[8] ? "bi-check-circle-fill pyes" : "bi-x-circle pno")"></i></td>
                                <td><i class="bi @(p.V[9] ? "bi-check-circle-fill pyes" : "bi-x-circle pno")"></i></td>
                                <td><i class="bi @(p.V[10] ? "bi-check-circle-fill pyes" : "bi-x-circle pno")"></i></td>
                                <td><i class="bi @(p.V[11] ? "bi-check-circle-fill pyes" : "bi-x-circle pno")"></i></td>
                                <td><i class="bi @(p.V[12] ? "bi-check-circle-fill pyes" : "bi-x-circle pno")"></i></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div style="font-size:.7rem;color:#94a3b8;margin-top:.7rem;">
                ترتيب الأعمدة: SuperAdmin · Admin · Manager · Employee · Finances · Urbanisme · EtatCivil · SIG · BureauOrdre · Reclamations · Nettoyage · Stock · RessourcesHumaines
            </div>
            <div class="mfoot"><button class="btn btn-ghost" @onclick="() => ShowPerms = false">إغلاق</button></div>
        </div>
    </div>
}


<!-- ══════════════════════════════════════════════════════════════
     MODAL: إعادة تعيين كلمة المرور
     POST api/auth/users/reset-password
══════════════════════════════════════════════════════════════ -->
@if (ShowReset && SelU != null)
{
    <div class="mbk" @onclick="() => ShowReset = false">
        <div class="mbox" @onclick:stopPropagation="true" style="max-width:400px;" dir="rtl">
            <div class="mhead"><i class="bi bi-lock-fill" style="color:#f59e0b;"></i>إعادة تعيين كلمة المرور</div>
            @if (!string.IsNullOrEmpty(FErr))
            {
                <div class="aerr"><i class="bi bi-exclamation-circle-fill"></i> @FErr</div>
            }
            <div class="warn-box"><i class="bi bi-exclamation-triangle-fill"></i> سيتم تغيير كلمة مرور: <strong>@SelU.Email</strong></div>
            <div class="fg">
                <label class="fl">كلمة المرور الجديدة *</label>
                <input class="fc" type="password" @bind="P1" placeholder="••••••••" />
                <div class="hint">8 أحرف على الأقل · حرف كبير · رقم · رمز خاص</div>
            </div>
            <div class="fg">
                <label class="fl">تأكيد كلمة المرور *</label>
                <input class="fc" type="password" @bind="P2" placeholder="••••••••" />
            </div>
            <div class="mfoot">
                <button class="btn btn-ghost" @onclick="() => ShowReset = false">إلغاء</button>
                <button class="btn btn-danger" @onclick="DoReset" disabled="@Busy">
                    @if (Busy)
                    {
                        <span class="spin"></span>
