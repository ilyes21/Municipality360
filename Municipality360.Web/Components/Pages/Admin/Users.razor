<!-- ══════════════════════════════════════════════════════════════
     SIDEBAR: تفاصيل المستخدم
══════════════════════════════════════════════════════════════ -->
@if (DetailU != null)
{
    <div class="dbk" @onclick="() => DetailU = null"></div>
    <div class="dsb">
        <div class="dsb-head">
            <button class="dsb-close" @onclick="() => DetailU = null"><i class="bi bi-x-lg"></i></button>
            <div class="dsb-av" style="background:@AvatarGradient(DetailU.Roles);">@Initials(DetailU)</div>
            <div class="dsb-name">@DetailU.FullName</div>
            <div class="dsb-email">@DetailU.Email</div>
            <div class="dsb-tags">
                @foreach (var r in DetailU.Roles)
                {
                    <span class="rtag r-@r"><i class="bi @RoleIco(r)" style="font-size:.6rem;"></i>@RoleAr(r)</span>
                }
            </div>
        </div>
        <div class="dsb-body">
            <!-- معلومات -->
            <div class="dsb-sec">
                <div class="dsb-sec-t">معلومات الحساب</div>
                <div class="dsb-row">
                    <span class="dsb-l">الحالة</span>
                    @if (DetailU.IsActive)
                    {
                        <span class="pill-on"><span class="sdot" style="background:#22c55e;"></span>نشط</span>
                    }
                    else
                    {

                        <span class="pill-off"><span class="sdot" style="background:#dc2626;"></span>موقوف</span>
                    }
                </div>
                <div class="dsb-row">
                    <span class="dsb-l">البريد الإلكتروني</span>
                    <span class="dsb-v" style="font-size:.72rem;direction:ltr;">@DetailU.Email</span>
                </div>
                <div class="dsb-row">
                    <span class="dsb-l">تأكيد البريد</span>
                    @if (DetailU.EmailConfirmed)
                    {
                        <i class="bi bi-patch-check-fill" style="color:#22c55e;"></i>
                    }
                    else
                    {

                        <span style="color:#94a3b8;font-size:.77rem;">غير مؤكد</span>
                    }
                </div>
                <div class="dsb-row">
                    <span class="dsb-l">عدد الأدوار</span>
                    <span class="dsb-v">@DetailU.Roles.Count دور</span>
                </div>
            </div>

            <!-- الأدوار الإدارية -->
            <div class="dsb-sec">
                <div class="dsb-sec-t">الأدوار الإدارية</div>
                @foreach (var r in AdminRoles)
                {
                    bool has = DetailU.Roles.Contains(r);
                    <div class="rm-row">
                        <div class="rm-l">
                            <div class="rm-dot" style="background:@(has? RoleColor(r):"#e2e8f0");"></div>
                            <div class="rm-name" style="color:@(has ? "#0f172a" : "#94a3b8");font-weight:@(has ? "700" : "400");">@RoleAr(r)</div>
                        </div>
                        @if (has)
                        {
                            <i class="bi bi-check-circle-fill" style="color:#22c55e;font-size:.85rem;"></i>
                        }
                        else
                        {

                            <i class="bi bi-circle" style="color:#e2e8f0;font-size:.85rem;"></i>
                        }
                    </div>
                }
            </div>

            <!-- أدوار الوحدات -->
            <div class="dsb-sec">
                <div class="dsb-sec-t">أدوار الوحدات</div>
                @foreach (var r in UnitRoles)
                {
                    bool has = DetailU.Roles.Contains(r);
                    <div class="rm-row">
                        <div class="rm-l">
                            <div class="rm-dot" style="background:@(has? RoleColor(r):"#e2e8f0");"></div>
                            <div class="rm-name" style="color:@(has ? "#0f172a" : "#94a3b8");font-weight:@(has ? "700" : "400");">@RoleAr(r)</div>
                        </div>
                        @if (has)
                        {
                            <i class="bi bi-check-circle-fill" style="color:#22c55e;font-size:.85rem;"></i>
                        }
                        else
                        {

                            <i class="bi bi-circle" style="color:#e2e8f0;font-size:.85rem;"></i>
                        }
                    </div>
                }
            </div>

            <!-- إجراءات سريعة -->
            <div style="display:flex;flex-direction:column;gap:.45rem;margin-top:.75rem;">
                <AuthorizeView Roles="SuperAdmin">
                    <Authorized>
                        <button class="btn btn-primary" style="justify-content:center;"
                                @onclick="() => { OpenRolesMgr(DetailU!); DetailU = null; }">
                            <i class="bi bi-key"></i> إدارة الأدوار
                        </button>
                    </Authorized>
                </AuthorizeView>
                @if (DetailU.Email != MeEmail)
                {
                    @if (DetailU.IsActive)
                    {
                        <button class="btn" style="justify-content:center;background:#fef2f2;color:#dc2626;border:1px solid #fecaca;"
                                @onclick="() => { ConfirmOff(DetailU!); DetailU = null; }">
                            <i class="bi bi-person-dash"></i> إيقاف الحساب
                        </button>
                    }
                    else
                    {
                        <button class="btn" style="justify-content:center;background:#f0fdf4;color:#16a34a;border:1px solid #bbf7d0;"
                                @onclick="() => { DoToggle(DetailU!, true); DetailU = null; }">
                            <i class="bi bi-person-check"></i> تفعيل الحساب
                        </button>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    // ── DI ─────────────────────────────────────────────────────
    [Inject] IUserApiService UserSvc { get; set; } = null!;
    [Inject] AuthenticationStateProvider AuthSP { get; set; } = null!;

    // ── Data ────────────────────────────────────────────────────
    private IEnumerable<UserDetailDto>? UserList;
    private bool Loading = true;
    private bool Busy = false;
    private string MeEmail = "";

    // ── Filters ─────────────────────────────────────────────────
    private string SF = "";
    private string Search = "";

    // ── Page alerts ─────────────────────────────────────────────
    private string OkMsg = "", ErrMsg = "";

    // ── Modals ──────────────────────────────────────────────────
    private bool ShowAdd, ShowRoles, ShowPerms, ShowReset, ShowDel, ShowToggleConf;

    // ── Selected ────────────────────────────────────────────────
    private UserDetailDto? SelU;
    private UserDetailDto? DetailU;
    private UserDetailDto? RUser;

    // ── Add form ────────────────────────────────────────────────
    private string FA = "", FB = "", FC = "", FD = "", FRole = "Employee", FErr = "";

    // ── Reset pwd ───────────────────────────────────────────────
    private string P1 = "", P2 = "";

    // ── Roles modal feedback ─────────────────────────────────────
    private string ROk = "", RErr = "";

    // ══ الأدوار الـ 13 المُعرَّفة في DbSeeder ════════════════════
    private static readonly string[] AllRoles =
    {
        "SuperAdmin","Admin","Manager","Employee",
        "Finances","Urbanisme","EtatCivil","SIG",
        "BureauOrdre","Reclamations","Nettoyage","Stock","RessourcesHumaines"
    };

    // تقسيم الأدوار إلى فئتين للعرض
    private static readonly string[] AdminRoles =
        { "SuperAdmin","Admin","Manager","Employee" };

    private static readonly string[] UnitRoles =
        { "Finances","Urbanisme","EtatCivil","SIG",
          "BureauOrdre","Reclamations","Nettoyage","Stock","RessourcesHumaines" };

    // لون كل دور في بطاقات الإحصاء
    private static readonly (string Role, string Color)[] RoleColors =
    {
        ("SuperAdmin",        "#f59e0b"),
        ("Admin",             "#7c3aed"),
        ("Manager",           "#0369a1"),
        ("Employee",          "#16a34a"),
        ("Finances",          "#d97706"),
        ("Urbanisme",         "#059669"),
        ("EtatCivil",         "#ea580c"),
        ("SIG",               "#0e7490"),
        ("BureauOrdre",       "#0369a1"),
        ("Reclamations",      "#a21caf"),
        ("Nettoyage",         "#4d7c0f"),
        ("Stock",             "#be123c"),
        ("RessourcesHumaines","#6d28d9"),
    };

    // ══ جدول الصلاحيات (13 عمود) ═════════════════════════════════
    // ترتيب V[]: SA, AD, MG, EM, FI, UR, EC, SI, BO, RE, NE, ST, RH
    private record Perm(string N, bool[] V);
    private static readonly Perm[] Perms =
    {
        new("تسجيل الدخول",                     new[]{true,true,true,true,true,true,true,true,true,true,true,true,true}),
        new("إدارة المستخدمين",                   new[]{true,true,false,false,false,false,false,false,false,false,false,false,false}),
        new("تعيين / إلغاء الأدوار",              new[]{true,false,false,false,false,false,false,false,false,false,false,false,false}),
        new("حذف المستخدمين",                      new[]{true,false,false,false,false,false,false,false,false,false,false,false,false}),
        new("إعادة كلمة المرور",                   new[]{true,false,false,false,false,false,false,false,false,false,false,false,false}),
        new("إدارة الأقسام والمصالح",              new[]{true,true,false,false,false,false,false,false,false,false,false,false,false}),
        new("إدارة الموظفين",                      new[]{true,true,true,false,false,false,false,false,false,false,false,false,true}),
        new("عرض الموظفين",                        new[]{true,true,true,true,false,false,false,false,false,false,false,false,true}),
        new("إدارة الميزانية / المالية",           new[]{true,true,false,false,true,false,false,false,false,false,false,false,false}),
        new("عرض التقارير المالية",                 new[]{true,true,true,false,true,false,false,false,false,false,false,false,false}),
        new("إدارة التعمير والبناء",               new[]{true,true,false,false,false,true,false,false,false,false,false,false,false}),
        new("إدارة الحالة المدنية",                 new[]{true,true,false,false,false,false,true,false,false,false,false,false,false}),
        new("الوصول لنظام SIG",                   new[]{true,true,true,false,false,false,false,true,false,false,false,false,false}),
        new("إدارة البريد والأوامر",               new[]{true,true,false,false,false,false,false,false,true,false,false,false,false}),
        new("إدارة الشكاوى والمطالبات",            new[]{true,true,true,false,false,false,false,false,false,true,false,false,false}),
        new("إدارة النظافة والبيئة",               new[]{true,true,false,false,false,false,false,false,false,false,true,false,false}),
        new("إدارة المخزون والمعدات",              new[]{true,true,false,false,false,false,false,false,false,false,false,true,false}),
        new("إدارة الموارد البشرية",               new[]{true,true,false,false,false,false,false,false,false,false,false,false,true}),
    };

    // ── Computed ─────────────────────────────────────────────────
    private IEnumerable<UserDetailDto> Visible =>
        (UserList ?? Enumerable.Empty<UserDetailDto>())
        .Where(u =>
            (SF == ""
             || (SF == "on" && u.IsActive)
             || (SF == "off" && !u.IsActive)
             || u.Roles.Contains(SF))
            && (string.IsNullOrEmpty(Search)
                || u.FullName.Contains(Search, StringComparison.OrdinalIgnoreCase)
                || u.Email.Contains(Search, StringComparison.OrdinalIgnoreCase)));

    // ── Init ──────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var state = await AuthSP.GetAuthenticationStateAsync();
        MeEmail = state.User.FindFirst(ClaimTypes.Email)?.Value
               ?? state.User.FindFirst("email")?.Value ?? "";
        await Load();
    }

    // ── Load — GET api/auth/users ─────────────────────────────────
    private async Task Load()
    {
        Loading = true; StateHasChanged();
        var r = await UserSvc.GetAllDetailAsync();
        UserList = r?.Data ?? Enumerable.Empty<UserDetailDto>();
        Loading = false;
    }

    // ── Open modals ───────────────────────────────────────────────
    private void OpenAdd() { FA = ""; FB = ""; FC = ""; FD = ""; FRole = "Employee"; FErr = ""; ShowAdd = true; }
    private void OpenDetail(UserDetailDto u) => DetailU = u;
    private void OpenDelete(UserDetailDto u) { SelU = u; ShowDel = true; }
    private void OpenResetPwd(UserDetailDto u) { SelU = u; P1 = ""; P2 = ""; FErr = ""; ShowReset = true; }
    private void OpenRolesMgr(UserDetailDto u) { RUser = u; ROk = ""; RErr = ""; ShowRoles = true; }
    private void ConfirmOff(UserDetailDto u) { SelU = u; ShowToggleConf = true; }

    // ── DoAdd — POST api/auth/users ───────────────────────────────
    private async Task DoAdd()
    {
        if (string.IsNullOrWhiteSpace(FA)) { FErr = "الاسم مطلوب."; return; }
        if (string.IsNullOrWhiteSpace(FB)) { FErr = "اللقب مطلوب."; return; }
        if (string.IsNullOrWhiteSpace(FC)) { FErr = "البريد الإلكتروني مطلوب."; return; }
        if (string.IsNullOrWhiteSpace(FD)) { FErr = "كلمة المرور مطلوبة."; return; }
        if (FD.Length < 8) { FErr = "كلمة المرور 8 أحرف على الأقل."; return; }
        Busy = true; FErr = "";
        var r = await UserSvc.RegisterAsync(new RegisterDto
        { FirstName = FA.Trim(), LastName = FB.Trim(), Email = FC.Trim(), Password = FD, Role = FRole });
        Busy = false;
        if (r?.Succeeded == true) { ShowAdd = false; Flash($"✓ تم إنشاء حساب {FA} {FB}."); await Load(); }
        else FErr = r?.Errors?.FirstOrDefault() ?? "حدث خطأ. تحقق من متطلبات كلمة المرور.";
    }

    // ── DoDel — DELETE api/auth/users/{id} ────────────────────────
    private async Task DoDel()
    {
        if (SelU == null) return;
        Busy = true;
        var ok = await UserSvc.DeleteAsync(SelU.Id);
        Busy = false; ShowDel = false;
        if (ok) { Flash($"✓ تم حذف حساب {SelU.FullName}."); await Load(); }
        else FlashErr("فشل الحذف.");
    }

    // ── DoToggle — PATCH api/auth/users/toggle ────────────────────
    private async Task DoToggle(UserDetailDto u, bool activate)
    {
        ShowToggleConf = false; Busy = true;
        var ok = await UserSvc.ToggleActiveAsync(u.Id, activate);
        Busy = false;
        if (ok) { Flash(activate ? $"✓ تم تفعيل {u.FullName}." : $"✓ تم إيقاف {u.FullName}."); await Load(); }
        else FlashErr("فشلت العملية.");
    }

    // ── DoReset — POST api/auth/users/reset-password ──────────────
    private async Task DoReset()
    {
        if (SelU == null) return;
        if (string.IsNullOrWhiteSpace(P1)) { FErr = "كلمة المرور مطلوبة."; return; }
        if (P1.Length < 8) { FErr = "8 أحرف على الأقل."; return; }
        if (P1 != P2) { FErr = "كلمتا المرور غير متطابقتين."; return; }
        Busy = true; FErr = "";
        var ok = await UserSvc.ResetPasswordAsync(SelU.Id, P1);
        Busy = false;
        if (ok) { ShowReset = false; Flash($"✓ تم تغيير كلمة مرور {SelU.FullName}."); }
        else FErr = "فشلت العملية. تحقق من متطلبات كلمة المرور.";
    }

    // ── DoAddRole — POST api/auth/roles/assign ────────────────────
    private async Task DoAddRole(string role)
    {
        if (RUser == null) return;
        Busy = true; ROk = ""; RErr = "";
        var ok = await UserSvc.AssignRoleAsync(RUser.Id, role);
        Busy = false;
        if (ok)
        {
            if (!RUser.Roles.Contains(role)) RUser.Roles.Add(role);
            ROk = $"✓ تم تعيين «{RoleAr(role)}».";
            await Load();
            RUser = UserList?.FirstOrDefault(u => u.Id == RUser.Id) ?? RUser;
        }
        else RErr = "فشل تعيين الدور.";
    }

    // ── DoRemRole — POST api/auth/roles/remove ────────────────────
    private async Task DoRemRole(string role)
    {
        if (RUser == null) return;
        Busy = true; ROk = ""; RErr = "";
        var ok = await UserSvc.RemoveRoleAsync(RUser.Id, role);
        Busy = false;
        if (ok)
        {
            RUser.Roles.Remove(role);
            ROk = $"✓ تم إلغاء «{RoleAr(role)}».";
            await Load();
            RUser = UserList?.FirstOrDefault(u => u.Id == RUser.Id) ?? RUser;
        }
        else RErr = "فشل إلغاء الدور.";
    }

    // ── Flash ─────────────────────────────────────────────────────
    private async void Flash(string msg)
    { OkMsg = msg; ErrMsg = ""; StateHasChanged(); await Task.Delay(4000); OkMsg = ""; StateHasChanged(); }
    private async void FlashErr(string msg)
    { ErrMsg = msg; OkMsg = ""; StateHasChanged(); await Task.Delay(4500); ErrMsg = ""; StateHasChanged(); }

    // ══ Display helpers ══════════════════════════════════════════
    private static string Initials(UserDetailDto u)
    {
        var f = u.FirstName?.Trim() ?? ""; var l = u.LastName?.Trim() ?? "";
        return $"{(f.Length > 0 ? f[0] : ' ')}{(l.Length > 0 ? l[0] : ' ')}".Trim().ToUpper();
    }

    private static string AvatarGradient(IList<string> roles)
    {
        if (roles.Contains("SuperAdmin")) return "linear-gradient(135deg,#f59e0b,#f97316)";
        if (roles.Contains("Admin")) return "linear-gradient(135deg,#7c3aed,#a855f7)";
        if (roles.Contains("Manager")) return "linear-gradient(135deg,#0369a1,#0ea5e9)";
        if (roles.Contains("Finances")) return "linear-gradient(135deg,#d97706,#f59e0b)";
        if (roles.Contains("Urbanisme")) return "linear-gradient(135deg,#059669,#10b981)";
        if (roles.Contains("EtatCivil")) return "linear-gradient(135deg,#ea580c,#f97316)";
        if (roles.Contains("SIG")) return "linear-gradient(135deg,#0e7490,#06b6d4)";
        if (roles.Contains("BureauOrdre")) return "linear-gradient(135deg,#0369a1,#38bdf8)";
        if (roles.Contains("Reclamations")) return "linear-gradient(135deg,#a21caf,#d946ef)";
        if (roles.Contains("Nettoyage")) return "linear-gradient(135deg,#4d7c0f,#84cc16)";
        if (roles.Contains("Stock")) return "linear-gradient(135deg,#be123c,#fb7185)";
        if (roles.Contains("RessourcesHumaines")) return "linear-gradient(135deg,#6d28d9,#c084fc)";
        if (roles.Contains("Employee")) return "linear-gradient(135deg,#16a34a,#22c55e)";
        return "linear-gradient(135deg,#64748b,#94a3b8)";
    }

    private static string RoleColor(string r) => r switch
    {
        "SuperAdmin" => "#f59e0b",
        "Admin" => "#7c3aed",
        "Manager" => "#0369a1",
        "Employee" => "#16a34a",
        "Finances" => "#d97706",
