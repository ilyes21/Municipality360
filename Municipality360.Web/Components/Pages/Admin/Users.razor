@page "/admin/users"
@attribute [Authorize(Roles = "SuperAdmin")]
@using Microsoft.AspNetCore.Authorization
@using Municipality360.Application.Common
@using Municipality360.Application.DTOs.Identity
@inject IUserApiService UserService

<PageTitle>إدارة المستخدمين - Municipality360</PageTitle>

<style>
    :root { --accent:#0ea5e9; --accent-dark:#0369a1; --accent-glow:rgba(14,165,233,.15); --success:#10b981; --danger:#ef4444; --warning:#f59e0b; --border:#e2e8f0; --text1:#0f172a; --text2:#475569; --text3:#94a3b8; --font:'Tajawal',sans-serif; }
    .ph { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.75rem; flex-wrap:wrap; gap:1rem; }
    .ph-left h1 { font-size:1.45rem; font-weight:800; color:var(--text1); margin:0; display:flex; align-items:center; gap:.5rem; }
    .ph-left h1 i { color:var(--accent); } .ph-left p { font-size:.82rem; color:var(--text3); margin:.2rem 0 0; }
    .stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(170px,1fr)); gap:1rem; margin-bottom:1.75rem; }
    .stat { background:#fff; border-radius:14px; padding:1rem 1.2rem; border:1px solid var(--border); display:flex; align-items:center; gap:.85rem; box-shadow:0 2px 8px rgba(0,0,0,.04); }
    .stat-ico { width:42px; height:42px; border-radius:11px; display:flex; align-items:center; justify-content:center; font-size:1.15rem; flex-shrink:0; }
    .ic-blue { background:rgba(14,165,233,.12); color:var(--accent); } .ic-purple { background:rgba(139,92,246,.12); color:#7c3aed; } .ic-amber { background:rgba(245,158,11,.12); color:var(--warning); } .ic-green { background:rgba(16,185,129,.12); color:var(--success); }
    .stat-val { font-size:1.55rem; font-weight:800; color:var(--text1); line-height:1; } .stat-lbl { font-size:.73rem; color:var(--text3); margin-top:.15rem; }
    .card { background:#fff; border-radius:16px; border:1px solid var(--border); overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,.05); }
    .card-header { padding:.9rem 1.4rem; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; gap:.75rem; flex-wrap:wrap; }
    .card-header h5 { margin:0; font-weight:700; font-size:.95rem; color:var(--text1); display:flex; align-items:center; gap:.4rem; }
    .search-wrap { position:relative; } .search-wrap i { position:absolute; right:.75rem; top:50%; transform:translateY(-50%); color:var(--text3); font-size:.85rem; pointer-events:none; }
    .search-input { padding:.48rem 2rem .48rem .75rem; border:1.5px solid var(--border); border-radius:10px; font-size:.85rem; font-family:var(--font); outline:none; background:#f8fafc; color:var(--text1); transition:border-color .15s; width:220px; }
    .search-input:focus { border-color:var(--accent); background:#fff; }
    .tbl-wrap { overflow-x:auto; }
    table { width:100%; border-collapse:collapse; font-size:.875rem; }
    thead th { background:#f8fafc; padding:.8rem 1rem; text-align:right; font-weight:700; font-size:.73rem; color:var(--text3); text-transform:uppercase; letter-spacing:.04em; border-bottom:1px solid var(--border); white-space:nowrap; }
    tbody td { padding:.85rem 1rem; border-bottom:1px solid #f1f5f9; color:var(--text2); vertical-align:middle; }
    tbody tr:last-child td { border-bottom:none; } tbody tr:hover td { background:#f8fafc; }
    .user-avatar { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.82rem; font-weight:800; flex-shrink:0; }
    .role-chip { display:inline-flex; align-items:center; gap:.25rem; padding:.2rem .6rem; border-radius:100px; font-size:.72rem; font-weight:700; }
    .r-superadmin { background:rgba(139,92,246,.12); color:#7c3aed; }
    .r-admin   { background:rgba(14,165,233,.12); color:var(--accent-dark); }
    .r-manager { background:rgba(16,185,129,.12); color:#059669; }
    .r-employee{ background:rgba(148,163,184,.15); color:var(--text2); }
    .btn { display:inline-flex; align-items:center; gap:.4rem; padding:.5rem 1rem; border-radius:10px; font-size:.875rem; font-weight:600; cursor:pointer; border:none; transition:all .18s; font-family:var(--font); }
    .btn-primary { background:linear-gradient(135deg,var(--accent-dark),var(--accent)); color:#fff; box-shadow:0 3px 10px rgba(14,165,233,.3); }
    .btn-primary:hover { opacity:.9; transform:translateY(-1px); }
    .btn-ghost { background:transparent; border:1.5px solid var(--border); color:var(--text2); }
    .btn-ghost:hover { border-color:var(--accent); color:var(--accent); background:var(--accent-glow); }
    .btn-danger-ghost { background:transparent; border:1.5px solid rgba(239,68,68,.3); color:var(--danger); }
    .btn-danger-ghost:hover { background:rgba(239,68,68,.08); }
    .btn-danger { background:linear-gradient(135deg,#dc2626,var(--danger)); color:#fff; border:none; }
    .btn-sm { padding:.3rem .65rem; font-size:.75rem; }
    .btn:disabled { opacity:.55; cursor:not-allowed; transform:none !important; }
    .action-btns { display:flex; gap:.35rem; }
    .backdrop { position:fixed; inset:0; background:rgba(10,15,30,.6); backdrop-filter:blur(6px); z-index:1000; display:flex; align-items:center; justify-content:center; padding:1rem; animation:fi .2s; }
    @@keyframes fi { from{opacity:0} to{opacity:1} }
    .modal { background:#fff; border-radius:18px; width:100%; max-width:500px; box-shadow:0 24px 60px rgba(0,0,0,.18); animation:su .22s; overflow:hidden; }
    @@keyframes su { from{opacity:0;transform:translateY(16px) scale(.97)} to{opacity:1;transform:none} }
    .mh { padding:1.1rem 1.4rem; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
    .mh h5 { margin:0; font-weight:800; font-size:1rem; color:var(--text1); display:flex; align-items:center; gap:.5rem; }
    .mh h5 i { color:var(--accent); }
    .mbtn-close { background:none; border:none; cursor:pointer; color:var(--text3); font-size:1.2rem; padding:.2rem .4rem; border-radius:6px; }
    .mbtn-close:hover { color:var(--danger); background:rgba(239,68,68,.08); }
    .mb { padding:1.3rem 1.4rem; } .mf { padding:.9rem 1.4rem; border-top:1px solid var(--border); display:flex; justify-content:flex-end; gap:.65rem; }
    .fg { margin-bottom:1rem; } .fg label { display:block; font-size:.82rem; font-weight:700; color:var(--text2); margin-bottom:.4rem; }
    .fg .req { color:var(--danger); margin-right:.2rem; }
    .fc { width:100%; padding:.58rem .9rem; border:1.5px solid var(--border); border-radius:10px; font-size:.875rem; font-family:var(--font); color:var(--text1); background:#f8fafc; outline:none; transition:border-color .15s,box-shadow .15s; }
    .fc:focus { border-color:var(--accent); background:#fff; box-shadow:0 0 0 3px var(--accent-glow); }
    .row2 { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
    .conf-icon { width:64px; height:64px; border-radius:50%; background:rgba(239,68,68,.1); border:2px solid rgba(239,68,68,.2); display:flex; align-items:center; justify-content:center; margin:0 auto 1rem; color:var(--danger); font-size:1.8rem; }
    .conf-title { font-size:1.1rem; font-weight:800; color:var(--text1); text-align:center; margin-bottom:.5rem; }
    .conf-desc { font-size:.88rem; color:var(--text2); text-align:center; line-height:1.6; }
    .alert { padding:.75rem 1rem; border-radius:10px; font-size:.875rem; display:flex; align-items:center; gap:.5rem; margin-bottom:1rem; }
    .alert-danger { background:rgba(239,68,68,.08); border:1px solid rgba(239,68,68,.2); color:#dc2626; }
    .alert-success { background:rgba(16,185,129,.08); border:1px solid rgba(16,185,129,.2); color:#059669; }
    .info-banner { background:rgba(139,92,246,.06); border:1px solid rgba(139,92,246,.18); border-radius:12px; padding:1rem 1.2rem; margin-bottom:1.5rem; display:flex; align-items:flex-start; gap:.8rem; }
    .info-banner i { color:#7c3aed; font-size:1.1rem; flex-shrink:0; margin-top:.1rem; }
    .info-banner p { margin:0; font-size:.84rem; color:var(--text2); line-height:1.6; }
    .loading-wrap { display:flex; align-items:center; justify-content:center; min-height:280px; flex-direction:column; gap:1rem; }
    .spinner { width:36px; height:36px; border:3px solid rgba(14,165,233,.2); border-top-color:var(--accent); border-radius:50%; animation:spin .7s linear infinite; }
    @@keyframes spin { to{transform:rotate(360deg)} }
    .empty { text-align:center; padding:3rem 1rem; color:var(--text3); }
    .empty i { font-size:2.8rem; opacity:.35; display:block; margin-bottom:.75rem; }
    .empty p { font-size:.9rem; margin:0; }
    .pw-hint { font-size:.75rem; color:var(--text3); margin-top:.3rem; }
</style>

<div class="ph">
    <div class="ph-left">
        <h1><i class="bi bi-people"></i> إدارة المستخدمين</h1>
        <p>عرض وإدارة حسابات المستخدمين وصلاحياتهم</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenCreate"><i class="bi bi-person-plus"></i> إضافة مستخدم</button>
</div>

<div class="info-banner">
    <i class="bi bi-shield-lock"></i>
    <p>هذه الصفحة مخصصة لمدير النظام الأعلى فقط. يمكنك هنا إضافة مستخدمين جدد، وتعيين أدوارهم، وحذف الحسابات.</p>
</div>

<div class="stats">
    <div class="stat"><div class="stat-ico ic-blue"><i class="bi bi-people"></i></div><div><div class="stat-val">@users.Count()</div><div class="stat-lbl">إجمالي المستخدمين</div></div></div>
    <div class="stat"><div class="stat-ico ic-purple"><i class="bi bi-star"></i></div><div><div class="stat-val">@users.Count(u => u.Roles.Contains("SuperAdmin"))</div><div class="stat-lbl">مدراء النظام</div></div></div>
    <div class="stat"><div class="stat-ico ic-amber"><i class="bi bi-person-gear"></i></div><div><div class="stat-val">@users.Count(u => u.Roles.Contains("Admin"))</div><div class="stat-lbl">المسؤولون</div></div></div>
    <div class="stat"><div class="stat-ico ic-green"><i class="bi bi-person-badge"></i></div><div><div class="stat-val">@users.Count(u => u.Roles.Contains("Employee"))</div><div class="stat-lbl">الأعوان</div></div></div>
</div>

<div class="card">
    <div class="card-header">
        <h5><i class="bi bi-table"></i> قائمة المستخدمين</h5>
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input class="search-input" placeholder="بحث بالاسم أو البريد..." @bind="searchTerm" @bind:event="oninput" />
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loading-wrap"><div class="spinner"></div><span style="color:var(--text3);font-size:.85rem;">جاري التحميل...</span></div>
    }
    else if (!filtered.Any())
    {
        <div class="empty"><i class="bi bi-people"></i><p>لا يوجد مستخدمون</p></div>
    }
    else
    {
        <div class="tbl-wrap">
            <table>
                <thead>
                    <tr><th>#</th><th>المستخدم</th><th>البريد الإلكتروني</th><th>الدور</th><th>الإجراءات</th></tr>
                </thead>
                <tbody>
                    @foreach (var (u, idx) in filtered.Select((u, i) => (u, i + 1)))
                    {
                        <tr>
                            <td style="color:var(--text3);font-size:.78rem;">@idx</td>
                            <td>
                                <div style="display:flex;align-items:center;gap:.65rem;">
                                    <div class="user-avatar" style="background:@AvatarColor(u.Roles);">
                                        <span style="color:#fff;">@(u.FullName?.Length > 0 ? u.FullName[0].ToString() : "؟")</span>
                                    </div>
                                    <span style="font-weight:600;color:var(--text1);">@(string.IsNullOrEmpty(u.FullName) ? (u.Email?.Split('@')[0] ?? "Utilisateur") : u.FullName)</span>
                                </div>
                            </td>
                            <td>@u.Email</td>
                            <td>
                                <div style="display:flex;flex-wrap:wrap;gap:.3rem;">
                                    @foreach (var role in u.Roles)
                                    {
                                        <span class="role-chip @RoleClass(role)">
                                            <i class="bi @RoleIcon(role)"></i>@RoleAr(role)
                                        </span>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="action-btns">
                                    <button class="btn btn-danger-ghost btn-sm" @onclick="() => OpenDelete(u)" title="حذف">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Modal: Create User -->
@if (showForm)
{
    <div class="backdrop" @onclick="CloseForm">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="mh">
                <h5><i class="bi bi-person-plus"></i>إضافة مستخدم جديد</h5>
                <button class="mbtn-close" @onclick="CloseForm"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="mb">
                @if (!string.IsNullOrEmpty(formMsg))
                {
                    <div class="alert @(formSuccess ? "alert-success" : "alert-danger")">
                        <i class="bi @(formSuccess ? "bi-check-circle" : "bi-exclamation-circle")"></i>@formMsg
                    </div>
                }
                <div class="row2">
                    <div class="fg"><label><span class="req">*</span>الاسم</label><input class="fc" placeholder="الاسم الأول" @bind="fFirstName" /></div>
                    <div class="fg"><label><span class="req">*</span>اللقب</label><input class="fc" placeholder="القب" @bind="fLastName" /></div>
                </div>
                <div class="fg"><label><span class="req">*</span>البريد الإلكتروني</label><input class="fc" type="email" placeholder="user@elain.dz" @bind="fEmail" /></div>
                <div class="fg">
                    <label><span class="req">*</span>الدور (الصلاحية)</label>
                    <select class="fc" @bind="fRole">
                        <option value="SuperAdmin">⭐ مدير النظام الأعلى (SuperAdmin)</option>
                        <option value="Admin">🔵 مسؤول (Admin)</option>
                        <option value="Manager">🟢 مدير مصلحة (Manager)</option>
                        <option value="Employee">⚪ عون إداري (Employee)</option>
                    </select>
                </div>
                <div class="fg">
                    <label><span class="req">*</span>كلمة المرور</label>
                    <input class="fc" type="password" placeholder="••••••••" @bind="fPassword" />
                    <p class="pw-hint">يجب أن تحتوي على 8 أحرف على الأقل، حرف كبير، حرف صغير، رقم ورمز.</p>
                </div>
                <div class="fg">
                    <label><span class="req">*</span>تأكيد كلمة المرور</label>
                    <input class="fc" type="password" placeholder="••••••••" @bind="fConfirmPassword" />
                </div>
            </div>
            <div class="mf">
                <button class="btn btn-ghost" @onclick="CloseForm">إلغاء</button>
                <button class="btn btn-primary" @onclick="SaveUser" disabled="@(isSaving || formSuccess)">
                    @if (isSaving) { <span class="spinner" style="width:16px;height:16px;border-width:2px;"></span> } else { <i class="bi bi-person-check"></i> }
                    إنشاء الحساب
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal: Confirm Delete -->
@if (showDelete)
{
    <div class="backdrop" @onclick="() => showDelete = false">
        <div class="modal" style="max-width:400px;" @onclick:stopPropagation="true">
            <div class="mb" style="padding-top:1.75rem;text-align:center;">
                <div class="conf-icon"><i class="bi bi-person-x"></i></div>
                <div class="conf-title">حذف المستخدم</div>
                <div class="conf-desc">
                    هل أنت متأكد من حذف حساب <strong>"@deleteTarget?.FullName"</strong>؟<br />
                    لا يمكن التراجع عن هذه العملية.
                </div>
            </div>
            <div class="mf">
                <button class="btn btn-ghost" @onclick="() => showDelete = false">إلغاء</button>
                <button class="btn btn-danger" @onclick="ConfirmDelete" disabled="@isSaving">
                    @if (isSaving) { <span class="spinner" style="width:16px;height:16px;border-width:2px;"></span> } else { <i class="bi bi-trash3"></i> } حذف الحساب
                </button>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(toast))
{
    <div style="position:fixed;bottom:1.5rem;left:1.5rem;z-index:2000;background:#0f172a;color:#fff;padding:.8rem 1.2rem;border-radius:12px;display:flex;align-items:center;gap:.6rem;font-size:.875rem;box-shadow:0 8px 24px rgba(0,0,0,.25);animation:fi .25s;">
        <i class="bi bi-check-circle-fill" style="color:var(--success);"></i>@toast
    </div>
}

@code {
    private IEnumerable<UserDto> users = Enumerable.Empty<UserDto>();
    private string searchTerm = "";
    private bool isLoading = true, showForm, showDelete, isSaving, formSuccess;
    private UserDto? deleteTarget;
    private string fFirstName = "", fLastName = "", fEmail = "", fPassword = "", fConfirmPassword = "", fRole = "Employee";
    private string formMsg = "", toast = "";

    private IEnumerable<UserDto> filtered =>
        string.IsNullOrWhiteSpace(searchTerm) ? users
        : users.Where(u =>
            (u.FullName ?? "").Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            (u.Email ?? "").Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        var r = await UserService.GetAllAsync();
        users = r?.Data ?? Enumerable.Empty<UserDto>();
        isLoading = false;
    }

    private void OpenCreate() { fFirstName = fLastName = fEmail = fPassword = fConfirmPassword = formMsg = ""; fRole = "Employee"; formSuccess = false; showForm = true; }
    private void OpenDelete(UserDto u) { deleteTarget = u; showDelete = true; }
    private void CloseForm() { showForm = false; formMsg = ""; }

    private async Task SaveUser()
    {
        if (string.IsNullOrWhiteSpace(fFirstName) || string.IsNullOrWhiteSpace(fLastName) || string.IsNullOrWhiteSpace(fEmail) || string.IsNullOrWhiteSpace(fPassword))
        { formMsg = "يجب تعبئة جميع الحقول."; return; }
        if (fPassword != fConfirmPassword) { formMsg = "كلمتا المرور غير متطابقتان."; return; }
        if (fPassword.Length < 8) { formMsg = "كلمة المرور يجب أن لا تقل عن 8 أحرف."; return; }

        isSaving = true; formMsg = "";
        var dto = new RegisterDto
        {
            FirstName = fFirstName, LastName = fLastName,
            Email = fEmail, Password = fPassword, 
            Role = fRole
        };
        var r = await UserService.RegisterAsync(dto);
        isSaving = false;
        if (r?.Succeeded == true) { formMsg = "تم إنشاء الحساب بنجاح! ✅"; formSuccess = true; await LoadAsync(); ShowToast("تم إنشاء حساب المستخدم بنجاح"); }
        else formMsg = r?.Message ?? r?.Errors.FirstOrDefault() ?? "فشل إنشاء الحساب.";
    }

    private async Task ConfirmDelete()
    {
        if (deleteTarget == null) return;
        isSaving = true;
        var ok = await UserService.DeleteAsync(deleteTarget.Id);
        isSaving = false; showDelete = false;
        if (ok) { await LoadAsync(); ShowToast("تم حذف المستخدم بنجاح"); }
    }

    private string AvatarColor(IEnumerable<string> roles)
    {
        if (roles.Contains("SuperAdmin")) return "linear-gradient(135deg,#7c3aed,#a78bfa)";
        if (roles.Contains("Admin"))      return "linear-gradient(135deg,#0369a1,#38bdf8)";
        if (roles.Contains("Manager"))    return "linear-gradient(135deg,#059669,#34d399)";
        return "linear-gradient(135deg,#475569,#94a3b8)";
    }

    private string RoleClass(string role) => role switch
    {
        "SuperAdmin" => "r-superadmin",
        "Admin"      => "r-admin",
        "Manager"    => "r-manager",
        _            => "r-employee"
    };

    private string RoleIcon(string role) => role switch
    {
        "SuperAdmin" => "bi-star-fill",
        "Admin"      => "bi-shield-check",
        "Manager"    => "bi-person-gear",
        _            => "bi-person"
    };

    private string RoleAr(string role) => role switch
    {
        "SuperAdmin" => "مدير النظام",
        "Admin"      => "مسؤول",
        "Manager"    => "مدير مصلحة",
        "Employee"   => "عون إداري",
        _            => role
    };

    private async void ShowToast(string msg) { toast = msg; StateHasChanged(); await Task.Delay(3000); toast = ""; StateHasChanged(); }
}
