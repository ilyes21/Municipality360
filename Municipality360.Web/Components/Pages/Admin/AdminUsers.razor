@page "/admin/usersfsd"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@layout Municipality360.Web.Components.Layout.MainLayout

<PageTitle>المستخدمون - Municipality360</PageTitle>

<style>
    .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;}
    .page-title{font-size:1.35rem;font-weight:800;color:#0f172a;margin:0;}
    .page-sub{font-size:.8rem;color:#94a3b8;margin-top:.2rem;}
    .btn-add{display:flex;align-items:center;gap:.5rem;padding:.55rem 1.1rem;background:linear-gradient(135deg,#7c3aed,#a855f7);color:#fff;border:none;border-radius:10px;font-family:'Tajawal',sans-serif;font-size:.88rem;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(124,58,237,.3);transition:all .2s;}
    .btn-add:hover{transform:translateY(-1px);}
    .stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1rem;margin-bottom:1.5rem;}
    .stat-card{background:#fff;border-radius:12px;padding:1rem 1.2rem;box-shadow:0 1px 6px rgba(0,0,0,.06);border:1px solid #f1f5f9;}
    .stat-val{font-size:1.6rem;font-weight:800;}
    .stat-lbl{font-size:.73rem;color:#94a3b8;margin-top:.15rem;}
    .search-bar{display:flex;gap:.75rem;margin-bottom:1.2rem;}
    .search-wrap{position:relative;flex:1;}
    .search-input{width:100%;height:40px;padding:0 1rem 0 2.5rem;border:1.5px solid #e2e8f0;border-radius:10px;font-family:'Tajawal',sans-serif;font-size:.88rem;outline:none;background:#fff;}
    .search-input:focus{border-color:#7c3aed;box-shadow:0 0 0 3px rgba(124,58,237,.1);}
    .search-icon{position:absolute;right:10px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.9rem;pointer-events:none;}

    .users-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;}
    .user-card{background:#fff;border-radius:14px;padding:1.4rem;box-shadow:0 1px 8px rgba(0,0,0,.07);border:1px solid #f1f5f9;transition:all .2s;position:relative;}
    .user-card:hover{box-shadow:0 4px 18px rgba(0,0,0,.1);transform:translateY(-2px);}
    .user-card-header{display:flex;align-items:flex-start;gap:.9rem;margin-bottom:1rem;}
    .user-avatar{width:46px;height:46px;border-radius:13px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1rem;font-weight:700;flex-shrink:0;}
    .avatar-superadmin{background:linear-gradient(135deg,#f59e0b,#f97316);}
    .avatar-admin{background:linear-gradient(135deg,#7c3aed,#a855f7);}
    .avatar-manager{background:linear-gradient(135deg,#0369a1,#0ea5e9);}
    .avatar-employee{background:linear-gradient(135deg,#16a34a,#22c55e);}
    .avatar-user{background:linear-gradient(135deg,#64748b,#94a3b8);}
    .user-card-name{font-weight:700;color:#0f172a;font-size:.95rem;line-height:1.2;}
    .user-card-email{font-size:.75rem;color:#94a3b8;margin-top:.2rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:170px;}
    .roles-wrap{display:flex;flex-wrap:wrap;gap:.25rem;margin-bottom:.85rem;}
    .role-tag{display:inline-flex;align-items:center;gap:.3rem;border-radius:6px;padding:.2rem .6rem;font-size:.72rem;font-weight:700;}
    .role-superadmin{background:linear-gradient(135deg,#fef3c7,#fde68a);color:#92400e;border:1px solid #fcd34d;}
    .role-admin{background:#ede9fe;color:#5b21b6;border:1px solid #c4b5fd;}
    .role-manager{background:#e0f2fe;color:#0369a1;border:1px solid #7dd3fc;}
    .role-employee{background:#dcfce7;color:#15803d;border:1px solid #86efac;}
    .role-user{background:#f1f5f9;color:#475569;border:1px solid #cbd5e1;}
    .user-card-actions{display:flex;gap:.4rem;padding-top:.9rem;border-top:1px solid #f1f5f9;}
    .me-badge{position:absolute;top:.75rem;left:.75rem;background:#dcfce7;color:#15803d;border-radius:99px;padding:.15rem .55rem;font-size:.65rem;font-weight:700;}
    .btn-sm{display:inline-flex;align-items:center;gap:.35rem;padding:.38rem .75rem;border-radius:8px;font-family:'Tajawal',sans-serif;font-size:.78rem;font-weight:600;cursor:pointer;border:none;transition:all .15s;}
    .btn-delete-sm{background:#fef2f2;color:#dc2626;border:1px solid #fecaca;}.btn-delete-sm:hover{background:#fee2e2;}

    .modal-back{position:fixed;inset:0;background:rgba(0,0,0,.45);backdrop-filter:blur(3px);z-index:800;display:flex;align-items:center;justify-content:center;padding:1rem;}
    .modal-box{background:#fff;border-radius:16px;padding:1.75rem;width:100%;max-width:460px;box-shadow:0 20px 60px rgba(0,0,0,.18);animation:modal-in .22s cubic-bezier(.34,1.56,.64,1);}
    @@keyframes modal-in{from{opacity:0;transform:scale(.93)}to{opacity:1;transform:scale(1)}}
    .modal-title{font-size:1.05rem;font-weight:800;color:#0f172a;margin-bottom:1.2rem;display:flex;align-items:center;gap:.6rem;}
    .form-group{margin-bottom:1rem;}
    .form-label{display:block;font-size:.8rem;font-weight:600;color:#374151;margin-bottom:.4rem;}
    .form-control{width:100%;height:42px;padding:0 .85rem;border:1.5px solid #e2e8f0;border-radius:10px;font-family:'Tajawal',sans-serif;font-size:.88rem;outline:none;transition:border-color .2s;background:#fff;}
    .form-control:focus{border-color:#7c3aed;box-shadow:0 0 0 3px rgba(124,58,237,.1);}
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;}
    .modal-footer{display:flex;gap:.75rem;justify-content:flex-end;margin-top:1.3rem;}
    .btn-cancel{padding:.55rem 1.1rem;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:9px;color:#374151;font-family:'Tajawal',sans-serif;font-size:.86rem;font-weight:600;cursor:pointer;}
    .btn-cancel:hover{background:#e2e8f0;}
    .btn-save{padding:.55rem 1.3rem;background:linear-gradient(135deg,#7c3aed,#a855f7);border:none;border-radius:9px;color:#fff;font-family:'Tajawal',sans-serif;font-size:.86rem;font-weight:700;cursor:pointer;box-shadow:0 3px 10px rgba(124,58,237,.3);}
    .btn-save:disabled{opacity:.6;cursor:not-allowed;}
    .confirm-icon{width:52px;height:52px;border-radius:50%;background:#fef2f2;display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#ef4444;margin:0 auto 1rem;}
    .confirm-msg{text-align:center;color:#64748b;font-size:.88rem;line-height:1.6;margin-bottom:1.3rem;}
    .pwd-hint{font-size:.73rem;color:#94a3b8;margin-top:.3rem;}
    .role-picker{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.3rem;}
    .role-chip{padding:.4rem .85rem;border-radius:8px;border:1.5px solid #e2e8f0;font-family:'Tajawal',sans-serif;font-size:.82rem;font-weight:600;cursor:pointer;transition:all .15s;color:#64748b;background:#f8fafc;}
    .role-chip.sel-SuperAdmin{background:linear-gradient(135deg,#fef3c7,#fde68a);color:#92400e;border-color:#fcd34d;}
    .role-chip.sel-Admin{background:#ede9fe;color:#5b21b6;border-color:#c4b5fd;}
    .role-chip.sel-Manager{background:#e0f2fe;color:#0369a1;border-color:#7dd3fc;}
    .role-chip.sel-Employee{background:#dcfce7;color:#15803d;border-color:#86efac;}
    .alert-err{background:#fef2f2;border:1px solid #fecaca;border-radius:9px;padding:.65rem .9rem;color:#dc2626;font-size:.83rem;margin-bottom:.9rem;display:flex;align-items:center;gap:.5rem;}
    .alert-ok{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:9px;padding:.65rem .9rem;color:#16a34a;font-size:.83rem;margin-bottom:.9rem;display:flex;align-items:center;gap:.5rem;}
    .loading-wrap{display:flex;align-items:center;justify-content:center;padding:3rem;color:#94a3b8;gap:.75rem;}
    .empty-wrap{text-align:center;padding:3rem;color:#94a3b8;}
</style>

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-shield-lock me-2" style="color:#7c3aed;"></i>المستخدمون والصلاحيات</h1>
        <div class="page-sub">إدارة حسابات المستخدمين وأدوارهم في النظام</div>
    </div>
    @if (IsSuperAdmin)
    {
        <button class="btn-add" @onclick="OpenAdd"><i class="bi bi-person-plus"></i> إضافة مستخدم</button>
    }
</div>

@if (!string.IsNullOrEmpty(SuccessMsg)) { <div class="alert-ok"><i class="bi bi-check-circle-fill"></i>@SuccessMsg</div> }
@if (!string.IsNullOrEmpty(ErrorMsg))   { <div class="alert-err"><i class="bi bi-exclamation-circle-fill"></i>@ErrorMsg</div> }

<div class="stats-row">
    <div class="stat-card"><div class="stat-val" style="color:#7c3aed;">@(Users?.Count() ?? 0)</div><div class="stat-lbl">إجمالي المستخدمين</div></div>
    <div class="stat-card"><div class="stat-val" style="color:#f59e0b;">@(Users?.Count(u => u.Roles.Contains("SuperAdmin")) ?? 0)</div><div class="stat-lbl">مدراء النظام</div></div>
    <div class="stat-card"><div class="stat-val" style="color:#a855f7;">@(Users?.Count(u => u.Roles.Contains("Admin")) ?? 0)</div><div class="stat-lbl">المسؤولون</div></div>
    <div class="stat-card"><div class="stat-val" style="color:#0ea5e9;">@(Users?.Count(u => u.Roles.Contains("Manager")) ?? 0)</div><div class="stat-lbl">المشرفون</div></div>
</div>

<div class="search-bar">
    <div class="search-wrap">
        <input class="search-input" placeholder="بحث بالاسم أو البريد الإلكتروني..."
               @bind="SearchTerm" @bind:event="oninput" />
        <i class="bi bi-search search-icon"></i>
    </div>
</div>

@if (IsLoading)
{
    <div class="loading-wrap"><div class="spinner-border spinner-border-sm" style="color:#7c3aed;"></div><span>جاري التحميل...</span></div>
}
else if (!Filtered.Any())
{
    <div class="empty-wrap"><i class="bi bi-people" style="font-size:2.5rem;display:block;margin-bottom:.5rem;color:#94a3b8;"></i><div>لا يوجد مستخدمون</div></div>
}
else
{
    <div class="users-grid">
        @foreach (var u in Filtered)
        {
            var isMe = u.Email == CurrentUserEmail;
            <div class="user-card">
                @if (isMe) { <div class="me-badge"><i class="bi bi-person-check-fill me-1"></i>حسابي</div> }
                <div class="user-card-header">
                    <div class="user-avatar @GetAvatarClass(u.Roles)">@GetInitials(u.FirstName, u.LastName)</div>
                    <div style="flex:1;overflow:hidden;">
                        <div class="user-card-name">@u.FullName</div>
                        <div class="user-card-email" title="@u.Email">@u.Email</div>
                    </div>
                </div>
                <div class="roles-wrap">
                    @foreach (var role in u.Roles)
                    { <span class="role-tag @GetRoleClass(role)"><i class="bi @GetRoleIcon(role)"></i> @GetRoleAr(role)</span> }
                </div>
                @if (IsSuperAdmin && !isMe)
                {
                    <div class="user-card-actions">
                        <button class="btn-sm btn-delete-sm" @onclick="() => OpenDelete(u)">
                            <i class="bi bi-trash3"></i> حذف الحساب
                        </button>
                    </div>
                }
            </div>
        }
    </div>
}

@* ── ADD USER MODAL ── *@
@if (ShowForm)
{
    <div class="modal-back" @onclick="CloseForm">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-title"><i class="bi bi-person-plus" style="color:#7c3aed;"></i>إضافة مستخدم جديد</div>
            @if (!string.IsNullOrEmpty(FormError)) { <div class="alert-err"><i class="bi bi-exclamation-circle-fill"></i>@FormError</div> }
            <div class="form-grid">
                <div class="form-group"><label class="form-label">الاسم *</label><input class="form-control" @bind="RegFirst" placeholder="الاسم" /></div>
                <div class="form-group"><label class="form-label">اللقب *</label><input class="form-control" @bind="RegLast" placeholder="اللقب" /></div>
            </div>
            <div class="form-group"><label class="form-label">البريد الإلكتروني *</label><input class="form-control" type="email" @bind="RegEmail" placeholder="user@municipality360.dz" /></div>
            <div class="form-group">
                <label class="form-label">كلمة المرور *</label>
                <input class="form-control" type="password" @bind="RegPassword" placeholder="••••••••" />
                <div class="pwd-hint">8 أحرف على الأقل، يشمل: حرف كبير، رقم، رمز خاص.</div>
            </div>
            <div class="form-group">
                <label class="form-label">الدور *</label>
                <div class="role-picker">
                    @foreach (var role in new[]{"SuperAdmin","Admin","Manager","Employee"})
                    {
                        var r = role;
                        <button type="button" class="role-chip @(RegRole == r ? "sel-"+r : "")"
                                @onclick="() => RegRole = r">
                            <i class="bi @GetRoleIcon(r) me-1"></i>@GetRoleAr(r)
                        </button>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseForm">إلغاء</button>
                <button class="btn-save" @onclick="SaveUser" disabled="@IsSaving">
                    @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1" style="width:.8rem;height:.8rem;border-width:2px;"></span> }
                    إنشاء الحساب
                </button>
            </div>
        </div>
    </div>
}

@* ── DELETE CONFIRM ── *@
@if (ShowDelete)
{
    <div class="modal-back" @onclick="() => ShowDelete = false">
        <div class="modal-box" @onclick:stopPropagation="true" style="max-width:380px;">
            <div class="confirm-icon"><i class="bi bi-person-dash"></i></div>
            <div class="modal-title" style="justify-content:center;">تأكيد حذف الحساب</div>
            <div class="confirm-msg">
                هل أنت متأكد من حذف حساب<br/><strong>@SelectedUser?.FullName</strong>؟<br/>
                <span style="color:#ef4444;font-size:.8rem;">لا يمكن التراجع عن هذا الإجراء.</span>
            </div>
            <div class="modal-footer" style="justify-content:center;">
                <button class="btn-cancel" @onclick="() => ShowDelete = false">إلغاء</button>
                <button class="btn-save" style="background:linear-gradient(135deg,#dc2626,#ef4444);box-shadow:0 3px 10px rgba(239,68,68,.3);"
                        @onclick="ConfirmDelete" disabled="@IsSaving">
                    @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1" style="width:.8rem;height:.8rem;border-width:2px;"></span> }
                    تأكيد الحذف
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Inject] IUserApiService UserSvc { get; set; } = null!;
    [Inject] AuthenticationStateProvider AuthStateProvider { get; set; } = null!;

    private IEnumerable<UserDto>? Users;
    private bool IsLoading = true, IsSuperAdmin = false, IsSaving = false;
    private string SearchTerm = "", SuccessMsg = "", ErrorMsg = "", FormError = "";
    private string CurrentUserEmail = "";
    private bool ShowForm, ShowDelete;
    private UserDto? SelectedUser;
    private string RegFirst = "", RegLast = "", RegEmail = "", RegPassword = "", RegRole = "Employee";

    private IEnumerable<UserDto> Filtered => Users?.Where(u =>
        string.IsNullOrEmpty(SearchTerm) ||
        u.FullName.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
        u.Email.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase))
        ?? Enumerable.Empty<UserDto>();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user  = state.User;
        CurrentUserEmail = user.FindFirst(ClaimTypes.Email)?.Value
            ?? user.FindFirst("email")?.Value ?? "";
        IsSuperAdmin = user.IsInRole("SuperAdmin");
        await Load();
    }

    private async Task Load()
    {
        IsLoading = true;
        var r = await UserSvc.GetAllAsync();
        Users = r?.Data ?? Enumerable.Empty<UserDto>();
        IsLoading = false;
    }

    private void OpenAdd()
    {
        RegFirst = ""; RegLast = ""; RegEmail = ""; RegPassword = ""; RegRole = "Employee"; FormError = "";
        ShowForm = true;
    }

    private void OpenDelete(UserDto u) { SelectedUser = u; ShowDelete = true; }
    private void CloseForm() { ShowForm = false; FormError = ""; }

    private async Task SaveUser()
    {
        if (string.IsNullOrWhiteSpace(RegFirst))    { FormError = "الاسم مطلوب."; return; }
        if (string.IsNullOrWhiteSpace(RegLast))     { FormError = "اللقب مطلوب."; return; }
        if (string.IsNullOrWhiteSpace(RegEmail))    { FormError = "البريد الإلكتروني مطلوب."; return; }
        if (string.IsNullOrWhiteSpace(RegPassword)) { FormError = "كلمة المرور مطلوبة (8 أحرف على الأقل)."; return; }
        IsSaving = true; FormError = "";
        var dto = new RegisterDto { FirstName=RegFirst, LastName=RegLast, Email=RegEmail, Password=RegPassword, Role=RegRole };
        var r = await UserSvc.RegisterAsync(dto);
        IsSaving = false;
        if (r?.Succeeded == true)
        {
            SuccessMsg = "✓ تم إنشاء الحساب بنجاح."; CloseForm(); await Load();
            await Task.Delay(3500); SuccessMsg = ""; StateHasChanged();
        }
        else FormError = r?.Errors?.FirstOrDefault() ?? "حدث خطأ أثناء إنشاء الحساب.";
    }

    private async Task ConfirmDelete()
    {
        if (SelectedUser == null) return;
        IsSaving = true;
        var ok = await UserSvc.DeleteAsync(SelectedUser.Id);
        IsSaving = false; ShowDelete = false;
        if (ok) { SuccessMsg = "تم حذف الحساب بنجاح."; await Load(); await Task.Delay(3000); SuccessMsg = ""; StateHasChanged(); }
        else ErrorMsg = "فشل الحذف. تأكد من صلاحياتك.";
    }

    private string GetInitials(string f, string l) =>
        $"{(f.Length>0?f[0]:' ')}{(l.Length>0?l[0]:' ')}".Trim().ToUpper();

    private string GetAvatarClass(IList<string> roles) =>
        roles.Contains("SuperAdmin") ? "avatar-superadmin" :
        roles.Contains("Admin")      ? "avatar-admin" :
        roles.Contains("Manager")    ? "avatar-manager" :
        roles.Contains("Employee")   ? "avatar-employee" : "avatar-user";

    private string GetRoleClass(string r) =>
        r == "SuperAdmin" ? "role-superadmin" :
        r == "Admin"      ? "role-admin" :
        r == "Manager"    ? "role-manager" :
        r == "Employee"   ? "role-employee" : "role-user";

    private string GetRoleIcon(string r) =>
        r == "SuperAdmin" ? "bi-star-fill" :
        r == "Admin"      ? "bi-shield-fill" :
        r == "Manager"    ? "bi-person-gear" :
        r == "Employee"   ? "bi-person-badge" : "bi-person";

    private string GetRoleAr(string r) =>
        r == "SuperAdmin" ? "مدير النظام الأعلى" :
        r == "Admin"      ? "مسؤول" :
        r == "Manager"    ? "مشرف" :
        r == "Employee"   ? "موظف" : "مستخدم";
}
