@code {
    [Parameter] public int? Id { get; set; }

    // ── State ──────────────────────────────────────────────────────
    private PagedResult<CourrierEntrantDto>?  _result;
    private CourrierEntrantDetailDto?         _detail;
    private BOStatsDto?                       _stats;
    private CourrierEntrantFilterDto          _filter  = new() { PageNumber = 1, PageSize = 15 };
    private bool                              _loading;

    // Form
    private CreateCourrierEntrantDto _dto   = new() { DateReception = DateTime.Today, DateCourrier = DateTime.Today };
    private int?                     _editId;
    private bool                     _showForm, _saving, _v;
    private string?                  _formError, _formSuccess;
    private List<IBrowserFile>       _selectedFiles = new();

    // Contact search
    private BOContactDto?            _selectedContact;
    private string                   _contactSearch   = "";
    private List<BOContactDto>       _contactResults  = new();
    private CancellationTokenSource? _contactCts;

    // New contact modal
    private bool                 _showNewContact;
    private CreateBOContactDto   _newContactDto  = new() { TypeContact = "Personne" };
    private string?              _newContactError;

    // Modals
    private bool _showAcheminer, _showAffecter, _showArchiver, _showUploadPJ;
    private bool _v2;
    private AcheminerCourrierDto     _acheminerDto = new() { TypeAction = "PourAction" };
    private AffecterCourrierEntrantDto _affecterDto = new();
    private ArchiversCourrierDto     _archiverDto  = new() { DureeConservationAns = 10, Classification = "Courant" };
    private List<IBrowserFile>       _pjFiles      = new();
    private string                   _pjTypePiece  = "Annexe";
    private string?                  _pjError;

    // Services list for dropdowns
    private List<ServiceItemDto> _services = new();

    private int TotalPages => _result == null ? 1
        : (int)Math.Ceiling(_result.TotalCount / (double)_filter.PageSize);

    // ── Lifecycle ──────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await LoadServicesAsync();
        await LoadAsync();
        await LoadStatsAsync();
        if (Id.HasValue) await OpenDetail(Id.Value);
    }

    // ── Chargement ─────────────────────────────────────────────────
    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        _result  = await Api.GetPagedAsync(_filter);
        _loading = false;
    }
    private async Task LoadStatsAsync() => _stats = await Api.GetStatsAsync();
    private async Task LoadServicesAsync()
    {
        try { _services = await Api.GetServicesAsync() ?? new(); }
        catch { _services = new(); }
    }

    // ── Contact Search ─────────────────────────────────────────────
    private async Task OnContactSearch(ChangeEventArgs e)
    {
        _contactSearch = e.Value?.ToString() ?? "";
        _contactCts?.Cancel();
        _contactCts = new();
        try
        {
            await Task.Delay(350, _contactCts.Token);
            if (_contactSearch.Length >= 2)
            {
                var results = await ContactApi.SearchAsync(_contactSearch);
                _contactResults = results ?? new();
            }
            else _contactResults.Clear();
            StateHasChanged();
        }
        catch (OperationCanceledException) { }
        catch { _contactResults.Clear(); }
    }

    private void SelectContact(BOContactDto contact)
    {
        _selectedContact          = contact;
        _dto.ExpediteurContactId  = contact.Id;
        _dto.ExpediteurLibreNom   = null;
        _contactResults.Clear();
        _contactSearch = "";
    }

    private void ClearContact()
    {
        _selectedContact         = null;
        _dto.ExpediteurContactId = null;
        _contactSearch           = "";
    }

    // ── New Contact ────────────────────────────────────────────────
    private async Task SaveNewContact()
    {
        if (string.IsNullOrEmpty(_newContactDto.TypeContact)) { _newContactError = "اختر نوع الجهة."; return; }
        _saving = true; _newContactError = null;
        try
        {
            var created = await ContactApi.CreateAsync(_newContactDto);
            if (created != null)
            {
                SelectContact(created);
                _showNewContact = false;
                _newContactDto  = new() { TypeContact = "Personne" };
            }
            else _newContactError = "حدث خطأ أثناء الحفظ.";
        }
        finally { _saving = false; }
    }

    // ── Form Navigation ────────────────────────────────────────────
    private void OpenNew()
    {
        _dto           = new() { DateReception = DateTime.Today, DateCourrier = DateTime.Today };
        _editId        = null; _showForm = true; _v = false;
        _selectedContact = null; _contactSearch = ""; _contactResults.Clear();
        _selectedFiles.Clear(); _formError = _formSuccess = null;
    }

    private async Task OpenEdit(int id)
    {
        var detail = await Api.GetByIdAsync(id);
        if (detail == null) return;
        _dto = new CreateCourrierEntrantDto
        {
            DateCourrier          = detail.DateCourrier,
            DateReception         = detail.DateReception,
            ObjetCourrier         = detail.ObjetCourrier,
            TypeDocument          = detail.TypeDocument,
            ModeReception         = detail.ModeReception,
            ExpediteurContactId   = detail.ExpediteurContactId,
            ExpediteurLibreNom    = detail.ExpediteurNom,
            Priorite              = detail.Priorite,
            EstConfidentiel       = detail.EstConfidentiel,
            NecessiteReponse      = detail.NecessiteReponse,
            DelaiReponse          = detail.DelaiReponse,
            Observation           = detail.Observation,
            NumeroExterne         = detail.NumeroExterne,
            NombrePages           = detail.NombrePages,
            ServiceDestinataireId = detail.ServiceDestinataireId,
            DossierId             = detail.DossierId,
            NumeroRecommande      = detail.NumeroRecommande,
            CategorieId           = detail.CategorieId
        };
        // Restore contact display
        if (detail.ExpediteurContactId.HasValue)
            _selectedContact = new BOContactDto { Id = detail.ExpediteurContactId.Value, NomComplet = detail.ExpediteurNom ?? "" };
        else _selectedContact = null;

        _editId = id; _showForm = true; _v = false;
        _formError = _formSuccess = null; _detail = null;
    }

    private void BackToList()
    {
        _showForm = false; _editId = null; _formError = _formSuccess = null;
        _selectedFiles.Clear(); _selectedContact = null;
        if (Id.HasValue) Nav.NavigateTo("/bureau/incoming");
    }

    // ── Detail drawer ──────────────────────────────────────────────
    private async Task OpenDetail(int id)
    {
        _detail        = await Api.GetByIdAsync(id);
        _showAcheminer = false; _showAffecter  = false;
        _showArchiver  = false; _showUploadPJ  = false;
    }
    private void CloseDetail() => _detail = null;

    // ── Sauvegarde ─────────────────────────────────────────────────
    private async Task SaveAsync()
    {
        _v = true;
        if (_dto.DateCourrier == default || _dto.DateReception == default || string.IsNullOrEmpty(_dto.ObjetCourrier))
        { _formError = "الرجاء ملء الحقول الإلزامية المُشار إليها بـ *."; return; }

        _saving = true; _formError = null;
        try
        {
            if (_editId.HasValue)
            {
                var upd = new UpdateCourrierEntrantDto
                {
                    ObjetCourrier         = _dto.ObjetCourrier,
                    TypeDocument          = _dto.TypeDocument,
                    CategorieId           = _dto.CategorieId,
                    DossierId             = _dto.DossierId,
                    ExpediteurContactId   = _dto.ExpediteurContactId,
                    ExpediteurLibreNom    = _selectedContact == null ? _dto.ExpediteurLibreNom : null,
                    ServiceDestinataireId = _dto.ServiceDestinataireId,
                    Priorite              = _dto.Priorite,
                    EstConfidentiel       = _dto.EstConfidentiel,
                    NecessiteReponse      = _dto.NecessiteReponse,
                    DelaiReponse          = _dto.DelaiReponse,
                    NombrePages           = _dto.NombrePages,
                    NumeroRecommande      = _dto.NumeroRecommande,
                    Observation           = _dto.Observation
                };
                var res = await Api.ModifierAsync(_editId.Value, upd);
                if (res != null) { _formSuccess = "تم التعديل بنجاح."; _showForm = false; await LoadAsync(); await LoadStatsAsync(); }
                else _formError = "حدث خطأ أثناء التعديل.";
            }
            else
            {
                // Set contact id from selected
                if (_selectedContact != null) _dto.ExpediteurContactId = _selectedContact.Id;

                CourrierEntrantDetailDto? res;
                if (_selectedFiles.Count > 0)
                    res = await Api.EnregistrerAvecFichiersAsync(_dto, _selectedFiles);
                else
                    res = await Api.EnregistrerAsync(_dto);

                if (res != null)
                {
                    _formSuccess = $"تم تسجيل البريد الوارد بنجاح. رقم الترتيب: {res.NumeroOrdre}";
                    _showForm = false; _selectedFiles.Clear();
                    await LoadAsync(); await LoadStatsAsync();
                }
                else _formError = "حدث خطأ أثناء الحفظ. تحقق من البيانات وأعد المحاولة.";
            }
        }
        finally { _saving = false; }
    }

    // ── Actions ────────────────────────────────────────────────────
    private async Task MarquerTraite(int id)
    {
        await Api.ChangerStatutAsync(id, new ChangerStatutEntrantDto { NouveauStatut = "Traite" });
        await OpenDetail(id); await LoadAsync(); await LoadStatsAsync();
    }

    private void OpenAcheminer() { _acheminerDto = new() { TypeAction = "PourAction" }; _showAcheminer = true; _v2 = false; }
    private async Task ConfirmAcheminer()
    {
        _v2 = true;
        if (_acheminerDto.ServiceRecepteurId == 0) return;
        _saving = true;
        await Api.AcheminerAsync(_detail!.Id, _acheminerDto);
        _showAcheminer = false; await OpenDetail(_detail.Id); await LoadAsync();
        _saving = false;
    }

    private void OpenAffecter() { _affecterDto = new(); _showAffecter = true; _v2 = false; }
    private async Task ConfirmAffecter()
    {
        _v2 = true;
        if (_affecterDto.ServiceDestinataireId == 0) return;
        _saving = true;
        await Api.AffecterAsync(_detail!.Id, _affecterDto);
        _showAffecter = false; await OpenDetail(_detail.Id); await LoadAsync();
        _saving = false;
    }

    private void OpenArchiver() { _archiverDto = new() { DureeConservationAns = 10, Classification = "Courant" }; _showArchiver = true; }
    private async Task ConfirmArchiver()
    {
        _saving = true;
        await Api.ArchiverAsync(_detail!.Id, _archiverDto);
        _showArchiver = false; await OpenDetail(_detail.Id); await LoadAsync(); await LoadStatsAsync();
        _saving = false;
    }

    // ── Upload PJ ──────────────────────────────────────────────────
    private void OpenUploadPJ() { _pjFiles.Clear(); _pjError = null; _showUploadPJ = true; }
    private void OnFilesSelected2(InputFileChangeEventArgs e)
    {
        foreach (var f in e.GetMultipleFiles(10))
        {
            var ext = Path.GetExtension(f.Name).ToLowerInvariant();
            if (ext is ".pdf" or ".png" or ".jpg" or ".jpeg" or ".tiff") _pjFiles.Add(f);
        }
    }
    private void RemoveFile2(int i) => _pjFiles.RemoveAt(i);
    private async Task TriggerFilePicker2() => await JS.InvokeVoidAsync("eval", "document.getElementById('fileInput2').click()");

    private async Task ConfirmUploadPJ()
    {
        if (_pjFiles.Count == 0) return;
        _saving = true; _pjError = null;
        try
        {
            var ok = await Api.UploadPiecesJointesAsync(_detail!.Id, _pjFiles, _pjTypePiece);
            if (ok) { _showUploadPJ = false; _pjFiles.Clear(); await OpenDetail(_detail.Id); }
            else _pjError = "حدث خطأ أثناء رفع الملفات.";
        }
        catch { _pjError = "خطأ في الرفع. تحقق من حجم الملفات والصيغة."; }
        finally { _saving = false; }
    }

    // ── File picker form ───────────────────────────────────────────
    private void OnFilesSelected(InputFileChangeEventArgs e)
    {
        foreach (var f in e.GetMultipleFiles(10))
        {
            var ext = Path.GetExtension(f.Name).ToLowerInvariant();
            if (ext is ".pdf" or ".png" or ".jpg" or ".jpeg" or ".tiff") _selectedFiles.Add(f);
        }
    }
    private void RemoveFile(int i) => _selectedFiles.RemoveAt(i);
    private async Task TriggerFilePicker() => await JS.InvokeVoidAsync("eval", "document.getElementById('fileInput').click()");
    private Task OnFileDrop(DragEventArgs e) => Task.CompletedTask;

    // ── Filter / Pagination ────────────────────────────────────────
    private CancellationTokenSource? _cts;
    private async Task OnSearch()
    {
        _cts?.Cancel(); _cts = new();
        try { await Task.Delay(400, _cts.Token); _filter.PageNumber = 1; await LoadAsync(); } catch { }
    }
    private async Task GoPage(int p) { _filter.PageNumber = p; await LoadAsync(); }
    private async Task ResetFilter() { _filter = new() { PageNumber = 1, PageSize = 15 }; await LoadAsync(); }

    // ── Helpers UI ─────────────────────────────────────────────────
    private static string RowClass(CourrierEntrantDto c)
    {
        var cls = new List<string>();
        if (c.Priorite is "Urgent" or "TresUrgent") cls.Add("tr-urgent");
        if (c.EnRetard) cls.Add("tr-retard");
        if (c.Statut == "Archive") cls.Add("tr-archive");
        return string.Join(" ", cls);
    }

