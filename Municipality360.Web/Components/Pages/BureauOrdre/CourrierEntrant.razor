@page "/bureau/incoming"
@page "/bureau/incoming/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@using Municipality360.Application.DTOs.BureauOrdre
@using Municipality360.Application.Common
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,BureauOrdre")]
@layout Municipality360.Web.Components.Layout.MainLayout

@inject ICourrierEntrantApiService Api
@inject IBOContactApiService ContactApi
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>البريد الوارد — مكتب الضبط</PageTitle>

<style>
/* ═══ BASE ═══ */
.page-header   { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; flex-wrap:wrap; gap:.75rem; }
.page-title    { font-size:1.3rem; font-weight:800; color:#0f172a; margin:0; display:flex; align-items:center; gap:.5rem; }
.page-sub      { font-size:.8rem; color:#94a3b8; margin-top:.2rem; }
.btn           { display:inline-flex; align-items:center; gap:.4rem; padding:.45rem .95rem; border-radius:9px; border:none; cursor:pointer; font-family:'Tajawal',sans-serif; font-size:.85rem; font-weight:600; transition:all .2s; }
.btn-primary   { background:linear-gradient(135deg,#0369a1,#0ea5e9); color:#fff; box-shadow:0 3px 10px rgba(14,165,233,.3); }
.btn-primary:hover { transform:translateY(-1px); }
.btn-secondary { background:#f1f5f9; color:#374151; }
.btn-secondary:hover { background:#e2e8f0; }
.btn-danger    { background:#fee2e2; color:#dc2626; }
.btn-warning   { background:#fef3c7; color:#b45309; }
.btn-success   { background:#dcfce7; color:#15803d; }
.btn-purple    { background:#ede9fe; color:#7c3aed; }
.btn-info      { background:#e0f2fe; color:#0369a1; }
.btn:disabled  { opacity:.5; cursor:not-allowed; transform:none !important; }

/* ═══ STATS BAR ═══ */
.stats-bar { display:grid; grid-template-columns:repeat(auto-fit,minmax(110px,1fr)); gap:.75rem; margin-bottom:1.25rem; }
.stat-card { background:#fff; border-radius:12px; padding:.85rem 1rem; border:1px solid #f1f5f9; box-shadow:0 1px 4px rgba(0,0,0,.06); }
.stat-num  { font-size:1.5rem; font-weight:800; color:#0f172a; line-height:1; }
.stat-lbl  { font-size:.72rem; color:#64748b; margin-top:.2rem; }
.stat-card.urgent .stat-num { color:#dc2626; }
.stat-card.retard .stat-num { color:#b45309; }
.stat-card.traite .stat-num { color:#15803d; }

/* ═══ FILTERS ═══ */
.filters-bar { display:flex; gap:.6rem; flex-wrap:wrap; margin-bottom:1.2rem; align-items:center; background:#fff; padding:.85rem 1rem; border-radius:12px; border:1px solid #f1f5f9; }
.search-wrap { position:relative; flex:1; min-width:200px; }
.search-input { width:100%; height:38px; padding:0 1rem 0 2.5rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.86rem; outline:none; transition:border-color .2s; background:#fff; }
.search-input:focus { border-color:#0ea5e9; }
.search-icon  { position:absolute; right:10px; top:50%; transform:translateY(-50%); color:#94a3b8; font-size:.9rem; }
select.filter-sel { height:38px; padding:0 .75rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.85rem; outline:none; background:#fff; }
.filter-date { height:38px; padding:0 .6rem; border:1.5px solid #e2e8f0; border-radius:9px; font-size:.85rem; outline:none; background:#fff; }

/* ═══ TABLE ═══ */
.table-card  { background:#fff; border-radius:14px; box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #f1f5f9; overflow:hidden; }
.table-inner { overflow-x:auto; }
table { width:100%; border-collapse:collapse; }
thead tr { background:#f8fafc; border-bottom:2px solid #e2e8f0; }
th { padding:.65rem 1rem; text-align:right; font-size:.73rem; font-weight:700; color:#64748b; white-space:nowrap; }
td { padding:.75rem 1rem; font-size:.84rem; color:#374151; border-bottom:1px solid #f8fafc; vertical-align:middle; }
tbody tr { cursor:pointer; transition:background .15s; }
tbody tr:hover { background:#f0f9ff; }
tbody tr:last-child td { border-bottom:none; }
.tr-urgent  { border-right:3px solid #ef4444 !important; }
.tr-retard  { background:#fff7ed !important; }
.tr-archive { opacity:.7; }

/* ═══ BADGES ═══ */
.badge { display:inline-flex; align-items:center; gap:.25rem; border-radius:99px; padding:.2rem .6rem; font-size:.71rem; font-weight:700; white-space:nowrap; }
.badge-recu       { background:#f3f4f6; color:#6b7280; }
.badge-enregistre { background:#dbeafe; color:#1d4ed8; }
.badge-encours    { background:#fef3c7; color:#b45309; }
.badge-traite     { background:#dcfce7; color:#15803d; }
.badge-archive    { background:#f3f4f6; color:#6b7280; }
.badge-rejete     { background:#fee2e2; color:#dc2626; }
.badge-normal     { background:#e0f2fe; color:#0369a1; }
.badge-urgent     { background:#fee2e2; color:#dc2626; }
.badge-tresurgent { background:#fce7f3; color:#be185d; }
.badge-conf       { background:#fdf4ff; color:#9333ea; }
.badge-retard     { background:#fff7ed; color:#b45309; }

/* ═══ PAGINATION ═══ */
.pagination { display:flex; align-items:center; justify-content:space-between; padding:.85rem 1rem; border-top:1px solid #f1f5f9; flex-wrap:wrap; gap:.5rem; }
.pg-btns { display:flex; gap:.3rem; }
.pg-btn { width:32px; height:32px; border-radius:7px; border:1.5px solid #e2e8f0; background:#fff; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:.82rem; color:#374151; transition:all .15s; }
.pg-btn:hover:not(:disabled) { border-color:#0ea5e9; color:#0ea5e9; }
.pg-btn.active { background:#0ea5e9; border-color:#0ea5e9; color:#fff; }
.pg-btn:disabled { opacity:.4; cursor:not-allowed; }
.pg-info { font-size:.82rem; color:#64748b; }

/* ═══ DRAWER DETAIL ═══ */
.overlay  { position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:500; display:flex; align-items:flex-start; justify-content:flex-end; }
.drawer   { width:min(700px,96vw); height:100vh; background:#fff; box-shadow:-8px 0 50px rgba(0,0,0,.18); display:flex; flex-direction:column; overflow:hidden; animation:slideIn .25s ease; }
@@keyframes slideIn { from{transform:translateX(100%)} to{transform:translateX(0)} }
.drawer-header { padding:1.1rem 1.5rem; border-bottom:1px solid #f1f5f9; display:flex; align-items:center; justify-content:space-between; background:#f8fafc; flex-shrink:0; gap:.75rem; }
.drawer-title  { font-size:1rem; font-weight:700; color:#0f172a; flex:1; }
.drawer-body   { flex:1; overflow-y:auto; padding:1.4rem 1.5rem; display:flex; flex-direction:column; gap:1.25rem; }
.close-btn { background:none; border:none; font-size:1.2rem; cursor:pointer; color:#64748b; }
.close-btn:hover { color:#0f172a; }
.info-grid { display:grid; grid-template-columns:1fr 1fr; gap:.7rem 1.5rem; }
.info-item label { display:block; font-size:.71rem; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:.04em; margin-bottom:.18rem; }
.info-item span  { font-size:.88rem; color:#0f172a; }
.info-item.full  { grid-column:1/-1; }
.section-sep { border:none; border-top:1px solid #f1f5f9; margin:.1rem 0; }
.section-ttl { font-size:.82rem; font-weight:700; color:#374151; display:flex; align-items:center; gap:.4rem; }
.circuit-wrap { display:flex; flex-direction:column; gap:.1rem; }
.c-step { display:flex; gap:.85rem; padding:.65rem 0; border-bottom:1px dashed #f1f5f9; }
.c-step:last-child { border-bottom:none; }
.c-num  { width:28px; height:28px; border-radius:50%; background:#e0f2fe; color:#0369a1; display:flex; align-items:center; justify-content:center; font-size:.75rem; font-weight:700; flex-shrink:0; }
.c-done .c-num   { background:#dcfce7; color:#15803d; }
.c-retour .c-num { background:#fee2e2; color:#dc2626; }
.c-attente .c-num{ background:#fef3c7; color:#b45309; }
.c-body { flex:1; }
.c-title { font-size:.84rem; font-weight:600; color:#0f172a; }
.c-meta  { font-size:.76rem; color:#64748b; margin-top:.15rem; }
.c-instr { font-size:.8rem; color:#374151; background:#f8fafc; border-radius:6px; padding:.3rem .6rem; margin-top:.3rem; }
.pj-list { display:flex; flex-direction:column; gap:.5rem; }
.pj-item { display:flex; align-items:center; gap:.75rem; padding:.6rem .85rem; border-radius:9px; background:#f8fafc; border:1px solid #f1f5f9; }
.pj-icon { font-size:1.3rem; flex-shrink:0; }
.pj-name { flex:1; font-size:.84rem; font-weight:600; color:#374151; }
.pj-meta { font-size:.73rem; color:#94a3b8; }
.action-row { display:flex; gap:.6rem; flex-wrap:wrap; padding-top:.25rem; }

/* ═══ FORM ═══ */
.form-wrap  { max-width:900px; }
.section-card { background:#fff; border-radius:14px; box-shadow:0 1px 8px rgba(0,0,0,.06); border:1px solid #f1f5f9; padding:1.35rem 1.5rem; margin-bottom:1rem; }
.section-card h3 { font-size:.92rem; font-weight:700; color:#0369a1; margin:0 0 1rem; display:flex; align-items:center; gap:.4rem; border-bottom:1px solid #f0f9ff; padding-bottom:.65rem; }
.form-grid  { display:grid; grid-template-columns:1fr 1fr; gap:.85rem 1.25rem; }
.form-group { display:flex; flex-direction:column; gap:.3rem; }
.form-group.full { grid-column:1/-1; }
.form-label { font-size:.8rem; font-weight:700; color:#374151; }
.form-label .req { color:#ef4444; margin-right:.2rem; }
.form-control { height:38px; padding:0 .85rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.88rem; outline:none; transition:border-color .2s; background:#fff; width:100%; box-sizing:border-box; }
.form-control:focus { border-color:#0ea5e9; box-shadow:0 0 0 3px rgba(14,165,233,.1); }
.form-control.invalid { border-color:#ef4444; box-shadow:0 0 0 3px rgba(239,68,68,.1); }
textarea.form-control { height:80px; resize:vertical; padding:.6rem .85rem; }
.form-check  { display:flex; align-items:center; gap:.5rem; cursor:pointer; font-size:.88rem; padding:.5rem 0; }
.form-check input { width:16px; height:16px; cursor:pointer; accent-color:#0ea5e9; }
.form-footer { display:flex; gap:.75rem; justify-content:flex-end; padding-top:1.25rem; border-top:1px solid #f1f5f9; margin-top:.5rem; }

/* Contact search */
.contact-search-wrap { position:relative; }
.contact-results { position:absolute; top:calc(100% + 4px); right:0; left:0; background:#fff; border:1.5px solid #e2e8f0; border-radius:9px; box-shadow:0 8px 25px rgba(0,0,0,.12); z-index:100; max-height:220px; overflow-y:auto; }
.contact-result-item { padding:.6rem .85rem; cursor:pointer; font-size:.85rem; display:flex; align-items:center; gap:.5rem; border-bottom:1px solid #f8fafc; transition:background .1s; }
.contact-result-item:hover { background:#f0f9ff; }
.contact-result-item:last-child { border-bottom:none; }
.contact-tag { display:flex; align-items:center; gap:.5rem; background:#e0f2fe; border:1px solid #bae6fd; border-radius:8px; padding:.35rem .75rem; font-size:.84rem; }
.contact-tag button { background:none; border:none; cursor:pointer; color:#64748b; font-size:.9rem; padding:0 0 0 .25rem; }
.contact-tag button:hover { color:#dc2626; }

/* Dropzone */
.dropzone { border:2px dashed #cbd5e1; border-radius:12px; padding:1.5rem; text-align:center; color:#64748b; cursor:pointer; transition:all .2s; background:#f8fafc; }
.dropzone:hover { border-color:#0ea5e9; background:#f0f9ff; color:#0369a1; }
.dropzone i { font-size:2rem; display:block; margin-bottom:.5rem; }
.file-list { display:flex; flex-direction:column; gap:.4rem; margin-top:.75rem; }
.file-item { display:flex; align-items:center; gap:.5rem; background:#f0f9ff; border-radius:8px; padding:.4rem .75rem; font-size:.83rem; }
.file-item .remove { background:none; border:none; color:#94a3b8; cursor:pointer; font-size:.9rem; margin-right:auto; margin-left:.25rem; }
.file-item .remove:hover { color:#dc2626; }

/* Modals */
.modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:600; display:flex; align-items:center; justify-content:center; }
.modal-card    { background:#fff; border-radius:16px; box-shadow:0 20px 60px rgba(0,0,0,.2); padding:1.75rem; width:min(500px,94vw); animation:popIn .2s ease; }
@@keyframes popIn { from{transform:scale(.92);opacity:0} to{transform:scale(1);opacity:1} }
.modal-title   { font-size:1rem; font-weight:700; color:#0f172a; margin:0 0 1.25rem; display:flex; align-items:center; gap:.5rem; }
.modal-footer  { display:flex; gap:.75rem; justify-content:flex-end; margin-top:1.25rem; }

/* Alerts */
.alert-err { background:#fef2f2; border:1px solid #fca5a5; border-radius:9px; padding:.75rem 1rem; font-size:.85rem; color:#dc2626; margin-bottom:1rem; display:flex; align-items:center; gap:.5rem; }
.alert-ok  { background:#f0fdf4; border:1px solid #86efac; border-radius:9px; padding:.75rem 1rem; font-size:.85rem; color:#15803d; margin-bottom:1rem; display:flex; align-items:center; gap:.5rem; }

/* Skeleton */
.skeleton { background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:8px; }
@@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
</style>

@* ═══════════════ VUE : FORMULAIRE ═══════════════ *@
@if (_showForm)
{
    <div class="form-wrap">
        <div class="page-header">
            <div>
                <div class="page-title">
                    <i class="bi bi-envelope-arrow-down" style="color:#0ea5e9"></i>
                    @(_editId.HasValue ? "تعديل بريد وارد" : "تسجيل بريد وارد جديد")
                </div>
                <div class="page-sub">مكتب الضبط / البريد الوارد / @(_editId.HasValue ? "تعديل" : "إضافة")</div>
            </div>
            <button class="btn btn-secondary" @onclick="BackToList">
                <i class="bi bi-arrow-right"></i> رجوع
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_formError))
            { <div class="alert-err"><i class="bi bi-exclamation-triangle-fill"></i> @_formError</div> }
        @if (!string.IsNullOrEmpty(_formSuccess))
            { <div class="alert-ok"><i class="bi bi-check-circle-fill"></i> @_formSuccess</div> }

        @* ── القسم 1: معلومات الوثيقة ── *@
        <div class="section-card">
            <h3><i class="bi bi-file-text"></i> معلومات الوثيقة</h3>
            <div class="form-grid">

                <div class="form-group">
                    <label class="form-label">تاريخ الوثيقة <span class="req">*</span></label>
                    <input type="date" class="form-control @(_v && _dto.DateCourrier == default ? "invalid" : "")"
                           @bind="_dto.DateCourrier" />
                </div>

                <div class="form-group">
                    <label class="form-label">تاريخ الاستلام <span class="req">*</span></label>
                    <input type="date" class="form-control @(_v && _dto.DateReception == default ? "invalid" : "")"
                           @bind="_dto.DateReception" />
                </div>

                <div class="form-group full">
                    <label class="form-label">موضوع البريد <span class="req">*</span></label>
                    <input type="text" class="form-control @(_v && string.IsNullOrEmpty(_dto.ObjetCourrier) ? "invalid" : "")"
                           placeholder="أدخل موضوع البريد…" @bind="_dto.ObjetCourrier" />
                </div>

                <div class="form-group">
                    <label class="form-label">نوع الوثيقة <span class="req">*</span></label>
                    <select class="form-control" @bind="_dto.TypeDocument">
                        <option value="Lettre">رسالة</option>
                        <option value="Note">مذكرة</option>
                        <option value="Circulaire">منشور / تعميم</option>
                        <option value="Rapport">تقرير</option>
                        <option value="Decision">قرار</option>
                        <option value="Arrete">مقرر</option>
                        <option value="Instruction">تعليمة</option>
                        <option value="Demande">طلب</option>
                        <option value="Recours">تظلم / شكوى</option>
                        <option value="Facture">فاتورة</option>
                        <option value="Autre">أخرى</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">الرقم الخارجي للوثيقة</label>
                    <input type="text" class="form-control" placeholder="رقم مرجعي للمرسل إن وجد"
                           @bind="_dto.NumeroExterne" />
                </div>

                <div class="form-group">
                    <label class="form-label">الأولوية</label>
                    <select class="form-control" @bind="_dto.Priorite">
                        <option value="Normal">عادي</option>
                        <option value="Urgent">عاجل</option>
                        <option value="TresUrgent">عاجل جداً</option>
                        <option value="Confidentiel">سري</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">عدد الصفحات</label>
                    <input type="number" class="form-control" min="1" @bind="_dto.NombrePages" />
                </div>

            </div>

            <div style="display:flex;gap:1.5rem;margin-top:.75rem;flex-wrap:wrap;">
                <label class="form-check">
                    <input type="checkbox" @bind="_dto.EstConfidentiel" />
                    <i class="bi bi-shield-lock" style="color:#9333ea"></i> سري
                </label>
                <label class="form-check">
                    <input type="checkbox" @bind="_dto.NecessiteReponse" />
                    <i class="bi bi-reply" style="color:#0369a1"></i> يستلزم ردًا
                </label>
            </div>

            @if (_dto.NecessiteReponse)
            {
                <div class="form-group" style="margin-top:.75rem;max-width:260px;">
                    <label class="form-label">أجل الرد</label>
                    <input type="date" class="form-control" @bind="_dto.DelaiReponse" />
                </div>
            }
        </div>

        @* ── القسم 2: المُرسِل ── *@
        <div class="section-card">
            <h3><i class="bi bi-person-lines-fill"></i> المُرسِل وطريقة الاستلام</h3>
            <div class="form-grid">

                @* Contact Search *@
                <div class="form-group full">
                    <label class="form-label">المُرسِل <span class="req">*</span></label>
                    @if (_selectedContact != null)
                    {
                        <div class="contact-tag">
                            <i class="bi bi-person-check-fill" style="color:#0369a1"></i>
                            <span style="font-weight:600">@_selectedContact.NomComplet</span>
                            @if (!string.IsNullOrEmpty(_selectedContact.Telephone))
                            { <span style="color:#64748b;font-size:.78rem">— @_selectedContact.Telephone</span> }
                            <button type="button" @onclick="ClearContact" title="إزالة">
                                <i class="bi bi-x-circle-fill"></i>
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="contact-search-wrap">
                            <div style="position:relative">
                                <i class="bi bi-search" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.9rem;pointer-events:none"></i>
                                <input type="text" class="form-control"
                                       style="padding-right:2.5rem"
                                       placeholder="ابحث في جهات الاتصال بالاسم أو الجهة…"
                                       value="@_contactSearch"
                                       @oninput="OnContactSearch" />
                            </div>
                            @if (_contactResults.Count > 0)
                            {
                                <div class="contact-results">
                                    @foreach (var c in _contactResults)
                                    {
                                        <div class="contact-result-item" @onclick="() => SelectContact(c)">
                                            <i class="bi @(c.TypeContact == "Personne" ? "bi-person" : "bi-building")"
                                               style="color:#0369a1"></i>
                                            <div>
                                                <div style="font-weight:600">@c.NomComplet</div>
                                                @if (!string.IsNullOrEmpty(c.Telephone))
                                                { <div style="font-size:.75rem;color:#64748b">@c.Telephone — @(c.Ville ?? "")</div> }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        <div style="margin-top:.4rem;display:flex;align-items:center;gap:.5rem">
                            <span style="font-size:.78rem;color:#94a3b8">أو</span>
                            <button type="button" class="btn btn-secondary" style="font-size:.78rem;padding:.3rem .7rem"
                                    @onclick="() => _showNewContact = true">
                                <i class="bi bi-person-plus"></i> إضافة جهة اتصال جديدة
                            </button>
                        </div>
                        @* Fallback: free text *@
                        <div style="margin-top:.5rem">
                            <label class="form-label" style="font-weight:400;color:#94a3b8">أو أدخل اسم المرسل يدوياً</label>
                            <input type="text" class="form-control" placeholder="اسم الشخص أو الجهة…"
                                   @bind="_dto.ExpediteurLibreNom" />
                        </div>
                    }
                </div>

                <div class="form-group">
                    <label class="form-label">طريقة الاستلام <span class="req">*</span></label>
                    <select class="form-control" @bind="_dto.ModeReception">
                        <option value="Guichet">على الواجهة</option>
                        <option value="Recommande">بريد مضمون</option>
                        <option value="Email">بريد إلكتروني</option>
                        <option value="Fax">فاكس</option>
                        <option value="Messagerie">مراسلة داخلية</option>
                        <option value="Coursier">ساعي</option>
                        <option value="PSEM">PSEM</option>
                    </select>
                </div>

                @if (_dto.ModeReception == "Recommande")
                {
                    <div class="form-group">
                        <label class="form-label">رقم الوصل المضمون</label>
                        <input type="text" class="form-control" placeholder="رقم AR…"
                               @bind="_dto.NumeroRecommande" />
                    </div>
                }

            </div>
        </div>

        @* ── القسم 3: التوجيه والإحالة ── *@
        <div class="section-card">
            <h3><i class="bi bi-diagram-3"></i> التوجيه والإحالة</h3>
            <div class="form-grid">

                <div class="form-group">
                    <label class="form-label">المصلحة المعنية</label>
                    <select class="form-control" @bind="_dto.ServiceDestinataireId">
                        <option value="">— اختر المصلحة —</option>
                        @foreach (var s in _services)
                        {
                            <option value="@s.Id">@s.Nom</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">ربط بملف (دوسيه)</label>
                    <input type="number" class="form-control" placeholder="رقم الملف إن وجد"
                           @bind="_dto.DossierId" />
                </div>

            </div>
        </div>

        @* ── القسم 4: الملفات المرفقة ── *@
        @if (!_editId.HasValue)
        {
            <div class="section-card">
                <h3><i class="bi bi-paperclip"></i> الملفات المرفقة</h3>

                <div class="dropzone" @onclick="TriggerFilePicker"
                     @ondragover:preventDefault="true"
                     @ondrop="OnFileDrop">
                    <i class="bi bi-cloud-arrow-up"></i>
                    <strong>اسحب الملفات هنا أو انقر للاختيار</strong>
                    <div style="font-size:.8rem;margin-top:.3rem;color:#94a3b8">PDF · PNG · JPG · TIFF — بحد أقصى 10 MB للملف الواحد</div>
                </div>

                <InputFile id="fileInput" style="display:none" multiple
                           accept=".pdf,.png,.jpg,.jpeg,.tiff"
                           OnChange="OnFilesSelected" />

                @if (_selectedFiles.Count > 0)
                {
                    <div class="file-list">
                        @foreach (var (f, i) in _selectedFiles.Select((f,i) => (f,i)))
                        {
                            <div class="file-item">
                                <i class="bi @FileIcon(f.Name)" style="font-size:1.1rem;color:#0369a1"></i>
                                <span style="flex:1">@f.Name</span>
                                <span style="color:#94a3b8;font-size:.75rem">@FormatSize(f.Size)</span>
                                <button class="remove" @onclick="() => RemoveFile(i)" type="button">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @* ── القسم 5: ملاحظات ── *@
        <div class="section-card">
            <h3><i class="bi bi-chat-left-text"></i> ملاحظات</h3>
            <div class="form-group">
                <textarea class="form-control" placeholder="ملاحظات إضافية…"
                          @bind="_dto.Observation"></textarea>
            </div>
        </div>

        <div class="form-footer">
            <button class="btn btn-secondary" @onclick="BackToList">إلغاء</button>
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                @if (_saving) { <span class="spinner-border spinner-border-sm"></span> }
                <i class="bi bi-check2-circle"></i>
                @(_editId.HasValue ? "حفظ التعديلات" : "تسجيل البريد")
            </button>
        </div>
    </div>
}
else
{
    @* ═══════════════ VUE : LISTE ═══════════════ *@
    <div class="page-header">
        <div>
            <div class="page-title">
                <i class="bi bi-envelope-arrow-down" style="color:#0ea5e9"></i> البريد الوارد
            </div>
            <div class="page-sub">مكتب الضبط / إدارة البريد الوارد</div>
        </div>
        <button class="btn btn-primary" @onclick="OpenNew">
            <i class="bi bi-plus-lg"></i> تسجيل بريد جديد
        </button>
    </div>

    @* Stats *@
    @if (_stats != null)
    {
        <div class="stats-bar">
            <div class="stat-card">
                <div class="stat-num">@_stats.TotalEntrants</div>
                <div class="stat-lbl">إجمالي البريد</div>
            </div>
            <div class="stat-card">
                <div class="stat-num" style="color:#1d4ed8">@_stats.Enregistres</div>
                <div class="stat-lbl">مسجّل</div>
            </div>
            <div class="stat-card">
                <div class="stat-num" style="color:#b45309">@_stats.EnCours</div>
                <div class="stat-lbl">قيد المعالجة</div>
            </div>
            <div class="stat-card traite">
                <div class="stat-num">@_stats.Traites</div>
                <div class="stat-lbl">تمت المعالجة</div>
            </div>
            <div class="stat-card urgent">
                <div class="stat-num">@_stats.Urgents</div>
                <div class="stat-lbl">عاجل</div>
            </div>
            <div class="stat-card retard">
                <div class="stat-num">@_stats.EnRetard</div>
                <div class="stat-lbl">متأخر</div>
            </div>
            <div class="stat-card">
                <div class="stat-num" style="color:#6b7280">@_stats.Archives</div>
                <div class="stat-lbl">مؤرشف</div>
            </div>
        </div>
    }

    @* Filters *@
    <div class="filters-bar">
        <div class="search-wrap">
            <i class="bi bi-search search-icon"></i>
            <input class="search-input" placeholder="بحث بالموضوع أو الرقم أو المرسل…"
                   @bind="_filter.SearchTerm" @oninput="OnSearch" />
        </div>

        <select class="filter-sel" @bind="_filter.Statut" @bind:after="LoadAsync">
            <option value="">كل الحالات</option>
            <option value="Recu">مستلم</option>
            <option value="Enregistre">مسجّل</option>
            <option value="EnCours">قيد المعالجة</option>
            <option value="Traite">تمت المعالجة</option>
            <option value="Archive">مؤرشف</option>
            <option value="Rejete">مرفوض</option>
        </select>

        <select class="filter-sel" @bind="_filter.Priorite" @bind:after="LoadAsync">
            <option value="">كل الأولويات</option>
            <option value="Normal">عادي</option>
            <option value="Urgent">عاجل</option>
            <option value="TresUrgent">عاجل جداً</option>
            <option value="Confidentiel">سري</option>
        </select>

        <select class="filter-sel" @bind="_filter.TypeDocument" @bind:after="LoadAsync">
            <option value="">كل الأنواع</option>
            <option value="Lettre">رسالة</option>
            <option value="Note">مذكرة</option>
            <option value="Circulaire">منشور</option>
            <option value="Rapport">تقرير</option>
            <option value="Demande">طلب</option>
            <option value="Recours">تظلم / شكوى</option>
            <option value="Decision">قرار</option>
            <option value="Autre">أخرى</option>
        </select>

        <input type="date" class="filter-date" title="من تاريخ"
               @bind="_filter.DateDebut" @bind:after="LoadAsync" />
        <input type="date" class="filter-date" title="إلى تاريخ"
               @bind="_filter.DateFin" @bind:after="LoadAsync" />

        <button class="btn btn-secondary" @onclick="ResetFilter">
            <i class="bi bi-arrow-counterclockwise"></i> إعادة تعيين
        </button>
    </div>

    @* Table *@
    <div class="table-card">
        <div class="table-inner">
            <table>
                <thead>
                    <tr>
                        <th>رقم الترتيب</th>
                        <th>التاريخ</th>
                        <th>الموضوع</th>
                        <th>المُرسِل</th>
                        <th>النوع</th>
                        <th>الأولوية</th>
                        <th>المصلحة</th>
                        <th>الحالة</th>
                        <th>مرفقات</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (_loading)
                    {
                        @for (int i = 0; i < 8; i++)
                        {
                            <tr>
                                @for (int j = 0; j < 10; j++)
                                {
                                    <td><div class="skeleton" style="height:14px;width:@(j==2?"120px":j==1?"80px":"60px")"></div></td>
                                }
                            </tr>
                        }
                    }
                    else if (_result?.Items?.Any() == true)
                    {
                        @foreach (var c in _result.Items)
                        {
                            <tr class="@RowClass(c)" @onclick="() => OpenDetail(c.Id)">
                                <td>
                                    <strong style="color:#0369a1">@c.NumeroOrdre</strong>
                                    @if (!string.IsNullOrEmpty(c.NumeroExterne))
                                    { <div style="font-size:.72rem;color:#94a3b8">@c.NumeroExterne</div> }
                                </td>
                                <td>
                                    <div>@c.DateReception.ToString("dd/MM/yyyy")</div>
                                    <div style="font-size:.72rem;color:#94a3b8">@c.DateCourrier.ToString("dd/MM/yyyy")</div>
                                </td>
                                <td style="max-width:220px;">
                                    <div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:220px;font-weight:600">@c.ObjetCourrier</div>
                                    @if (c.EnRetard)
                                    { <span class="badge badge-retard" style="margin-top:.2rem"><i class="bi bi-clock-history"></i> متأخر</span> }
                                </td>
                                <td style="max-width:160px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@c.ExpediteurNom</td>
                                <td><span style="font-size:.78rem;color:#374151">@TypeDocLabel(c.TypeDocument)</span></td>
                                <td><span class="badge @PrioriteBadge(c.Priorite)">@PrioriteLabel(c.Priorite)</span></td>
                                <td style="font-size:.8rem;color:#374151">@(c.ServiceDestinataireNom ?? "—")</td>
                                <td><span class="badge @StatutBadge(c.Statut)">@StatutLabel(c.Statut)</span></td>
                                <td>
                                    @if (c.NombrePiecesJointes > 0)
                                    { <span class="badge badge-normal"><i class="bi bi-paperclip"></i> @c.NombrePiecesJointes</span> }
                                </td>
                                <td @onclick:stopPropagation="true">
                                    <div style="display:flex;gap:.3rem">
                                        <button class="btn btn-info" style="padding:.3rem .6rem;font-size:.78rem"
                                                @onclick="() => OpenDetail(c.Id)" title="تفاصيل">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        @if (c.Statut is not "Archive")
                                        {
                                            <button class="btn btn-secondary" style="padding:.3rem .6rem;font-size:.78rem"
                                                    @onclick="() => OpenEdit(c.Id)" title="تعديل">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="10" style="text-align:center;padding:2rem;color:#94a3b8">
                            <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:.5rem"></i>
                            لا توجد نتائج
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_result != null && _result.TotalCount > 0)
        {
            <div class="pagination">
                <div class="pg-info">@_result.TotalCount سجل — صفحة @_result.PageNumber من @TotalPages</div>
                <div class="pg-btns">
                    <button class="pg-btn" disabled="@(_filter.PageNumber <= 1)"
                            @onclick="() => GoPage(_filter.PageNumber - 1)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                    @for (int p = Math.Max(1, _filter.PageNumber - 2);
                          p <= Math.Min(TotalPages, _filter.PageNumber + 2); p++)
                    {
                        var pg = p;
                        <button class="pg-btn @(pg == _filter.PageNumber ? "active" : "")"
                                @onclick="() => GoPage(pg)">@pg</button>
                    }
                    <button class="pg-btn" disabled="@(_filter.PageNumber >= TotalPages)"
                            @onclick="() => GoPage(_filter.PageNumber + 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                </div>
            </div>
        }
    </div>
}

@* ═══════════════ DRAWER : DÉTAIL ═══════════════ *@
@if (_detail != null)
{
    <div class="overlay" @onclick="CloseDetail">
        <div class="drawer" @onclick:stopPropagation="true">
            <div class="drawer-header">
                <div style="flex:1">
                    <div class="drawer-title">
                        <i class="bi bi-envelope-open" style="color:#0ea5e9;margin-left:.4rem"></i>
                        @_detail.NumeroOrdre
                        @if (_detail.EstConfidentiel)
                        { <span class="badge badge-conf" style="margin-right:.5rem"><i class="bi bi-shield-lock"></i> سري</span> }
                    </div>
                    <div style="font-size:.75rem;color:#94a3b8;margin-top:.15rem">
                        @StatutLabel(_detail.Statut) · @_detail.DateReception.ToString("dd/MM/yyyy")
                    </div>
                </div>
                <div style="display:flex;gap:.4rem;align-items:center">
                    <span class="badge @StatutBadge(_detail.Statut)">@StatutLabel(_detail.Statut)</span>
                    <span class="badge @PrioriteBadge(_detail.Priorite)">@PrioriteLabel(_detail.Priorite)</span>
                    <button class="close-btn" @onclick="CloseDetail"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>

            <div class="drawer-body">

                <div class="info-grid">
                    <div class="info-item">
                        <label>رقم الترتيب</label>
                        <span style="font-weight:700;color:#0369a1">@_detail.NumeroOrdre</span>
                    </div>
                    @if (!string.IsNullOrEmpty(_detail.NumeroExterne))
                    {
                        <div class="info-item">
                            <label>الرقم الخارجي</label>
                            <span>@_detail.NumeroExterne</span>
                        </div>
                    }
                    <div class="info-item">
                        <label>تاريخ الوثيقة</label>
                        <span>@_detail.DateCourrier.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="info-item">
                        <label>تاريخ الاستلام</label>
                        <span>@_detail.DateReception.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="info-item full">
                        <label>الموضوع</label>
                        <span style="font-weight:600">@_detail.ObjetCourrier</span>
                    </div>
                    <div class="info-item">
                        <label>نوع الوثيقة</label>
                        <span>@TypeDocLabel(_detail.TypeDocument)</span>
                    </div>
                    <div class="info-item">
                        <label>طريقة الاستلام</label>
                        <span>@ModeReceptionLabel(_detail.ModeReception)</span>
                    </div>
                    @if (!string.IsNullOrEmpty(_detail.NumeroRecommande))
                    {
                        <div class="info-item">
                            <label>رقم الوصل المضمون</label>
                            <span>@_detail.NumeroRecommande</span>
                        </div>
                    }
                    <div class="info-item">
                        <label>المُرسِل</label>
                        <span>@(_detail.ExpediteurNom ?? "—")</span>
                    </div>
                    <div class="info-item">
                        <label>عدد الصفحات</label>
                        <span>@_detail.NombrePages صفحة</span>
                    </div>
                </div>

                <hr class="section-sep" />

                <div>
                    <div class="section-ttl"><i class="bi bi-diagram-3" style="color:#0369a1"></i> التوجيه</div>
                    <div class="info-grid" style="margin-top:.65rem">
                        <div class="info-item">
                            <label>المصلحة المعنية</label>
                            <span>@(_detail.ServiceDestinataireNom ?? "لم يُحدد")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(_detail.DossierIntitule))
                        {
                            <div class="info-item">
                                <label>الملف (دوسيه)</label>
                                <span>@_detail.DossierIntitule</span>
                            </div>
                        }
                        @if (_detail.NecessiteReponse)
                        {
                            <div class="info-item">
                                <label>أجل الرد</label>
                                <span class="@(_detail.EnRetard ? "badge badge-retard" : "")">
                                    @(_detail.DelaiReponse?.ToString("dd/MM/yyyy") ?? "—")
                                    @if (_detail.EnRetard) { <text> ⚠️ متأخر</text> }
                                </span>
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_detail.Observation))
                {
                    <hr class="section-sep" />
                    <div>
                        <div class="section-ttl"><i class="bi bi-chat-left-text" style="color:#64748b"></i> ملاحظات</div>
                        <div style="font-size:.86rem;color:#374151;margin-top:.5rem;background:#f8fafc;border-radius:8px;padding:.65rem .9rem">@_detail.Observation</div>
                    </div>
                }

                @* الملفات المرفقة *@
                @if (_detail.PiecesJointes?.Count > 0)
                {
                    <hr class="section-sep" />
                    <div>
                        <div class="section-ttl" style="justify-content:space-between">
                            <span><i class="bi bi-paperclip" style="color:#0369a1"></i> المرفقات (@_detail.PiecesJointes.Count)</span>
                            @if (_detail.Statut is not "Archive")
                            {
                                <button class="btn btn-secondary" style="font-size:.77rem;padding:.3rem .65rem"
                                        @onclick="OpenUploadPJ">
                                    <i class="bi bi-plus"></i> إضافة
                                </button>
                            }
                        </div>
                        <div class="pj-list" style="margin-top:.65rem">
                            @foreach (var pj in _detail.PiecesJointes)
                            {
                                <div class="pj-item">
                                    <i class="@FileIcon(pj.NomFichierOriginal) pj-icon" style="color:#0369a1"></i>
                                    <div style="flex:1">
                                        <div class="pj-name">@pj.NomFichierOriginal</div>
                                        <div class="pj-meta">@TypePieceLabel(pj.TypePiece) · @FormatSize(pj.TailleFichierOctets)</div>
                                        @if (!string.IsNullOrEmpty(pj.Description))
                                        { <div style="font-size:.76rem;color:#374151">@pj.Description</div> }
                                    </div>
                                    @if (!string.IsNullOrEmpty(pj.UrlTelechargement))
                                    {
                                        <a href="@pj.UrlTelechargement" target="_blank" class="btn btn-secondary"
                                           style="font-size:.76rem;padding:.25rem .55rem" title="تحميل">
                                            <i class="bi bi-download"></i>
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                else if (_detail.Statut is not "Archive")
                {
                    <div style="display:flex;justify-content:flex-start;margin-top:.25rem">
                        <button class="btn btn-secondary" style="font-size:.8rem"
                                @onclick="OpenUploadPJ">
                            <i class="bi bi-paperclip"></i> إضافة مرفقات
                        </button>
                    </div>
                }

                @* Circuit de traitement *@
                @if (_detail.Circuit?.Count > 0)
                {
                    <hr class="section-sep" />
                    <div>
                        <div class="section-ttl"><i class="bi bi-arrow-left-right" style="color:#7c3aed"></i> مسار المعالجة</div>
                        <div class="circuit-wrap" style="margin-top:.65rem">
                            @foreach (var step in _detail.Circuit)
                            {
                                var stepClass = step.StatutEtape switch {
                                    "Traite"   => "c-done",
                                    "Retourne" => "c-retour",
                                    _          => "c-attente"
                                };
                                <div class="c-step @stepClass">
                                    <div class="c-num">@step.NumeroEtape</div>
                                    <div class="c-body">
                                        <div class="c-title">@step.ServiceRecepteurNom</div>
                                        <div class="c-meta">
                                            @TypeActionLabel(step.TypeAction) ·
                                            @step.DateTransmission.ToString("dd/MM/yyyy")
                                            @if (step.DateTraitement.HasValue)
                                            { <text> → @step.DateTraitement.Value.ToString("dd/MM/yyyy")</text> }
                                            · <span class="badge @CircuitBadge(step.StatutEtape)">@CircuitLabel(step.StatutEtape)</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(step.InstructionTransmission))
                                        { <div class="c-instr"><i class="bi bi-info-circle"></i> @step.InstructionTransmission</div> }
                                        @if (!string.IsNullOrEmpty(step.CommentaireTraitement))
                                        { <div class="c-instr" style="background:#f0fdf4;color:#15803d"><i class="bi bi-check-circle"></i> @step.CommentaireTraitement</div> }
                                        @if (step.EstRetour && !string.IsNullOrEmpty(step.MotifRetour))
                                        { <div class="c-instr" style="background:#fef2f2;color:#dc2626"><i class="bi bi-arrow-return-right"></i> إعادة: @step.MotifRetour</div> }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @* Actions *@
                @if (_detail.Statut is not "Archive")
                {
                    <hr class="section-sep" />
                    <div class="section-ttl"><i class="bi bi-gear" style="color:#374151"></i> الإجراءات</div>
                    <div class="action-row">
                        <button class="btn btn-secondary" @onclick="() => OpenEdit(_detail.Id)">
                            <i class="bi bi-pencil"></i> تعديل
                        </button>

                        @if (_detail.Statut is not "Traite")
                        {
                            <button class="btn btn-success" @onclick="() => MarquerTraite(_detail.Id)">
                                <i class="bi bi-check2-all"></i> تمت المعالجة
                            </button>
                        }

                        <button class="btn btn-purple" @onclick="OpenAcheminer">
                            <i class="bi bi-arrow-left-right"></i> توجيه / إحالة
                        </button>

                        <button class="btn btn-warning" @onclick="OpenAffecter">
                            <i class="bi bi-person-check"></i> تحويل مباشر
                        </button>

                        @if (_detail.Statut == "Traite")
                        {
                            <button class="btn btn-secondary" @onclick="OpenArchiver">
                                <i class="bi bi-archive"></i> أرشفة
                            </button>
                        }
                    </div>
                }

            </div>
        </div>
    </div>
}

@* ════════════ MODAL: ACHEMINEMENT ════════════ *@
@if (_showAcheminer)
{
    <div class="modal-overlay" @onclick="() => _showAcheminer = false">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-title"><i class="bi bi-arrow-left-right" style="color:#7c3aed"></i> توجيه البريد إلى مصلحة</div>

            <div class="form-group" style="margin-bottom:.75rem">
                <label class="form-label">المصلحة المستقبِلة <span class="req">*</span></label>
                <select class="form-control @(_v2 && _acheminerDto.ServiceRecepteurId==0 ? "invalid" : "")"
                        @bind="_acheminerDto.ServiceRecepteurId">
                    <option value="0">— اختر المصلحة —</option>
                    @foreach (var s in _services)
                    { <option value="@s.Id">@s.Nom</option> }
                </select>
            </div>

            <div class="form-group" style="margin-bottom:.75rem">
                <label class="form-label">نوع الإجراء</label>
                <select class="form-control" @bind="_acheminerDto.TypeAction">
                    <option value="PourAction">للإجراء اللازم</option>
                    <option value="PourDecision">لاتخاذ القرار</option>
