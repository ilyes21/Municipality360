    private static string FileIcon(string name)
    {
        var ext = Path.GetExtension(name).ToLowerInvariant();
        return ext switch
        {
            ".pdf"  => "bi-file-earmark-pdf",
            ".png" or ".jpg" or ".jpeg" or ".tiff" => "bi-file-earmark-image",
            _       => "bi-file-earmark"
        };
    }
    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} o";
        if (bytes < 1_048_576) return $"{bytes / 1024.0:F1} Ko";
        return $"{bytes / 1_048_576.0:F1} Mo";
    }
    private static string FormatSize(long? bytes) => bytes.HasValue ? FormatSize(bytes.Value) : "—";
