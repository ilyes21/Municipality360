@page "/bureau/responsable"
@using Microsoft.AspNetCore.Authorization
@using Municipality360.Application.DTOs.BureauOrdre
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager")]
@layout Municipality360.Web.Components.Layout.MainLayout
@inject ICourrierEntrantApiService EntrantApi
@inject ICourrierSortantApiService SortantApi
@inject NavigationManager Nav

<PageTitle>لوحة الرئيس البلدي — مكتب الضبط</PageTitle>

<style>
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; }
    .page-title  { font-size:1.3rem; font-weight:800; color:#0f172a; margin:0; }
    .page-sub    { font-size:.8rem; color:#94a3b8; margin-top:.2rem; }

    .kpi-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(170px,1fr)); gap:1rem; margin-bottom:1.5rem; }
    .kpi-card { background:#fff; border-radius:14px; padding:1.1rem 1.25rem; box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #f1f5f9; display:flex; flex-direction:column; gap:.3rem; position:relative; overflow:hidden; }
    .kpi-card::before { content:''; position:absolute; top:0; right:0; width:4px; height:100%; border-radius:0 14px 14px 0; }
    .kpi-blue::before   { background:#0ea5e9; }
    .kpi-green::before  { background:#22c55e; }
    .kpi-orange::before { background:#f59e0b; }
    .kpi-red::before    { background:#ef4444; }
    .kpi-purple::before { background:#8b5cf6; }
    .kpi-icon { width:38px; height:38px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; margin-bottom:.2rem; }
    .bg-blue   { background:#e0f2fe; color:#0369a1; }
    .bg-green  { background:#dcfce7; color:#15803d; }
    .bg-orange { background:#fef3c7; color:#d97706; }
    .bg-red    { background:#fee2e2; color:#dc2626; }
    .bg-purple { background:#ede9fe; color:#7c3aed; }
    .kpi-val { font-size:1.6rem; font-weight:800; color:#0f172a; line-height:1; }
    .kpi-lbl { font-size:.78rem; color:#64748b; }

    .two-col { display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; }
    @@media(max-width:900px) { .two-col { grid-template-columns:1fr; } }

    .section-card  { background:#fff; border-radius:14px; box-shadow:0 1px 8px rgba(0,0,0,.06); border:1px solid #f1f5f9; overflow:hidden; }
    .section-header { display:flex; align-items:center; justify-content:space-between; padding:.9rem 1.2rem; border-bottom:1px solid #f1f5f9; }
    .section-title  { font-size:.9rem; font-weight:700; color:#0f172a; display:flex; align-items:center; gap:.5rem; }
    .btn-link { background:none; border:none; color:#0ea5e9; font-family:'Tajawal',sans-serif; font-size:.82rem; cursor:pointer; }
    .btn-link:hover { text-decoration:underline; }

    table { width:100%; border-collapse:collapse; }
    thead tr { background:#f8fafc; border-bottom:1px solid #e2e8f0; }
    th { padding:.6rem 1rem; text-align:right; font-size:.72rem; font-weight:700; color:#64748b; }
    td { padding:.75rem 1rem; font-size:.84rem; color:#374151; border-bottom:1px solid #f8fafc; vertical-align:middle; }
    tbody tr { cursor:pointer; }
    tbody tr:hover { background:#f0fdfa; }
    tbody tr:last-child td { border-bottom:none; }

    .badge { display:inline-flex; align-items:center; border-radius:99px; padding:.2rem .6rem; font-size:.71rem; font-weight:600; }
    .badge-urgent   { background:#fee2e2; color:#dc2626; }
    .badge-normal   { background:#dbeafe; color:#1d4ed8; }
    .badge-high     { background:#fef3c7; color:#b45309; }
    .badge-enregistre { background:#dbeafe; color:#1d4ed8; }
    .badge-encours    { background:#fef3c7; color:#b45309; }
    .badge-traite     { background:#dcfce7; color:#15803d; }

    .alert-urgent { background:linear-gradient(135deg,#fef2f2,#fff7ed); border:1px solid #fca5a5; border-radius:12px; padding:.85rem 1.25rem; display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem; }
    .alert-urgent i { font-size:1.3rem; color:#ef4444; }

    .skeleton { background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:8px; }
    @@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

    .routing-panel { padding:1rem 1.2rem; display:flex; flex-direction:column; gap:.5rem; }
    .action-btn { display:inline-flex; align-items:center; gap:.4rem; padding:.5rem 1rem; border-radius:9px; border:none; cursor:pointer; font-family:'Tajawal',sans-serif; font-size:.84rem; font-weight:600; transition:all .2s; }
    .btn-primary { background:linear-gradient(135deg,#0369a1,#0ea5e9); color:#fff; }
    .btn-primary:hover { transform:translateY(-1px); box-shadow:0 4px 12px rgba(14,165,233,.3); }
    .btn-secondary { background:#f1f5f9; color:#374151; }
    .btn-secondary:hover { background:#e2e8f0; }
    .btn-warning { background:linear-gradient(135deg,#d97706,#f59e0b); color:#fff; }
</style>

<div class="page-header">
    <div>
        <div class="page-title"><i class="bi bi-shield-check" style="color:#0ea5e9"></i> لوحة الرئيس البلدي</div>
        <div class="page-sub">مراقبة وتوجيه البريد الوارد والصادر</div>
    </div>
    <div style="display:flex;gap:.6rem">
        <button class="action-btn btn-secondary" @onclick='()=>Nav.NavigateTo("/bureau/incoming")'><i class="bi bi-envelope-arrow-down"></i> البريد الوارد</button>
        <button class="action-btn btn-primary" @onclick='()=>Nav.NavigateTo("/bureau/outgoing")'><i class="bi bi-envelope-arrow-up"></i> البريد الصادر</button>
    </div>
</div>

@* KPI Cards *@
<div class="kpi-grid">
    <div class="kpi-card kpi-blue">
        <div class="kpi-icon bg-blue"><i class="bi bi-envelope-arrow-down"></i></div>
        <div class="kpi-val">@_totalEntrants</div>
        <div class="kpi-lbl">إجمالي الوارد</div>
    </div>
    <div class="kpi-card kpi-orange">
        <div class="kpi-icon bg-orange"><i class="bi bi-hourglass-split"></i></div>
        <div class="kpi-val">@_entrantsEnCours</div>
        <div class="kpi-lbl">في المعالجة</div>
    </div>
    <div class="kpi-card kpi-red">
        <div class="kpi-icon bg-red"><i class="bi bi-alarm"></i></div>
        <div class="kpi-val">@_entrantsEnRetard</div>
        <div class="kpi-lbl">متأخرة في الرد</div>
    </div>
    <div class="kpi-card kpi-purple">
        <div class="kpi-icon bg-purple"><i class="bi bi-envelope-arrow-up"></i></div>
        <div class="kpi-val">@_totalSortants</div>
        <div class="kpi-lbl">إجمالي الصادر</div>
    </div>
    <div class="kpi-card kpi-green">
        <div class="kpi-icon bg-green"><i class="bi bi-check-circle"></i></div>
        <div class="kpi-val">@_entrantsTraites</div>
        <div class="kpi-lbl">معالجة مكتملة</div>
    </div>
</div>

@* Urgent alert *@
@if (_entrantsEnRetard > 0)
{
    <div class="alert-urgent">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>
            <strong>تنبيه:</strong> يوجد <strong>@_entrantsEnRetard</strong> بريد وارد متأخر في الرد.
            <button class="btn-link" style="margin-right:.5rem" @onclick='()=>Nav.NavigateTo("/bureau/incoming")'>عرض الكل ←</button>
        </div>
    </div>
}

<div class="two-col">
    @* Recent incoming *@
    <div class="section-card">
        <div class="section-header">
            <div class="section-title"><i class="bi bi-envelope-arrow-down" style="color:#0369a1"></i> أحدث البريد الوارد</div>
            <button class="btn-link" @onclick='()=>Nav.NavigateTo("/bureau/incoming")'>عرض الكل</button>
        </div>
        <table>
            <thead><tr>
                <th>الرقم</th><th>الموضوع</th><th>المرسل</th><th>الأولوية</th><th>الحالة</th>
            </tr></thead>
            <tbody>
                @if (_loadingEntrants)
                {
                    @for (int i = 0; i < 5; i++) {
                        <tr><td colspan="5"><div class="skeleton" style="height:16px;margin:.3rem 0"></div></td></tr>
                    }
                }
                else if (_recentEntrants?.Any() == true)
                {
                    @foreach (var c in _recentEntrants)
                    {
                        <tr @onclick='()=>Nav.NavigateTo($"/bureau/incoming/{c.Id}")'>
                            <td><strong style="color:#0369a1;font-size:.75rem">@c.NumeroOrdre</strong></td>
                            <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@c.ObjetCourrier">@c.ObjetCourrier</td>
                            <td style="font-size:.78rem">@(c.ExpediteurNom.Length > 20 ? c.ExpediteurNom[..20] + "…" : c.ExpediteurNom)</td>
                            <td>
                                <span class="badge @(c.Priorite=="Urgent"?"badge-urgent":c.Priorite=="Haute"?"badge-high":"badge-normal")">@c.Priorite</span>
                            </td>
                            <td>
                                <span class="badge @GetStatutBadge(c.Statut)">@c.Statut</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" style="text-align:center;color:#94a3b8;padding:2rem">لا يوجد بريد وارد</td></tr>
                }
            </tbody>
        </table>
    </div>

    @* Recent outgoing *@
    <div class="section-card">
        <div class="section-header">
            <div class="section-title"><i class="bi bi-envelope-arrow-up" style="color:#7c3aed"></i> أحدث البريد الصادر</div>
            <button class="btn-link" @onclick='()=>Nav.NavigateTo("/bureau/outgoing")'>عرض الكل</button>
        </div>
        <table>
            <thead><tr>
                <th>الرقم</th><th>الموضوع</th><th>المرسل إليه</th><th>الحالة</th><th>تاريخ التحرير</th>
            </tr></thead>
            <tbody>
                @if (_loadingSortants)
                {
                    @for (int i = 0; i < 5; i++) {
                        <tr><td colspan="5"><div class="skeleton" style="height:16px;margin:.3rem 0"></div></td></tr>
                    }
                }
                else if (_recentSortants?.Any() == true)
                {
                    @foreach (var s in _recentSortants)
                    {
                        <tr @onclick='()=>Nav.NavigateTo($"/bureau/outgoing/{s.Id}")'>
                            <td><strong style="color:#7c3aed;font-size:.75rem">@s.NumeroOrdre</strong></td>
                            <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@s.ObjetCourrier">@s.ObjetCourrier</td>
                            <td style="font-size:.78rem">@(s.DestinataireNom != null && s.DestinataireNom.Length > 20 ? s.DestinataireNom[..20] + "…" : s.DestinataireNom ?? "—")</td>
                            <td><span class="badge @GetSortantBadge(s.Statut)">@s.Statut</span></td>
                            <td style="font-size:.78rem">@s.DateRedaction.ToString("dd/MM/yy")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" style="text-align:center;color:#94a3b8;padding:2rem">لا يوجد بريد صادر</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Pending entrants (EnRegistre / EnCours) for routing *@
@if (_pendingEntrants?.Any() == true)
{
    <div class="section-card" style="margin-top:1.25rem">
        <div class="section-header">
            <div class="section-title"><i class="bi bi-arrows-move" style="color:#f59e0b"></i> بريد ينتظر التوجيه / المعالجة</div>
        </div>
        <table>
            <thead><tr>
                <th>الرقم</th><th>تاريخ الاستلام</th><th>الموضوع</th><th>المرسل</th><th>الأولوية</th><th>الخدمة المعنية</th><th></th>
            </tr></thead>
            <tbody>
                @foreach (var c in _pendingEntrants)
                {
                    <tr>
                        <td><strong style="color:#0369a1;font-size:.75rem">@c.NumeroOrdre</strong></td>
                        <td style="font-size:.78rem">@c.DateReception.ToString("dd/MM/yyyy")</td>
                        <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@c.ObjetCourrier">@c.ObjetCourrier</td>
                        <td style="font-size:.78rem">@(c.ExpediteurNom.Length > 18 ? c.ExpediteurNom[..18] + "…" : c.ExpediteurNom)</td>
                        <td><span class="badge @(c.Priorite=="Urgent"?"badge-urgent":c.Priorite=="Haute"?"badge-high":"badge-normal")">@c.Priorite</span></td>
                        <td style="font-size:.78rem">@(c.ServiceDestinataireNom ?? "—")</td>
                        <td>
                            <button class="action-btn btn-primary" style="padding:.35rem .7rem;font-size:.78rem"
                                    @onclick='()=>Nav.NavigateTo($"/bureau/incoming/{c.Id}")'>
                                <i class="bi bi-eye"></i> عرض
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<CourrierEntrantDto>? _recentEntrants;
    private List<CourrierEntrantDto>? _pendingEntrants;
    private List<CourrierSortantDto>? _recentSortants;

    private bool _loadingEntrants = true;
    private bool _loadingSortants = true;

    private int _totalEntrants, _entrantsEnCours, _entrantsEnRetard, _entrantsTraites, _totalSortants;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadEntrantsAsync(), LoadSortantsAsync());
    }

    private async Task LoadEntrantsAsync()
    {
        _loadingEntrants = true;
        try
        {
            // Recent (all statuts)
            var recent = await EntrantApi.GetPagedAsync(new CourrierEntrantFilterDto { PageNumber = 1, PageSize = 8 });
            _recentEntrants = recent?.Items?.ToList();
            _totalEntrants = recent?.TotalCount ?? 0;

            // En cours
            var encours = await EntrantApi.GetPagedAsync(new CourrierEntrantFilterDto { Statut = "EnCours", PageNumber = 1, PageSize = 1 });
            _entrantsEnCours = encours?.TotalCount ?? 0;

            // Traités
            var traite = await EntrantApi.GetPagedAsync(new CourrierEntrantFilterDto { Statut = "Traite", PageNumber = 1, PageSize = 1 });
            _entrantsTraites = traite?.TotalCount ?? 0;

            // En retard
            var retard = await EntrantApi.GetPagedAsync(new CourrierEntrantFilterDto { EnRetard = true, PageNumber = 1, PageSize = 1 });
            _entrantsEnRetard = retard?.TotalCount ?? 0;

            // Pending routing
            var pending = await EntrantApi.GetPagedAsync(new CourrierEntrantFilterDto { Statut = "Enregistre", PageNumber = 1, PageSize = 10 });
            _pendingEntrants = pending?.Items?.ToList();
        }
        catch { }
        finally { _loadingEntrants = false; }
    }

    private async Task LoadSortantsAsync()
    {
        _loadingSortants = true;
        try
        {
            var paged = await SortantApi.GetPagedAsync(new CourrierSortantFilterDto { PageNumber = 1, PageSize = 8 });
            _recentSortants = paged?.Items?.ToList();
            _totalSortants = paged?.TotalCount ?? 0;
        }
        catch { }
        finally { _loadingSortants = false; }
    }

    private static string GetStatutBadge(string statut) => statut switch
    {
        "Enregistre"  => "badge-enregistre",
        "EnCours"     => "badge-encours",
        "Traite"      => "badge-traite",
        _             => "badge-enregistre"
    };

    private static string GetSortantBadge(string statut) => statut switch
    {
        "Brouillon"   => "badge-encours",
        "EnValidation"=> "badge-encours",
        "Signe"       => "badge-traite",
        "Envoye"      => "badge-enregistre",
        _             => "badge-enregistre"
    };
}
