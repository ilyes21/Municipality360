@page "/bureau/archive"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,BureauOrdre")]
@layout Municipality360.Web.Components.Layout.MainLayout
@inject ICourrierEntrantApiService EntrantApi
@inject ICourrierSortantApiService SortantApi
@inject NavigationManager Nav

<PageTitle>الأرشيف — مكتب الضبط</PageTitle>

<style>
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; }
    .page-title  { font-size:1.3rem; font-weight:800; color:#0f172a; margin:0; }
    .page-sub    { font-size:.8rem; color:#94a3b8; margin-top:.2rem; }
    .btn         { display:inline-flex; align-items:center; gap:.4rem; padding:.45rem .95rem; border-radius:9px; border:none; cursor:pointer; font-family:'Tajawal',sans-serif; font-size:.85rem; font-weight:600; transition:all .2s; }
    .btn-secondary { background:#f1f5f9; color:#374151; }
    .btn-secondary:hover { background:#e2e8f0; }

    .filters-bar { display:flex; gap:.75rem; flex-wrap:wrap; margin-bottom:1.2rem; align-items:center; }
    .search-wrap { position:relative; flex:1; min-width:200px; }
    .search-input { width:100%; height:38px; padding:0 1rem 0 2.5rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.86rem; outline:none; transition:border-color .2s; background:#fff; }
    .search-input:focus { border-color:#14b8a6; box-shadow:0 0 0 3px rgba(20,184,166,.1); }
    .search-icon { position:absolute; right:10px; top:50%; transform:translateY(-50%); color:#94a3b8; pointer-events:none; }
    select.filter-sel { height:38px; padding:0 .75rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.85rem; outline:none; background:#fff; cursor:pointer; }
    .filter-date { height:38px; padding:0 .6rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.85rem; outline:none; background:#fff; }

    .tab-row { display:flex; gap:.5rem; margin-bottom:1rem; }
    .tab-btn  { padding:.42rem 1rem; border-radius:8px; border:1.5px solid #e2e8f0; background:#fff; font-family:'Tajawal',sans-serif; font-size:.85rem; cursor:pointer; transition:all .2s; display:inline-flex; align-items:center; gap:.4rem; }
    .tab-btn.active { background:#14b8a6; color:#fff; border-color:#14b8a6; }

    .table-card  { background:#fff; border-radius:14px; box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #f1f5f9; overflow:hidden; }
    .table-inner { overflow-x:auto; }
    table { width:100%; border-collapse:collapse; }
    thead tr { background:#f0fdfa; border-bottom:1px solid #ccfbf1; }
    th { padding:.65rem 1rem; text-align:right; font-size:.73rem; font-weight:700; color:#0f766e; white-space:nowrap; }
    td { padding:.8rem 1rem; font-size:.85rem; color:#374151; border-bottom:1px solid #f8fafc; vertical-align:middle; }
    tbody tr { cursor:pointer; }
    tbody tr:hover { background:#f0fdfa; }
    tbody tr:last-child td { border-bottom:none; }

    .badge { display:inline-flex; align-items:center; gap:.3rem; border-radius:99px; padding:.2rem .65rem; font-size:.72rem; font-weight:600; }
    .badge-entrant { background:#e0f2fe; color:#0369a1; }
    .badge-sortant { background:#ede9fe; color:#7c3aed; }
    .badge-archive { background:#ccfbf1; color:#0f766e; }

    .pagination { display:flex; align-items:center; justify-content:center; gap:.4rem; padding:1rem; }
    .pg-btn { width:34px; height:34px; border-radius:8px; border:1.5px solid #e2e8f0; background:#fff; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:.82rem; color:#374151; transition:all .2s; }
    .pg-btn:hover { border-color:#14b8a6; color:#14b8a6; }
    .pg-btn.active { background:#14b8a6; border-color:#14b8a6; color:#fff; }
    .pg-btn:disabled { opacity:.4; cursor:not-allowed; }
    .pg-info { font-size:.82rem; color:#64748b; margin:0 .5rem; }

    .overlay  { position:fixed; inset:0; background:rgba(0,0,0,.4); z-index:500; display:flex; align-items:flex-start; justify-content:flex-end; }
    .drawer   { width:min(550px,95vw); height:100vh; background:#fff; box-shadow:-6px 0 40px rgba(0,0,0,.15); display:flex; flex-direction:column; }
    .drawer-header { padding:1.2rem 1.5rem; border-bottom:1px solid #f1f5f9; display:flex; align-items:center; justify-content:space-between; background:#f0fdfa; flex-shrink:0; }
    .drawer-title  { font-size:1rem; font-weight:700; color:#0f172a; }
    .drawer-body   { flex:1; overflow-y:auto; padding:1.5rem; display:flex; flex-direction:column; gap:1rem; }
    .close-btn { background:none; border:none; font-size:1.2rem; cursor:pointer; color:#64748b; padding:.25rem; }
    .close-btn:hover { color:#0f172a; }
    .detail-grid { display:grid; grid-template-columns:1fr 1fr; gap:.75rem 1.5rem; }
    .detail-item label { display:block; font-size:.72rem; font-weight:700; color:#64748b; text-transform:uppercase; margin-bottom:.2rem; }
    .detail-item span  { font-size:.88rem; color:#0f172a; }
    .detail-item.full  { grid-column:1/-1; }

    .stat-row { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; margin-bottom:1.5rem; }
    .stat-card { background:#fff; border-radius:12px; padding:1rem; box-shadow:0 1px 6px rgba(0,0,0,.06); border:1px solid #f1f5f9; text-align:center; }
    .stat-val  { font-size:1.6rem; font-weight:800; color:#0f172a; }
    .stat-lbl  { font-size:.75rem; color:#64748b; }

    .skeleton { background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:8px; }
    @@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
</style>

<div class="page-header">
    <div>
        <div class="page-title"><i class="bi bi-archive-fill" style="color:#14b8a6"></i> الأرشيف</div>
        <div class="page-sub">إجمالي المؤرشفات: البريد الوارد والصادر</div>
    </div>
</div>

@* Stats *@
<div class="stat-row">
    <div class="stat-card">
        <div class="stat-val">@_totalEntrants</div>
        <div class="stat-lbl"><i class="bi bi-envelope-arrow-down" style="color:#0369a1"></i> وارد مؤرشف</div>
    </div>
    <div class="stat-card">
        <div class="stat-val">@_totalSortants</div>
        <div class="stat-lbl"><i class="bi bi-envelope-arrow-up" style="color:#7c3aed"></i> صادر مؤرشف</div>
    </div>
    <div class="stat-card">
        <div class="stat-val">@(_totalEntrants + _totalSortants)</div>
        <div class="stat-lbl"><i class="bi bi-archive-fill" style="color:#14b8a6"></i> إجمالي الأرشيف</div>
    </div>
</div>

<div class="tab-row">
    <button class="tab-btn @(_tab=="entrant"?"active":"")" @onclick='()=>SwitchTab("entrant")'><i class="bi bi-envelope-arrow-down"></i> وارد مؤرشف</button>
    <button class="tab-btn @(_tab=="sortant"?"active":"")" @onclick='()=>SwitchTab("sortant")'><i class="bi bi-envelope-arrow-up"></i> صادر مؤرشف</button>
</div>

<div class="filters-bar">
    <div class="search-wrap">
        <i class="bi bi-search search-icon"></i>
        <input class="search-input" placeholder="بحث في الأرشيف…" @bind="_searchTerm" @bind:event="oninput" @onkeyup="OnSearch" />
    </div>
    <input type="date" class="filter-date" @bind="_dateDebut" @bind:after="LoadAsync" title="من تاريخ" />
    <input type="date" class="filter-date" @bind="_dateFin"   @bind:after="LoadAsync" title="إلى تاريخ" />
    <button class="btn btn-secondary" @onclick="ResetFilter"><i class="bi bi-x-circle"></i></button>
</div>

<div class="table-card">
    <div class="table-inner">
        <table>
            <thead><tr>
                <th>رقم الترتيب</th>
                @if (_tab == "entrant")
                {
                    <th>تاريخ الاستلام</th>
                }
                else
                {
                    <th>تاريخ التحرير</th>
                }
                <th>الموضوع</th>
                @if (_tab == "entrant")
                {
                    <th>المرسل</th>
                }
                else
                {
                    <th>المرسل إليه</th>
                }
                @if (_tab == "entrant")
                {
                    <th>تاريخ الأرشفة</th>
                }
                else
                {
                    <th>تاريخ الإرسال</th>
                }
                <th>النوع</th>
            </tr></thead>
            <tbody>
                @if (_loading)
                {
                    @for (int i = 0; i < 6; i++)
                    {
                        <tr><td colspan="6"><div class="skeleton" style="height:18px;margin:.4rem 0"></div></td></tr>
                    }
                }
                else if (_tab == "entrant" && _entrants?.Any() == true)
                {
                    @foreach (var c in _entrants)
                    {
                        <tr @onclick="()=>ShowEntrantDetail(c.Id)">
                            <td><strong style="color:#0369a1">@c.NumeroOrdre</strong></td>
                            <td>@c.DateReception.ToString("dd/MM/yyyy")</td>
                            <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@c.ObjetCourrier">@c.ObjetCourrier</td>
                            <td>@(c.ExpediteurNom ?? "—")</td>
                            <td>—</td>
                            <td><span class="badge badge-entrant"><i class="bi bi-envelope-arrow-down"></i> وارد</span></td>
                        </tr>
                    }
                }
                else if (_tab == "sortant" && _sortants?.Any() == true)
                {
                    @foreach (var s in _sortants)
                    {
                        <tr @onclick="()=>ShowSortantDetail(s.Id)">
                            <td><strong style="color:#7c3aed">@s.NumeroOrdre</strong></td>
                            <td>@s.DateRedaction.ToString("dd/MM/yyyy")</td>
                            <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@s.ObjetCourrier">@s.ObjetCourrier</td>
                            <td>@(s.DestinataireNom ?? "—")</td>
                            <td>@(s.DateEnvoi.HasValue ? s.DateEnvoi.Value.ToString("dd/MM/yyyy") : "—")</td>
                            <td><span class="badge badge-sortant"><i class="bi bi-envelope-arrow-up"></i> صادر</span></td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="text-align:center;color:#94a3b8;padding:3rem">
                            <i class="bi bi-archive" style="font-size:2rem;display:block;margin-bottom:.5rem"></i>
                            لا يوجد محتوى في الأرشيف
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_totalPages > 1)
    {
        <div class="pagination">
            <button class="pg-btn" disabled="@(_page==1)" @onclick="()=>GoPage(_page-1)"><i class="bi bi-chevron-right"></i></button>
            @for (int p = Math.Max(1, _page - 2); p <= Math.Min(_totalPages, _page + 2); p++)
            {
                int pp = p;
                <button class="pg-btn @(pp==_page?"active":"")" @onclick="()=>GoPage(pp)">@pp</button>
            }
            <button class="pg-btn" disabled="@(_page==_totalPages)" @onclick="()=>GoPage(_page+1)"><i class="bi bi-chevron-left"></i></button>
            <span class="pg-info">@_page / @_totalPages</span>
        </div>
    }
</div>

@* DRAWER — Entrant Detail *@
@if (_entrantDetail != null)
{
    <div class="overlay" @onclick="()=>_entrantDetail=null">
        <div class="drawer" @onclick:stopPropagation="true">
            <div class="drawer-header">
                <div class="drawer-title"><i class="bi bi-archive-fill" style="color:#14b8a6"></i> تفاصيل الأرشيف — بريد وارد</div>
                <button class="close-btn" @onclick="()=>_entrantDetail=null"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="drawer-body">
                <div class="detail-grid">
                    <div class="detail-item"><label>رقم الترتيب</label><span style="font-weight:700;color:#0369a1">@_entrantDetail.NumeroOrdre</span></div>
                    <div class="detail-item"><label>تاريخ الاستلام</label><span>@_entrantDetail.DateReception.ToString("dd/MM/yyyy")</span></div>
                    <div class="detail-item full"><label>الموضوع</label><span>@_entrantDetail.ObjetCourrier</span></div>
                    <div class="detail-item"><label>المرسل</label><span>@(_entrantDetail.ExpediteurNom ?? "—")</span></div>
                    <div class="detail-item"><label>النوع</label><span>@_entrantDetail.TypeDocument</span></div>
                    <div class="detail-item"><label>الأولوية</label><span>@_entrantDetail.Priorite</span></div>
                    <div class="detail-item"><label>طريقة الاستلام</label><span>@_entrantDetail.ModeReception</span></div>
                    <div class="detail-item"><label>الحالة</label><span class="badge badge-archive">مؤرشف</span></div>
                    @if (!string.IsNullOrEmpty(_entrantDetail.CategorieLibelle))
                    {
                        <div class="detail-item"><label>الفئة</label><span>@_entrantDetail.CategorieLibelle</span></div>
                    }
                    @if (_entrantDetail.Archive != null)
                    {
                        <div class="detail-item"><label>تاريخ الأرشفة</label><span>@_entrantDetail.Archive.CreatedAt.ToString("dd/MM/yyyy")</span></div>
                    }
                    @if (!string.IsNullOrEmpty(_entrantDetail.ServiceDestinataireNom))
                    {
                        <div class="detail-item full"><label>الخدمة المعنية</label><span>@_entrantDetail.ServiceDestinataireNom</span></div>
                    }
                    @if (!string.IsNullOrEmpty(_entrantDetail.Observation))
                    {
                        <div class="detail-item full"><label>ملاحظات</label><span>@_entrantDetail.Observation</span></div>
                    }
                </div>
                <div style="margin-top:.5rem">
                    <button class="btn btn-secondary" @onclick='()=>Nav.NavigateTo($"/bureau/incoming/{_entrantDetail.Id}")'>
                        <i class="bi bi-eye"></i> عرض التفاصيل الكاملة
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* DRAWER — Sortant Detail *@
@if (_sortantDetail != null)
{
    <div class="overlay" @onclick="()=>_sortantDetail=null">
        <div class="drawer" @onclick:stopPropagation="true">
            <div class="drawer-header">
                <div class="drawer-title"><i class="bi bi-archive-fill" style="color:#14b8a6"></i> تفاصيل الأرشيف — بريد صادر</div>
                <button class="close-btn" @onclick="()=>_sortantDetail=null"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="drawer-body">
                <div class="detail-grid">
                    <div class="detail-item"><label>رقم الترتيب</label><span style="font-weight:700;color:#7c3aed">@_sortantDetail.NumeroOrdre</span></div>
                    <div class="detail-item"><label>تاريخ التحرير</label><span>@_sortantDetail.DateRedaction.ToString("dd/MM/yyyy")</span></div>
                    <div class="detail-item full"><label>الموضوع</label><span>@_sortantDetail.ObjetCourrier</span></div>
                    <div class="detail-item"><label>المرسل إليه</label><span>@(_sortantDetail.DestinataireNom ?? "—")</span></div>
                    <div class="detail-item"><label>تاريخ الإرسال</label><span>@(_sortantDetail.DateEnvoi.HasValue ? _sortantDetail.DateEnvoi.Value.ToString("dd/MM/yyyy") : "—")</span></div>
                    <div class="detail-item"><label>الموقِّع</label><span>@(_sortantDetail.FonctionSignataire ?? "—")</span></div>
                    <div class="detail-item"><label>الحالة</label><span class="badge badge-archive">مؤرشف</span></div>
                    @if (!string.IsNullOrEmpty(_sortantDetail.CategorieLibelle))
                    {
                        <div class="detail-item"><label>الفئة</label><span>@_sortantDetail.CategorieLibelle</span></div>
                    }
                    @if (!string.IsNullOrEmpty(_sortantDetail.Observation))
                    {
                        <div class="detail-item full"><label>ملاحظات</label><span>@_sortantDetail.Observation</span></div>
                    }
                </div>
                <div style="margin-top:.5rem">
                    <button class="btn btn-secondary" @onclick='()=>Nav.NavigateTo($"/bureau/outgoing/{_sortantDetail.Id}")'>
                        <i class="bi bi-eye"></i> عرض التفاصيل الكاملة
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<CourrierEntrantDto>?     _entrants;
    private List<CourrierSortantDto>?     _sortants;
    private CourrierEntrantDetailDto?     _entrantDetail;
    private CourrierSortantDetailDto?     _sortantDetail;
    private bool   _loading = true;
    private string _tab = "entrant";
    private string? _searchTerm;
    private DateTime? _dateDebut, _dateFin;
    private int _page = 1, _pageSize = 12, _totalPages = 1;
    private int _totalEntrants, _totalSortants;

    protected override async Task OnInitializedAsync()
    {
        // Load stat counts in parallel with initial list
        var countTask = LoadCountsAsync();
        await LoadAsync();
        await countTask;
    }

    private async Task LoadCountsAsync()
    {
        try
        {
            var ep = await EntrantApi.GetPagedAsync(new CourrierEntrantFilterDto { Statut = "Archive", PageNumber = 1, PageSize = 1 });
            _totalEntrants = ep?.TotalCount ?? 0;
        }
        catch { _totalEntrants = 0; }

        try
        {
            var sp = await SortantApi.GetPagedAsync(new CourrierSortantFilterDto { Statut = "Archive", PageNumber = 1, PageSize = 1 });
            _totalSortants = sp?.TotalCount ?? 0;
        }
        catch { _totalSortants = 0; }
    }

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try
        {
            if (_tab == "entrant")
            {
                var f = new CourrierEntrantFilterDto
                {
                    Statut      = "Archive",
                    PageNumber  = _page,
                    PageSize    = _pageSize,
                    SearchTerm  = _searchTerm,
                    DateDebut   = _dateDebut,
                    DateFin     = _dateFin
                };
                var paged = await EntrantApi.GetPagedAsync(f);
                _entrants   = paged?.Items?.ToList();
                _totalPages = paged?.TotalPages ?? 1;
            }
            else
            {
                var f = new CourrierSortantFilterDto
                {
                    Statut      = "Archive",
                    PageNumber  = _page,
                    PageSize    = _pageSize,
                    SearchTerm  = _searchTerm,
                    DateDebut   = _dateDebut,
                    DateFin     = _dateFin
                };
                var paged = await SortantApi.GetPagedAsync(f);
                _sortants   = paged?.Items?.ToList();
                _totalPages = paged?.TotalPages ?? 1;
            }
        }
        catch { }
        finally { _loading = false; }
    }

    private async Task SwitchTab(string t) { _tab = t; _page = 1; await LoadAsync(); }
    private async Task GoPage(int p)       { _page = p; await LoadAsync(); }
    private async Task ResetFilter()       { _searchTerm = null; _dateDebut = _dateFin = null; _page = 1; await LoadAsync(); }

    private System.Threading.CancellationTokenSource? _cts;
    private async Task OnSearch()
    {
        _cts?.Cancel(); _cts = new();
        try { await Task.Delay(400, _cts.Token); _page = 1; await LoadAsync(); } catch { }
    }

    private async Task ShowEntrantDetail(int id)
    {
        _sortantDetail = null;
        try { _entrantDetail = await EntrantApi.GetByIdAsync(id); } catch { }
    }

    private async Task ShowSortantDetail(int id)
    {
        _entrantDetail = null;
        try { _sortantDetail = await SortantApi.GetByIdAsync(id); } catch { }
    }
}
