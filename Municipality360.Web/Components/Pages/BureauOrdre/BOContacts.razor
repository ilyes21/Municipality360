@page "/bureau/contacts"
@using Microsoft.AspNetCore.Authorization
@using Municipality360.Application.DTOs.BureauOrdre
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,BureauOrdre")]
@layout Municipality360.Web.Components.Layout.MainLayout
@inject IBOContactApiService ContactApi

<PageTitle>جهات الاتصال — مكتب الضبط</PageTitle>

<style>
.page-header   { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; flex-wrap:wrap; gap:.75rem; }
.page-title    { font-size:1.3rem; font-weight:800; color:#0f172a; margin:0; display:flex; align-items:center; gap:.5rem; }
.page-sub      { font-size:.8rem; color:#94a3b8; margin-top:.2rem; }
.btn           { display:inline-flex; align-items:center; gap:.4rem; padding:.45rem .95rem; border-radius:9px; border:none; cursor:pointer; font-family:'Tajawal',sans-serif; font-size:.85rem; font-weight:600; transition:all .2s; }
.btn-primary   { background:linear-gradient(135deg,#0369a1,#0ea5e9); color:#fff; box-shadow:0 3px 10px rgba(14,165,233,.3); }
.btn-primary:hover { transform:translateY(-1px); }
.btn-secondary { background:#f1f5f9; color:#374151; }
.btn-secondary:hover { background:#e2e8f0; }
.btn-danger    { background:#fee2e2; color:#dc2626; }
.btn-sm        { padding:.3rem .65rem; font-size:.78rem; }
.btn:disabled  { opacity:.5; cursor:not-allowed; }

.filters-bar { display:flex; gap:.6rem; flex-wrap:wrap; margin-bottom:1.2rem; align-items:center; background:#fff; padding:.85rem 1rem; border-radius:12px; border:1px solid #f1f5f9; }
.search-wrap { position:relative; flex:1; min-width:200px; }
.search-input { width:100%; height:38px; padding:0 1rem 0 2.5rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.86rem; outline:none; background:#fff; }
.search-input:focus { border-color:#0ea5e9; }
.search-icon { position:absolute; right:10px; top:50%; transform:translateY(-50%); color:#94a3b8; }
select.filter-sel { height:38px; padding:0 .75rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.85rem; outline:none; background:#fff; }

.table-card  { background:#fff; border-radius:14px; box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #f1f5f9; overflow:hidden; }
.table-inner { overflow-x:auto; }
table { width:100%; border-collapse:collapse; }
thead tr { background:#f8fafc; border-bottom:2px solid #e2e8f0; }
th { padding:.65rem 1rem; text-align:right; font-size:.73rem; font-weight:700; color:#64748b; white-space:nowrap; }
td { padding:.75rem 1rem; font-size:.84rem; color:#374151; border-bottom:1px solid #f8fafc; vertical-align:middle; }
tbody tr:hover { background:#f0f9ff; }
tbody tr:last-child td { border-bottom:none; }

.badge { display:inline-flex; align-items:center; gap:.25rem; border-radius:99px; padding:.2rem .6rem; font-size:.71rem; font-weight:700; }
.badge-personne { background:#dbeafe; color:#1d4ed8; }
.badge-organisme { background:#dcfce7; color:#15803d; }
.badge-admin { background:#fef3c7; color:#b45309; }

.modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:600; display:flex; align-items:center; justify-content:center; }
.modal-card { background:#fff; border-radius:16px; box-shadow:0 20px 60px rgba(0,0,0,.2); padding:1.75rem; width:min(560px,94vw); animation:popIn .2s ease; max-height:90vh; overflow-y:auto; }
@@keyframes popIn { from{transform:scale(.92);opacity:0} to{transform:scale(1);opacity:1} }
.modal-title { font-size:1rem; font-weight:700; color:#0f172a; margin:0 0 1.25rem; display:flex; align-items:center; gap:.5rem; }
.modal-footer { display:flex; gap:.75rem; justify-content:flex-end; margin-top:1.25rem; }
.form-grid { display:grid; grid-template-columns:1fr 1fr; gap:.75rem; }
.form-group { display:flex; flex-direction:column; gap:.3rem; }
.form-group.full { grid-column:1/-1; }
.form-label { font-size:.8rem; font-weight:700; color:#374151; }
.form-label .req { color:#ef4444; }
.form-control { height:38px; padding:0 .85rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.88rem; outline:none; transition:border-color .2s; background:#fff; width:100%; box-sizing:border-box; }
.form-control:focus { border-color:#0ea5e9; }
.form-control.invalid { border-color:#ef4444; }
.alert-err { background:#fef2f2; border:1px solid #fca5a5; border-radius:9px; padding:.75rem 1rem; font-size:.85rem; color:#dc2626; margin-bottom:1rem; }
.alert-ok  { background:#f0fdf4; border:1px solid #86efac; border-radius:9px; padding:.75rem 1rem; font-size:.85rem; color:#15803d; margin-bottom:1rem; }
.skeleton { background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:8px; }
@@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
</style>

<div class="page-header">
    <div>
        <div class="page-title"><i class="bi bi-person-lines-fill" style="color:#0ea5e9"></i> جهات الاتصال</div>
        <div class="page-sub">مكتب الضبط / إدارة جهات الاتصال</div>
    </div>
    <button class="btn btn-primary" @onclick="OpenNew">
        <i class="bi bi-plus-lg"></i> إضافة جهة اتصال
    </button>
</div>

@if (!string.IsNullOrEmpty(_successMsg))
{ <div class="alert-ok"><i class="bi bi-check-circle-fill"></i> @_successMsg</div> }

<div class="filters-bar">
    <div class="search-wrap">
        <i class="bi bi-search search-icon"></i>
        <input class="search-input" placeholder="ابحث بالاسم أو الجهة أو البريد…"
               @bind="_searchTerm" @bind:event="oninput" @onkeyup="OnSearch" />
    </div>
    <select class="filter-sel" @bind="_typeFilter" @bind:after="LoadAsync">
        <option value="">كل الأنواع</option>
        <option value="Personne">شخص</option>
        <option value="Organisme">هيئة</option>
        <option value="Administration">إدارة</option>
    </select>
    <button class="btn btn-secondary" @onclick="ResetFilter"><i class="bi bi-x-circle"></i> إعادة تعيين</button>
</div>

<div class="table-card">
    <div class="table-inner">
        <table>
            <thead>
                <tr>
                    <th>النوع</th>
                    <th>الاسم الكامل</th>
                    <th>رقم التعريف / CIN</th>
                    <th>الوظيفة / الصفة</th>
                    <th>الهاتف</th>
                    <th>البريد الإلكتروني</th>
                    <th>المدينة</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (_loading)
                {
                    @for (int i = 0; i < 5; i++)
                    {
                        <tr><td colspan="8"><div class="skeleton" style="height:18px;margin:.4rem 0"></div></td></tr>
                    }
                }
                else if (_contacts.Count > 0)
                {
                    @foreach (var c in _contacts)
                    {
                        <tr>
                            <td><span class="badge @TypeBadge(c.TypeContact)">@TypeLabel(c.TypeContact)</span></td>
                            <td style="font-weight:600">@c.NomComplet</td>
                            <td style="font-size:.8rem;color:#64748b">@(c.CIN ?? "—")</td>
                            <td style="font-size:.8rem">@(c.Fonction ?? "—")</td>
                            <td>@(c.Telephone ?? "—")</td>
                            <td style="font-size:.8rem">@(c.Email ?? "—")</td>
                            <td>@(c.Ville ?? "—")</td>
                            <td>
                                <div style="display:flex;gap:.4rem">
                                    <button class="btn btn-secondary btn-sm" @onclick="() => OpenEdit(c)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => ConfirmDelete(c)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" style="text-align:center;color:#94a3b8;padding:3rem">
                            <i class="bi bi-person-x" style="font-size:2rem;display:block;margin-bottom:.5rem"></i>
                            لا توجد جهات اتصال
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* ════════ MODAL: AJOUT / MODIFICATION ════════ *@
@if (_showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-title">
                <i class="bi @(_editContact == null ? "bi-person-plus" : "bi-person-gear")" style="color:#0ea5e9"></i>
                @(_editContact == null ? "إضافة جهة اتصال جديدة" : "تعديل جهة الاتصال")
            </div>

            @if (!string.IsNullOrEmpty(_modalError))
            { <div class="alert-err">@_modalError</div> }

            <div class="form-grid">
                <div class="form-group full">
                    <label class="form-label">نوع الجهة <span class="req">*</span></label>
                    <select class="form-control" @bind="_dto.TypeContact">
                        <option value="Personne">شخص</option>
                        <option value="Organisme">هيئة / مؤسسة</option>
                        <option value="Administration">إدارة</option>
                    </select>
                </div>

                @if (_dto.TypeContact == "Personne")
                {
                    <div class="form-group">
                        <label class="form-label">اللقب</label>
                        <input type="text" class="form-control" placeholder="اللقب…" @bind="_dto.Nom" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">الاسم</label>
                        <input type="text" class="form-control" placeholder="الاسم…" @bind="_dto.Prenom" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">رقم التعريف (CIN)</label>
                        <input type="text" class="form-control" placeholder="رقم بطاقة الهوية…" @bind="_dto.CIN" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">الوظيفة / الصفة</label>
                        <input type="text" class="form-control" placeholder="مثال: مدير، محامي…" @bind="_dto.Fonction" />
                    </div>
                }
                else
                {
                    <div class="form-group full">
                        <label class="form-label">اسم الجهة <span class="req">*</span></label>
                        <input type="text" class="form-control" placeholder="اسم الهيئة أو الإدارة…" @bind="_dto.RaisonSociale" />
                    </div>
                    <div class="form-group full">
                        <label class="form-label">الوظيفة / الصفة</label>
                        <input type="text" class="form-control" placeholder="مثال: رئاسة، مديرية…" @bind="_dto.Fonction" />
                    </div>
                }

                <div class="form-group">
                    <label class="form-label">الهاتف</label>
                    <input type="tel" class="form-control" placeholder="رقم الهاتف…" @bind="_dto.Telephone" />
                </div>
                <div class="form-group">
                    <label class="form-label">البريد الإلكتروني</label>
                    <input type="email" class="form-control" placeholder="البريد الإلكتروني…" @bind="_dto.Email" />
                </div>
                <div class="form-group">
                    <label class="form-label">العنوان</label>
                    <input type="text" class="form-control" placeholder="العنوان…" @bind="_dto.Adresse" />
                </div>
                <div class="form-group">
                    <label class="form-label">المدينة</label>
                    <input type="text" class="form-control" placeholder="المدينة…" @bind="_dto.Ville" />
                </div>
                <div class="form-group">
                    <label class="form-label">الولاية</label>
                    <input type="text" class="form-control" placeholder="الولاية…" @bind="_dto.Wilaya" />
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">إلغاء</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm"></span> }
                    <i class="bi bi-check2-circle"></i> حفظ
                </button>
            </div>
        </div>
    </div>
}

@* ════════ MODAL: CONFIRM DELETE ════════ *@
@if (_deleteContact != null)
{
    <div class="modal-overlay" @onclick="() => _deleteContact = null">
        <div class="modal-card" style="width:min(400px,94vw)" @onclick:stopPropagation="true">
            <div class="modal-title"><i class="bi bi-trash" style="color:#dc2626"></i> تأكيد الحذف</div>
            <p style="color:#374151;margin:.5rem 0 1rem">
                هل تريد حذف جهة الاتصال <strong>@_deleteContact.NomComplet</strong> نهائياً؟
            </p>
            @if (!string.IsNullOrEmpty(_modalError))
            { <div class="alert-err">@_modalError</div> }
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => _deleteContact = null">إلغاء</button>
                <button class="btn btn-danger" @onclick="DeleteAsync" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm"></span> }
                    حذف
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<BOContactDto> _contacts    = new();
    private bool               _loading;
    private string             _searchTerm  = "";
    private string             _typeFilter  = "";
    private string?            _successMsg;

    private bool               _showModal;
    private bool               _saving;
    private string?            _modalError;
    private CreateBOContactDto _dto          = new() { TypeContact = "Personne" };
    private BOContactDto?      _editContact;
    private BOContactDto?      _deleteContact;

    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try
        {
            var all = await ContactApi.SearchAsync(_searchTerm);
            _contacts = (all ?? new())
                .Where(c => string.IsNullOrEmpty(_typeFilter) || c.TypeContact == _typeFilter)
                .ToList();
        }
        catch { _contacts = new(); }
        finally { _loading = false; }
    }

    private async Task OnSearch()
    {
        _cts?.Cancel(); _cts = new();
        try { await Task.Delay(350, _cts.Token); await LoadAsync(); }
        catch { }
    }

    private async Task ResetFilter()
    {
        _searchTerm = ""; _typeFilter = "";
        await LoadAsync();
    }

    private void OpenNew()
    {
        _dto = new CreateBOContactDto { TypeContact = "Personne" };
        _editContact = null; _modalError = null; _showModal = true;
    }

    private void OpenEdit(BOContactDto c)
    {
        _editContact = c;
        _dto = new CreateBOContactDto
        {
            TypeContact   = c.TypeContact,
            Nom           = c.Nom,
            Prenom        = c.Prenom,
            CIN           = c.CIN,
            RaisonSociale = c.RaisonSociale,
            Fonction      = c.Fonction,
            Adresse       = c.Adresse,
            Ville         = c.Ville,
            Wilaya        = c.Wilaya,
            Telephone     = c.Telephone,
            Email         = c.Email
        };
        _modalError = null; _showModal = true;
    }

    private void CloseModal() { _showModal = false; _editContact = null; }

    private async Task SaveAsync()
    {
        if (string.IsNullOrEmpty(_dto.TypeContact)) { _modalError = "اختر نوع الجهة."; return; }
        _saving = true; _modalError = null;
        try
        {
            bool ok;
            if (_editContact == null)
                ok = await ContactApi.CreateAsync(_dto) != null;
            else
                ok = await ContactApi.UpdateAsync(_editContact.Id, _dto) != null;

            if (ok)
            {
                _successMsg = _editContact == null ? "تم إضافة جهة الاتصال بنجاح." : "تم تعديل جهة الاتصال.";
                CloseModal();
                await LoadAsync();
                _ = Task.Delay(3000).ContinueWith(_ => { _successMsg = null; InvokeAsync(StateHasChanged); });
            }
            else _modalError = "حدث خطأ أثناء الحفظ.";
        }
        finally { _saving = false; }
    }

    private void ConfirmDelete(BOContactDto c) { _deleteContact = c; _modalError = null; }

    private async Task DeleteAsync()
    {
        if (_deleteContact == null) return;
        _saving = true; _modalError = null;
        try
        {
            var ok = await ContactApi.DeleteAsync(_deleteContact.Id);
            if (ok)
            {
                _successMsg = "تم حذف جهة الاتصال.";
                _deleteContact = null;
                await LoadAsync();
                _ = Task.Delay(3000).ContinueWith(_ => { _successMsg = null; InvokeAsync(StateHasChanged); });
            }
            else _modalError = "حدث خطأ أثناء الحذف.";
        }
        finally { _saving = false; }
    }

    private static string TypeBadge(string t) => t switch
    {
        "Personne"       => "badge-personne",
        "Organisme"      => "badge-organisme",
        "Administration" => "badge-admin",
        _                => "badge-personne"
    };

    private static string TypeLabel(string t) => t switch
    {
        "Personne"       => "شخص",
        "Organisme"      => "هيئة",
        "Administration" => "إدارة",
        _                => t
    };
}
