@page "/bureau/inbox"
@using Microsoft.AspNetCore.Authorization
@using Municipality360.Application.DTOs.BureauOrdre
@using System.Security.Claims
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,BureauOrdre,Employee")]
@layout Municipality360.Web.Components.Layout.MainLayout
@inject ICourrierEntrantApiService EntrantApi
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<PageTitle>صندوق الوارد — مكتب الضبط</PageTitle>

<style>
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; }
    .page-title  { font-size:1.3rem; font-weight:800; color:#0f172a; margin:0; }
    .page-sub    { font-size:.8rem; color:#94a3b8; margin-top:.2rem; }

    .kpi-row { display:flex; gap:1rem; margin-bottom:1.2rem; flex-wrap:wrap; }
    .kpi-pill { background:#fff; border-radius:10px; padding:.55rem 1rem; box-shadow:0 1px 6px rgba(0,0,0,.06); border:1px solid #f1f5f9; display:flex; align-items:center; gap:.6rem; }
    .kpi-pill-val { font-size:1.1rem; font-weight:800; color:#0f172a; }
    .kpi-pill-lbl { font-size:.78rem; color:#64748b; }

    .filters-bar { display:flex; gap:.75rem; flex-wrap:wrap; margin-bottom:1.2rem; align-items:center; }
    .search-wrap { position:relative; flex:1; min-width:200px; }
    .search-input { width:100%; height:38px; padding:0 1rem 0 2.5rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.86rem; outline:none; transition:border-color .2s; background:#fff; }
    .search-input:focus { border-color:#0ea5e9; box-shadow:0 0 0 3px rgba(14,165,233,.1); }
    .search-icon { position:absolute; right:10px; top:50%; transform:translateY(-50%); color:#94a3b8; pointer-events:none; }
    select.filter-sel { height:38px; padding:0 .75rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.85rem; outline:none; background:#fff; cursor:pointer; }
    .btn { display:inline-flex; align-items:center; gap:.4rem; padding:.45rem .95rem; border-radius:9px; border:none; cursor:pointer; font-family:'Tajawal',sans-serif; font-size:.85rem; font-weight:600; transition:all .2s; }
    .btn-secondary { background:#f1f5f9; color:#374151; }
    .btn-secondary:hover { background:#e2e8f0; }

    .table-card  { background:#fff; border-radius:14px; box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #f1f5f9; overflow:hidden; }
    .table-inner { overflow-x:auto; }
    table { width:100%; border-collapse:collapse; }
    thead tr { background:#f0f9ff; border-bottom:1px solid #bae6fd; }
    th { padding:.65rem 1rem; text-align:right; font-size:.73rem; font-weight:700; color:#0369a1; white-space:nowrap; }
    td { padding:.8rem 1rem; font-size:.85rem; color:#374151; border-bottom:1px solid #f8fafc; vertical-align:middle; }
    tbody tr { cursor:pointer; }
    tbody tr:hover { background:#f0f9ff; }
    tbody tr:last-child td { border-bottom:none; }
    .row-unread td { font-weight:600; background:#fefce8 !important; }

    .badge { display:inline-flex; align-items:center; gap:.25rem; border-radius:99px; padding:.2rem .65rem; font-size:.72rem; font-weight:600; }
    .badge-urgent   { background:#fee2e2; color:#dc2626; }
    .badge-haute    { background:#fef3c7; color:#b45309; }
    .badge-normale  { background:#dbeafe; color:#1d4ed8; }
    .badge-basse    { background:#f3f4f6; color:#6b7280; }
    .badge-enregistre { background:#dbeafe; color:#1d4ed8; }
    .badge-encours    { background:#fef3c7; color:#b45309; }
    .badge-traite     { background:#dcfce7; color:#15803d; }
    .badge-retard     { background:#fee2e2; color:#dc2626; }

    .pagination { display:flex; align-items:center; justify-content:center; gap:.4rem; padding:1rem; }
    .pg-btn { width:34px; height:34px; border-radius:8px; border:1.5px solid #e2e8f0; background:#fff; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:.82rem; color:#374151; transition:all .2s; }
    .pg-btn:hover { border-color:#0ea5e9; color:#0ea5e9; }
    .pg-btn.active { background:#0ea5e9; border-color:#0ea5e9; color:#fff; }
    .pg-btn:disabled { opacity:.4; cursor:not-allowed; }
    .pg-info { font-size:.82rem; color:#64748b; margin:0 .5rem; }

    .overlay  { position:fixed; inset:0; background:rgba(0,0,0,.4); z-index:500; display:flex; align-items:flex-start; justify-content:flex-end; }
    .drawer   { width:min(560px,95vw); height:100vh; background:#fff; box-shadow:-6px 0 40px rgba(0,0,0,.15); display:flex; flex-direction:column; }
    .drawer-header { padding:1.2rem 1.5rem; border-bottom:1px solid #f1f5f9; display:flex; align-items:center; justify-content:space-between; background:#f0f9ff; flex-shrink:0; }
    .drawer-title  { font-size:1rem; font-weight:700; color:#0f172a; }
    .drawer-body   { flex:1; overflow-y:auto; padding:1.5rem; display:flex; flex-direction:column; gap:1rem; }
    .close-btn { background:none; border:none; font-size:1.2rem; cursor:pointer; color:#64748b; }
    .close-btn:hover { color:#0f172a; }
    .detail-grid { display:grid; grid-template-columns:1fr 1fr; gap:.75rem 1.5rem; }
    .detail-item label { display:block; font-size:.72rem; font-weight:700; color:#64748b; text-transform:uppercase; margin-bottom:.2rem; }
    .detail-item span  { font-size:.88rem; color:#0f172a; }
    .detail-item.full  { grid-column:1/-1; }

    .action-row { display:flex; gap:.6rem; flex-wrap:wrap; }
    .btn-primary { background:linear-gradient(135deg,#0369a1,#0ea5e9); color:#fff; box-shadow:0 3px 10px rgba(14,165,233,.3); }
    .btn-primary:hover { transform:translateY(-1px); }
    .btn-success { background:linear-gradient(135deg,#059669,#10b981); color:#fff; }

    .skeleton { background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:8px; }
    @@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
</style>

<div class="page-header">
    <div>
        <div class="page-title"><i class="bi bi-inbox" style="color:#0ea5e9"></i> صندوق الوارد</div>
        <div class="page-sub">البريد الموجه إليك شخصياً</div>
    </div>
</div>

@* KPI pills *@
<div class="kpi-row">
    <div class="kpi-pill">
        <i class="bi bi-envelope" style="color:#0369a1;font-size:1.1rem"></i>
        <div><div class="kpi-pill-val">@_total</div><div class="kpi-pill-lbl">إجمالي</div></div>
    </div>
    <div class="kpi-pill">
        <i class="bi bi-hourglass-split" style="color:#d97706;font-size:1.1rem"></i>
        <div><div class="kpi-pill-val">@_enCours</div><div class="kpi-pill-lbl">في المعالجة</div></div>
    </div>
    <div class="kpi-pill">
        <i class="bi bi-alarm" style="color:#dc2626;font-size:1.1rem"></i>
        <div><div class="kpi-pill-val">@_enRetard</div><div class="kpi-pill-lbl">متأخرة</div></div>
    </div>
    <div class="kpi-pill">
        <i class="bi bi-check-circle" style="color:#059669;font-size:1.1rem"></i>
        <div><div class="kpi-pill-val">@_traite</div><div class="kpi-pill-lbl">معالجة</div></div>
    </div>
</div>

<div class="filters-bar">
    <div class="search-wrap">
        <i class="bi bi-search search-icon"></i>
        <input class="search-input" placeholder="بحث في موضوع أو رقم الترتيب…" @bind="_search" @bind:event="oninput" @onkeyup="OnSearch" />
    </div>
    <select class="filter-sel" @bind="_filterStatut" @bind:after="Reload">
        <option value="">كل الحالات</option>
        <option value="Enregistre">مسجل</option>
        <option value="EnCours">جاري المعالجة</option>
        <option value="Traite">تمت المعالجة</option>
    </select>
    <select class="filter-sel" @bind="_filterPriorite" @bind:after="Reload">
        <option value="">كل الأولويات</option>
        <option value="Urgent">عاجل</option>
        <option value="Haute">مرتفعة</option>
        <option value="Normale">عادية</option>
    </select>
    <button class="btn btn-secondary" @onclick="ResetFilters"><i class="bi bi-x-circle"></i> إعادة تعيين</button>
</div>

<div class="table-card">
    <div class="table-inner">
        <table>
            <thead><tr>
                <th>رقم الترتيب</th>
                <th>تاريخ الاستلام</th>
                <th>الموضوع</th>
                <th>المرسل</th>
                <th>الأولوية</th>
                <th>الحالة</th>
                <th>الرد المطلوب</th>
            </tr></thead>
            <tbody>
                @if (_loading)
                {
                    @for (int i = 0; i < 8; i++) {
                        <tr><td colspan="7"><div class="skeleton" style="height:16px;margin:.35rem 0"></div></td></tr>
                    }
                }
                else if (_items?.Any() == true)
                {
                    @foreach (var c in _items)
                    {
                        <tr class="@(c.EnRetard ? "row-unread" : "")" @onclick="()=>OpenDetail(c.Id)">
                            <td><strong style="color:#0369a1">@c.NumeroOrdre</strong></td>
                            <td>@c.DateReception.ToString("dd/MM/yyyy")</td>
                            <td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@c.ObjetCourrier">@c.ObjetCourrier</td>
                            <td>@(c.ExpediteurNom.Length > 20 ? c.ExpediteurNom[..20] + "…" : c.ExpediteurNom)</td>
                            <td>
                                <span class="badge @GetPrioriteBadge(c.Priorite)">@c.Priorite</span>
                            </td>
                            <td>
                                @if (c.EnRetard)
                                {
                                    <span class="badge badge-retard"><i class="bi bi-alarm"></i> متأخر</span>
                                }
                                else
                                {
                                    <span class="badge @GetStatutBadge(c.Statut)">@c.Statut</span>
                                }
                            </td>
                            <td>
                                @if (c.NecessiteReponse)
                                {
                                    @if (c.DelaiReponse.HasValue)
                                    {
                                        <span style="font-size:.75rem;color:#d97706"><i class="bi bi-calendar-event"></i> @c.DelaiReponse.Value.ToString("dd/MM/yyyy")</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-encours"><i class="bi bi-reply"></i> نعم</span>
                                    }
                                }
                                else
                                {
                                    <span style="color:#94a3b8;font-size:.8rem">—</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" style="text-align:center;color:#94a3b8;padding:3rem">
                            <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:.5rem"></i>
                            صندوق الوارد فارغ
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_totalPages > 1)
    {
        <div class="pagination">
            <button class="pg-btn" disabled="@(_page==1)" @onclick="()=>GoPage(_page-1)"><i class="bi bi-chevron-right"></i></button>
            @for (int p = Math.Max(1, _page-2); p <= Math.Min(_totalPages, _page+2); p++)
            {
                int pp = p;
                <button class="pg-btn @(pp==_page?"active":"")" @onclick="()=>GoPage(pp)">@pp</button>
            }
            <button class="pg-btn" disabled="@(_page==_totalPages)" @onclick="()=>GoPage(_page+1)"><i class="bi bi-chevron-left"></i></button>
            <span class="pg-info">@_page / @_totalPages</span>
        </div>
    }
</div>

@* Detail Drawer *@
@if (_detail != null)
{
    <div class="overlay" @onclick="()=>_detail=null">
        <div class="drawer" @onclick:stopPropagation="true">
            <div class="drawer-header">
                <div class="drawer-title"><i class="bi bi-envelope-open" style="color:#0ea5e9"></i> تفاصيل البريد الوارد</div>
                <button class="close-btn" @onclick="()=>_detail=null"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="drawer-body">
                <div class="detail-grid">
                    <div class="detail-item"><label>رقم الترتيب</label><span style="font-weight:700;color:#0369a1">@_detail.NumeroOrdre</span></div>
                    <div class="detail-item"><label>تاريخ الاستلام</label><span>@_detail.DateReception.ToString("dd/MM/yyyy")</span></div>
                    <div class="detail-item full"><label>الموضوع</label><span>@_detail.ObjetCourrier</span></div>
                    <div class="detail-item"><label>المرسل</label><span>@(_detail.ExpediteurNom ?? "—")</span></div>
                    <div class="detail-item"><label>طريقة الاستلام</label><span>@_detail.ModeReception</span></div>
                    <div class="detail-item"><label>الأولوية</label><span class="badge @GetPrioriteBadge(_detail.Priorite)">@_detail.Priorite</span></div>
                    <div class="detail-item"><label>الحالة</label><span class="badge @GetStatutBadge(_detail.Statut)">@_detail.Statut</span></div>
                    @if (!string.IsNullOrEmpty(_detail.CategorieLibelle))
                    {
                        <div class="detail-item"><label>الفئة</label><span>@_detail.CategorieLibelle</span></div>
                    }
                    @if (_detail.NecessiteReponse)
                    {
                        <div class="detail-item"><label>تاريخ الرد المطلوب</label><span style="color:@(_detail.EnRetard?"#dc2626":"inherit")">@(_detail.DelaiReponse?.ToString("dd/MM/yyyy") ?? "—")</span></div>
                    }
                    @if (!string.IsNullOrEmpty(_detail.ServiceDestinataireNom))
                    {
                        <div class="detail-item full"><label>الخدمة المعنية</label><span>@_detail.ServiceDestinataireNom</span></div>
                    }
                    @if (!string.IsNullOrEmpty(_detail.Observation))
                    {
                        <div class="detail-item full"><label>ملاحظات</label><span>@_detail.Observation</span></div>
                    }
                </div>

                @if (_detail.PiecesJointes?.Any() == true)
                {
                    <div>
                        <div style="font-size:.8rem;font-weight:700;color:#64748b;margin-bottom:.5rem">المرفقات (@_detail.PiecesJointes.Count)</div>
                        @foreach (var pj in _detail.PiecesJointes)
                        {
                            <div style="display:flex;align-items:center;gap:.5rem;padding:.4rem .6rem;background:#f8fafc;border-radius:7px;margin-bottom:.3rem;font-size:.8rem">
                                <i class="bi bi-paperclip" style="color:#64748b"></i>
                                <span>@pj.NomFichierOriginal</span>
                                <span style="color:#94a3b8;font-size:.72rem">(@(pj.TailleFichierOctets / 1024) KB)</span>
                            </div>
                        }
                    </div>
                }

                @if (_detail.Circuit?.Any() == true)
                {
                    <div>
                        <div style="font-size:.8rem;font-weight:700;color:#64748b;margin-bottom:.5rem">مسار المعالجة</div>
                        @foreach (var step in _detail.Circuit)
                        {
                            <div style="display:flex;align-items:flex-start;gap:.6rem;padding:.5rem .7rem;border-right:3px solid @(step.StatutEtape=="Traite"?"#10b981":"#e2e8f0");margin-bottom:.4rem;background:#f8fafc;border-radius:0 8px 8px 0">
                                <i class="bi @(step.StatutEtape=="Traite"?"bi-check-circle-fill":"bi-circle") " style="color:@(step.StatutEtape=="Traite"?"#10b981":"#94a3b8");margin-top:.1rem"></i>
                                <div>
                                    <div style="font-size:.82rem;font-weight:600">@step.ServiceRecepteurNom</div>
                                    <div style="font-size:.75rem;color:#64748b">@step.TypeAction — @step.DateTransmission.ToString("dd/MM/yyyy")</div>
                                    @if (!string.IsNullOrEmpty(step.CommentaireTraitement))
                                    {
                                        <div style="font-size:.75rem;color:#374151;margin-top:.2rem">@step.CommentaireTraitement</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="action-row">
                    <button class="btn btn-primary" @onclick='()=>Nav.NavigateTo($"/bureau/incoming/{_detail.Id}")'>
                        <i class="bi bi-eye"></i> عرض الكامل
                    </button>
                    @if (_detail.Statut != "Traite" && _detail.Statut != "Archive")
                    {
                        <button class="btn btn-success" @onclick='()=>Nav.NavigateTo($"/bureau/outgoing/new?ref={_detail.Id}")'>
                            <i class="bi bi-reply"></i> إنشاء رد
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<CourrierEntrantDto>? _items;
    private CourrierEntrantDetailDto? _detail;
    private bool _loading = true;
    private string? _search;
    private string? _filterStatut;
    private string? _filterPriorite;
    private int _page = 1, _totalPages = 1;
    private int _total, _enCours, _enRetard, _traite;
    private string? _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _currentUserId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        await Task.WhenAll(LoadAsync(), LoadCountsAsync());
    }

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try
        {
            var f = new CourrierEntrantFilterDto
            {
                PageNumber = _page,
                PageSize = 12,
                SearchTerm = _search,
                Statut = _filterStatut,
                Priorite = _filterPriorite
            };
            var paged = await EntrantApi.GetPagedAsync(f);
            _items = paged?.Items?.ToList();
            _totalPages = paged?.TotalPages ?? 1;
            _total = paged?.TotalCount ?? 0;
        }
        catch { }
        finally { _loading = false; }
    }

    private async Task LoadCountsAsync()
    {
        try
        {
            var ec = await EntrantApi.GetPagedAsync(new CourrierEntrantFilterDto { Statut = "EnCours", PageNumber = 1, PageSize = 1 });
            _enCours = ec?.TotalCount ?? 0;
            var er = await EntrantApi.GetPagedAsync(new CourrierEntrantFilterDto { EnRetard = true, PageNumber = 1, PageSize = 1 });
            _enRetard = er?.TotalCount ?? 0;
            var et = await EntrantApi.GetPagedAsync(new CourrierEntrantFilterDto { Statut = "Traite", PageNumber = 1, PageSize = 1 });
            _traite = et?.TotalCount ?? 0;
        }
        catch { }
    }

    private async Task OpenDetail(int id)
    {
        try { _detail = await EntrantApi.GetByIdAsync(id); } catch { }
    }

    private async Task Reload() { _page = 1; await LoadAsync(); }
    private async Task GoPage(int p) { _page = p; await LoadAsync(); }
    private async Task ResetFilters() { _search = null; _filterStatut = null; _filterPriorite = null; _page = 1; await LoadAsync(); }

    private System.Threading.CancellationTokenSource? _cts;
    private async Task OnSearch()
    {
        _cts?.Cancel(); _cts = new();
        try { await Task.Delay(350, _cts.Token); _page = 1; await LoadAsync(); } catch { }
    }

    private static string GetPrioriteBadge(string p) => p switch
    {
        "Urgent"  => "badge-urgent",
        "Haute"   => "badge-haute",
        "Normale" => "badge-normale",
        _         => "badge-basse"
    };

    private static string GetStatutBadge(string s) => s switch
    {
        "Enregistre" => "badge-enregistre",
        "EnCours"    => "badge-encours",
        "Traite"     => "badge-traite",
        _            => "badge-enregistre"
    };
}
