@page "/bureau/search"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,BureauOrdre")]
@layout Municipality360.Web.Components.Layout.MainLayout
@inject ICourrierEntrantApiService EntrantApi
@inject ICourrierSortantApiService SortantApi
@inject NavigationManager Nav

<PageTitle>البحث — مكتب الضبط</PageTitle>

<style>
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; }
    .page-title  { font-size:1.3rem; font-weight:800; color:#0f172a; margin:0; }
    .page-sub    { font-size:.8rem; color:#94a3b8; margin-top:.2rem; }

    .search-hero { background:linear-gradient(135deg,#0b1628,#0d2035); border-radius:16px; padding:2rem; margin-bottom:1.75rem; text-align:center; }
    .search-hero h2 { color:#e0f2fe; font-size:1.4rem; margin:0 0 1.2rem; font-weight:700; }
    .search-big-wrap { display:flex; gap:.75rem; max-width:700px; margin:0 auto; }
    .search-big { flex:1; height:50px; padding:0 1.25rem 0 3.5rem; border:2px solid rgba(14,165,233,.4); border-radius:12px; font-family:'Tajawal',sans-serif; font-size:1rem; outline:none; background:rgba(255,255,255,.08); color:#e0f2fe; transition:all .25s; }
    .search-big::placeholder { color:rgba(224,242,254,.45); }
    .search-big:focus { border-color:#0ea5e9; background:rgba(255,255,255,.12); }
    .search-big-wrap { position:relative; }
    .search-big-icon { position:absolute; right:16px; top:50%; transform:translateY(-50%); color:#7dd3fc; font-size:1.2rem; pointer-events:none; }
    .btn-search { height:50px; padding:0 1.5rem; background:linear-gradient(135deg,#0369a1,#0ea5e9); color:#fff; border:none; border-radius:12px; font-family:'Tajawal',sans-serif; font-size:.95rem; font-weight:700; cursor:pointer; transition:all .2s; white-space:nowrap; }
    .btn-search:hover { transform:translateY(-1px); box-shadow:0 4px 16px rgba(14,165,233,.4); }

    .adv-filters { background:#fff; border-radius:14px; box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #f1f5f9; padding:1.25rem; margin-bottom:1.5rem; }
    .adv-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:.85rem; }
    .form-group { display:flex; flex-direction:column; gap:.3rem; }
    .form-label { font-size:.78rem; font-weight:700; color:#64748b; }
    .form-control { height:36px; padding:0 .75rem; border:1.5px solid #e2e8f0; border-radius:8px; font-family:'Tajawal',sans-serif; font-size:.85rem; outline:none; transition:border-color .2s; background:#fff; }
    .form-control:focus { border-color:#0ea5e9; }
    .adv-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:.85rem; }
    .adv-title  { font-size:.88rem; font-weight:700; color:#374151; display:flex; align-items:center; gap:.4rem; }
    .btn-clear  { background:none; border:none; color:#ef4444; font-family:'Tajawal',sans-serif; font-size:.8rem; cursor:pointer; }

    .results-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:.85rem; }
    .results-count  { font-size:.9rem; font-weight:700; color:#0f172a; }
    .tab-row { display:flex; gap:.5rem; margin-bottom:1rem; }
    .tab-btn { padding:.38rem .9rem; border-radius:8px; border:1.5px solid #e2e8f0; background:#fff; font-family:'Tajawal',sans-serif; font-size:.84rem; cursor:pointer; transition:all .2s; display:flex; align-items:center; gap:.4rem; }
    .tab-btn.active { background:#0ea5e9; color:#fff; border-color:#0ea5e9; }
    .tab-count { background:rgba(0,0,0,.1); border-radius:99px; padding:.1rem .5rem; font-size:.72rem; }

    .table-card  { background:#fff; border-radius:14px; box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #f1f5f9; overflow:hidden; }
    .table-inner { overflow-x:auto; }
    table { width:100%; border-collapse:collapse; }
    th { padding:.6rem 1rem; text-align:right; font-size:.72rem; font-weight:700; color:#64748b; white-space:nowrap; background:#f8fafc; border-bottom:1px solid #e2e8f0; }
    td { padding:.75rem 1rem; font-size:.84rem; color:#374151; border-bottom:1px solid #f8fafc; vertical-align:middle; }
    tbody tr { cursor:pointer; }
    tbody tr:hover { background:#f0f9ff; }
    tbody tr:last-child td { border-bottom:none; }

    .badge { display:inline-flex; align-items:center; gap:.3rem; border-radius:99px; padding:.2rem .6rem; font-size:.72rem; font-weight:600; }
    .badge-entrant    { background:#e0f2fe; color:#0369a1; }
    .badge-sortant    { background:#ede9fe; color:#7c3aed; }
    .badge-encours    { background:#fef3c7; color:#b45309; }
    .badge-traite     { background:#dcfce7; color:#15803d; }
    .badge-enregistre { background:#dbeafe; color:#1d4ed8; }
    .badge-archive    { background:#f3f4f6; color:#6b7280; }
    .badge-envoye     { background:#dbeafe; color:#1d4ed8; }
    .badge-urgent     { background:#fee2e2; color:#dc2626; }

    mark { background:#fef9c3; color:#78350f; border-radius:3px; padding:0 2px; }

    .empty-state { text-align:center; padding:3rem; color:#94a3b8; }
    .empty-state i { font-size:2.5rem; display:block; margin-bottom:.75rem; }
    .empty-state h3 { font-size:1rem; font-weight:600; color:#374151; margin:0 0 .35rem; }

    .skeleton { background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:8px; }
    @@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

    .result-num { font-weight:700; color:#0369a1; }
    .result-num-s { font-weight:700; color:#7c3aed; }
</style>

<div class="page-header">
    <div>
        <div class="page-title"><i class="bi bi-search" style="color:#0ea5e9"></i> البحث</div>
        <div class="page-sub">بحث شامل في البريد الوارد والصادر</div>
    </div>
</div>

@* Hero Search *@
<div class="search-hero">
    <h2>🔍 ابحث في جميع وثائق مكتب الضبط</h2>
    <div class="search-big-wrap">
        <i class="bi bi-search search-big-icon"></i>
        <input class="search-big" placeholder="أدخل رقم الوثيقة أو الموضوع أو اسم المرسل…"
               @bind="_searchTerm" @bind:event="oninput"
               @onkeyup="OnKeyUp" />
        <button class="btn-search" @onclick="SearchAsync">
            <i class="bi bi-search"></i> بحث
        </button>
    </div>
</div>

@* Advanced filters *@
<div class="adv-filters">
    <div class="adv-header">
        <div class="adv-title"><i class="bi bi-funnel"></i> تصفية متقدمة</div>
        <button class="btn-clear" @onclick="ClearAll"><i class="bi bi-x-circle"></i> مسح الكل</button>
    </div>
    <div class="adv-grid">
        <div class="form-group">
            <label class="form-label">نوع الوثيقة</label>
            <select class="form-control" @bind="_typeDocument">
                <option value="">الكل</option>
                <option value="Lettre">رسالة</option><option value="Décision">قرار</option>
                <option value="Note">مذكرة</option><option value="Rapport">تقرير</option>
                <option value="Circulaire">منشور</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">الأولوية</label>
            <select class="form-control" @bind="_priorite">
                <option value="">الكل</option>
                <option value="Normal">عادي</option><option value="Urgent">عاجل</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">الحالة — وارد</label>
            <select class="form-control" @bind="_statutEntrant">
                <option value="">الكل</option>
                <option value="Enregistre">مسجّل</option><option value="EnCours">قيد المعالجة</option>
                <option value="Traite">تمت المعالجة</option><option value="Archive">مؤرشف</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">الحالة — صادر</label>
            <select class="form-control" @bind="_statutSortant">
                <option value="">الكل</option>
                <option value="Brouillon">مسودة</option><option value="EnValidation">في انتظار التوقيع</option>
                <option value="Signe">موقّع</option><option value="Envoye">مُرسَل</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">من تاريخ</label>
            <input type="date" class="form-control" @bind="_dateDebut" />
        </div>
        <div class="form-group">
            <label class="form-label">إلى تاريخ</label>
            <input type="date" class="form-control" @bind="_dateFin" />
        </div>
    </div>
    <div style="display:flex;justify-content:flex-end;margin-top:1rem">
        <button style="padding:.45rem 1.1rem;border-radius:9px;border:none;background:linear-gradient(135deg,#0369a1,#0ea5e9);color:#fff;font-family:'Tajawal',sans-serif;font-size:.88rem;font-weight:700;cursor:pointer" @onclick="SearchAsync">
            <i class="bi bi-search"></i> بحث
        </button>
    </div>
</div>

@* Results *@
@if(_searched)
{
    <div class="results-header">
        <div class="results-count">
            نتائج البحث:
            <strong>@_entrants.Count</strong> وارد،
            <strong>@_sortants.Count</strong> صادر
            @if(!string.IsNullOrEmpty(_searchTerm))
            { <text> — "<em>@_searchTerm</em>"</text> }
        </div>
    </div>

    <div class="tab-row">
        <button class="tab-btn @(_tab=="all"?"active":"")"     @onclick='()=>_tab="all"'>
            الكل <span class="tab-count">@(_entrants.Count+_sortants.Count)</span>
        </button>
        <button class="tab-btn @(_tab=="entrant"?"active":"")" @onclick='()=>_tab="entrant"'>
            <i class="bi bi-envelope-arrow-down"></i> وارد <span class="tab-count">@_entrants.Count</span>
        </button>
        <button class="tab-btn @(_tab=="sortant"?"active":"")" @onclick='()=>_tab="sortant"'>
            <i class="bi bi-envelope-arrow-up"></i> صادر <span class="tab-count">@_sortants.Count</span>
        </button>
    </div>

    @if(_loading)
    {
        <div class="table-card">
            <div style="padding:1rem">
                @for(int i=0;i<6;i++){ <div class="skeleton" style="height:18px;margin-bottom:.75rem"></div> }
            </div>
        </div>
    }
    else if (_entrants.Count == 0 && _sortants.Count == 0)
    {
        <div class="table-card">
            <div class="empty-state">
                <i class="bi bi-search"></i>
                <h3>لا توجد نتائج</h3>
                <p style="font-size:.85rem">جرّب كلمات بحث مختلفة أو تغيير الفلاتر</p>
            </div>
        </div>
    }
    else
    {
        @* Combined results (all) *@
        @if(_tab == "all" || _tab == "entrant")
        {
            @if(_entrants.Any())
            {
                <div class="table-card" style="margin-bottom:1.25rem">
                    <div style="padding:.85rem 1.2rem;background:#f0f9ff;border-bottom:1px solid #bae6fd;font-size:.85rem;font-weight:700;color:#0369a1">
                        <i class="bi bi-envelope-arrow-down"></i> البريد الوارد (@_entrants.Count)
                    </div>
                    <div class="table-inner">
                        <table>
                            <thead><tr><th>الرقم</th><th>تاريخ الاستلام</th><th>الموضوع</th><th>المرسل</th><th>النوع</th><th>الأولوية</th><th>الحالة</th></tr></thead>
                            <tbody>
                                @foreach(var c in _entrants)
                                {
                                    <tr @onclick='()=>Nav.NavigateTo($"/bureau/incoming/{c.Id}")'>
                                        <td><span class="result-num">@c.NumeroOrdre</span></td>
                                        <td>@c.DateReception.ToString("dd/MM/yyyy")</td>
                                        <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@c.ObjetCourrier">
                                            @HighlightText(c.ObjetCourrier)
                                        </td>
                                        <td>@HighlightText(c.ExpediteurNom ?? "—")</td>
                                        <td>@c.TypeDocument</td>
                                        <td><span class="badge @(c.Priorite=="Urgent"?"badge-urgent":"badge-entrant")">@c.Priorite</span></td>
                                        <td><span class="badge @StatutEntrantBadge(c.Statut)">@StatutEntrantLabel(c.Statut)</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }

        @if(_tab == "all" || _tab == "sortant")
        {
            @if(_sortants.Any())
            {
                <div class="table-card">
                    <div style="padding:.85rem 1.2rem;background:#faf5ff;border-bottom:1px solid #ddd6fe;font-size:.85rem;font-weight:700;color:#7c3aed">
                        <i class="bi bi-envelope-arrow-up"></i> البريد الصادر (@_sortants.Count)
                    </div>
                    <div class="table-inner">
                        <table>
                            <thead><tr><th>الرقم</th><th>تاريخ التحرير</th><th>الموضوع</th><th>المرسل إليه</th><th>النوع</th><th>الأولوية</th><th>الحالة</th></tr></thead>
                            <tbody>
                                @foreach(var s in _sortants)
                                {
                                    <tr @onclick='()=>Nav.NavigateTo($"/bureau/outgoing/{s.Id}")'>
                                        <td><span class="result-num-s">@s.NumeroOrdre</span></td>
                                        <td>@s.DateRedaction.ToString("dd/MM/yyyy")</td>
                                        <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@s.ObjetCourrier">
                                            @HighlightText(s.ObjetCourrier)
                                        </td>
                                        <td>@HighlightText(s.DestinataireNom ?? "—")</td>
                                        <td>@s.TypeDocument</td>
                                        <td><span class="badge @(s.Priorite=="Urgent"?"badge-urgent":"badge-sortant")">@s.Priorite</span></td>
                                        <td><span class="badge @StatutSortantBadge(s.Statut)">@StatutSortantLabel(s.Statut)</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    }
}
else
{
    @* Initial state *@
    <div class="table-card">
        <div class="empty-state">
            <i class="bi bi-search" style="color:#0ea5e9"></i>
            <h3>ابدأ البحث</h3>
            <p style="font-size:.85rem">أدخل كلمة بحث للعثور على البريد الوارد والصادر</p>
        </div>
    </div>
}

@code {
    private string? _searchTerm;
    private string? _typeDocument, _priorite, _statutEntrant, _statutSortant;
    private DateTime? _dateDebut, _dateFin;
    private string _tab = "all";
    private bool _loading, _searched;
    private List<CourrierEntrantDto> _entrants = new();
    private List<CourrierSortantDto> _sortants = new();

    private async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

    private async Task SearchAsync()
    {
        _loading = true;
        _searched = true;
        StateHasChanged();

        var ef = new CourrierEntrantFilterDto
        {
            SearchTerm = _searchTerm, TypeDocument = _typeDocument,
            Priorite = _priorite, Statut = _statutEntrant,
            DateDebut = _dateDebut, DateFin = _dateFin,
            PageNumber = 1, PageSize = 50
        };
        var sf = new CourrierSortantFilterDto
        {
            SearchTerm = _searchTerm, TypeDocument = _typeDocument,
            Priorite = _priorite, Statut = _statutSortant,
            DateDebut = _dateDebut, DateFin = _dateFin,
            PageNumber = 1, PageSize = 50
        };

        // var (ep, sp) = await (EntrantApi.GetPagedAsync(ef), SortantApi.GetPagedAsync(sf));
        // _entrants = ep?.Items?.ToList() ?? new();
        // _sortants = sp?.Items?.ToList() ?? new();
        // _tab = "all";
        // _loading = false;
    }

    private async Task ClearAll()
    {
        _searchTerm = _typeDocument = _priorite = _statutEntrant = _statutSortant = null;
        _dateDebut = _dateFin = null;
        _searched = false;
        _entrants = new(); _sortants = new();
        await Task.CompletedTask;
    }

    private RenderFragment HighlightText(string text)
    {
        if (string.IsNullOrEmpty(_searchTerm) || string.IsNullOrEmpty(text))
            return builder => builder.AddContent(0, text);

        int idx = text.IndexOf(_searchTerm, StringComparison.OrdinalIgnoreCase);
        if (idx < 0) return builder => builder.AddContent(0, text);

        return builder =>
        {
            builder.AddContent(0, text[..idx]);
            builder.OpenElement(1, "mark");
            builder.AddContent(2, text.Substring(idx, _searchTerm.Length));
            builder.CloseElement();
            builder.AddContent(3, text[(idx + _searchTerm.Length)..]);
        };
    }

    private static string StatutEntrantBadge(string s) => s switch
    {
        "Enregistre"=>"badge-enregistre","EnCours"=>"badge-encours","Traite"=>"badge-traite","Archive"=>"badge-archive",_=>"badge-enregistre"
    };
    private static string StatutEntrantLabel(string s) => s switch
    {
        "Enregistre"=>"مسجّل","EnCours"=>"قيد المعالجة","Traite"=>"تمت المعالجة","Archive"=>"مؤرشف",_=>s
    };
    private static string StatutSortantBadge(string s) => s switch
    {
        "Brouillon"=>"badge-archive","EnValidation"=>"badge-encours","Signe"=>"badge-traite","Envoye"=>"badge-envoye","Archive"=>"badge-archive",_=>"badge-archive"
    };
    private static string StatutSortantLabel(string s) => s switch
    {
        "Brouillon"=>"مسودة","EnValidation"=>"في انتظار التوقيع","Signe"=>"موقّع","Envoye"=>"مُرسَل","Archive"=>"مؤرشف","Annule"=>"ملغى",_=>s
    };
}
