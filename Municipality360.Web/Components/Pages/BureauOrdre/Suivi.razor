@page "/bureau/follow"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,BureauOrdre")]
@layout Municipality360.Web.Components.Layout.MainLayout
@inject ICourrierEntrantApiService EntrantApi
@inject ICourrierSortantApiService SortantApi
@inject NavigationManager Nav

<PageTitle>المتابعة — مكتب الضبط</PageTitle>

<style>
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; }
    .page-title  { font-size:1.3rem; font-weight:800; color:#0f172a; margin:0; }
    .page-sub    { font-size:.8rem; color:#94a3b8; margin-top:.2rem; }

    .kpi-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(170px,1fr)); gap:1rem; margin-bottom:1.5rem; }
    .kpi-card { background:#fff; border-radius:14px; padding:1rem 1.2rem; box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #f1f5f9; position:relative; overflow:hidden; transition:transform .2s; cursor:pointer; }
    .kpi-card:hover { transform:translateY(-2px); box-shadow:0 4px 18px rgba(0,0,0,.1); }
    .kpi-card::before { content:''; position:absolute; top:0; right:0; width:4px; height:100%; }
    .kpi-red::before    { background:#ef4444; }
    .kpi-orange::before { background:#f59e0b; }
    .kpi-blue::before   { background:#0ea5e9; }
    .kpi-purple::before { background:#8b5cf6; }
    .kpi-icon { width:38px; height:38px; border-radius:9px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; margin-bottom:.3rem; }
    .bg-red    { background:#fee2e2; color:#dc2626; }
    .bg-orange { background:#fef3c7; color:#d97706; }
    .bg-blue   { background:#e0f2fe; color:#0369a1; }
    .bg-purple { background:#ede9fe; color:#7c3aed; }
    .kpi-val { font-size:1.6rem; font-weight:800; color:#0f172a; }
    .kpi-lbl { font-size:.78rem; color:#64748b; }
    .kpi-sub { font-size:.72rem; color:#94a3b8; }

    .section-wrap { background:#fff; border-radius:14px; box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #f1f5f9; overflow:hidden; margin-bottom:1.5rem; }
    .section-header { display:flex; align-items:center; justify-content:space-between; padding:.9rem 1.25rem; background:#f8fafc; border-bottom:1px solid #f1f5f9; }
    .section-title  { font-size:.92rem; font-weight:700; color:#0f172a; display:flex; align-items:center; gap:.5rem; }
    .btn-link { background:none; border:none; color:#0ea5e9; font-family:'Tajawal',sans-serif; font-size:.82rem; cursor:pointer; }
    .btn-link:hover { text-decoration:underline; }

    .table-inner { overflow-x:auto; }
    table { width:100%; border-collapse:collapse; }
    th { padding:.6rem 1rem; text-align:right; font-size:.72rem; font-weight:700; color:#64748b; white-space:nowrap; background:#f8fafc; border-bottom:1px solid #e2e8f0; }
    td { padding:.75rem 1rem; font-size:.84rem; color:#374151; border-bottom:1px solid #f8fafc; vertical-align:middle; }
    tbody tr { cursor:pointer; }
    tbody tr:hover { background:#f8fafc; }
    tbody tr:last-child td { border-bottom:none; }

    .badge { display:inline-flex; align-items:center; gap:.3rem; border-radius:99px; padding:.2rem .65rem; font-size:.72rem; font-weight:600; }
    .badge-urgent       { background:#fee2e2; color:#dc2626; }
    .badge-encours      { background:#fef3c7; color:#b45309; }
    .badge-enregistre   { background:#dbeafe; color:#1d4ed8; }
    .badge-envalidation { background:#fef3c7; color:#b45309; }
    .badge-signe        { background:#dcfce7; color:#15803d; }

    .retard-row { background:#fff7ed !important; }
    .retard-badge { background:#fef3c7; color:#b45309; border-radius:6px; padding:.15rem .5rem; font-size:.72rem; font-weight:600; }
    .urgent-row { border-right:3px solid #ef4444; }

    .skeleton { background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:8px; }
    @@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

    .empty-state { text-align:center; padding:2.5rem; color:#94a3b8; }
    .empty-state i { font-size:2.5rem; display:block; margin-bottom:.5rem; }
</style>

<div class="page-header">
    <div>
        <div class="page-title"><i class="bi bi-clock-history" style="color:#f59e0b"></i> المتابعة</div>
        <div class="page-sub">متابعة حالة البريد الوارد والصادر</div>
    </div>
    <button style="display:inline-flex;align-items:center;gap:.4rem;padding:.45rem .95rem;border-radius:9px;border:none;background:#f1f5f9;color:#374151;font-family:'Tajawal',sans-serif;font-size:.85rem;font-weight:600;cursor:pointer"
            @onclick="RefreshAll" disabled="@_loading">
        <i class="bi bi-arrow-clockwise @(_loading?"spin":"")"></i> تحديث
    </button>
</div>

@* KPI *@
<div class="kpi-grid">
    <div class="kpi-card kpi-red" @onclick='()=>Nav.NavigateTo("/bureau/incoming")'>
        <div class="kpi-icon bg-red"><i class="bi bi-lightning-fill"></i></div>
        <div class="kpi-val">@(_entrantsUrgents?.Count ?? 0)</div>
        <div class="kpi-lbl">عاجل — وارد</div>
        <div class="kpi-sub">يستوجب معالجة فورية</div>
    </div>
    <div class="kpi-card kpi-orange" @onclick='()=>Nav.NavigateTo("/bureau/incoming")'>
        <div class="kpi-icon bg-orange"><i class="bi bi-clock-history"></i></div>
        <div class="kpi-val">@(_retards?.Count ?? 0)</div>
        <div class="kpi-lbl">متأخر عن الموعد</div>
        <div class="kpi-sub">تجاوز أجل الرد</div>
    </div>
    <div class="kpi-card kpi-blue" @onclick='()=>Nav.NavigateTo("/bureau/incoming")'>
        <div class="kpi-icon bg-blue"><i class="bi bi-inbox"></i></div>
        <div class="kpi-val">@(_encours?.Count ?? 0)</div>
        <div class="kpi-lbl">قيد المعالجة</div>
        <div class="kpi-sub">وارد معلّق</div>
    </div>
    <div class="kpi-card kpi-purple" @onclick='()=>Nav.NavigateTo("/bureau/outgoing")'>
        <div class="kpi-icon bg-purple"><i class="bi bi-pen"></i></div>
        <div class="kpi-val">@(_enValidation?.Count ?? 0)</div>
        <div class="kpi-lbl">ينتظر التوقيع</div>
        <div class="kpi-sub">صادر في انتظار توقيع</div>
    </div>
</div>

@if (_loading)
{
    @for (int i = 0; i < 3; i++)
    {
        <div class="section-wrap">
            <div class="section-header"><div class="skeleton" style="width:200px;height:20px"></div></div>
            <div style="padding:1rem"><div class="skeleton" style="height:80px"></div></div>
        </div>
    }
}
else
{
    @* ── Urgents ── *@
    <div class="section-wrap">
        <div class="section-header">
            <div class="section-title"><i class="bi bi-lightning-fill" style="color:#ef4444"></i> البريد العاجل (@(_entrantsUrgents?.Count ?? 0))</div>
            <button class="btn-link" @onclick='()=>Nav.NavigateTo("/bureau/incoming")'>عرض الكل <i class="bi bi-arrow-left"></i></button>
        </div>
        <div class="table-inner">
            <table>
                <thead><tr>
                    <th>الرقم</th><th>الموضوع</th><th>المرسل</th>
                    <th>تاريخ الاستلام</th><th>الحالة</th><th>أجل الرد</th>
                </tr></thead>
                <tbody>
                    @if (_entrantsUrgents?.Any() == true)
                    {
                        @foreach (var c in _entrantsUrgents)
                        {
                            bool retard = c.DelaiReponse.HasValue && c.DelaiReponse.Value < DateTime.Today && c.Statut != "Traite";
                            <tr class="urgent-row @(retard ? "retard-row" : "")"
                                @onclick='()=>Nav.NavigateTo($"/bureau/incoming/{c.Id}")'>
                                <td><strong style="color:#0369a1">@c.NumeroOrdre</strong></td>
                                <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@c.ObjetCourrier</td>
                                <td>@(c.ExpediteurNom ?? "—")</td>
                                <td>@c.DateReception.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge badge-urgent">@StatutLabel(c.Statut)</span></td>
                                <td>
                                    @if (c.DelaiReponse.HasValue)
                                    {
                                        int jours = (c.DelaiReponse.Value - DateTime.Today).Days;
                                        <span style="color:@(jours<0?"#dc2626":jours<=2?"#b45309":"#374151");font-weight:600">
                                            @(jours < 0 ? $"متأخر {-jours}ي" : $"{jours}ي متبقية")
                                        </span>
                                    }
                                    else { <text>—</text> }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6"><div class="empty-state"><i class="bi bi-check-circle-fill" style="color:#22c55e"></i>لا يوجد بريد عاجل</div></td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ── En retard ── *@
    <div class="section-wrap">
        <div class="section-header">
            <div class="section-title"><i class="bi bi-alarm-fill" style="color:#f59e0b"></i> البريد المتأخر (@(_retards?.Count ?? 0))</div>
        </div>
        <div class="table-inner">
            <table>
                <thead><tr>
                    <th>الرقم</th><th>الموضوع</th><th>المرسل</th>
                    <th>أجل الرد</th><th>التأخر</th><th>الحالة</th>
                </tr></thead>
                <tbody>
                    @if (_retards?.Any() == true)
                    {
                        @foreach (var c in _retards)
                        {
                            int jours = c.DelaiReponse.HasValue ? (DateTime.Today - c.DelaiReponse.Value).Days : 0;
                            <tr class="retard-row" @onclick='()=>Nav.NavigateTo($"/bureau/incoming/{c.Id}")'>
                                <td><strong style="color:#0369a1">@c.NumeroOrdre</strong></td>
                                <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@c.ObjetCourrier</td>
                                <td>@(c.ExpediteurNom ?? "—")</td>
                                <td style="color:#dc2626;font-weight:600">
                                    @(c.DelaiReponse.HasValue ? c.DelaiReponse.Value.ToString("dd/MM/yyyy") : "—")
                                </td>
                                <td><span class="retard-badge">@jours يوم</span></td>
                                <td><span class="badge badge-encours">@StatutLabel(c.Statut)</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6"><div class="empty-state"><i class="bi bi-check2-all" style="color:#22c55e"></i>لا يوجد بريد متأخر</div></td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ── En cours ── *@
    <div class="section-wrap">
        <div class="section-header">
            <div class="section-title"><i class="bi bi-hourglass-split" style="color:#0ea5e9"></i> البريد قيد المعالجة (@(_encours?.Count ?? 0))</div>
            <button class="btn-link" @onclick='()=>Nav.NavigateTo("/bureau/incoming")'>عرض الكل <i class="bi bi-arrow-left"></i></button>
        </div>
        <div class="table-inner">
            <table>
                <thead><tr>
                    <th>الرقم</th><th>الموضوع</th><th>المرسل</th>
                    <th>تاريخ الاستلام</th><th>الخدمة المعنية</th><th>أجل الرد</th>
                </tr></thead>
                <tbody>
                    @if (_encours?.Any() == true)
                    {
                        @foreach (var c in _encours.Take(10))
                        {
                            <tr @onclick='()=>Nav.NavigateTo($"/bureau/incoming/{c.Id}")'>
                                <td><strong style="color:#0369a1">@c.NumeroOrdre</strong></td>
                                <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@c.ObjetCourrier</td>
                                <td>@(c.ExpediteurNom ?? "—")</td>
                                <td>@c.DateReception.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(c.ServiceDestinataireNom))
                                    {
                                        <span style="font-size:.8rem;color:#0369a1">@c.ServiceDestinataireNom</span>
                                    }
                                    else { }
                                </td>
                                <td>
                                    @if (c.DelaiReponse.HasValue)
                                    {
                                        int j = (c.DelaiReponse.Value - DateTime.Today).Days;
                                        <span style="color:@(j<0?"#dc2626":j<=3?"#b45309":"#374151");font-weight:@(j<=3?"700":"400")">
                                            @c.DelaiReponse.Value.ToString("dd/MM/yyyy")
                                        </span>
                                    }
                                    else { <text>—</text> }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6"><div class="empty-state"><i class="bi bi-inbox" style="color:#94a3b8"></i>لا يوجد بريد قيد المعالجة</div></td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ── Sortants en validation ── *@
    <div class="section-wrap">
        <div class="section-header">
            <div class="section-title"><i class="bi bi-pen" style="color:#8b5cf6"></i> البريد الصادر في انتظار التوقيع (@(_enValidation?.Count ?? 0))</div>
            <button class="btn-link" @onclick='()=>Nav.NavigateTo("/bureau/outgoing")'>عرض الكل <i class="bi bi-arrow-left"></i></button>
        </div>
        <div class="table-inner">
            <table>
                <thead><tr>
                    <th>الرقم</th><th>الموضوع</th><th>المرسل إليه</th><th>تاريخ التحرير</th><th>الحالة</th>
                </tr></thead>
                <tbody>
                    @if (_enValidation?.Any() == true)
                    {
                        @foreach (var s in _enValidation)
                        {
                            <tr @onclick='()=>Nav.NavigateTo($"/bureau/outgoing/{s.Id}")'>
                                <td><strong style="color:#7c3aed">@s.NumeroOrdre</strong></td>
                                <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@s.ObjetCourrier</td>
                                <td>@(s.DestinataireNom ?? "—")</td>
                                <td>@s.DateRedaction.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge badge-envalidation">في انتظار التوقيع</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5"><div class="empty-state"><i class="bi bi-check-circle" style="color:#22c55e"></i>لا يوجد بريد صادر ينتظر التوقيع</div></td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<CourrierEntrantDto>? _entrantsUrgents;
    private List<CourrierEntrantDto>? _retards;
    private List<CourrierEntrantDto>? _encours;
    private List<CourrierSortantDto>? _enValidation;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await RefreshAll();

    private async Task RefreshAll()
    {
        _loading = true; StateHasChanged();

        try
        {
            // Urgents en cours
            var urg = await EntrantApi.GetPagedAsync(new CourrierEntrantFilterDto
            { Priorite = "Urgent", Statut = "EnCours", PageNumber = 1, PageSize = 50 });
            _entrantsUrgents = urg?.Items?.ToList() ?? new();
        }
        catch { _entrantsUrgents = new(); }

        try
        {
            // En retard
            _retards = await EntrantApi.GetEnRetardAsync() ?? new();
        }
        catch { _retards = new(); }

        try
        {
            // En cours
            var ec = await EntrantApi.GetPagedAsync(new CourrierEntrantFilterDto
            { Statut = "EnCours", PageNumber = 1, PageSize = 20 });
            _encours = ec?.Items?.ToList() ?? new();
        }
        catch { _encours = new(); }

        try
        {
            // Sortants en validation
            var ev = await SortantApi.GetPagedAsync(new CourrierSortantFilterDto
            { Statut = "EnValidation", PageNumber = 1, PageSize = 50 });
            _enValidation = ev?.Items?.ToList() ?? new();
        }
        catch { _enValidation = new(); }

        _loading = false;
    }

    private static string StatutLabel(string s) => s switch
    {
        "Recu"       => "مستلم",
        "Enregistre" => "مسجّل",
        "EnCours"    => "قيد المعالجة",
        "Traite"     => "تمت المعالجة",
        "Archive"    => "مؤرشف",
        _            => s
    };
}
