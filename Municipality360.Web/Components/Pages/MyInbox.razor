                @if (!string.IsNullOrEmpty(recl.SolutionApportee))
                {
                    <div class="desc-card" style="border-color:#86efac;">
                        <div class="desc-card-title" style="color:#15803d;"><i class="bi bi-check-circle-fill me-1"></i> الحل المُقدَّم</div>
                        <div class="desc-text">@recl.SolutionApportee</div>
