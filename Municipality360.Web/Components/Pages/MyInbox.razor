    private bool IsUnread(object item) => item switch
    {
        CourrierEntrantDetailDto m => m.Statut is "Enregistre" or "Recu",
        ReclamationDetailDto     r => r.Statut == "Nouvelle",
        NotificationDto          n => !n.EstLue,
        _ => false
    };

    private bool IsLate(object item) => item switch
    {
        CourrierEntrantDetailDto m => m.EnRetard,
        ReclamationDetailDto     r => r.Statut != "Traitee" && r.Statut != "Rejetee"
                                    && r.DateDepot < DateTime.UtcNow.AddDays(-15),
        _ => false
    };

