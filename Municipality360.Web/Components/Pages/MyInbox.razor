                                    @onclick="SubmitReclAction" disabled="@IsSaving">
                                @if (IsSaving) { <i class="bi bi-arrow-clockwise spinner"></i> }
                                تأكيد
                            </button>
                            <button class="btn-action" @onclick='() => ActiveReclAction = null'>
