    </div>
</div>

<!-- Toast -->
@if (!string.IsNullOrEmpty(ToastMessage))
{
    <div class="toast-confirm @ToastClass">
        <i class="bi @(ToastClass == "success" ? "bi-check-circle-fill" : "bi-exclamation-circle-fill")"></i>
        @ToastMessage
    </div>
}

@code {
    // ── Auth ─────────────────────────────────────────────
    private string UserName    = "مستخدم";
    private string UserId      = "";
    private List<string> Roles = new();

    // ── Tab / filter state ───────────────────────────────
    private string ActiveTab  = "mail";
    private string SubFilter  = "all";
    private string SearchTerm = "";

    // ── Data ─────────────────────────────────────────────
    private List<CourrierEntrantDetailDto> Mails        = new();
    private List<ReclamationDetailDto>     Reclamations = new();
    private bool IsLoadingList = true;

    // ── Selection ────────────────────────────────────────
    private object?  SelectedItem = null;
    private int      SelectedId   = 0;

    // ── Actions ──────────────────────────────────────────
    private string?  ActiveMailAction = null;
    private string?  ActiveReclAction = null;
    private string   ActionComment    = "";
    private string   NewMailStatus    = "";
    private string   SolutionText     = "";
    private bool     IsSaving         = false;

    // ── Toast ─────────────────────────────────────────────
    private string ToastMessage = "";
    private string ToastClass   = "success";

    // ── Computed counts ──────────────────────────────────
    private int UnreadMailCount => Mails.Count(m => m.Statut is "Enregistre" or "Recu");
    private int UnreadReclCount => Reclamations.Count(r => r.Statut is "Nouvelle");
    private int CurrentListCount => GetCurrentList().Count;

    // ══════════════════════════════════════════════════════
    //  LIFECYCLE
    // ══════════════════════════════════════════════════════

    protected override async Task OnInitializedAsync()
    {
        SignalRNotif.OnChanged += Refresh;
        SignalRNotif.OnNotificationReceived += OnNewNotification;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var state = await AuthState.GetAuthenticationStateAsync();
        var user  = state.User;
        if (!user.Identity?.IsAuthenticated ?? true) return;

        UserName = user.FindFirst("firstName")?.Value is { Length: > 0 } fn
                 ? fn + " " + (user.FindFirst("lastName")?.Value ?? "")
                 : user.Identity?.Name ?? "مستخدم";

        UserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value
              ?? user.FindFirst("sub")?.Value ?? "";

        Roles = user.FindAll(ClaimTypes.Role).Select(c => c.Value).ToList();

        await LoadAllData();
        StateHasChanged();
    }

    private async Task LoadAllData()
    {
        IsLoadingList = true;
        StateHasChanged();

        try
        {
            // بريد وارد: جلب ما هو مخصص للمستخدم
            var mailFilter = new CourrierEntrantFilterDto
            {
                PageSize = 50, PageNumber = 1
            };
            var mailPage = await CourrierApi.GetPagedAsync(mailFilter);
            Mails = new();
            if (mailPage?.Items != null)
            {
                foreach (var m in mailPage.Items)
                {
                    try
                    {
                        var detail = await CourrierApi.GetByIdAsync(m.Id);
                        if (detail != null) Mails.Add(detail);
                    }
                    catch { }
                }
            }

            // شكاوى: جلب ما هو مخصص للمستخدم
            var reclFilter = new ReclamationFilterDto { PageSize = 50, PageNumber = 1 };
            var reclPage = await ReclamationApi.GetPagedAsync(reclFilter);
            Reclamations = new();
            if (reclPage?.Items != null)
            {
                foreach (var r in reclPage.Items)
                {
                    try
                    {
                        var detail = await ReclamationApi.GetByIdAsync(r.Id);
                        if (detail != null) Reclamations.Add(detail);
                    }
                    catch { }
                }
            }

            // إشعارات: تحميل إذا فارغة
            if (!SignalRNotif.Notifications.Any())
            {
                var notifs = await NotifApi.GetMyNotificationsAsync();
                SignalRNotif.LoadInitialNotifications(notifs);
            }
        }
        catch { }
        finally
        {
            IsLoadingList = false;
        }
    }

    // ══════════════════════════════════════════════════════
    //  TAB SWITCHING
    // ══════════════════════════════════════════════════════

    private async Task SwitchTab(string tab)
    {
        ActiveTab      = tab;
        SubFilter      = "all";
        SearchTerm     = "";
        SelectedItem   = null;
        SelectedId     = 0;
        ActiveMailAction = null;
        ActiveReclAction = null;
    }

    // ══════════════════════════════════════════════════════
    //  LIST LOGIC
    // ══════════════════════════════════════════════════════

    private List<object> GetCurrentList()
    {
        if (ActiveTab == "mail")
        {
            var list = Mails.AsEnumerable();
            if (SubFilter == "unread") list = list.Where(m => m.Statut is "Enregistre" or "Recu");
            if (SubFilter == "late")   list = list.Where(m => m.EnRetard);
            if (!string.IsNullOrEmpty(SearchTerm))
                list = list.Where(m => m.ObjetCourrier.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)
                                    || m.ExpediteurNom.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)
                                    || m.NumeroOrdre.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase));
            return list.OrderByDescending(m => m.DateReception).Cast<object>().ToList();
        }
        else if (ActiveTab == "reclamations")
        {
            var list = Reclamations.AsEnumerable();
            if (SubFilter == "unread") list = list.Where(r => r.Statut == "Nouvelle");
            if (SubFilter == "late")   list = list.Where(r => r.Statut != "Traitee" && r.Statut != "Rejetee"
                                                              && r.DateDepot < DateTime.UtcNow.AddDays(-15));
            if (!string.IsNullOrEmpty(SearchTerm))
                list = list.Where(r => r.Objet.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)
                                    || r.CitoyenNomComplet.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)
                                    || r.NumeroReclamation.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase));
            return list.OrderByDescending(r => r.DateDepot).Cast<object>().ToList();
        }
        else // notifications
        {
            var list = SignalRNotif.Notifications.AsEnumerable();
            if (SubFilter == "unread") list = list.Where(n => !n.EstLue);
            if (!string.IsNullOrEmpty(SearchTerm))
                list = list.Where(n => n.Titre.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)
                                    || n.Message.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase));
            return list.OrderByDescending(n => n.DateCreation).Cast<object>().ToList();
        }
    }

    // ══════════════════════════════════════════════════════
    //  ITEM SELECTION
    // ══════════════════════════════════════════════════════

    private async Task SelectItem(object item)
    {
        SelectedItem     = item;
        ActiveMailAction = null;
        ActiveReclAction = null;
        ActionComment    = "";
        NewMailStatus    = "";
        SolutionText     = "";
        SelectedId       = GetItemId(item);

        // Mark notification as read
        if (item is NotificationDto n && !n.EstLue)
        {
            await SignalRNotif.MarkAsReadAsync(n.Id);
            try { await NotifApi.MarkAsReadAsync(n.Id); } catch { }
        }
    }

    private int GetItemId(object item) => item switch
    {
        CourrierEntrantDetailDto m => m.Id,
        ReclamationDetailDto     r => r.Id,
        NotificationDto          n => n.Id,
        _ => 0
    };

    // ══════════════════════════════════════════════════════
    //  MAIL ACTIONS
    // ══════════════════════════════════════════════════════

    private void ShowMailAction(string action)
    {
        ActiveMailAction = action;
        ActiveReclAction = null;
        ActionComment    = "";
        NewMailStatus    = "";
    }

    private async Task MarkMailTraite(int id)
    {
        IsSaving = true;
        try
        {
            var dto = new ChangerStatutEntrantDto { NouveauStatut = "Traite", Commentaire = "تمت المعالجة" };
            await CourrierApi.ChangerStatutAsync(id, dto);
            await ReloadMail(id);
            ShowToast("تم تحديد البريد كمعالج ✓", "success");
        }
        catch { ShowToast("حدث خطأ أثناء التحديث", "error"); }
        finally { IsSaving = false; }
    }

    private async Task SubmitMailAction()
    {
        if (SelectedItem is not CourrierEntrantDetailDto mail) return;
        if (string.IsNullOrEmpty(NewMailStatus)) return;

        IsSaving = true;
        try
        {
            var dto = new ChangerStatutEntrantDto
            {
                NouveauStatut = NewMailStatus,
                Commentaire   = ActionComment
            };
            await CourrierApi.ChangerStatutAsync(mail.Id, dto);
            await ReloadMail(mail.Id);
            ActiveMailAction = null;
            ActionComment    = "";
            NewMailStatus    = "";
            ShowToast("تم تحديث حالة البريد ✓", "success");
        }
        catch { ShowToast("حدث خطأ أثناء التحديث", "error"); }
        finally { IsSaving = false; }
    }

    private async Task ReloadMail(int id)
    {
        try
        {
            var updated = await CourrierApi.GetByIdAsync(id);
            if (updated != null)
            {
                var idx = Mails.FindIndex(m => m.Id == id);
                if (idx >= 0) Mails[idx] = updated;
                if (SelectedItem is CourrierEntrantDetailDto) SelectedItem = updated;
            }
        }
        catch { }
    }

    // ══════════════════════════════════════════════════════
    //  RECLAMATION ACTIONS
    // ══════════════════════════════════════════════════════

    private void ShowReclAction(string action)
    {
        ActiveReclAction = action;
        ActiveMailAction = null;
        ActionComment    = "";
        SolutionText     = "";
    }

    private async Task SubmitReclAction()
    {
        if (SelectedItem is not ReclamationDetailDto recl) return;
        IsSaving = true;
        try
        {
            var nouveauStatut = ActiveReclAction switch
            {
                "treat"  => "Traitee",
                "reject" => "Rejetee",
                _        => "EnCours"
            };

            var dto = new ChangerStatutReclamationDto
            {
                NouveauStatut   = nouveauStatut,
                Commentaire     = ActionComment,
                SolutionApportee = ActiveReclAction == "treat" ? SolutionText : null,
                VisibleCitoyen  = true
            };
            await ReclamationApi.ChangerStatutAsync(recl.Id, dto);
            await ReloadReclamation(recl.Id);
            ActiveReclAction = null;
            ActionComment    = "";
            SolutionText     = "";
            ShowToast(nouveauStatut == "Traitee" ? "تمت معالجة الشكوى ✓"
                    : nouveauStatut == "Rejetee"  ? "تم رفض الشكوى"
                    : "تم تحديث حالة الشكوى ✓", "success");
        }
        catch { ShowToast("حدث خطأ أثناء التحديث", "error"); }
        finally { IsSaving = false; }
    }

    private async Task ReloadReclamation(int id)
    {
        try
        {
            var updated = await ReclamationApi.GetByIdAsync(id);
            if (updated != null)
            {
                var idx = Reclamations.FindIndex(r => r.Id == id);
                if (idx >= 0) Reclamations[idx] = updated;
                if (SelectedItem is ReclamationDetailDto) SelectedItem = updated;
            }
        }
        catch { }
    }

