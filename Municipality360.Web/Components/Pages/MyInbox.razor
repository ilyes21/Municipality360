    private string FormatTime(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        return diff.TotalMinutes < 1  ? "الآن"
             : diff.TotalMinutes < 60 ? $"منذ {(int)diff.TotalMinutes} دق"
             : diff.TotalHours < 24   ? $"منذ {(int)diff.TotalHours} سا"
             : diff.TotalDays < 7     ? $"منذ {(int)diff.TotalDays} أيام"
             : dt.ToString("dd/MM/yy");
    }

    public void Dispose()
    {
        SignalRNotif.OnChanged              -= Refresh;
        SignalRNotif.OnNotificationReceived -= OnNewNotification;
    }
