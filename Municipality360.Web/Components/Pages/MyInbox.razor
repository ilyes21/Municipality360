                    </div>
                </div>
                <div class="detail-actions">
                    @if (mail.Statut != "Traite" && mail.Statut != "Archive")
                    {
                        <button class="btn-action primary" @onclick='() => ShowMailAction("reply")'>
                            <i class="bi bi-reply-fill"></i> رد
                        </button>
                        <button class="btn-action success" @onclick="() => MarkMailTraite(mail.Id)">
                            <i class="bi bi-check-circle-fill"></i> معالجة
                        </button>
