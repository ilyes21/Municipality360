    private async Task MarkNotifRead(NotificationDto n)
    {
        await SignalRNotif.MarkAsReadAsync(n.Id);
        try { await NotifApi.MarkAsReadAsync(n.Id); } catch { }
    }

    private void OnNewNotification(NotificationDto n) => InvokeAsync(StateHasChanged);
    private void Refresh() => InvokeAsync(StateHasChanged);

    // ══════════════════════════════════════════════════════
    //  TOAST
    // ══════════════════════════════════════════════════════

    private void ShowToast(string msg, string cls)
    {
        ToastMessage = msg;
        ToastClass   = cls;
        StateHasChanged();
        Task.Delay(3200).ContinueWith(_ => InvokeAsync(() =>
        {
            ToastMessage = "";
            StateHasChanged();
        }));
    }

