                }

                <!-- Timeline des suivis -->
                @if (recl.Suivis?.Any() == true)
                {
                    <div class="timeline">
                        <div class="tl-title"><i class="bi bi-clock-history me-1"></i> سجل المعالجة</div>
                        @foreach (var s in recl.Suivis.OrderByDescending(x => x.DateChangement))
