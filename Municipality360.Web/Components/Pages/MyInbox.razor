                        { <i class="bi bi-person-fill-gear" style="color:#f59e0b;"></i><text> إسناد الشكوى</text> }
                        else
                        { <i class="bi bi-x-circle-fill" style="color:#ef4444;"></i><text> رفض الشكوى</text> }
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">تعليق / ملاحظة</label>
                            <input class="form-input" @bind="ActionComment"
                                   placeholder="أدخل تعليقك..." />
                        </div>
                        @if (ActiveReclAction == "treat")
                        {
                            <div class="form-group">
                                <label class="form-label">الحل المُقدَّم (اختياري)</label>
                                <input class="form-input" @bind="SolutionText"
