        else if (SelectedItem is NotificationDto notif)
        {
            <!-- ═══ DETAIL: NOTIFICATION ═══ -->
            <div class="detail-header">
                <div class="detail-header-icon ii-notif"><i class="bi bi-bell-fill"></i></div>
                <div style="flex:1;">
                    <div class="detail-title">@notif.Titre</div>
                    <div class="detail-sub">
                        <span><i class="bi bi-calendar3"></i> @notif.DateCreation.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        <span class="status-pill @(notif.EstLue ? "sp-archive" : "sp-nouvelle")">
                            @(notif.EstLue ? "مقروء" : "غير مقروء")
