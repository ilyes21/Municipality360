            <div class="detail-body">
                <!-- معلومات البريد -->
                <div class="info-grid">
                    <div class="info-card">
                        <div class="info-card-title"><i class="bi bi-info-circle me-1"></i> معلومات البريد</div>
                        <div class="info-row"><span class="info-row-label">رقم التسجيل</span><span class="info-row-value">@mail.NumeroOrdre</span></div>
                        <div class="info-row"><span class="info-row-label">نوع الوثيقة</span><span class="info-row-value">@mail.TypeDocument</span></div>
                        <div class="info-row"><span class="info-row-label">طريقة الاستقبال</span><span class="info-row-value">@mail.ModeReception</span></div>
                        <div class="info-row"><span class="info-row-label">الأولوية</span><span class="info-row-value">@GetPriorityLabel(mail.Priorite)</span></div>
                        <div class="info-row"><span class="info-row-label">يتطلب رداً</span><span class="info-row-value">@(mail.NecessiteReponse ? "نعم" : "لا")</span></div>
