@page "/notifications"
@using Municipality360.Application.DTOs.Notifications
@using Municipality360.Web.Services
@inject ISignalRNotificationService SignalRNotif
@inject INotificationApiService NotifApi
@inject NavigationManager NavManager
@implements IDisposable

<PageTitle>مركز الإشعارات</PageTitle>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap');

    .np-wrap {
        max-width: 760px;
        margin: 0 auto;
        font-family: 'Tajawal', sans-serif;
    }

    /* ── Header ── */
    .np-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .np-header-icon {
        width: 50px;
        height: 50px;
        border-radius: 14px;
        background: linear-gradient(135deg, #0369a1, #0ea5e9);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: #fff;
        box-shadow: 0 6px 20px rgba(14,165,233,.35);
        flex-shrink: 0;
    }

    .np-header-title {
        font-size: 1.3rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.2;
    }

    .np-header-sub {
        font-size: .8rem;
        color: #64748b;
        margin-top: .15rem;
    }

    /* ── Toolbar ── */
    .np-toolbar {
        display: flex;
        align-items: center;
        gap: .6rem;
        margin-bottom: 1.1rem;
        flex-wrap: wrap;
    }

    .np-filter {
        padding: .38rem .88rem;
        border-radius: 99px;
        border: 1px solid #e2e8f0;
        background: #fff;
        font-size: .78rem;
        font-weight: 600;
        color: #64748b;
        cursor: pointer;
        transition: all .18s;
        font-family: 'Tajawal', sans-serif;
    }

    .np-filter.active {
        background: #0ea5e9;
        border-color: #0ea5e9;
        color: #fff;
        box-shadow: 0 4px 12px rgba(14,165,233,.3);
    }

    .np-filter:hover:not(.active) {
        border-color: #94a3b8;
        color: #374151;
    }

    .np-filter .np-badge-inline {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(239,68,68,.9);
        color: #fff;
        border-radius: 99px;
        font-size: .62rem;
        font-weight: 700;
        min-width: 16px;
        height: 16px;
        padding: 0 4px;
        margin-right: .3rem;
    }

    .np-filter.active .np-badge-inline {
        background: rgba(255,255,255,.35);
    }

    .np-mark-all {
        margin-right: auto;
        padding: .38rem .88rem;
        border-radius: 99px;
        border: 1px solid #bae6fd;
        background: #f0f9ff;
        font-size: .78rem;
        font-weight: 600;
        color: #0369a1;
        cursor: pointer;
        transition: all .18s;
        font-family: 'Tajawal', sans-serif;
        display: flex;
        align-items: center;
        gap: .35rem;
    }

    .np-mark-all:hover { background: #e0f2fe; border-color: #7dd3fc; }

    /* ── Card container ── */
    .np-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        overflow: hidden;
    }

    /* ── Day group label ── */
    .np-day-label {
        padding: .55rem 1.2rem;
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: #94a3b8;
        background: #f8fafc;
        border-bottom: 1px solid #f1f5f9;
        border-top: 1px solid #f1f5f9;
        position: sticky;
        top: 0;
        z-index: 1;
    }

    /* ── Row ── */
    .np-row {
        display: flex;
        align-items: flex-start;
        gap: .9rem;
        padding: .95rem 1.2rem;
        border-bottom: 1px solid #f8fafc;
        cursor: pointer;
        transition: background .15s;
        position: relative;
    }

    .np-row:last-child { border-bottom: none; }
    .np-row:hover { background: #f8fafc; }

    .np-row.unread {
        background: #f0f9ff;
    }

    .np-row.unread::after {
        content: '';
        position: absolute;
        right: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: #0ea5e9;
        border-radius: 0 4px 4px 0;
    }

    /* ── Icon ── */
    .np-icon {
        width: 40px;
        height: 40px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .np-icon.blue  { background: #dbeafe; color: #1d4ed8; }
    .np-icon.green { background: #dcfce7; color: #15803d; }
    .np-icon.amber { background: #fef3c7; color: #b45309; }
    .np-icon.red   { background: #fee2e2; color: #b91c1c; }

    /* ── Body ── */
    .np-body { flex: 1; min-width: 0; }

    .np-title {
        font-size: .86rem;
        font-weight: 600;
        color: #0f172a;
        margin-bottom: .22rem;
        line-height: 1.35;
    }

    .np-row.unread .np-title { font-weight: 700; }

    .np-msg {
        font-size: .78rem;
        color: #64748b;
        line-height: 1.45;
        margin-bottom: .28rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .np-meta {
        display: flex;
        align-items: center;
        gap: .65rem;
    }

    .np-time {
        font-size: .7rem;
        color: #94a3b8;
    }

    .np-type-tag {
        font-size: .64rem;
        font-weight: 700;
        padding: .1em .45em;
        border-radius: 4px;
        background: #f1f5f9;
        color: #475569;
    }

    /* ── Unread dot ── */
    .np-unread-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #0ea5e9;
        flex-shrink: 0;
        margin-top: 5px;
    }

    /* ── Empty ── */
    .np-empty {
        padding: 4rem 2rem;
        text-align: center;
        color: #94a3b8;
    }

    .np-empty i {
        font-size: 2.8rem;
        display: block;
        margin-bottom: .85rem;
        color: #cbd5e1;
    }

    .np-empty-title {
        font-size: .95rem;
        font-weight: 700;
        color: #64748b;
        margin-bottom: .4rem;
    }

    .np-empty-sub { font-size: .8rem; }

    /* ── Loading ── */
    .np-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .7rem;
        padding: 3rem;
        color: #94a3b8;
        font-size: .88rem;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }
    .np-spinner { animation: spin .75s linear infinite; }

    /* ── Stats bar ── */
    .np-stats {
        display: flex;
        gap: .75rem;
        margin-bottom: 1.1rem;
        flex-wrap: wrap;
    }

    .np-stat {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: .7rem 1rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        min-width: 130px;
        flex: 1;
    }

    .np-stat-icon {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
        flex-shrink: 0;
    }

    .np-stat-icon.blue  { background: #dbeafe; color: #1d4ed8; }
    .np-stat-icon.red   { background: #fee2e2; color: #b91c1c; }
    .np-stat-icon.green { background: #dcfce7; color: #15803d; }
    .np-stat-icon.amber { background: #fef3c7; color: #b45309; }

    .np-stat-val {
        font-size: 1.2rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1;
    }

    .np-stat-lbl {
        font-size: .7rem;
        color: #64748b;
        margin-top: .1rem;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="np-wrap">

    
    <div class="np-header">
        <div class="np-header-icon"><i class="bi bi-bell-fill"></i></div>
        <div>
            <div class="np-header-title">مركز الإشعارات</div>
            <div class="np-header-sub">
                @if (SignalRNotif.IsConnected)
                {
                    <span style="color:#22c55e;font-weight:600;">
                        <i class="bi bi-circle-fill" style="font-size:.45rem;"></i> متصل —
                    </span>
                }
                @SignalRNotif.Notifications.Count إشعار · @SignalRNotif.UnreadCount غير مقروء
            </div>
        </div>
    </div>

    
    @{
        var all = SignalRNotif.Notifications;
        int totalMail      = all.Count(n => n.Type.Contains("Courrier"));
        int totalRecl      = all.Count(n => n.Type.Contains("Reclamation"));
        int totalPermis    = all.Count(n => n.Type.Contains("Permis") || n.Type.Contains("Demande"));
    }
    <div class="np-stats">
        <div class="np-stat">
            <div class="np-stat-icon red"><i class="bi bi-bell-fill"></i></div>
            <div>
                <div class="np-stat-val">@SignalRNotif.UnreadCount</div>
                <div class="np-stat-lbl">غير مقروء</div>
            </div>
        </div>
        <div class="np-stat">
            <div class="np-stat-icon amber"><i class="bi bi-envelope-fill"></i></div>
            <div>
                <div class="np-stat-val">@totalMail</div>
                <div class="np-stat-lbl">البريد</div>
            </div>
        </div>
        <div class="np-stat">
            <div class="np-stat-icon blue"><i class="bi bi-chat-square-text-fill"></i></div>
            <div>
                <div class="np-stat-val">@totalRecl</div>
                <div class="np-stat-lbl">الشكاوى</div>
            </div>
        </div>
        <div class="np-stat">
            <div class="np-stat-icon green"><i class="bi bi-building-fill"></i></div>
            <div>
                <div class="np-stat-val">@totalPermis</div>
                <div class="np-stat-lbl">رخص البناء</div>
            </div>
        </div>
    </div>

    
    <div class="np-toolbar">
        <button class="np-filter @(Filter=="all"?"active":"")"    @onclick='()=>Filter="all"'>الكل</button>
        <button class="np-filter @(Filter=="unread"?"active":"")" @onclick='()=>Filter="unread"'>
            @if (SignalRNotif.UnreadCount > 0)
            {
                <span class="np-badge-inline">@SignalRNotif.UnreadCount</span>
            }
            غير مقروء
        </button>
        <button class="np-filter @(Filter=="courrier"?"active":"")"    @onclick='()=>Filter="courrier"'>البريد</button>
        <button class="np-filter @(Filter=="reclamation"?"active":"")" @onclick='()=>Filter="reclamation"'>الشكاوى</button>
        <button class="np-filter @(Filter=="permis"?"active":"")"      @onclick='()=>Filter="permis"'>رخص البناء</button>

        @if (SignalRNotif.UnreadCount > 0)
        {
            <button class="np-mark-all" @onclick="MarkAllRead">
                <i class="bi bi-check2-all"></i> تحديد الكل كمقروء
            </button>
        }
    </div>

    
    <div class="np-card">
        @if (IsLoading)
        {
            <div class="np-loading">
                <i class="bi bi-arrow-clockwise np-spinner"></i>
                جارٍ تحميل الإشعارات...
            </div>
        }
        else
        {
            var filtered = GetFiltered();

            @if (!filtered.Any())
            {
                <div class="np-empty">
                    <i class="bi bi-bell-slash"></i>
                    <div class="np-empty-title">لا توجد إشعارات</div>
                    <div class="np-empty-sub">ستظهر إشعاراتك هنا فور وصولها</div>
                </div>
            }
            else
            {
                var grouped = filtered
                    .GroupBy(n => n.DateCreation.ToLocalTime().Date)
                    .OrderByDescending(g => g.Key);

                @foreach (var group in grouped)
                {
                    <div class="np-day-label">
                        @if (group.Key == DateTime.Today)             { <text>اليوم</text> }
                        else if (group.Key == DateTime.Today.AddDays(-1)) { <text>أمس</text> }
                        else { @group.Key.ToString("dddd، d MMMM yyyy") }
                    </div>

                    @foreach (var n in group.OrderByDescending(x => x.DateCreation))
                    {
                        <div class="np-row @(!n.EstLue ? "unread" : "")" @onclick="() => HandleClick(n)">
                            <div class="np-icon @GetColor(n.Type)">
                                <i class="bi @GetIcon(n.Type)"></i>
                            </div>
                            <div class="np-body">
                                <div class="np-title">@n.Titre</div>
                                <div class="np-msg">@n.Message</div>
                                <div class="np-meta">
                                    <span class="np-time">
                                        @n.DateCreation.ToLocalTime().ToString("HH:mm") — @FormatDate(n.DateCreation)
                                    </span>
                                    <span class="np-type-tag">@GetTypeLabel(n.Type)</span>
                                </div>
                            </div>
                            @if (!n.EstLue)
                            {
                                <div class="np-unread-dot"></div>
                            }
                        </div>
                    }
                }
            }
        }
    </div>

</div>

@code {
    private string Filter   = "all";
    private bool   IsLoading = true;

    protected override void OnInitialized()
    {
        SignalRNotif.OnChanged += Refresh;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!SignalRNotif.Notifications.Any())
        {
            try
            {
                var list = await NotifApi.GetMyNotificationsAsync();
                SignalRNotif.LoadInitialNotifications(list);
            }
            catch { }
        }

        IsLoading = false;
        StateHasChanged();
    }

    // ── فلترة ──────────────────────────────────────────
    private List<NotificationDto> GetFiltered() => Filter switch
    {
        "unread"      => SignalRNotif.Notifications.Where(n => !n.EstLue).ToList(),
        "courrier"    => SignalRNotif.Notifications.Where(n => n.Type.Contains("Courrier")).ToList(),
        "reclamation" => SignalRNotif.Notifications.Where(n => n.Type.Contains("Reclamation")).ToList(),
        "permis"      => SignalRNotif.Notifications.Where(n => n.Type.Contains("Permis") || n.Type.Contains("Demande")).ToList(),
        _             => SignalRNotif.Notifications
    };

    // ── نقر على إشعار ──────────────────────────────────
    private async Task HandleClick(NotificationDto n)
    {
        if (!n.EstLue)
        {
            await SignalRNotif.MarkAsReadAsync(n.Id);
            try { await NotifApi.MarkAsReadAsync(n.Id); } catch { }
        }

        if (!string.IsNullOrEmpty(n.LienNavigation))
            NavManager.NavigateTo(n.LienNavigation);
    }

    // ── تحديد الكل ─────────────────────────────────────
    private async Task MarkAllRead()
    {
        await SignalRNotif.MarkAllAsReadAsync();
        try { await NotifApi.MarkAllAsReadAsync(); } catch { }
    }

    // ── Helpers ─────────────────────────────────────────
    private void Refresh() => InvokeAsync(StateHasChanged);

    private string GetColor(string type) => type switch
    {
        "NouveauCourrier" or "CourrierAssigne"         => "amber",
        "CourrierTraite"                               => "green",
        "NouvelleReclamation" or "ReclamationAssignee" => "blue",
        "ReclamationResolue"                           => "green",
        "ReclamationRejetee"                           => "red",
        "DemandePermisApprouvee" or "PermisDelivre"    => "green",
        "DemandePermisRefusee"                         => "red",
        _ => "blue"
    };

    private string GetIcon(string type) => type switch
    {
        "NouveauCourrier"        => "bi-envelope",
        "CourrierAssigne"        => "bi-envelope-arrow-down",
        "CourrierTraite"         => "bi-envelope-check",
        "NouvelleReclamation"    => "bi-chat-square-text",
        "ReclamationAssignee"    => "bi-chat-square-arrow",
        "ReclamationResolue"     => "bi-check-circle",
        "ReclamationRejetee"     => "bi-x-circle",
        "NouvelleDemandePermis"  => "bi-building",
        "DemandePermisApprouvee" => "bi-building-check",
        "DemandePermisRefusee"   => "bi-building-x",
        "PermisDelivre"          => "bi-file-earmark-check",
        _ => "bi-bell"
    };

    private string GetTypeLabel(string type) => type switch
    {
        var t when t.Contains("Courrier")                         => "البريد",
        var t when t.Contains("Reclamation")                      => "الشكاوى",
        var t when t.Contains("Permis") || t.Contains("Demande")  => "رخص البناء",
        _ => "إشعار"
    };

    private string FormatDate(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        return diff.TotalMinutes < 1  ? "الآن"
             : diff.TotalMinutes < 60 ? $"منذ {(int)diff.TotalMinutes} دقيقة"
             : diff.TotalHours < 24   ? $"منذ {(int)diff.TotalHours} ساعة"
             : diff.TotalDays < 7     ? $"منذ {(int)diff.TotalDays} يوم"
             : dt.ToLocalTime().ToString("d MMM");
    }

    public void Dispose()
    {
        SignalRNotif.OnChanged -= Refresh;
    }
}
