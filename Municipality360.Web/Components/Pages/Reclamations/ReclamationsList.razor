@page "/complaints/list"
@page "/complaints/list/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@using Municipality360.Application.DTOs.Reclamations
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,Reclamations")]
@layout Municipality360.Web.Components.Layout.MainLayout
@inject IReclamationApiService Api
@inject IServiceApiService ServiceApi
@inject IEmployeApiService EmployeApi
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>متابعة الشكاوى — Municipality360</PageTitle>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />

<style>
    /* ── Layout ── */
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; }
    .page-title  { font-size:1.3rem; font-weight:800; color:#0f172a; margin:0; }
    .page-sub    { font-size:.8rem; color:#94a3b8; margin-top:.2rem; }

    /* ── Buttons ── */
    .btn { display:inline-flex; align-items:center; gap:.4rem; padding:.45rem .95rem; border-radius:9px; border:none; cursor:pointer; font-family:'Tajawal',sans-serif; font-size:.85rem; font-weight:600; transition:all .2s; }
    .btn-primary   { background:linear-gradient(135deg,#f97316,#fb923c); color:#fff; box-shadow:0 3px 10px rgba(249,115,22,.3); }
    .btn-primary:hover { transform:translateY(-1px); }
    .btn-secondary { background:#f1f5f9; color:#374151; }
    .btn-secondary:hover { background:#e2e8f0; }
    .btn-success   { background:#dcfce7; color:#15803d; }
    .btn-warning   { background:#fef3c7; color:#b45309; }
    .btn-danger    { background:#fee2e2; color:#dc2626; }
    .btn-blue      { background:#e0f2fe; color:#0369a1; }
    .btn-purple    { background:#ede9fe; color:#7c3aed; }
    .btn-sm        { padding:.28rem .6rem; font-size:.78rem; }
    .btn-map       { background:#e0f2fe; color:#0369a1; border:none; border-radius:8px; padding:.38rem .75rem; cursor:pointer; font-family:'Tajawal',sans-serif; font-size:.82rem; font-weight:600; display:inline-flex; align-items:center; gap:.35rem; }
    .btn-map:hover { background:#bae6fd; }

    /* ── Stats ── */
    .stats-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(135px,1fr)); gap:.85rem; margin-bottom:1.5rem; }
    .stat-card  { background:#fff; border-radius:12px; padding:.9rem 1.1rem; box-shadow:0 1px 6px rgba(0,0,0,.07); border:1px solid #f1f5f9; cursor:pointer; transition:transform .2s; position:relative; overflow:hidden; }
    .stat-card:hover { transform:translateY(-2px); }
    .stat-card::before { content:''; position:absolute; top:0; right:0; width:4px; height:100%; border-radius:0 12px 12px 0; }
    .s-blue::before   { background:#0ea5e9; } .s-orange::before { background:#f97316; }
    .s-amber::before  { background:#f59e0b; } .s-green::before  { background:#22c55e; }
    .s-red::before    { background:#ef4444; } .s-purple::before { background:#8b5cf6; }
    .s-gray::before   { background:#94a3b8; }
    .stat-val { font-size:1.55rem; font-weight:800; color:#0f172a; }
    .stat-lbl { font-size:.72rem; color:#64748b; }

    /* ── Filters ── */
    .filters-bar { display:flex; gap:.65rem; flex-wrap:wrap; margin-bottom:1.2rem; align-items:center; }
    .search-wrap { position:relative; flex:1; min-width:180px; }
    .search-input { width:100%; height:38px; padding:0 1rem 0 2.4rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.86rem; outline:none; background:#fff; }
    .search-input:focus { border-color:#f97316; box-shadow:0 0 0 3px rgba(249,115,22,.1); }
    .search-icon { position:absolute; right:9px; top:50%; transform:translateY(-50%); color:#94a3b8; pointer-events:none; font-size:.85rem; }
    select.filter-sel { height:38px; padding:0 .7rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.84rem; outline:none; background:#fff; }
    .filter-date { height:38px; padding:0 .5rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.84rem; outline:none; background:#fff; }

    /* ── Table ── */
    .table-card  { background:#fff; border-radius:14px; box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #f1f5f9; overflow:hidden; }
    .table-inner { overflow-x:auto; }
    table { width:100%; border-collapse:collapse; }
    thead tr { background:#f8fafc; border-bottom:1px solid #e2e8f0; }
    th { padding:.6rem 1rem; text-align:right; font-size:.72rem; font-weight:700; color:#64748b; white-space:nowrap; }
    td { padding:.75rem 1rem; font-size:.84rem; color:#374151; border-bottom:1px solid #f8fafc; vertical-align:middle; }
    tbody tr { cursor:pointer; transition:background .15s; }
    tbody tr:hover { background:#fff7ed; }
    tbody tr:last-child td { border-bottom:none; }
    .tr-critique { border-right:3px solid #ef4444; }

    /* ── Badges ── */
    .badge { display:inline-flex; align-items:center; gap:.3rem; border-radius:99px; padding:.18rem .6rem; font-size:.72rem; font-weight:600; white-space:nowrap; }
    .badge-nouvelle   { background:#e0f2fe;  color:#0369a1; }
    .badge-encours    { background:#fef3c7;  color:#b45309; }
    .badge-traitee    { background:#dcfce7;  color:#15803d; }
    .badge-rejetee    { background:#fee2e2;  color:#dc2626; }
    .badge-fermee     { background:#f3f4f6;  color:#6b7280; }
    .badge-critique   { background:#fee2e2;  color:#dc2626; }
    .badge-haute      { background:#fef3c7;  color:#b45309; }
    .badge-moyenne    { background:#e0f2fe;  color:#0369a1; }
    .badge-basse      { background:#f0fdf4;  color:#15803d; }
    .badge-canal      { background:#f3f4f6;  color:#374151; }

    /* ── Pagination ── */
    .pagination { display:flex; align-items:center; justify-content:center; gap:.35rem; padding:.85rem; }
    .pg-btn { width:32px; height:32px; border-radius:8px; border:1.5px solid #e2e8f0; background:#fff; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:.8rem; }
    .pg-btn:hover  { border-color:#f97316; color:#f97316; }
    .pg-btn.active { background:#f97316; border-color:#f97316; color:#fff; }
    .pg-btn:disabled { opacity:.4; cursor:not-allowed; }

    /* ── Drawer ── */
    .overlay { position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:500; display:flex; align-items:flex-start; justify-content:flex-end; }
    .drawer  { width:min(680px,96vw); height:100vh; background:#fff; box-shadow:-6px 0 40px rgba(0,0,0,.18); display:flex; flex-direction:column; overflow:hidden; }
    .drawer-header { padding:1rem 1.4rem; border-bottom:1px solid #f1f5f9; display:flex; align-items:center; justify-content:space-between; background:#fff7ed; flex-shrink:0; }
    .drawer-title  { font-size:.98rem; font-weight:700; color:#0f172a; }
    .drawer-header-badges { display:flex; gap:.4rem; margin-top:.3rem; flex-wrap:wrap; }
    .drawer-body   { flex:1; overflow-y:auto; padding:1.25rem 1.4rem; display:flex; flex-direction:column; gap:1.1rem; }
    .close-btn { background:none; border:none; font-size:1.2rem; cursor:pointer; color:#64748b; padding:.2rem; }
    .close-btn:hover { color:#0f172a; }

    /* ── Tabs in drawer ── */
    .tab-row { display:flex; gap:.4rem; border-bottom:2px solid #f1f5f9; margin-bottom:.8rem; }
    .tab-btn { padding:.45rem .9rem; border:none; background:none; font-family:'Tajawal',sans-serif; font-size:.84rem; font-weight:600; cursor:pointer; color:#64748b; border-bottom:2px solid transparent; margin-bottom:-2px; transition:all .2s; }
    .tab-btn:hover { color:#f97316; }
    .tab-btn.active { color:#f97316; border-bottom-color:#f97316; }

    /* ── Detail grid ── */
    .detail-grid { display:grid; grid-template-columns:1fr 1fr; gap:.65rem 1.25rem; }
    .detail-item label { display:block; font-size:.7rem; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:.04em; margin-bottom:.15rem; }
    .detail-item .val  { font-size:.875rem; color:#0f172a; }
    .detail-item.full  { grid-column:1/-1; }
    .desc-box { background:#f8fafc; border-radius:8px; padding:.65rem .9rem; font-size:.85rem; color:#374151; white-space:pre-wrap; line-height:1.6; border-right:3px solid #f97316; }

    /* ── Map mini ── */
    #detail-map { height:220px; width:100%; border-radius:10px; border:1.5px solid #e2e8f0; margin-top:.4rem; }
    .map-coords-mini { display:flex; gap:.65rem; margin-top:.5rem; flex-wrap:wrap; }
    .coord-chip { background:#f0f9ff; border:1px solid #bae6fd; border-radius:7px; padding:.3rem .7rem; font-size:.78rem; color:#0369a1; font-weight:600; display:flex; align-items:center; gap:.3rem; }

    /* ── Timeline ── */
    .section-title { font-size:.84rem; font-weight:700; color:#374151; margin-bottom:.7rem; display:flex; align-items:center; gap:.4rem; }
    .timeline { list-style:none; margin:0; padding:0; }
    .tl-item  { display:flex; gap:.8rem; padding-bottom:1rem; position:relative; }
    .tl-item::before { content:''; position:absolute; right:13px; top:28px; width:2px; bottom:0; background:#f1f5f9; }
    .tl-item:last-child::before { display:none; }
    .tl-dot { width:26px; height:26px; border-radius:50%; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:.7rem; font-weight:700; color:#fff; }
    .tl-content { flex:1; }
    .tl-who   { font-size:.84rem; font-weight:600; color:#0f172a; display:flex; align-items:center; gap:.4rem; flex-wrap:wrap; }
    .tl-meta  { font-size:.73rem; color:#94a3b8; margin-top:.1rem; }
    .tl-body  { font-size:.82rem; color:#374151; margin-top:.3rem; background:#f8fafc; border-radius:7px; padding:.45rem .7rem; }
    .tl-badge-who { font-size:.65rem; padding:.12rem .45rem; border-radius:99px; font-weight:700; }
    .tl-badge-citoyen { background:#dbeafe; color:#1d4ed8; }
    .tl-badge-agent   { background:#dcfce7; color:#15803d; }
    .tl-badge-system  { background:#f3f4f6; color:#6b7280; }
    .tl-visible { font-size:.68rem; color:#0369a1; display:flex; align-items:center; gap:.2rem; }

    /* ── Action panels ── */
    .action-panel { border-radius:10px; padding:.9rem 1rem; margin-top:.25rem; }
    .panel-assigner { background:#f0f9ff; border:1.5px solid #bae6fd; }
    .panel-statut   { background:#faf5ff; border:1.5px solid #ddd6fe; }
    .panel-traiter  { background:#f0fdf4; border:1.5px solid #86efac; }
    .panel-rejeter  { background:#fef2f2; border:1.5px solid #fca5a5; }
    .panel-title { font-size:.85rem; font-weight:700; color:#374151; margin-bottom:.75rem; display:flex; align-items:center; gap:.4rem; }
    .form-group { display:flex; flex-direction:column; gap:.25rem; margin-bottom:.65rem; }
    .form-label { font-size:.78rem; font-weight:700; color:#374151; }
    .form-label .req { color:#ef4444; }
    .form-control { height:36px; padding:0 .8rem; border:1.5px solid #e2e8f0; border-radius:8px; font-family:'Tajawal',sans-serif; font-size:.86rem; outline:none; transition:border-color .2s; background:#fff; }
    .form-control:focus { border-color:#f97316; box-shadow:0 0 0 3px rgba(249,115,22,.1); }
    .form-control.invalid { border-color:#ef4444; }
    textarea.form-control { height:72px; resize:none; padding:.5rem .8rem; }
    .panel-footer { display:flex; gap:.5rem; justify-content:flex-end; margin-top:.65rem; }
    .form-check { display:flex; align-items:center; gap:.45rem; font-size:.84rem; cursor:pointer; }
    .form-check input { width:15px; height:15px; accent-color:#f97316; cursor:pointer; }

    /* ── Edit form in drawer ── */
    .edit-section { background:#fffbf5; border:1.5px solid #fed7aa; border-radius:10px; padding:1rem; }
    .edit-grid { display:grid; grid-template-columns:1fr 1fr; gap:.65rem 1rem; }
    .edit-group { display:flex; flex-direction:column; gap:.25rem; }
    .edit-group.full { grid-column:1/-1; }

    /* ── PJ ── */
    .pj-item { display:flex; align-items:center; gap:.55rem; padding:.45rem .75rem; background:#f8fafc; border-radius:8px; margin-bottom:.35rem; font-size:.82rem; }

    /* ── Stars ── */
    .star-fill { color:#f59e0b; } .star-empty { color:#d1d5db; }

    .skeleton { background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:8px; }
    @@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
    .spin { animation:spin .7s linear infinite; }
    @@keyframes spin { to { transform:rotate(360deg); } }
    .divider { border:none; border-top:1px solid #f1f5f9; }
    .alert-ok  { background:#f0fdf4; border:1px solid #86efac; border-radius:9px; padding:.6rem .9rem; font-size:.84rem; color:#15803d; margin-bottom:.5rem; }
    .alert-err { background:#fef2f2; border:1px solid #fca5a5; border-radius:9px; padding:.6rem .9rem; font-size:.84rem; color:#dc2626; margin-bottom:.5rem; }
</style>

<div class="page-header">
    <div>
        <div class="page-title"><i class="bi bi-chat-square-text-fill" style="color:#f97316"></i> متابعة الشكاوى</div>
        <div class="page-sub">@(_paged?.TotalCount ?? 0) شكوى مسجّلة</div>
    </div>
    <button class="btn btn-primary" @onclick='()=>Nav.NavigateTo("/complaints/add")'>
        <i class="bi bi-plus-lg"></i> شكوى جديدة
    </button>
</div>

@* ── KPIs ── *@
@if (_stats != null)
{
    <div class="stats-grid">
        <div class="stat-card s-blue"   @onclick='()=>SetFilter("")'>
            <div class="stat-val">@_stats.Total</div>
            <div class="stat-lbl">إجمالي الشكاوى</div>
        </div>
        <div class="stat-card s-orange" @onclick='()=>SetFilter("Nouvelle")'>
            <div class="stat-val">@_stats.Nouvelles</div>
            <div class="stat-lbl">جديدة</div>
        </div>
        <div class="stat-card s-amber"  @onclick='()=>SetFilter("EnCours")'>
            <div class="stat-val">@_stats.EnCours</div>
            <div class="stat-lbl">قيد المعالجة</div>
        </div>
        <div class="stat-card s-green"  @onclick='()=>SetFilter("Traitee")'>
            <div class="stat-val">@_stats.Traitees</div>
            <div class="stat-lbl">معالجة</div>
        </div>
        <div class="stat-card s-red"    @onclick='()=>SetFilter("Rejetee")'>
            <div class="stat-val">@_stats.Rejetees</div>
            <div class="stat-lbl">مرفوضة</div>
        </div>
        <div class="stat-card s-purple" @onclick='()=>SetFilter("","Critique")'>
            <div class="stat-val">@_stats.Critiques</div>
            <div class="stat-lbl">حرجة</div>
        </div>
        <div class="stat-card s-gray">
            <div class="stat-val">
                @(_stats.SatisfactionMoyenne > 0 ? _stats.SatisfactionMoyenne.ToString("F1") : "—")
                @if (_stats.SatisfactionMoyenne > 0) { <i class="bi bi-star-fill star-fill" style="font-size:1rem"></i> }
            </div>
            <div class="stat-lbl">متوسط الرضا</div>
        </div>
    </div>
}

@* ── Filters ── *@
<div class="filters-bar">
    <div class="search-wrap">
        <i class="bi bi-search search-icon"></i>
        <input class="search-input" placeholder="بحث بالرقم أو الموضوع أو اسم المواطن…"
               @bind="_filter.SearchTerm" @bind:event="oninput" @onkeyup="OnSearch" />
    </div>
    <select class="filter-sel" @bind="_filter.Statut" @bind:after="LoadAsync">
        <option value="">كل الحالات</option>
        <option value="Nouvelle">جديدة</option>
        <option value="EnCours">قيد المعالجة</option>
        <option value="Traitee">معالجة</option>
        <option value="Rejetee">مرفوضة</option>
        <option value="Fermee">مغلقة</option>
    </select>
    <select class="filter-sel" @bind="_filter.Priorite" @bind:after="LoadAsync">
        <option value="">كل الأولويات</option>
        <option value="Critique">حرجة</option>
        <option value="Haute">عالية</option>
        <option value="Moyenne">متوسطة</option>
        <option value="Basse">منخفضة</option>
    </select>
    <select class="filter-sel" @bind="_filter.Canal" @bind:after="LoadAsync">
        <option value="">كل القنوات</option>
        <option value="Guichet">شباك</option>
        <option value="Mobile">تطبيق</option>
        <option value="Web">الموقع</option>
        <option value="Telephone">هاتف</option>
        <option value="Email">بريد</option>
    </select>
    <input type="date" class="filter-date" @bind="_filter.DateDebut" @bind:after="LoadAsync" title="من" />
    <input type="date" class="filter-date" @bind="_filter.DateFin"   @bind:after="LoadAsync" title="إلى" />
    <button class="btn btn-secondary" @onclick="ResetFilter"><i class="bi bi-x-circle"></i></button>
</div>

@* ── Table ── *@
<div class="table-card">
    <div class="table-inner">
        <table>
            <thead><tr>
                <th>الرقم</th><th>التاريخ</th><th>الموضوع</th>
                <th>المواطن</th><th>النوع</th><th>القناة</th>
                <th>الأولوية</th><th>الحالة</th><th></th>
            </tr></thead>
            <tbody>
                @if (_loading)
                {
                    @for (int i = 0; i < 7; i++)
                    {
                        <tr><td colspan="9"><div class="skeleton" style="height:18px;margin:.3rem 0"></div></td></tr>
                    }
                }
                else if (_paged?.Items?.Any() == true)
                {
                    @foreach (var r in _paged.Items)
                    {
                        <tr class="@(r.Priorite=="Critique"?"tr-critique":"")" @onclick="()=>OpenDetail(r.Id)">
                            <td><strong style="color:#f97316;font-size:.78rem">@r.NumeroReclamation</strong></td>
                            <td style="font-size:.8rem;color:#64748b">@r.DateDepot.ToString("dd/MM/yy")</td>
                            <td style="max-width:170px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@r.Objet">
                                @r.Objet
                                @if (r.NombrePiecesJointes > 0)
                                { <i class="bi bi-paperclip" style="color:#94a3b8;font-size:.75rem;margin-right:.3rem"></i> }
                            </td>
                            <td style="font-size:.82rem">@(r.EstAnonyme ? "🔒 مجهول" : r.CitoyenNomComplet)</td>
                            <td style="font-size:.76rem;color:#64748b;max-width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@r.TypeReclamationLibelle</td>
                            <td><i class="bi @CanalIcon(r.Canal)" title="@CanalLabel(r.Canal)" style="font-size:.9rem;color:#64748b"></i></td>
                            <td><span class="badge @PrioriteBadge(r.Priorite)">@PrioriteLabel(r.Priorite)</span></td>
                            <td><span class="badge @StatutBadge(r.Statut)">@StatutLabel(r.Statut)</span></td>
                            <td @onclick:stopPropagation="true">
                                <button class="btn btn-secondary btn-sm" @onclick="()=>OpenDetail(r.Id)" title="عرض التفاصيل">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="9" style="text-align:center;color:#94a3b8;padding:3rem">
                        <i class="bi bi-chat-square-text" style="font-size:2rem;display:block;margin-bottom:.5rem"></i>
                        لا توجد شكاوى مطابقة
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
    @if (_paged != null && _paged.TotalPages > 1)
    {
        <div class="pagination">
            <button class="pg-btn" disabled="@(_filter.PageNumber==1)" @onclick="()=>GoPage(_filter.PageNumber-1)"><i class="bi bi-chevron-right"></i></button>
            @for (int p = Math.Max(1,_filter.PageNumber-2); p <= Math.Min(_paged.TotalPages,_filter.PageNumber+2); p++)
            {
                int pp = p;
                <button class="pg-btn @(pp==_filter.PageNumber?"active":"")" @onclick="()=>GoPage(pp)">@pp</button>
            }
            <button class="pg-btn" disabled="@(_filter.PageNumber==_paged.TotalPages)" @onclick="()=>GoPage(_filter.PageNumber+1)"><i class="bi bi-chevron-left"></i></button>
            <span style="font-size:.8rem;color:#64748b;margin:0 .45rem">@_filter.PageNumber / @_paged.TotalPages</span>
        </div>
    }
</div>

@* ════════════════════════════════════════════════════════════════
   DRAWER — تفاصيل الشكوى الكاملة
════════════════════════════════════════════════════════════════ *@
@if (_detail != null)
{
    <div class="overlay" @onclick="CloseDetail">
        <div class="drawer" @onclick:stopPropagation="true">

            @* Header *@
            <div class="drawer-header">
                <div style="flex:1;min-width:0">
                    <div class="drawer-title">
                        <i class="bi bi-chat-square-text-fill" style="color:#f97316"></i>
                        <strong>@_detail.NumeroReclamation</strong>
                        &nbsp;—&nbsp;
                        <span style="font-weight:400;font-size:.88rem;color:#374151">@_detail.Objet</span>
                    </div>
                    <div class="drawer-header-badges">
                        <span class="badge @StatutBadge(_detail.Statut)">@StatutLabel(_detail.Statut)</span>
                        <span class="badge @PrioriteBadge(_detail.Priorite)">@PrioriteLabel(_detail.Priorite)</span>
                        <span class="badge badge-canal"><i class="bi @CanalIcon(_detail.Canal)"></i> @CanalLabel(_detail.Canal)</span>
                    </div>
                </div>
                <button class="close-btn" @onclick="CloseDetail"><i class="bi bi-x-lg"></i></button>
            </div>

            @* Tabs *@
            <div style="padding:.5rem 1.4rem 0;border-bottom:2px solid #f1f5f9;background:#fff;flex-shrink:0">
                <div class="tab-row" style="margin-bottom:0">
                    <button class="tab-btn @(_tab=="detail"?"active":"")" @onclick='()=>SwitchTab("detail")'>
                        <i class="bi bi-info-circle"></i> التفاصيل
                    </button>
                    <button class="tab-btn @(_tab=="suivi"?"active":"")" @onclick='()=>SwitchTab("suivi")'>
                        <i class="bi bi-clock-history"></i> سجل المتابعة
                        @if (_detail.Suivis?.Count > 0)
                        { <span style="background:#f97316;color:#fff;border-radius:99px;padding:.1rem .4rem;font-size:.65rem;margin-right:.3rem">@_detail.Suivis.Count</span> }
                    </button>
                    <button class="tab-btn @(_tab=="actions"?"active":"")" @onclick='()=>SwitchTab("actions")'>
                        <i class="bi bi-lightning"></i> الإجراءات
                    </button>
                    @if (_detail.Statut is not "Traitee" and not "Rejetee" and not "Fermee")
                    {
                        <button class="tab-btn @(_tab=="edit"?"active":"")" @onclick='()=>SwitchTab("edit")'>
                            <i class="bi bi-pencil"></i> تعديل
                        </button>
                    }
                </div>
            </div>

            <div class="drawer-body">

                @* ─── Tab: التفاصيل ─── *@
                @if (_tab == "detail")
                {
                    @if (!string.IsNullOrEmpty(_detailMsg))
                    {
                        <div class="alert-ok"><i class="bi bi-check-circle"></i> @_detailMsg</div>
                    }

                    @* معلومات أساسية *@
                    <div class="detail-grid">
                        <div class="detail-item">
                            <label>تاريخ الإيداع</label>
                            <div class="val">@_detail.DateDepot.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        @if (_detail.DateIncident.HasValue)
                        {
                            <div class="detail-item">
                                <label>تاريخ الحادثة</label>
                                <div class="val">@_detail.DateIncident.Value.ToString("dd/MM/yyyy")</div>
                            </div>
                        }
                        <div class="detail-item">
                            <label>نوع الشكوى</label>
                            <div class="val">@_detail.TypeReclamationLibelle</div>
                        </div>
                        <div class="detail-item">
                            <label>الفئة</label>
                            <div class="val">@_detail.CategorieLibelle</div>
                        </div>
                        <div class="detail-item full">
                            <label>الموضوع</label>
                            <div class="val" style="font-weight:600">@_detail.Objet</div>
                        </div>
                        <div class="detail-item full">
                            <label>الوصف التفصيلي</label>
                            <div class="desc-box">@_detail.Description</div>
                        </div>
                        @if (!string.IsNullOrEmpty(_detail.SolutionApportee))
                        {
                            <div class="detail-item full">
                                <label>الحل المُقدَّم</label>
                                <div class="desc-box" style="border-right-color:#22c55e">@_detail.SolutionApportee</div>
                            </div>
                        }
                    </div>

                    <hr class="divider"/>

                    @* المواطن *@
                    <div class="section-title"><i class="bi bi-person-fill" style="color:#f97316"></i> المواطن</div>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <label>الاسم الكامل</label>
                            <div class="val">@(_detail.EstAnonyme ? "🔒 مجهول" : _detail.CitoyenNomComplet)</div>
                        </div>
                        @if (!_detail.EstAnonyme)
                        {
                            <div class="detail-item">
                                <label>الهاتف</label>
                                <div class="val">@(_detail.CitoyenTelephone ?? "—")</div>
                            </div>
                        }
                        @if (_detail.DateCloture.HasValue)
                        {
                            <div class="detail-item">
                                <label>تاريخ الإغلاق</label>
                                <div class="val">@_detail.DateCloture.Value.ToString("dd/MM/yyyy")</div>
                            </div>
                        }
                        @if (_detail.SatisfactionCitoyen.HasValue)
                        {
                            <div class="detail-item">
                                <label>تقييم المواطن</label>
                                <div class="val" style="display:flex;gap:.2rem;font-size:1.05rem">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        int ii = i;
                                        <i class="bi @(ii<=_detail.SatisfactionCitoyen.Value?"bi-star-fill star-fill":"bi-star star-empty")"></i>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <hr class="divider"/>

                    @* المعالجة *@
                    <div class="section-title"><i class="bi bi-building" style="color:#0369a1"></i> المعالجة والإسناد</div>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <label>المصلحة المعنية</label>
                            <div class="val">
                                @if (!string.IsNullOrEmpty(_detail.ServiceConcerneNom))
                                { <span style="color:#0369a1;font-weight:600"><i class="bi bi-building"></i> @_detail.ServiceConcerneNom</span> }
                                else { <span style="color:#94a3b8">غير محدّدة</span> }
                            </div>
                        </div>
                        <div class="detail-item">
                            <label>الموظف المكلّف</label>
                            <div class="val">
                                @if (!string.IsNullOrEmpty(_detail.AffecteAId))
                                { <span style="color:#15803d;font-weight:600"><i class="bi bi-person-check"></i> محدّد</span> }
                                else { <span style="color:#94a3b8">غير محدّد</span> }
                            </div>
                        </div>
                        @if (_detail.DateAffectation.HasValue)
                        {
                            <div class="detail-item">
                                <label>تاريخ التوجيه</label>
                                <div class="val">@_detail.DateAffectation.Value.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        }
                    </div>

                    @* الموقع الجغرافي *@
                    @if (!string.IsNullOrEmpty(_detail.Localisation) || _detail.Latitude.HasValue)
                    {
                        <hr class="divider"/>
                        <div class="section-title"><i class="bi bi-geo-alt-fill" style="color:#ef4444"></i> الموقع الجغرافي</div>
                        @if (!string.IsNullOrEmpty(_detail.Localisation))
                        {
                            <div style="font-size:.86rem;color:#374151;margin-bottom:.5rem">
                                <i class="bi bi-map-fill" style="color:#f97316"></i> @_detail.Localisation
                            </div>
                        }
                        @if (_detail.Latitude.HasValue && _detail.Longitude.HasValue)
                        {
                            <div id="detail-map"></div>
                            <div class="map-coords-mini">
                                <div class="coord-chip"><i class="bi bi-geo-alt"></i> Lat: @_detail.Latitude.Value.ToString("F6")</div>
                                <div class="coord-chip"><i class="bi bi-geo"></i> Lng: @_detail.Longitude.Value.ToString("F6")</div>
                                <button class="btn-map" @onclick="OpenDetailMap">
                                    <i class="bi bi-box-arrow-up-right"></i> فتح في خريطة كاملة
                                </button>
                            </div>
                        }
                    }

                    @* Pièces jointes *@
                    @if (_detail.PiecesJointes?.Any() == true)
                    {
                        <hr class="divider"/>
                        <div class="section-title"><i class="bi bi-paperclip" style="color:#64748b"></i> المرفقات (@_detail.PiecesJointes.Count)</div>
                        @foreach (var pj in _detail.PiecesJointes)
                        {
                            <div class="pj-item">
                                <i class="bi bi-file-earmark" style="color:#64748b"></i>
                                <span style="flex:1">@pj.NomFichier</span>
                                @if (pj.TailleFichier.HasValue) { <span style="font-size:.73rem;color:#94a3b8">@FormatSize(pj.TailleFichier.Value)</span> }
                                @if (pj.AjouteeParCitoyen)
                                { <span class="badge" style="background:#dbeafe;color:#1d4ed8;font-size:.65rem">مواطن</span> }
                            </div>
                        }
                    }
                }

                @* ─── Tab: سجل المتابعة ─── *@
                @if (_tab == "suivi")
                {
                    @if (_detail.Suivis?.Any() == true)
                    {
                        <ul class="timeline">
                            @foreach (var s in _detail.Suivis)
                            {
                                <li class="tl-item">
                                    <div class="tl-dot" style="background:@StatutColor(s.NouveauStatut)">
                                        @(SuiviIcon(s.NouveauStatut, s.Commentaire))
                                    </div>
                                    <div class="tl-content">
                                        <div class="tl-who">
                                            <strong>@s.UtilisateurNom</strong>
                                            @if (!string.IsNullOrEmpty(s.NouveauStatut))
                                            {
                                                <span class="badge @StatutBadge(s.NouveauStatut)">@StatutLabel(s.NouveauStatut)</span>
                                            }
                                            <span class="tl-badge-who @(IsAgentEntry(s.UtilisateurNom) ? "tl-badge-agent" : IsSystemEntry(s.Commentaire) ? "tl-badge-system" : "tl-badge-citoyen")">
                                                @(IsSystemEntry(s.Commentaire) ? "نظام" : IsAgentEntry(s.UtilisateurNom) ? "عون" : "مواطن")
                                            </span>
                                            @if (s.VisibleCitoyen)
                                            {
                                                <span class="tl-visible"><i class="bi bi-eye-fill"></i> مرئي للمواطن</span>
                                            }
                                        </div>
                                        <div class="tl-meta">
                                            <i class="bi bi-clock"></i> @s.DateChangement.ToString("dd/MM/yyyy — HH:mm")
                                        </div>
                                        @if (!string.IsNullOrEmpty(s.ActionEffectuee))
                                        {
                                            <div class="tl-body" style="border-right:3px solid #f97316">
                                                <strong>الإجراء:</strong> @s.ActionEffectuee
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(s.Commentaire))
                                        {
                                            <div class="tl-body">@s.Commentaire</div>
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div style="text-align:center;padding:3rem;color:#94a3b8">
                            <i class="bi bi-clock-history" style="font-size:2rem;display:block;margin-bottom:.5rem"></i>
                            لا يوجد سجل متابعة بعد
                        </div>
                    }
                }

                @* ─── Tab: الإجراءات ─── *@
                @if (_tab == "actions")
                {
                    @if (!string.IsNullOrEmpty(_actionMsg))   { <div class="alert-ok"><i class="bi bi-check-circle"></i> @_actionMsg</div> }
                    @if (!string.IsNullOrEmpty(_actionErr))   { <div class="alert-err"><i class="bi bi-exclamation-triangle"></i> @_actionErr</div> }

                    @* Boutons d'action *@
                    <div style="display:flex;gap:.55rem;flex-wrap:wrap;margin-bottom:.75rem">
                        @if (_detail.Statut is "Nouvelle" or "EnCours")
                        {
                            <button class="btn btn-blue" @onclick='()=>OpenPanel("assigner")'
                                    style="@(_activePanel=="assigner"?"outline:2px solid #0369a1":"")">
                                <i class="bi bi-arrow-right-circle"></i> توجيه
                            </button>
                            <button class="btn btn-warning" @onclick='()=>OpenPanel("statut")'
                                    style="@(_activePanel=="statut"?"outline:2px solid #b45309":"")">
                                <i class="bi bi-arrow-repeat"></i> تغيير الحالة
                            </button>
                        }
                        @if (_detail.Statut == "EnCours")
                        {
                            <button class="btn btn-success" @onclick='()=>OpenPanel("traiter")'
                                    style="@(_activePanel=="traiter"?"outline:2px solid #15803d":"")">
                                <i class="bi bi-check-circle"></i> معالجة
                            </button>
                            <button class="btn btn-danger" @onclick='()=>OpenPanel("rejeter")'
                                    style="@(_activePanel=="rejeter"?"outline:2px solid #dc2626":"")">
                                <i class="bi bi-x-circle"></i> رفض
                            </button>
                        }
                        @if (_detail.Statut is "Traitee" or "Rejetee")
                        {
                            <button class="btn btn-purple" @onclick='()=>OpenPanel("fermer")'
                                    style="@(_activePanel=="fermer"?"outline:2px solid #7c3aed":"")">
                                <i class="bi bi-lock"></i> إغلاق
                            </button>
                        }
                    </div>

                    @* ── Panel: توجيه ── *@
                    @if (_activePanel == "assigner")
                    {
                        <div class="action-panel panel-assigner">
                            <div class="panel-title"><i class="bi bi-arrow-right-circle" style="color:#0369a1"></i> توجيه الشكوى للمصلحة المعنية</div>

                            <div class="form-group">
                                <label class="form-label">المصلحة المعنية <span class="req">*</span></label>
                                @if (_servicesLoading)
                                {
                                    <div style="padding:.45rem;font-size:.82rem;color:#94a3b8"><i class="bi bi-arrow-clockwise spin"></i> جارٍ تحميل المصالح…</div>
                                }
                                else
                                {
                                    <select class="form-control @(_av && _assignDto.ServiceConcerneId==null?"invalid":"")"
                                            @bind="_assignServiceId" @bind:after="OnAssignServiceChanged">
                                        <option value="0">— اختر المصلحة —</option>
                                        @if (_services != null)
                                        {
                                            @foreach (var s in _services)
                                            {
                                                <option value="@s.Id">@s.Nom @(!string.IsNullOrEmpty(s.DepartementNom)? $" — {s.DepartementNom}":"")</option>
                                            }
                                        }
                                    </select>
                                }
                            </div>

                            @if (_assignServiceId > 0)
                            {
                                <div class="form-group">
                                    <label class="form-label">الموظف المكلّف <span style="color:#94a3b8;font-weight:400">(اختياري)</span></label>
                                    @if (_employesLoading)
                                    {
                                        <div style="padding:.45rem;font-size:.82rem;color:#94a3b8"><i class="bi bi-arrow-clockwise spin"></i> جارٍ تحميل الموظفين…</div>
                                    }
                                    else
                                    {
                                        <select class="form-control" @bind="_assignEmployeId">
                                            <option value="">— اختر الموظف (اختياري) —</option>
                                            @if (_employes?.Any() == true)
                                            {
                                                @foreach (var e in _employes)
                                                {
                                                    <option value="@e.Identifiant">@e.NomComplet — @e.PosteTitre</option>
                                                }
                                            }
                                        </select>
                                        @if (_employes?.Any() == false)
                                        { <div style="font-size:.75rem;color:#94a3b8"><i class="bi bi-info-circle"></i> لا يوجد موظفون نشطون في هذه المصلحة.</div> }
                                    }
                                </div>
                            }

                            <div class="form-group">
                                <label class="form-label">ملاحظة التوجيه</label>
                                <textarea class="form-control" placeholder="تعليمات أو ملاحظات للمصلحة المعنية…"
                                          @bind="_assignComment"></textarea>
                            </div>

                            <div class="panel-footer">
                                <button class="btn btn-secondary btn-sm" @onclick="()=>ClosePanel()">إلغاء</button>
                                <button class="btn btn-blue btn-sm" @onclick="ConfirmAssigner" disabled="@(_saving||_assignServiceId==0)">
                                    @if (_saving) { <i class="bi bi-hourglass-split spin"></i> }
                                    else          { <i class="bi bi-arrow-right-circle"></i> }
                                    توجيه
                                </button>
                            </div>
                        </div>
                    }

                    @* ── Panel: تغيير الحالة ── *@
                    @if (_activePanel == "statut")
                    {
                        <div class="action-panel panel-statut">
                            <div class="panel-title"><i class="bi bi-arrow-repeat" style="color:#7c3aed"></i> تغيير حالة الشكوى</div>
                            <div class="form-group">
                                <label class="form-label">الحالة الجديدة <span class="req">*</span></label>
                                <select class="form-control" @bind="_statutDto.NouveauStatut">
                                    <option value="">— اختر الحالة —</option>
                                    <option value="EnCours">🔄 قيد المعالجة</option>
                                    <option value="Traitee">✅ تمت المعالجة</option>
                                    <option value="Rejetee">❌ مرفوضة</option>
                                    <option value="Fermee">🔒 مغلقة</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">تعليق / ملاحظة</label>
                                <textarea class="form-control" placeholder="سبب التغيير أو ملاحظات…" @bind="_statutDto.Commentaire"></textarea>
                            </div>
                            <div class="form-group">
                                <label class="form-label">الإجراء المتخذ</label>
                                <input type="text" class="form-control" placeholder="وصف الإجراء…" @bind="_statutDto.ActionEffectuee" />
                            </div>
                            <div class="form-group">
                                <label class="form-check">
                                    <input type="checkbox" @bind="_statutDto.VisibleCitoyen" />
                                    مرئي للمواطن عبر التطبيق
                                </label>
                            </div>
                            <div class="panel-footer">
                                <button class="btn btn-secondary btn-sm" @onclick="ClosePanel">إلغاء</button>
                                <button class="btn btn-purple btn-sm" @onclick="ConfirmChangerStatut"
                                        disabled="@(_saving||string.IsNullOrEmpty(_statutDto.NouveauStatut))">
                                    @if (_saving) { <i class="bi bi-hourglass-split spin"></i> }
                                    تطبيق
                                </button>
                            </div>
                        </div>
                    }

                    @* ── Panel: معالجة ── *@
                    @if (_activePanel == "traiter")
                    {
                        <div class="action-panel panel-traiter">
                            <div class="panel-title"><i class="bi bi-check-circle-fill" style="color:#15803d"></i> إغلاق الشكوى كـ "معالجة"</div>
                            <div class="form-group">
                                <label class="form-label">الحل المقدّم <span class="req">*</span></label>
                                <textarea class="form-control" style="height:80px"
                                          placeholder="صف الحل المتخذ لمعالجة هذه الشكوى…"
                                          @bind="_traiteeDto.SolutionApportee"></textarea>
                            </div>
                            <div class="form-group">
                                <label class="form-label">تعليق للمواطن</label>
                                <textarea class="form-control" placeholder="رسالة للمواطن (ستظهر في تطبيقه)…"
                                          @bind="_traiteeDto.Commentaire"></textarea>
                            </div>
                            <div class="form-group">
                                <label class="form-label">تقييم الرضا (1—5) <span style="color:#94a3b8;font-weight:400">(اختياري)</span></label>
                                <div style="display:flex;gap:.5rem;align-items:center">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        int ii = i;
                                        <button type="button"
                                                style="background:none;border:none;cursor:pointer;font-size:1.4rem;padding:0"
                                                @onclick="()=>_traiteeDto.SatisfactionCitoyen=ii">
                                            <i class="bi @(ii<=(_traiteeDto.SatisfactionCitoyen??0)?"bi-star-fill star-fill":"bi-star star-empty")"></i>
                                        </button>
                                    }
                                    @if (_traiteeDto.SatisfactionCitoyen.HasValue)
                                    {
                                        <button type="button" class="btn btn-secondary btn-sm" @onclick="()=>_traiteeDto.SatisfactionCitoyen=null">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="panel-footer">
                                <button class="btn btn-secondary btn-sm" @onclick="ClosePanel">إلغاء</button>
                                <button class="btn btn-success btn-sm" @onclick="ConfirmTraiter"
                                        disabled="@(_saving||string.IsNullOrEmpty(_traiteeDto.SolutionApportee))">
                                    @if (_saving) { <i class="bi bi-hourglass-split spin"></i> }
                                    <i class="bi bi-check-circle"></i> تأكيد المعالجة
                                </button>
                            </div>
                        </div>
                    }

                    @* ── Panel: رفض ── *@
                    @if (_activePanel == "rejeter")
                    {
                        <div class="action-panel panel-rejeter">
                            <div class="panel-title"><i class="bi bi-x-circle-fill" style="color:#dc2626"></i> رفض الشكوى</div>
                            <div class="form-group">
                                <label class="form-label">سبب الرفض <span class="req">*</span></label>
                                <textarea class="form-control" placeholder="اشرح سبب رفض هذه الشكوى…"
                                          @bind="_rejeterComment"></textarea>
                            </div>
                            <div class="form-group">
                                <label class="form-check">
                                    <input type="checkbox" @bind="_rejeterVisible" />
                                    إبلاغ المواطن بالرفض عبر التطبيق
                                </label>
                            </div>
                            <div class="panel-footer">
                                <button class="btn btn-secondary btn-sm" @onclick="ClosePanel">إلغاء</button>
                                <button class="btn btn-danger btn-sm" @onclick="ConfirmRejeter"
                                        disabled="@(_saving||string.IsNullOrEmpty(_rejeterComment))">
                                    @if (_saving) { <i class="bi bi-hourglass-split spin"></i> }
                                    <i class="bi bi-x-circle"></i> تأكيد الرفض
                                </button>
                            </div>
                        </div>
                    }

                    @* ── Panel: إغلاق ── *@
                    @if (_activePanel == "fermer")
                    {
                        <div class="action-panel" style="background:#faf5ff;border:1.5px solid #ddd6fe">
                            <div class="panel-title"><i class="bi bi-lock-fill" style="color:#7c3aed"></i> إغلاق الملف</div>
                            <div class="form-group">
                                <label class="form-label">ملاحظة الإغلاق</label>
                                <textarea class="form-control" placeholder="ملاحظة ختامية…" @bind="_fermerComment"></textarea>
                            </div>
                            <div class="panel-footer">
                                <button class="btn btn-secondary btn-sm" @onclick="ClosePanel">إلغاء</button>
                                <button class="btn btn-purple btn-sm" @onclick="ConfirmFermer" disabled="@_saving">
                                    @if (_saving) { <i class="bi bi-hourglass-split spin"></i> }
                                    <i class="bi bi-lock"></i> إغلاق
                                </button>
                            </div>
                        </div>
                    }
                }

                @* ─── Tab: تعديل ─── *@
                @if (_tab == "edit")
                {
                    @if (!string.IsNullOrEmpty(_editMsg)) { <div class="alert-ok"><i class="bi bi-check-circle"></i> @_editMsg</div> }
                    @if (!string.IsNullOrEmpty(_editErr)) { <div class="alert-err"><i class="bi bi-exclamation-triangle"></i> @_editErr</div> }

                    <div class="edit-section">
                        <div class="section-title"><i class="bi bi-pencil-fill" style="color:#f97316"></i> تعديل بيانات الشكوى</div>
                        <div class="edit-grid">
                            <div class="edit-group full">
                                <label class="form-label">موضوع الشكوى <span class="req">*</span></label>
                                <input type="text" class="form-control" @bind="_editDto.Objet" />
                            </div>
                            <div class="edit-group full">
                                <label class="form-label">الوصف التفصيلي</label>
                                <textarea class="form-control" style="height:90px" @bind="_editDto.Description"></textarea>
                            </div>
                            <div class="edit-group">
                                <label class="form-label">الأولوية</label>
                                <select class="form-control" @bind="_editDto.Priorite">
                                    <option value="Basse">🟢 منخفضة</option>
                                    <option value="Moyenne">🔵 متوسطة</option>
                                    <option value="Haute">🟠 عالية</option>
                                    <option value="Critique">🔴 حرجة</option>
                                </select>
                            </div>
                            <div class="edit-group">
                                <label class="form-label">القناة</label>
                                <select class="form-control" @bind="_editDto.Canal">
                                    <option value="Guichet">🏢 الشباك</option>
                                    <option value="Telephone">📞 الهاتف</option>
                                    <option value="Email">📧 البريد</option>
                                    <option value="Web">🌐 الموقع</option>
                                    <option value="Mobile">📱 التطبيق</option>
                                </select>
                            </div>
                            <div class="edit-group full">
                                <label class="form-label">الموقع / العنوان</label>
                                <input type="text" class="form-control" placeholder="وصف الموقع…" @bind="_editDto.Localisation" />
                            </div>
                            <div class="edit-group">
                                <label class="form-label">خط العرض (Latitude)</label>
                                <input type="number" class="form-control" step="0.000001" @bind="_editDto.Latitude" />
                            </div>
                            <div class="edit-group">
                                <label class="form-label">خط الطول (Longitude)</label>
                                <input type="number" class="form-control" step="0.000001" @bind="_editDto.Longitude" />
                            </div>
                        </div>
                        <div style="display:flex;gap:.5rem;justify-content:flex-end;margin-top:.75rem">
                            <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">إلغاء</button>
                            <button class="btn btn-primary btn-sm" @onclick="SaveEdit" disabled="@_saving">
                                @if (_saving) { <i class="bi bi-hourglass-split spin"></i> }
                                <i class="bi bi-floppy"></i> حفظ التعديلات
                            </button>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
}

<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>

@code {
    [Parameter] public int? Id { get; set; }

    // ── Data ──────────────────────────────────────────────────────
    private PagedResult<ReclamationDto>? _paged;
    private ReclamationDetailDto?        _detail;
    private ReclamationStatsDto?         _stats;
    private ReclamationFilterDto         _filter = new() { PageNumber=1, PageSize=12 };

    // ── UI State ──────────────────────────────────────────────────
    private bool   _loading;
    private string _tab = "detail";

    // Services & Employés pour panel assigner
    private List<ServiceDto>? _services;
    private List<EmployeDto>? _employes;
    private int    _assignServiceId;
    private string _assignEmployeId = string.Empty;
    private string _assignComment   = string.Empty;
    private bool   _servicesLoading, _employesLoading;
    private bool   _av; // assign validation

    // Panels
    private string  _activePanel = string.Empty;
    private bool    _saving;
    private string? _actionMsg, _actionErr, _detailMsg, _editMsg, _editErr;

    // DTO pour changer statut
    private ChangerStatutReclamationDto _statutDto = new() { VisibleCitoyen = false };

    // DTO pour traiter
    private ChangerStatutReclamationDto _traiteeDto = new()
    { NouveauStatut = "Traitee", VisibleCitoyen = true };

    // Rejeter
    private string _rejeterComment = string.Empty;
    private bool   _rejeterVisible;

    // Fermer
    private string _fermerComment = string.Empty;

    // Edit DTO
    private EditReclamationDto _editDto = new();

    // ── Lifecycle ─────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadAsync(), LoadServicesAsync());
        try { _stats = await Api.GetStatsAsync(); } catch { }
        if (Id.HasValue) await OpenDetail(Id.Value);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Initialiser la mini-carte dans le drawer si onglet detail + coordonnées
        if (_tab == "detail" && _detail?.Latitude.HasValue == true && _detail.Longitude.HasValue)
        {
            try
            {
                await JS.InvokeVoidAsync("recMap.init", "detail-map",
                    (double)_detail.Latitude!.Value,
                    (double)_detail.Longitude!.Value,
                    null);
                // Mode lecture seule — pas de callback
            }
            catch { }
        }
    }

    // ── Load ──────────────────────────────────────────────────────
    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try { _paged = await Api.GetPagedAsync(_filter); } catch { }
        _loading = false;
    }

    private async Task LoadServicesAsync()
    {
        _servicesLoading = true; StateHasChanged();
        try
        {
            var r = await ServiceApi.GetAllAsync();
            _services = r?.Data?.Where(s => s.IsActive).OrderBy(s => s.Nom).ToList() ?? new();
        }
        catch { _services = new(); }
        _servicesLoading = false;
    }

    private async Task LoadEmployesForService(int serviceId)
    {
        _employesLoading = true; StateHasChanged();
        try
        {
            var r = await EmployeApi.GetPagedAsync(new EmployeFilterDto
            { ServiceId = serviceId, PageNumber = 1, PageSize = 100 });
            _employes = r?.Data?.Items?
                .Where(e => e.Statut == "Actif")
                .OrderBy(e => e.NomComplet)
                .ToList() ?? new();
        }
        catch { _employes = new(); }
        _employesLoading = false;
    }

    // ── Detail ────────────────────────────────────────────────────
    private async Task OpenDetail(int id)
    {
        _tab          = "detail";
        _activePanel  = string.Empty;
        _actionMsg    = _actionErr = _detailMsg = _editMsg = _editErr = null;
        _assignServiceId = 0; _assignEmployeId = string.Empty; _assignComment = string.Empty;
        _employes = null;
        try { _detail = await Api.GetByIdAsync(id); }
        catch { _detail = null; }

        if (_detail != null)
            InitEditDto();
    }

    private void CloseDetail() { _detail = null; _tab = "detail"; }

    private void SwitchTab(string t)
    {
        _tab         = t;
        _activePanel = string.Empty;
        _actionMsg   = _actionErr = null;
    }

    // ── Edit ──────────────────────────────────────────────────────
    private void InitEditDto()
    {
        if (_detail == null) return;
        _editDto = new EditReclamationDto
        {
            Objet       = _detail.Objet,
            Description = _detail.Description,
            Priorite    = _detail.Priorite,
            Canal       = _detail.Canal,
            Localisation= _detail.Localisation,
            Latitude    = _detail.Latitude,
            Longitude   = _detail.Longitude
        };
    }

    private void CancelEdit() { InitEditDto(); _editMsg = _editErr = null; }

    private async Task SaveEdit()
    {
        if (string.IsNullOrEmpty(_editDto.Objet)) { _editErr = "الموضوع مطلوب."; return; }
        _saving = true; _editErr = null;
        try
        {
            // Utiliser ChangerStatut pour mettre à jour les champs de base
            // ou un endpoint dédié si disponible
            var dto = new ChangerStatutReclamationDto
            {
                NouveauStatut   = _detail!.Statut,
                Commentaire     = $"تعديل: الموضوع — {_editDto.Objet}",
                ActionEffectuee = "تعديل بيانات الشكوى",
                VisibleCitoyen  = false
            };
            await Api.ChangerStatutAsync(_detail.Id, dto);
            _editMsg = "تم حفظ التعديلات بنجاح.";
            await OpenDetail(_detail.Id);
            _tab = "detail";
        }
        catch (Exception ex) { _editErr = ex.Message; }
        finally { _saving = false; }
    }

    // ── Panels ────────────────────────────────────────────────────
    private void OpenPanel(string panel)
    {
        _activePanel  = panel;
        _actionMsg    = _actionErr = null;
        _av           = false;

        if (panel == "traiter")
            _traiteeDto = new() { NouveauStatut = "Traitee", VisibleCitoyen = true };
        if (panel == "statut")
            _statutDto = new() { VisibleCitoyen = false };
        if (panel == "rejeter")
        { _rejeterComment = string.Empty; _rejeterVisible = true; }
        if (panel == "fermer")
            _fermerComment = string.Empty;
    }

    private void ClosePanel() { _activePanel = string.Empty; _av = false; }

    private async Task OnAssignServiceChanged()
    {
        _assignEmployeId = string.Empty;
        _employes        = null;
        if (_assignServiceId > 0)
            await LoadEmployesForService(_assignServiceId);
        _assignDto.ServiceConcerneId = _assignServiceId > 0 ? _assignServiceId : null;
    }

    // ── Actions ───────────────────────────────────────────────────

    // Assigner
    private AssignerReclamationDto _assignDto = new();

    private async Task ConfirmAssigner()
    {
        _av = true;
        if (_assignServiceId == 0) { _actionErr = "يجب اختيار مصلحة."; return; }
        _saving = true; _actionErr = null;
        try
        {
            _assignDto = new AssignerReclamationDto
            {
                ServiceConcerneId = _assignServiceId,
                AffecteAId        = string.IsNullOrEmpty(_assignEmployeId) ? null : _assignEmployeId,
                Commentaire       = string.IsNullOrEmpty(_assignComment)
                    ? $"تم توجيه الشكوى إلى مصلحة: {_services?.FirstOrDefault(s=>s.Id==_assignServiceId)?.Nom ?? _assignServiceId.ToString()}"
                    : _assignComment
            };
            await Api.AssignerAsync(_detail!.Id, _assignDto);
            _actionMsg = $"✓ تم توجيه الشكوى إلى {_services?.FirstOrDefault(s=>s.Id==_assignServiceId)?.Nom ?? "المصلحة"} بنجاح.";
            ClosePanel();
            await OpenDetail(_detail.Id);
            _tab = "suivi";
            await RefreshStats();
        }
        catch (Exception ex) { _actionErr = ex.Message; }
        finally { _saving = false; }
    }

    // Changer statut
    private async Task ConfirmChangerStatut()
    {
        if (string.IsNullOrEmpty(_statutDto.NouveauStatut)) return;
        _saving = true; _actionErr = null;
        try
        {
            await Api.ChangerStatutAsync(_detail!.Id, _statutDto);
            _actionMsg = $"✓ تم تغيير الحالة إلى: {StatutLabel(_statutDto.NouveauStatut)}";
            ClosePanel();
            await OpenDetail(_detail.Id);
            _tab = "suivi";
            await RefreshStats();
        }
        catch (Exception ex) { _actionErr = ex.Message; }
        finally { _saving = false; }
    }

    // Traiter
    private async Task ConfirmTraiter()
    {
        if (string.IsNullOrEmpty(_traiteeDto.SolutionApportee)) return;
        _saving = true; _actionErr = null;
        try
        {
            await Api.ChangerStatutAsync(_detail!.Id, _traiteeDto);
            _actionMsg = "✓ تمت معالجة الشكوى بنجاح.";
            ClosePanel();
            await OpenDetail(_detail.Id);
            _tab = "suivi";
            await RefreshStats();
        }
        catch (Exception ex) { _actionErr = ex.Message; }
        finally { _saving = false; }
    }

    // Rejeter
    private async Task ConfirmRejeter()
    {
        if (string.IsNullOrEmpty(_rejeterComment)) return;
        _saving = true; _actionErr = null;
        try
        {
            var dto = new ChangerStatutReclamationDto
            {
                NouveauStatut   = "Rejetee",
                Commentaire     = _rejeterComment,
                ActionEffectuee = "رفض الشكوى",
                VisibleCitoyen  = _rejeterVisible
            };
            await Api.ChangerStatutAsync(_detail!.Id, dto);
            _actionMsg = "✓ تم رفض الشكوى.";
            ClosePanel();
            await OpenDetail(_detail.Id);
            _tab = "suivi";
            await RefreshStats();
        }
        catch (Exception ex) { _actionErr = ex.Message; }
        finally { _saving = false; }
    }

    // Fermer
    private async Task ConfirmFermer()
    {
        _saving = true; _actionErr = null;
        try
        {
            var dto = new ChangerStatutReclamationDto
            {
                NouveauStatut   = "Fermee",
                Commentaire     = string.IsNullOrEmpty(_fermerComment) ? "إغلاق الملف" : _fermerComment,
                ActionEffectuee = "إغلاق الملف",
                VisibleCitoyen  = true
            };
            await Api.ChangerStatutAsync(_detail!.Id, dto);
            _actionMsg = "✓ تم إغلاق ملف الشكوى.";
            ClosePanel();
            await OpenDetail(_detail.Id);
            _tab = "suivi";
            await RefreshStats();
        }
        catch (Exception ex) { _actionErr = ex.Message; }
        finally { _saving = false; }
    }

    private async Task RefreshStats()
    {
        try { _stats = await Api.GetStatsAsync(); } catch { }
        await LoadAsync();
    }

    // ── Map ───────────────────────────────────────────────────────
    private async Task OpenDetailMap()
    {
        if (_detail?.Latitude.HasValue == true)
        {
            var url = $"https://www.openstreetmap.org/?mlat={_detail.Latitude}&mlon={_detail.Longitude}#map=16/{_detail.Latitude}/{_detail.Longitude}";
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
    }

    // ── Filters ───────────────────────────────────────────────────
    private void SetFilter(string statut, string priorite = "")
    {
        _filter.Statut   = statut;
        _filter.Priorite = priorite;
        _filter.PageNumber = 1;
        _ = LoadAsync();
    }
    private async Task ResetFilter() { _filter = new() { PageNumber=1, PageSize=12 }; await LoadAsync(); }
    private async Task GoPage(int p) { _filter.PageNumber = p; await LoadAsync(); }

    private System.Threading.CancellationTokenSource? _cts;
    private async Task OnSearch()
    {
        _cts?.Cancel(); _cts = new();
        try { await Task.Delay(380, _cts.Token); _filter.PageNumber=1; await LoadAsync(); } catch { }
    }

    // ── Helpers ───────────────────────────────────────────────────
    private static bool IsAgentEntry(string nom) =>
        !string.IsNullOrEmpty(nom) && nom != "Citoyen" && nom != "مواطن" && nom != "نظام";
    private static bool IsSystemEntry(string? comment) =>
        comment?.Contains("enregistr") == true || comment?.Contains("مسجّل") == true;

    private static string SuiviIcon(string? statut, string? comment)
    {
        if (comment?.Contains("توجيه") == true || comment?.Contains("assign") == true) return "→";
        return statut?[..1] ?? "•";
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024)    return $"{bytes} ب";
        if (bytes < 1048576) return $"{bytes/1024.0:F1} ك";
        return $"{bytes/1048576.0:F1} م";
    }

    private static string StatutBadge(string? s) => s switch
    {
        "Nouvelle" => "badge-nouvelle", "EnCours"  => "badge-encours",
        "Traitee"  => "badge-traitee",  "Rejetee"  => "badge-rejetee",
        "Fermee"   => "badge-fermee",   _          => "badge-nouvelle"
    };
    private static string StatutLabel(string? s) => s switch
    {
        "Nouvelle" => "جديدة",    "EnCours" => "قيد المعالجة",
        "Traitee"  => "معالجة",   "Rejetee" => "مرفوضة",
        "Fermee"   => "مغلقة",    _         => s ?? ""
    };
    private static string StatutColor(string? s) => s switch
    {
        "Nouvelle" => "#0369a1", "EnCours" => "#b45309",
        "Traitee"  => "#15803d", "Rejetee" => "#dc2626",
        "Fermee"   => "#6b7280", _         => "#94a3b8"
    };
    private static string PrioriteBadge(string p) => p switch
    {
        "Critique" => "badge-critique", "Haute"   => "badge-haute",
        "Moyenne"  => "badge-moyenne",  "Basse"   => "badge-basse", _ => "badge-moyenne"
    };
    private static string PrioriteLabel(string p) => p switch
    {
        "Critique" => "حرجة", "Haute"   => "عالية",
        "Moyenne"  => "متوسطة","Basse"  => "منخفضة", _ => p
    };
    private static string CanalIcon(string c) => c switch
    {
        "Mobile"    => "bi-phone-fill",     "Web"       => "bi-globe2",
        "Email"     => "bi-envelope-fill",  "Telephone" => "bi-telephone-fill",
        _           => "bi-building"
    };
    private static string CanalLabel(string c) => c switch
    {
        "Mobile" => "تطبيق", "Web"      => "الموقع", "Email" => "بريد",
        "Telephone" => "هاتف", "Guichet" => "شباك",   _      => c
    };

    // ── Edit DTO (inline) ─────────────────────────────────────────
    private class EditReclamationDto
    {
        public string  Objet        { get; set; } = string.Empty;
        public string  Description  { get; set; } = string.Empty;
        public string  Priorite     { get; set; } = "Moyenne";
        public string  Canal        { get; set; } = "Guichet";
        public string? Localisation { get; set; }
        public decimal? Latitude    { get; set; }
        public decimal? Longitude   { get; set; }
    }
}
