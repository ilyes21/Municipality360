@page "/complaints/stats"
@using Microsoft.AspNetCore.Authorization
@using Municipality360.Application.DTOs.Reclamations
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,Reclamations")]
@layout Municipality360.Web.Components.Layout.MainLayout
@inject IReclamationApiService Api
@inject NavigationManager Nav

<PageTitle>إحصائيات الشكاوى — Municipality360</PageTitle>

<style>
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; }
    .page-title  { font-size:1.3rem; font-weight:800; color:#0f172a; margin:0; }
    .page-sub    { font-size:.8rem; color:#94a3b8; margin-top:.2rem; }
    .btn { display:inline-flex; align-items:center; gap:.4rem; padding:.45rem .95rem; border-radius:9px; border:none; cursor:pointer; font-family:'Tajawal',sans-serif; font-size:.85rem; font-weight:600; }
    .btn-secondary { background:#f1f5f9; color:#374151; }

    .kpi-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:1rem; margin-bottom:1.5rem; }
    .kpi-card { background:#fff; border-radius:14px; padding:1.1rem 1.25rem; box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #f1f5f9; position:relative; overflow:hidden; cursor:pointer; transition:transform .2s; }
    .kpi-card:hover { transform:translateY(-2px); box-shadow:0 4px 18px rgba(0,0,0,.1); }
    .kpi-card::before { content:''; position:absolute; top:0; right:0; width:4px; height:100%; }
    .kpi-blue::before   { background:#0ea5e9; }
    .kpi-orange::before { background:#f97316; }
    .kpi-amber::before  { background:#f59e0b; }
    .kpi-green::before  { background:#22c55e; }
    .kpi-red::before    { background:#ef4444; }
    .kpi-purple::before { background:#8b5cf6; }
    .kpi-yellow::before { background:#eab308; }
    .kpi-icon { width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; margin-bottom:.3rem; }
    .bg-blue   { background:#e0f2fe; color:#0369a1; }
    .bg-orange { background:#fff7ed; color:#c2410c; }
    .bg-amber  { background:#fef3c7; color:#d97706; }
    .bg-green  { background:#dcfce7; color:#15803d; }
    .bg-red    { background:#fee2e2; color:#dc2626; }
    .bg-purple { background:#ede9fe; color:#7c3aed; }
    .bg-yellow { background:#fefce8; color:#a16207; }
    .kpi-val { font-size:1.75rem; font-weight:800; color:#0f172a; line-height:1.1; }
    .kpi-lbl { font-size:.77rem; color:#64748b; font-weight:500; }
    .kpi-sub { font-size:.7rem; color:#94a3b8; }

    .two-col { display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; margin-bottom:1.25rem; }
    @@media(max-width:850px) { .two-col { grid-template-columns:1fr; } }

    .card { background:#fff; border-radius:14px; box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #f1f5f9; padding:1.25rem; }
    .card-title { font-size:.92rem; font-weight:700; color:#0f172a; margin-bottom:1rem; display:flex; align-items:center; gap:.4rem; }
    .card-title i { color:#f97316; }

    .progress-row  { display:flex; align-items:center; gap:.75rem; margin-bottom:.65rem; }
    .progress-lbl  { font-size:.8rem; color:#374151; min-width:90px; }
    .progress-bar  { flex:1; height:10px; background:#f1f5f9; border-radius:99px; overflow:hidden; }
    .progress-fill { height:100%; border-radius:99px; transition:width .5s ease; }
    .progress-val  { font-size:.75rem; font-weight:700; color:#64748b; min-width:32px; text-align:left; }

    .donut-wrap { display:flex; gap:1.5rem; align-items:center; flex-wrap:wrap; }
    .donut-legend { display:flex; flex-direction:column; gap:.5rem; }
    .legend-item { display:flex; align-items:center; gap:.5rem; font-size:.82rem; color:#374151; }
    .legend-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }

    .alert-banner { background:linear-gradient(135deg,#fef2f2,#fff7ed); border:1px solid #fca5a5; border-radius:12px; padding:.85rem 1.25rem; display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem; }

    .table-inner { overflow-x:auto; }
    table { width:100%; border-collapse:collapse; }
    th { padding:.6rem 1rem; text-align:right; font-size:.72rem; font-weight:700; color:#64748b; background:#f8fafc; border-bottom:1px solid #e2e8f0; white-space:nowrap; }
    td { padding:.75rem 1rem; font-size:.84rem; color:#374151; border-bottom:1px solid #f8fafc; vertical-align:middle; }
    tbody tr { cursor:pointer; } tbody tr:hover { background:#fff7ed; } tbody tr:last-child td { border-bottom:none; }
    .badge { display:inline-flex; align-items:center; gap:.3rem; border-radius:99px; padding:.2rem .65rem; font-size:.72rem; font-weight:600; }
    .badge-critique { background:#fee2e2; color:#dc2626; } .badge-haute { background:#fef3c7; color:#b45309; }
    .badge-encours  { background:#fef3c7; color:#b45309; } .badge-nouvelle { background:#e0f2fe; color:#0369a1; }

    .satisfaction-bar { display:flex; align-items:center; gap:.5rem; }
    .star-fill { color:#f59e0b; } .star-empty { color:#e2e8f0; }

    .skeleton { background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:8px; }
    @@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

    .refresh-btn { background:#f1f5f9; border:none; border-radius:9px; padding:.4rem .8rem; cursor:pointer; color:#374151; font-family:'Tajawal',sans-serif; font-size:.84rem; display:inline-flex; align-items:center; gap:.4rem; }
</style>

<div class="page-header">
    <div>
        <div class="page-title"><i class="bi bi-bar-chart-fill" style="color:#f97316"></i> إحصائيات الشكاوى</div>
        <div class="page-sub">لوحة المؤشرات والإحصائيات</div>
    </div>
    <div style="display:flex;gap:.6rem">
        <button class="refresh-btn" @onclick="LoadAsync" disabled="@_loading">
            <i class="bi bi-arrow-clockwise @(_loading?"spin":"")"></i> تحديث
        </button>
        <button class="btn btn-secondary" @onclick='()=>Nav.NavigateTo("/complaints/list")'>
            <i class="bi bi-list-check"></i> الشكاوى
        </button>
    </div>
</div>

@if (_loading)
{
    <div class="kpi-grid">
        @for (int i = 0; i < 7; i++)
        { <div class="kpi-card"><div class="skeleton" style="height:80px"></div></div> }
    </div>
    <div class="skeleton" style="height:300px;border-radius:14px"></div>
}
else if (_stats != null)
{
    @* Alert si critiques *@
    @if (_stats.Critiques > 0 || _retards?.Count > 0)
    {
        <div class="alert-banner">
            <i class="bi bi-exclamation-triangle-fill" style="font-size:1.4rem;color:#ef4444"></i>
            <div>
                <strong style="color:#991b1b;font-size:.9rem">يستوجب تدخلاً فورياً</strong><br/>
                <span style="font-size:.82rem;color:#b91c1c">
                    @if (_stats.Critiques > 0) { <text>@_stats.Critiques شكوى حرجة. </text> }
                    @if (_retards?.Count > 0)  { <text>@_retards.Count شكوى تجاوزت الأجل المحدد.</text> }
                </span>
            </div>
            <button class="btn btn-secondary" style="margin-right:auto" @onclick='()=>Nav.NavigateTo("/complaints/list")'>
                عرض الكل
            </button>
        </div>
    }

    @* KPIs *@
    <div class="kpi-grid">
        <div class="kpi-card kpi-blue" @onclick='()=>Nav.NavigateTo("/complaints/list")'>
            <div class="kpi-icon bg-blue"><i class="bi bi-chat-square-text-fill"></i></div>
            <div class="kpi-val">@_stats.Total</div>
            <div class="kpi-lbl">إجمالي الشكاوى</div>
        </div>
        <div class="kpi-card kpi-orange" @onclick='()=>NavFilter("Nouvelle")'>
            <div class="kpi-icon bg-orange"><i class="bi bi-inbox-fill"></i></div>
            <div class="kpi-val">@_stats.Nouvelles</div>
            <div class="kpi-lbl">شكاوى جديدة</div>
            <div class="kpi-sub">في انتظار المعالجة</div>
        </div>
        <div class="kpi-card kpi-amber" @onclick='()=>NavFilter("EnCours")'>
            <div class="kpi-icon bg-amber"><i class="bi bi-hourglass-split"></i></div>
            <div class="kpi-val">@_stats.EnCours</div>
            <div class="kpi-lbl">قيد المعالجة</div>
        </div>
        <div class="kpi-card kpi-green" @onclick='()=>NavFilter("Traitee")'>
            <div class="kpi-icon bg-green"><i class="bi bi-check-circle-fill"></i></div>
            <div class="kpi-val">@_stats.Traitees</div>
            <div class="kpi-lbl">معالجة</div>
            @if (_stats.Total > 0)
            {
                <div class="kpi-sub">@(Math.Round((double)_stats.Traitees / _stats.Total * 100, 1))% معدل الحل</div>
            }
        </div>
        <div class="kpi-card kpi-red" @onclick='()=>NavFilter("Rejetee")'>
            <div class="kpi-icon bg-red"><i class="bi bi-x-circle-fill"></i></div>
            <div class="kpi-val">@_stats.Rejetees</div>
            <div class="kpi-lbl">مرفوضة</div>
        </div>
        <div class="kpi-card kpi-purple">
            <div class="kpi-icon bg-purple"><i class="bi bi-lightning-fill"></i></div>
            <div class="kpi-val">@_stats.Critiques</div>
            <div class="kpi-lbl">حرجة</div>
            <div class="kpi-sub">أولوية قصوى</div>
        </div>
        <div class="kpi-card kpi-yellow">
            <div class="kpi-icon bg-yellow"><i class="bi bi-star-fill"></i></div>
            <div class="kpi-val">@(_stats.SatisfactionMoyenne > 0 ? _stats.SatisfactionMoyenne.ToString("F1") : "—")</div>
            <div class="kpi-lbl">متوسط الرضا</div>
            <div class="kpi-sub">من 5 نقاط</div>
        </div>
    </div>

    @* توزيع الحالات + المتأخرة *@
    <div class="two-col">
        <div class="card">
            <div class="card-title"><i class="bi bi-pie-chart-fill"></i> توزيع الحالات</div>
            @if (_stats.Total > 0)
            {
                int tot = _stats.Total;
                var rows = new[]
                {
                    ("جديدة",          _stats.Nouvelles, "#0ea5e9"),
                    ("قيد المعالجة",   _stats.EnCours,   "#f59e0b"),
                    ("معالجة",         _stats.Traitees,  "#22c55e"),
                    ("مرفوضة",         _stats.Rejetees,  "#ef4444"),
                    ("حرجة",           _stats.Critiques, "#8b5cf6"),
                };
                <div>
                    @foreach (var (lbl, cnt, col) in rows)
                    {
                        double pct = Math.Round((double)cnt / tot * 100, 1);
                        <div class="progress-row">
                            <span class="progress-lbl">@lbl</span>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width:@(pct)%;background:@col"></div>
                            </div>
                            <span class="progress-val">@cnt</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p style="text-align:center;color:#94a3b8;padding:2rem 0">لا توجد بيانات</p>
            }
        </div>

        <div class="card">
            <div class="card-title"><i class="bi bi-clock-history"></i> الشكاوى المتأخرة (@(_retards?.Count ?? 0))</div>
            @if (_retards?.Any() == true)
            {
                <div class="table-inner">
                    <table>
                        <thead><tr><th>الرقم</th><th>الموضوع</th><th>الأولوية</th></tr></thead>
                        <tbody>
                            @foreach (var r in _retards.Take(8))
                            {
                                <tr @onclick='()=>Nav.NavigateTo($"/complaints/list/{r.Id}")'>
                                    <td style="color:#f97316;font-weight:700;font-size:.78rem">@r.NumeroReclamation</td>
                                    <td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:.82rem">@r.Objet</td>
                                    <td><span class="badge badge-@r.Priorite.ToLower()">@PrioriteLabel(r.Priorite)</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (_retards.Count > 8)
                {
                    <div style="text-align:center;padding:.75rem 0;font-size:.8rem;color:#94a3b8">
                        و @(_retards.Count - 8) شكوى أخرى…
                    </div>
                }
            }
            else
            {
                <div style="text-align:center;padding:2.5rem;color:#94a3b8">
                    <i class="bi bi-check2-all" style="font-size:2rem;display:block;margin-bottom:.5rem;color:#22c55e"></i>
                    لا توجد شكاوى متأخرة ✓
                </div>
            }
        </div>
    </div>

    @* معدل الرضا *@
    @if (_stats.SatisfactionMoyenne > 0)
    {
        <div class="card" style="margin-bottom:1.25rem">
            <div class="card-title"><i class="bi bi-emoji-smile-fill" style="color:#eab308"></i> رضا المواطنين</div>
            <div style="display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap">
                <div style="font-size:3rem;font-weight:800;color:#f97316">
                    @_stats.SatisfactionMoyenne.ToString("F1")
                    <span style="font-size:1.2rem;color:#94a3b8">/5</span>
                </div>
                <div class="satisfaction-bar" style="font-size:1.5rem">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi @(i <= Math.Round(_stats.SatisfactionMoyenne) ? "bi-star-fill star-fill" : "bi-star star-empty")"></i>
                    }
                </div>
                <div style="flex:1;min-width:200px">
                    <div style="height:12px;background:#f1f5f9;border-radius:99px;overflow:hidden">
                        <div style="height:100%;width:@(_stats.SatisfactionMoyenne / 5 * 100)%;background:linear-gradient(90deg,#f97316,#fbbf24);border-radius:99px;transition:width .5s"></div>
                    </div>
                    <div style="font-size:.78rem;color:#64748b;margin-top:.3rem">بناءً على شكاوى مُغلقة بتقييم</div>
                </div>
            </div>
        </div>
    }

    @* Actions rapides *@
    <div style="display:flex;gap:.75rem;flex-wrap:wrap">
        <button class="btn btn-secondary" @onclick='()=>Nav.NavigateTo("/complaints/add")'>
            <i class="bi bi-plus-circle"></i> تسجيل شكوى
        </button>
        <button class="btn btn-secondary" @onclick='()=>Nav.NavigateTo("/complaints/list?statut=Nouvelle")'>
            <i class="bi bi-inbox"></i> الشكاوى الجديدة
        </button>
        <button class="btn btn-secondary" @onclick='()=>Nav.NavigateTo("/complaints/citizens")'>
            <i class="bi bi-people"></i> المواطنون
        </button>
    </div>
}
else
{
    <div style="text-align:center;padding:4rem;color:#94a3b8">
        <i class="bi bi-bar-chart" style="font-size:3rem;display:block;margin-bottom:1rem"></i>
        <p>تعذّر تحميل الإحصائيات. تحقق من الاتصال وأعد المحاولة.</p>
        <button class="btn btn-secondary" @onclick="LoadAsync">إعادة المحاولة</button>
    </div>
}

@code {
    private ReclamationStatsDto?   _stats;
    private List<ReclamationDto>?  _retards;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try { _stats   = await Api.GetStatsAsync(); }   catch { _stats   = null; }
        try { _retards = await Api.GetEnRetardAsync(); } catch { _retards = new(); }
        _loading = false;
    }

    private void NavFilter(string statut) =>
        Nav.NavigateTo($"/complaints/list");

    private static string PrioriteLabel(string p) => p switch
    {
        "Critique" => "حرجة", "Haute" => "عالية",
        "Moyenne"  => "متوسطة","Basse" => "منخفضة", _ => p
    };
}
