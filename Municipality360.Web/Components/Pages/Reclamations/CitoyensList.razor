@page "/complaints/citizens"
@page "/complaints/citizens/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@using Municipality360.Application.DTOs.Reclamations
@attribute [Authorize(Roles = "SuperAdmin,Admin,Manager,Reclamations")]
@layout Municipality360.Web.Components.Layout.MainLayout
@inject ICitoyenApiService Api
@inject IReclamationApiService ReclamationApi
@inject NavigationManager Nav

<PageTitle>إدارة المواطنين — Municipality360</PageTitle>

<style>
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; }
    .page-title  { font-size:1.3rem; font-weight:800; color:#0f172a; margin:0; }
    .page-sub    { font-size:.8rem; color:#94a3b8; margin-top:.2rem; }
    .btn { display:inline-flex; align-items:center; gap:.4rem; padding:.45rem .95rem; border-radius:9px; border:none; cursor:pointer; font-family:'Tajawal',sans-serif; font-size:.85rem; font-weight:600; transition:all .2s; }
    .btn-primary   { background:linear-gradient(135deg,#f97316,#fb923c); color:#fff; box-shadow:0 3px 10px rgba(249,115,22,.3); }
    .btn-primary:hover { transform:translateY(-1px); }
    .btn-secondary { background:#f1f5f9; color:#374151; }
    .btn-secondary:hover { background:#e2e8f0; }
    .btn-sm { padding:.3rem .65rem; font-size:.78rem; }

    .filters-bar { display:flex; gap:.75rem; flex-wrap:wrap; margin-bottom:1.2rem; align-items:center; }
    .search-wrap { position:relative; flex:1; min-width:200px; }
    .search-input { width:100%; height:38px; padding:0 1rem 0 2.5rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.86rem; outline:none; background:#fff; }
    .search-input:focus { border-color:#f97316; box-shadow:0 0 0 3px rgba(249,115,22,.1); }
    .search-icon { position:absolute; right:10px; top:50%; transform:translateY(-50%); color:#94a3b8; pointer-events:none; }
    select.filter-sel { height:38px; padding:0 .75rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.85rem; outline:none; background:#fff; }

    .table-card  { background:#fff; border-radius:14px; box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #f1f5f9; overflow:hidden; }
    .table-inner { overflow-x:auto; }
    table { width:100%; border-collapse:collapse; }
    thead tr { background:#f8fafc; border-bottom:1px solid #e2e8f0; }
    th { padding:.65rem 1rem; text-align:right; font-size:.73rem; font-weight:700; color:#64748b; white-space:nowrap; }
    td { padding:.8rem 1rem; font-size:.85rem; color:#374151; border-bottom:1px solid #f8fafc; vertical-align:middle; }
    tbody tr { cursor:pointer; } tbody tr:hover { background:#fff7ed; } tbody tr:last-child td { border-bottom:none; }

    .badge { display:inline-flex; align-items:center; gap:.3rem; border-radius:99px; padding:.2rem .65rem; font-size:.72rem; font-weight:600; }
    .badge-active   { background:#dcfce7; color:#15803d; }
    .badge-inactive { background:#f3f4f6; color:#6b7280; }

    .pagination { display:flex; align-items:center; justify-content:center; gap:.4rem; padding:1rem; }
    .pg-btn { width:34px; height:34px; border-radius:8px; border:1.5px solid #e2e8f0; background:#fff; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:.82rem; }
    .pg-btn:hover { border-color:#f97316; color:#f97316; }
    .pg-btn.active { background:#f97316; border-color:#f97316; color:#fff; }
    .pg-btn:disabled { opacity:.4; cursor:not-allowed; }

    /* Drawer */
    .overlay { position:fixed; inset:0; background:rgba(0,0,0,.4); z-index:500; display:flex; align-items:flex-start; justify-content:flex-end; }
    .drawer  { width:min(620px,95vw); height:100vh; background:#fff; box-shadow:-6px 0 40px rgba(0,0,0,.15); display:flex; flex-direction:column; }
    .drawer-header { padding:1.2rem 1.5rem; border-bottom:1px solid #f1f5f9; display:flex; align-items:center; justify-content:space-between; background:#fff7ed; flex-shrink:0; }
    .drawer-title  { font-size:1rem; font-weight:700; color:#0f172a; }
    .drawer-body   { flex:1; overflow-y:auto; padding:1.5rem; display:flex; flex-direction:column; gap:1.1rem; }
    .close-btn { background:none; border:none; font-size:1.2rem; cursor:pointer; color:#64748b; }
    .detail-grid { display:grid; grid-template-columns:1fr 1fr; gap:.75rem 1.5rem; }
    .detail-item label { display:block; font-size:.72rem; font-weight:700; color:#64748b; text-transform:uppercase; margin-bottom:.2rem; }
    .detail-item span  { font-size:.88rem; color:#0f172a; }
    .detail-item.full  { grid-column:1/-1; }
    .divider { border:none; border-top:1px solid #f1f5f9; }
    .section-sub { font-size:.82rem; font-weight:700; color:#374151; margin-bottom:.5rem; display:flex; align-items:center; gap:.4rem; }

    /* Form */
    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:.85rem 1.25rem; }
    .form-group { display:flex; flex-direction:column; gap:.3rem; }
    .form-group.full { grid-column:1/-1; }
    .form-label { font-size:.8rem; font-weight:700; color:#374151; }
    .form-label .req { color:#ef4444; }
    .form-control { height:38px; padding:0 .85rem; border:1.5px solid #e2e8f0; border-radius:9px; font-family:'Tajawal',sans-serif; font-size:.88rem; outline:none; }
    .form-control:focus { border-color:#f97316; }
    .form-control.invalid { border-color:#ef4444; }
    .alert-err { background:#fef2f2; border:1px solid #fca5a5; border-radius:9px; padding:.75rem 1rem; font-size:.85rem; color:#dc2626; margin-bottom:1rem; }
    .alert-ok  { background:#f0fdf4; border:1px solid #86efac; border-radius:9px; padding:.75rem 1rem; font-size:.85rem; color:#15803d; margin-bottom:1rem; }
    .form-footer { display:flex; gap:.75rem; justify-content:flex-end; margin-top:1rem; padding-top:1rem; border-top:1px solid #f1f5f9; }

    .skeleton { background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:8px; }
    @@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

    .rec-mini { display:flex; align-items:center; gap:.75rem; padding:.6rem .85rem; background:#f8fafc; border-radius:8px; margin-bottom:.4rem; cursor:pointer; }
    .rec-mini:hover { background:#fff7ed; }
    .rec-num { font-weight:700; color:#f97316; font-size:.8rem; min-width:90px; }
    .badge-nouvelle{background:#e0f2fe;color:#0369a1;} .badge-encours{background:#fef3c7;color:#b45309;}
    .badge-traitee{background:#dcfce7;color:#15803d;} .badge-rejetee{background:#fee2e2;color:#dc2626;}
    .badge-fermee{background:#f3f4f6;color:#6b7280;}
</style>

@if (_showForm)
{
    @* ── FORM (Add/Edit Citoyen) ── *@
    <div class="page-header">
        <div>
            <div class="page-title"><i class="bi bi-person-plus-fill" style="color:#f97316"></i> @(_editCitoyen?.Id > 0 ? "تعديل مواطن" : "مواطن جديد")</div>
        </div>
        <button class="btn btn-secondary" @onclick="()=>_showForm=false"><i class="bi bi-arrow-right"></i> رجوع</button>
    </div>

    @if (!string.IsNullOrEmpty(_formError))   { <div class="alert-err">@_formError</div> }
    @if (!string.IsNullOrEmpty(_formSuccess)) { <div class="alert-ok">@_formSuccess</div> }

    <div style="background:#fff;border-radius:14px;box-shadow:0 1px 8px rgba(0,0,0,.07);border:1px solid #f1f5f9;padding:1.5rem">
        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">الاسم <span class="req">*</span></label>
                <input type="text" class="form-control @(_fv && string.IsNullOrEmpty(_formDto.Nom)?"invalid":"")" @bind="_formDto.Nom" />
            </div>
            <div class="form-group">
                <label class="form-label">اللقب <span class="req">*</span></label>
                <input type="text" class="form-control @(_fv && string.IsNullOrEmpty(_formDto.Prenom)?"invalid":"")" @bind="_formDto.Prenom" />
            </div>
            <div class="form-group">
                <label class="form-label">رقم الهوية (CIN) <span class="req">*</span></label>
                <input type="text" class="form-control @(_fv && string.IsNullOrEmpty(_formDto.CIN)?"invalid":"")" @bind="_formDto.CIN" />
            </div>
            <div class="form-group">
                <label class="form-label">الهاتف <span class="req">*</span></label>
                <input type="text" class="form-control @(_fv && string.IsNullOrEmpty(_formDto.Telephone)?"invalid":"")" @bind="_formDto.Telephone" />
            </div>
            <div class="form-group">
                <label class="form-label">الجوال</label>
                <input type="text" class="form-control" @bind="_formDto.TelephoneMobile" />
            </div>
            <div class="form-group">
                <label class="form-label">البريد الإلكتروني</label>
                <input type="email" class="form-control" @bind="_formDto.Email" />
            </div>
            <div class="form-group">
                <label class="form-label">تاريخ الميلاد</label>
                <input type="date" class="form-control" @bind="_formDto.DateNaissance" />
            </div>
            <div class="form-group">
                <label class="form-label">الجنس</label>
                <select class="form-control" @bind="_formDto.Sexe">
                    <option value="">—</option>
                    <option value="Masculin">ذكر</option>
                    <option value="Feminin">أنثى</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">المدينة</label>
                <input type="text" class="form-control" @bind="_formDto.Ville" />
            </div>
            <div class="form-group">
                <label class="form-label">الرمز البريدي</label>
                <input type="text" class="form-control" @bind="_formDto.CodePostal" />
            </div>
            <div class="form-group full">
                <label class="form-label">العنوان</label>
                <input type="text" class="form-control" @bind="_formDto.Adresse" />
            </div>
            <div class="form-group">
                <label class="form-label">الحالة العائلية</label>
                <select class="form-control" @bind="_formDto.SituationFamiliale">
                    <option value="">—</option>
                    <option value="Celibataire">أعزب/عزباء</option>
                    <option value="Marie">متزوج/ة</option>
                    <option value="Divorce">مطلق/ة</option>
                    <option value="Veuf">أرمل/ة</option>
                </select>
            </div>
        </div>
        <div class="form-footer">
            <button class="btn btn-secondary" @onclick="()=>_showForm=false">إلغاء</button>
            <button class="btn btn-primary" @onclick="SaveCitoyen" disabled="@_saving">
                @if (_saving) { <text><i class="bi bi-hourglass-split"></i> جارٍ الحفظ…</text> }
                else          { <text><i class="bi bi-floppy"></i> حفظ</text> }
            </button>
        </div>
    </div>
}
else
{
    <div class="page-header">
        <div>
            <div class="page-title"><i class="bi bi-people-fill" style="color:#f97316"></i> إدارة المواطنين</div>
            <div class="page-sub">@(_paged?.TotalCount ?? 0) مواطن</div>
        </div>
        <button class="btn btn-primary" @onclick="OpenAdd"><i class="bi bi-plus-lg"></i> مواطن جديد</button>
    </div>

    <div class="filters-bar">
        <div class="search-wrap">
            <i class="bi bi-search search-icon"></i>
            <input class="search-input" placeholder="بحث بالاسم أو رقم الهوية أو الهاتف…"
                   @bind="_filter.SearchTerm" @bind:event="oninput" @onkeyup="OnSearch" />
        </div>
        <select class="filter-sel" @bind="_filter.IsActive" @bind:after="LoadAsync">
            <option value="">كل المواطنين</option>
            <option value="true">نشط</option>
            <option value="false">غير نشط</option>
        </select>
        <button class="btn btn-secondary" @onclick="ResetFilter"><i class="bi bi-x-circle"></i></button>
    </div>

    <div class="table-card">
        <div class="table-inner">
            <table>
                <thead><tr>
                    <th>الاسم الكامل</th><th>رقم الهوية</th><th>الهاتف</th>
                    <th>المدينة</th><th>الشكاوى</th><th>الحالة</th><th></th>
                </tr></thead>
                <tbody>
                    @if (_loading)
                    {
                        @for (int i = 0; i < 8; i++)
                        { <tr><td colspan="7"><div class="skeleton" style="height:18px;margin:.4rem 0"></div></td></tr> }
                    }
                    else if (_paged?.Items?.Any() == true)
                    {
                        @foreach (var c in _paged.Items)
                        {
                            <tr @onclick="()=>OpenDetail(c.Id)">
                                <td><strong>@c.NomComplet</strong></td>
                                <td style="font-family:monospace;letter-spacing:.05em">@c.CIN</td>
                                <td>@c.Telephone</td>
                                <td>@(c.Ville ?? "—")</td>
                                <td>
                                    @if (c.NombreReclamations > 0)
                                    {
                                        <span class="badge" style="background:#fff7ed;color:#f97316">@c.NombreReclamations</span>
                                    }
                                    else { }
                                </td>
                                <td><span class="badge @(c.IsActive?"badge-active":"badge-inactive")">@(c.IsActive?"نشط":"غير نشط")</span></td>
                                <td @onclick:stopPropagation="true" style="display:flex;gap:.4rem">
                                    <button class="btn btn-secondary btn-sm" @onclick="()=>OpenEdit(c)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-secondary btn-sm" style="color:#f97316" @onclick='()=>Nav.NavigateTo($"/complaints/add")'>
                                        <i class="bi bi-plus-circle"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" style="text-align:center;color:#94a3b8;padding:3rem">
                            <i class="bi bi-people" style="font-size:2rem;display:block;margin-bottom:.5rem"></i>
                            لا يوجد مواطنون مطابقون
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
        @if (_paged != null && _paged.TotalPages > 1)
        {
            <div class="pagination">
                <button class="pg-btn" disabled="@(_filter.PageNumber==1)" @onclick="()=>GoPage(_filter.PageNumber-1)"><i class="bi bi-chevron-right"></i></button>
                @for (int p = Math.Max(1, _filter.PageNumber - 2); p <= Math.Min(_paged.TotalPages, _filter.PageNumber + 2); p++)
                {
                    int pp = p;
                    <button class="pg-btn @(pp==_filter.PageNumber?"active":"")" @onclick="()=>GoPage(pp)">@pp</button>
                }
                <button class="pg-btn" disabled="@(_filter.PageNumber==_paged.TotalPages)" @onclick="()=>GoPage(_filter.PageNumber+1)"><i class="bi bi-chevron-left"></i></button>
                <span style="font-size:.82rem;color:#64748b;margin:0 .5rem">@_filter.PageNumber / @_paged.TotalPages</span>
            </div>
        }
    </div>
}

@* DRAWER Détail Citoyen *@
@if (_detail != null && !_showForm)
{
    <div class="overlay" @onclick="()=>_detail=null">
        <div class="drawer" @onclick:stopPropagation="true">
            <div class="drawer-header">
                <div>
                    <div class="drawer-title"><i class="bi bi-person-circle" style="color:#f97316"></i> @_detail.NomComplet</div>
                    <div style="font-size:.78rem;color:#94a3b8">@_detail.CIN — @_detail.Telephone</div>
                </div>
                <button class="close-btn" @onclick="()=>_detail=null"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="drawer-body">
                <div class="detail-grid">
                    <div class="detail-item"><label>الاسم</label><span>@_detail.Nom</span></div>
                    <div class="detail-item"><label>اللقب</label><span>@_detail.Prenom</span></div>
                    <div class="detail-item"><label>رقم الهوية</label><span style="font-family:monospace">@_detail.CIN</span></div>
                    <div class="detail-item"><label>الهاتف</label><span>@_detail.Telephone</span></div>
                    @if (!string.IsNullOrEmpty(_detail.TelephoneMobile))
                    { <div class="detail-item"><label>الجوال</label><span>@_detail.TelephoneMobile</span></div> }
                    @if (!string.IsNullOrEmpty(_detail.Email))
                    { <div class="detail-item"><label>البريد</label><span>@_detail.Email</span></div> }
                    @if (_detail.DateNaissance.HasValue)
                    { <div class="detail-item"><label>تاريخ الميلاد</label><span>@_detail.DateNaissance.Value.ToString("dd/MM/yyyy")</span></div> }
                    @if (!string.IsNullOrEmpty(_detail.Ville))
                    { <div class="detail-item"><label>المدينة</label><span>@_detail.Ville</span></div> }
                    @if (!string.IsNullOrEmpty(_detail.Adresse))
                    { <div class="detail-item full"><label>العنوان</label><span>@_detail.Adresse</span></div> }
                    <div class="detail-item"><label>الحالة</label><span class="badge @(_detail.IsActive?"badge-active":"badge-inactive")">@(_detail.IsActive?"نشط":"غير نشط")</span></div>
                    <div class="detail-item"><label>عدد الشكاوى</label><span style="font-weight:700;color:#f97316">@_detail.NombreReclamations</span></div>
                </div>

                <div style="display:flex;gap:.5rem">
                    <button class="btn btn-secondary" @onclick="()=>OpenEdit(_detail)"><i class="bi bi-pencil"></i> تعديل</button>
                    @* <button class="btn btn-primary" @onclick="()=>Nav.NavigateTo($\"/complaints/add\")"><i class="bi bi-plus-circle"></i> شكوى جديدة</button> *@
                </div>

                @if (_reclamations?.Any() == true)
                {
                    <hr class="divider"/>
                    <div class="section-sub"><i class="bi bi-chat-square-text"></i> شكاواه (@_reclamations.Count)</div>
                    @foreach (var r in _reclamations)
                    {
                        <div class="rec-mini" @onclick='()=>Nav.NavigateTo($"/complaints/list/{r.Id}")'>
                            <span class="rec-num">@r.NumeroReclamation</span>
                            <span style="flex:1;font-size:.83rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@r.Objet</span>
                            <span class="badge badge-@r.Statut.ToLower()" style="font-size:.65rem">@StatutLabel(r.Statut)</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }

    private PagedResult<CitoyenDto>? _paged;
    private CitoyenDto?              _detail;
    private CitoyenDto?              _editCitoyen;
    private List<ReclamationDto>?    _reclamations;
    private CitoyenFilterDto         _filter   = new() { PageNumber = 1, PageSize = 12 };
    private CreateCitoyenDto         _formDto  = new();
    private bool _loading, _saving, _showForm, _fv;
    private string? _formError, _formSuccess;

    // IsActive filter as string binding helper
    private string _isActiveStr
    {
        get => _filter.IsActive.HasValue ? _filter.IsActive.Value.ToString().ToLower() : "";
        set => _filter.IsActive = string.IsNullOrEmpty(value) ? null : bool.Parse(value);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        if (Id.HasValue) await OpenDetail(Id.Value);
    }

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try { _paged = await Api.GetPagedAsync(_filter); } catch { }
        _loading = false;
    }

    private async Task OpenDetail(int id)
    {
        try
        {
            _detail = await Api.GetByIdAsync(id);
            _reclamations = await Api.GetReclamationsAsync(id) ?? new();
        }
        catch { }
    }

    private void OpenAdd()
    {
        _editCitoyen = null;
        _formDto     = new();
        _fv = false; _formError = _formSuccess = null;
        _showForm    = true;
    }

    private void OpenEdit(CitoyenDto c)
    {
        _editCitoyen = c;
        _formDto = new CreateCitoyenDto
        {
            CIN = c.CIN, Nom = c.Nom, Prenom = c.Prenom,
            Telephone = c.Telephone, TelephoneMobile = c.TelephoneMobile,
            Email = c.Email, Adresse = c.Adresse, Ville = c.Ville,
            CodePostal = c.CodePostal, DateNaissance = c.DateNaissance,
            Sexe = c.Sexe, SituationFamiliale = c.SituationFamiliale
        };
        _fv = false; _formError = _formSuccess = null;
        _showForm = true;
        _detail   = null;
    }

    private async Task SaveCitoyen()
    {
        _fv = true;
        if (string.IsNullOrEmpty(_formDto.Nom))       { _formError = "الاسم مطلوب."; return; }
        if (string.IsNullOrEmpty(_formDto.Prenom))    { _formError = "اللقب مطلوب."; return; }
        if (string.IsNullOrEmpty(_formDto.CIN))       { _formError = "رقم الهوية مطلوب."; return; }
        if (string.IsNullOrEmpty(_formDto.Telephone)) { _formError = "رقم الهاتف مطلوب."; return; }

        _saving = true; _formError = null;
        try
        {
            CitoyenDto? result;
            if (_editCitoyen?.Id > 0)
                result = await Api.UpdateAsync(_editCitoyen.Id, _formDto);
            else
                result = await Api.CreateAsync(_formDto);

            if (result != null)
            {
                _formSuccess = "تم الحفظ بنجاح.";
                _showForm    = false;
                await LoadAsync();
                await OpenDetail(result.Id);
            }
            else { _formError = "حدث خطأ أثناء الحفظ."; }
        }
        catch (Exception ex) { _formError = ex.Message; }
        finally { _saving = false; }
    }

    private async Task ResetFilter() { _filter = new() { PageNumber = 1, PageSize = 12 }; await LoadAsync(); }
    private async Task GoPage(int p) { _filter.PageNumber = p; await LoadAsync(); }

    private System.Threading.CancellationTokenSource? _cts;
    private async Task OnSearch()
    {
        _cts?.Cancel(); _cts = new();
        try { await Task.Delay(350, _cts.Token); _filter.PageNumber = 1; await LoadAsync(); } catch { }
    }

    private static string StatutLabel(string s) => s switch
    {
        "Nouvelle" => "جديدة", "EnCours" => "جارية", "Traitee" => "معالجة",
        "Rejetee"  => "مرفوضة","Fermee"  => "مغلقة", _         => s
    };
}
